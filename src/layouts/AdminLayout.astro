---
import { supabaseAdmin } from "../lib/supabase";

interface Props {
    title: string;
    activeSection?: string;
    admin: { id: string; name: string; email: string; avatar_url?: string };
}

const { title, activeSection = "dashboard", admin } = Astro.props;

// ── Brand color (from settings) ───────────────────────────────────────────
function sanitizeColor(color: string): string {
    return /^#[0-9a-fA-F]{3,8}$/.test(color) ? color : "#39FF14";
}
function hexToRgb(hex: string): string {
    const c = hex.replace("#", "");
    const r = parseInt(c.substring(0, 2), 16);
    const g = parseInt(c.substring(2, 4), 16);
    const b = parseInt(c.substring(4, 6), 16);
    return `${r}, ${g}, ${b}`;
}
function deriveSecondaryColor(hex: string): string {
    const c = hex.replace("#", "");
    const factor = 0.8;
    const r = Math.round(parseInt(c.substring(0, 2), 16) * factor);
    const g = Math.round(parseInt(c.substring(2, 4), 16) * factor);
    const b = Math.round(parseInt(c.substring(4, 6), 16) * factor);
    return `#${r.toString(16).padStart(2, "0")}${g.toString(16).padStart(2, "0")}${b.toString(16).padStart(2, "0")}`;
}

let primaryColor = "#39FF14";
let brandLogoUrl = "/images/brand-mark.svg";
try {
    const { data } = await supabaseAdmin
        .from("site_settings")
        .select("value")
        .eq("key", "brand")
        .single();
    if (data?.value) {
        const v = data.value as any;
        primaryColor = sanitizeColor(v.primary_color || primaryColor);
        if (typeof v.logo_url === "string" && v.logo_url.trim()) {
            brandLogoUrl = v.logo_url.trim();
        }
    }
} catch {}

const secondaryColor = deriveSecondaryColor(primaryColor);

const brandRgb = hexToRgb(primaryColor);

const navItems = [
    { id: "dashboard", label: "Dashboard", icon: "layout", href: "/admin" },
    {
        id: "orders",
        label: "Pedidos",
        icon: "shopping-bag",
        href: "/admin/orders",
    },
    {
        id: "returns",
        label: "Devoluciones",
        icon: "corner-up-left",
        href: "/admin/returns",
    },
    { id: "coupons", label: "Cupones", icon: "tag", href: "/admin/coupons" },
    {
        id: "products",
        label: "Productos",
        icon: "box",
        href: "/admin/products",
    },
    {
        id: "categories",
        label: "Categorías",
        icon: "folder",
        href: "/admin/categories",
    },
    {
        id: "reviews",
        label: "Reseñas",
        icon: "message-square",
        href: "/admin/reviews",
    },
    {
        id: "settings",
        label: "Ajustes",
        icon: "sliders",
        href: "/admin/settings",
    },
    {
        id: "editor",
        label: "Editor Visual",
        icon: "pen-tool",
        href: "/admin/editor",
    },
];
---

<!doctype html>
<html lang="es" class="dark" style={`--brand:${primaryColor};--brand-500:${secondaryColor};--brand-rgb:${brandRgb};--scrollbar-thumb:${primaryColor};--selection-bg:${primaryColor};--border-hover:rgba(${brandRgb},0.3);--bg-card-hover-shadow:rgba(${brandRgb},0.05);--ve2-neon:${primaryColor};--ve2-neon-soft:${secondaryColor};--ve2-border-focus:${primaryColor};--ve2-neon-dim:rgba(${brandRgb},0.08);--ve2-neon-glow:rgba(${brandRgb},0.15);--ve2-neon-glow-lg:rgba(${brandRgb},0.25);--ve2-neon-ghost:rgba(${brandRgb},0.04)`}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} | PARRA Admin</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Oswald:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <script
            src="https://unpkg.com/feather-icons@4.29.1/dist/feather.min.js"
            is:inline></script>
        <style is:global>
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            html {
                font-size: 14px;
            }
            body {
                font-family:
                    "Inter",
                    system-ui,
                    -apple-system,
                    sans-serif;
                background: #0a0a0a;
                color: #e5e5e5;
                min-height: 100vh;
                -webkit-font-smoothing: antialiased;
                -moz-osx-font-smoothing: grayscale;
            }
            ::-webkit-scrollbar {
                width: 6px;
                height: 6px;
            }
            ::-webkit-scrollbar-track {
                background: transparent;
            }
            ::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.1);
                border-radius: 3px;
            }
            ::-webkit-scrollbar-thumb:hover {
                background: rgba(255, 255, 255, 0.2);
            }

            /* ── Layout ─────────────────────────────── */
            .admin-wrapper {
                display: flex;
                min-height: 100vh;
            }

            /* ── Sidebar ────────────────────────────── */
            .admin-sidebar {
                position: fixed;
                top: 0;
                left: 0;
                bottom: 0;
                width: 240px;
                background: #0f0f0f;
                border-right: 1px solid rgba(255, 255, 255, 0.06);
                display: flex;
                flex-direction: column;
                z-index: 100;
                transition:
                    transform 0.32s cubic-bezier(0.4, 0, 0.2, 1),
                    box-shadow 0.32s;
                overflow: hidden;
            }

            .sidebar-header {
                padding: 1.5rem 1.25rem 1.25rem;
                border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            }
            .sidebar-brand {
                display: inline-flex;
                align-items: center;
                gap: 0.55rem;
                font-family: "Oswald", system-ui, sans-serif;
                font-size: 1.5rem;
                font-weight: 700;
                color: var(--brand);
                text-decoration: none;
                letter-spacing: -0.02em;
            }
            .sidebar-brand-mark {
                width: 26px;
                height: 26px;
                object-fit: contain;
                filter: drop-shadow(0 0 8px rgba(var(--brand-rgb), 0.2));
            }
            .sidebar-brand-sub {
                font-size: 0.6rem;
                text-transform: uppercase;
                letter-spacing: 0.25em;
                color: rgba(255, 255, 255, 0.2);
                margin-top: 2px;
            }

            .sidebar-nav {
                flex: 1;
                padding: 0.75rem 0;
                overflow-y: auto;
            }

            .nav-section-label {
                font-size: 0.6rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.15em;
                color: rgba(255, 255, 255, 0.2);
                padding: 1rem 1.25rem 0.5rem;
            }

            .nav-item {
                display: flex;
                align-items: center;
                gap: 0.65rem;
                padding: 0.55rem 1.25rem;
                margin: 1px 0.5rem;
                border-radius: 6px;
                color: rgba(255, 255, 255, 0.5);
                text-decoration: none;
                font-size: 0.8rem;
                font-weight: 500;
                transition: all 0.15s;
            }
            .nav-item:hover {
                color: rgba(255, 255, 255, 0.85);
                background: rgba(255, 255, 255, 0.04);
            }
            .nav-item.active {
                color: var(--brand);
                background: rgba(var(--brand-rgb), 0.06);
            }
            .nav-item svg {
                width: 16px;
                height: 16px;
                flex-shrink: 0;
            }

            .sidebar-footer {
                padding: 1rem 1.25rem;
                border-top: 1px solid rgba(255, 255, 255, 0.04);
            }
            .admin-profile {
                display: flex;
                align-items: center;
                gap: 0.6rem;
            }
            .admin-avatar {
                width: 30px;
                height: 30px;
                border-radius: 50%;
                background: rgba(var(--brand-rgb), 0.1);
                color: var(--brand);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.7rem;
                font-weight: 700;
                flex-shrink: 0;
            }
            .admin-name {
                font-size: 0.75rem;
                font-weight: 600;
                color: rgba(255, 255, 255, 0.7);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }
            .admin-email {
                font-size: 0.6rem;
                color: rgba(255, 255, 255, 0.25);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }
            .btn-logout {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                width: 100%;
                padding: 0.5rem 0.75rem;
                margin-top: 0.75rem;
                background: rgba(248, 113, 113, 0.04);
                border: 1px solid rgba(248, 113, 113, 0.2);
                border-radius: 6px;
                color: #f87171;
                font-size: 0.7rem;
                font-weight: 500;
                cursor: pointer;
                transition: all 0.15s;
            }
            .btn-logout:hover {
                color: #f87171;
                border-color: rgba(248, 113, 113, 0.35);
                background: rgba(248, 113, 113, 0.08);
            }
            .btn-logout svg {
                width: 13px;
                height: 13px;
            }

            /* ── Main Content ───────────────────────── */
            .admin-main {
                flex: 1;
                margin-left: 240px;
                min-height: 100vh;
            }

            .admin-topbar {
                position: sticky;
                top: 0;
                z-index: 50;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0.75rem 1.5rem;
                background: rgba(10, 10, 10, 0.85);
                backdrop-filter: blur(16px);
                border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            }
            .topbar-title {
                font-family: "Oswald", system-ui, sans-serif;
                font-size: 1.1rem;
                font-weight: 600;
                letter-spacing: -0.01em;
            }
            .topbar-actions {
                display: flex;
                align-items: center;
                gap: 0.75rem;
            }
            .btn-store {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                padding: 0.45rem 0.85rem;
                background: rgba(var(--brand-rgb), 0.06);
                border: 1px solid rgba(var(--brand-rgb), 0.2);
                border-radius: 8px;
                color: var(--brand);
                font-size: 0.72rem;
                font-weight: 600;
                text-decoration: none;
                transition: all 0.15s;
                white-space: nowrap;
                letter-spacing: 0.01em;
            }
            .btn-store:hover {
                background: rgba(var(--brand-rgb), 0.1);
                border-color: rgba(var(--brand-rgb), 0.35);
                box-shadow: 0 0 12px rgba(var(--brand-rgb), 0.1);
            }
            .btn-store svg {
                width: 13px;
                height: 13px;
            }

            .admin-content {
                padding: 1.5rem;
            }

            /* ── Mobile toggle ──────────────────────── */
            .sidebar-toggle {
                display: none;
                align-items: center;
                justify-content: center;
                width: 32px;
                height: 32px;
                background: transparent;
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 6px;
                color: rgba(255, 255, 255, 0.6);
                cursor: pointer;
                flex-shrink: 0;
                transition:
                    background 0.15s,
                    border-color 0.15s;
            }
            .sidebar-toggle:hover {
                background: rgba(255, 255, 255, 0.05);
                border-color: rgba(255, 255, 255, 0.18);
            }
            .sidebar-toggle svg {
                width: 18px;
                height: 18px;
            }

            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.6);
                z-index: 99;
                transition: opacity 0.3s;
            }

            /* ════════════════════════════════════════════
           MOBILE FIRST — breakpoint < 1024px
           Real app-native experience
        ════════════════════════════════════════════ */

            /* Prevenir overflow horizontal en todo el layout */
            html,
            body {
                overflow-x: hidden;
                max-width: 100%;
            }

            /* Strict restriction: only for 1920x1080 class screens */
            .desktop-only {
                display: none !important;
            }

            @media (min-width: 1024px) {
                .desktop-only {
                    display: flex !important;
                }
            }

            @media (max-width: 1024px) {
                /* ── Sidebar: off-canvas drawer ───── */
                .admin-sidebar {
                    width: min(82vw, 300px);
                    transform: translateX(-105%);
                    will-change: transform;
                    box-shadow: none;
                }
                .admin-sidebar.open {
                    transform: translateX(0);
                    box-shadow: 24px 0 60px rgba(0, 0, 0, 0.6);
                }

                /* ── Sidebar nav items más grandes p/ táctil ── */
                .nav-item {
                    padding: 0.8rem 1.25rem;
                    font-size: 0.875rem;
                    margin: 2px 0.5rem;
                    gap: 0.85rem;
                }
                .nav-item svg {
                    width: 18px;
                    height: 18px;
                }
                .nav-section-label {
                    padding: 1.25rem 1.25rem 0.5rem;
                    font-size: 0.65rem;
                }

                /* ── Overlay con blur tipo glass ── */
                .sidebar-overlay {
                    display: none;
                    position: fixed;
                    inset: 0;
                    background: rgba(0, 0, 0, 0.72);
                    backdrop-filter: blur(4px);
                    -webkit-backdrop-filter: blur(4px);
                    z-index: 99;
                    transition: opacity 0.3s;
                }
                .sidebar-overlay.open {
                    display: block;
                }

                /* ── Main sin margen del sidebar ── */
                .admin-main {
                    margin-left: 0;
                    min-height: 100vh;
                    width: 100%;
                    max-width: 100%;
                    overflow-x: hidden;
                }

                /* ── Topbar más alto, táctil ── */
                .admin-topbar {
                    padding: 0.85rem 1rem;
                    min-height: 56px;
                }
                .topbar-title {
                    font-size: 1rem;
                }
                .sidebar-toggle {
                    display: flex;
                    width: 38px;
                    height: 38px;
                    border-radius: 8px;
                    border: 1px solid rgba(255, 255, 255, 0.08);
                }
                .sidebar-toggle svg {
                    width: 20px;
                    height: 20px;
                }

                /* ── Botón "Ver tienda" rediseñado mobile ── */
                .btn-store {
                    padding: 0.45rem 0.85rem;
                    background: rgba(var(--brand-rgb), 0.06);
                    border: 1px solid rgba(var(--brand-rgb), 0.2);
                    border-radius: 8px;
                    color: var(--brand);
                    font-size: 0.72rem;
                    font-weight: 600;
                    gap: 0.35rem;
                    width: auto;
                    height: auto;
                    letter-spacing: 0.01em;
                }
                .btn-store svg {
                    width: 12px;
                    height: 12px;
                }
                .btn-store span {
                    display: inline;
                }

                /* ── Content padding móvil ── */
                .admin-content {
                    padding: 1rem;
                    overflow-x: hidden;
                }

                /* ── Stat grid: 2 columnas ── */
                .stat-grid {
                    grid-template-columns: repeat(2, 1fr);
                    gap: 0.75rem;
                }
                .stat-card {
                    padding: 1rem 0.875rem;
                }
                .stat-value {
                    font-size: 1.5rem;
                }
                .stat-label {
                    font-size: 0.58rem;
                }
                .stat-change {
                    font-size: 0.62rem;
                }

                /* ── Cards más compactas ── */
                .card {
                    padding: 1rem;
                }
                .card-title {
                    font-size: 0.875rem;
                }

                /* ── Tablas → Mobile cards ── */
                .data-table,
                .data-table thead,
                .data-table tbody,
                .data-table tr,
                .data-table th,
                .data-table td {
                    display: block;
                }
                .data-table thead {
                    display: none !important;
                }
                .data-table tbody tr {
                    background: rgba(255, 255, 255, 0.02);
                    border: 1px solid rgba(255, 255, 255, 0.06);
                    border-radius: 10px;
                    padding: 0.875rem 1rem;
                    margin-bottom: 0.6rem;
                    position: relative;
                }
                .data-table tbody tr:hover {
                    background: rgba(var(--brand-rgb), 0.02);
                    border-color: rgba(var(--brand-rgb), 0.08);
                }
                .data-table td {
                    padding: 0.2rem 0;
                    border: none;
                    font-size: 0.8rem;
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 0.5rem;
                    min-height: 1.8rem;
                }
                .data-table td::before {
                    content: attr(data-label);
                    font-size: 0.58rem;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 0.1em;
                    color: rgba(255, 255, 255, 0.25);
                    flex-shrink: 0;
                    min-width: 80px;
                }
                .data-table td:last-child {
                    margin-top: 0.5rem;
                    padding-top: 0.6rem;
                    border-top: 1px solid rgba(255, 255, 255, 0.04);
                    justify-content: flex-end;
                }
                .data-table td:last-child::before {
                    display: none;
                }

                /* ── Gráficas: una encima de la otra ── */
                .charts-grid,
                [class*="chart-grid"],
                .grid-cols-2,
                .grid-2 {
                    grid-template-columns: 1fr !important;
                    gap: 0.75rem;
                }
                canvas {
                    max-height: 200px !important;
                }

                /* ── Botones full-width en móvil ── */
                .btn-primary,
                .btn-secondary,
                .btn-danger {
                    /* No forzar full-width global, solo en contexto de acción primaria */
                }

                /* ── Filter bar: scroll horizontal suave ── */
                .filter-bar {
                    flex-wrap: nowrap;
                    overflow-x: auto;
                    -webkit-overflow-scrolling: touch;
                    padding-bottom: 0.25rem;
                    gap: 0.4rem;
                    scrollbar-width: none;
                }
                .filter-bar::-webkit-scrollbar {
                    display: none;
                }
                .filter-chip {
                    flex-shrink: 0;
                }

                /* ── Search bar full width ── */
                .search-bar {
                    max-width: 100%;
                    width: 100%;
                }

                /* ── Modal full screen en móvil ── */
                .modal {
                    max-width: 100%;
                    max-height: 92vh;
                    border-radius: 16px 16px 0 0;
                    margin-top: auto;
                }
                .modal-overlay {
                    align-items: flex-end;
                    padding: 0;
                }

                /* ── Pagination táctil ── */
                .page-btn {
                    padding: 0.5rem 0.75rem;
                    font-size: 0.8rem;
                    min-width: 36px;
                    text-align: center;
                }

                /* ── Toast full-width abajo ── */
                .toast {
                    left: 1rem;
                    right: 1rem;
                    bottom: 1rem;
                    text-align: center;
                }

                /* ── Overflow guards generales ── */
                * {
                    max-width: 100%;
                }
                img,
                video,
                canvas,
                svg {
                    max-width: 100%;
                }
                table {
                    max-width: 100%;
                }

                /* Sidebar footer más compacto en drawer */
                .sidebar-footer {
                    padding: 1rem;
                }
                .admin-avatar {
                    width: 36px;
                    height: 36px;
                    font-size: 0.8rem;
                }
                .admin-name {
                    font-size: 0.8rem;
                }
                .btn-logout {
                    padding: 0.65rem 0.75rem;
                    font-size: 0.75rem;
                }
            }

            /* ── Extra small phones (< 400px) ──── */
            @media (max-width: 400px) {
                .stat-grid {
                    grid-template-columns: repeat(2, 1fr);
                    gap: 0.5rem;
                }
                .stat-value {
                    font-size: 1.25rem;
                }
                .admin-content {
                    padding: 0.75rem;
                }
                .card {
                    padding: 0.875rem;
                }
            }

            /* ── Shared Admin Components ────────────── */
            .card {
                background: rgba(255, 255, 255, 0.02);
                border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 10px;
                padding: 1.25rem;
            }
            .card-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 1rem;
            }
            .card-title {
                font-family: "Oswald", system-ui, sans-serif;
                font-size: 0.95rem;
                font-weight: 600;
            }

            .badge {
                display: inline-flex;
                align-items: center;
                padding: 0.2rem 0.5rem;
                border-radius: 4px;
                font-size: 0.65rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }
            .badge-success {
                background: rgba(var(--brand-rgb), 0.1);
                color: var(--brand);
            }
            .badge-warning {
                background: rgba(255, 186, 0, 0.1);
                color: #ffa400;
            }
            .badge-danger {
                background: rgba(239, 68, 68, 0.1);
                color: #f87171;
            }
            .badge-info {
                background: rgba(96, 165, 250, 0.1);
                color: #60a5fa;
            }
            .badge-neutral {
                background: rgba(255, 255, 255, 0.06);
                color: rgba(255, 255, 255, 0.5);
            }

            .data-table {
                width: 100%;
                border-collapse: collapse;
            }
            .data-table th {
                text-align: left;
                font-size: 0.6rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: rgba(255, 255, 255, 0.3);
                padding: 0.6rem 0.75rem;
                border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            }
            .data-table td {
                padding: 0.65rem 0.75rem;
                font-size: 0.8rem;
                border-bottom: 1px solid rgba(255, 255, 255, 0.03);
                color: rgba(255, 255, 255, 0.7);
            }
            .data-table tr:hover td {
                background: rgba(255, 255, 255, 0.01);
            }

            .btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 0.4rem;
                padding: 0.55rem 1rem;
                border-radius: 8px;
                font-size: 0.75rem;
                font-weight: 600;
                border: none;
                cursor: pointer;
                transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
                text-decoration: none;
                font-family: inherit;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }
            .btn svg {
                width: 14px;
                height: 14px;
            }
            .btn-primary {
                background: linear-gradient(135deg, var(--brand), var(--brand-500));
                color: #000;
                box-shadow: 0 4px 16px rgba(var(--brand-rgb), 0.2);
            }
            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(var(--brand-rgb), 0.3);
            }
            .btn-primary:active {
                transform: translateY(0);
            }
            .btn-secondary {
                background: linear-gradient(
                    135deg,
                    rgba(255, 255, 255, 0.08),
                    rgba(255, 255, 255, 0.04)
                );
                color: rgba(255, 255, 255, 0.85);
                border: 1.5px solid rgba(255, 255, 255, 0.1);
            }
            .btn-secondary:hover {
                background: linear-gradient(
                    135deg,
                    rgba(255, 255, 255, 0.12),
                    rgba(255, 255, 255, 0.06)
                );
                border-color: rgba(255, 255, 255, 0.15);
                transform: translateY(-1px);
            }
            .btn-danger {
                background: linear-gradient(
                    135deg,
                    rgba(239, 68, 68, 0.15),
                    rgba(239, 68, 68, 0.08)
                );
                color: #f87171;
                border: 1.5px solid rgba(239, 68, 68, 0.2);
            }
            .btn-danger:hover {
                background: linear-gradient(
                    135deg,
                    rgba(239, 68, 68, 0.2),
                    rgba(239, 68, 68, 0.12)
                );
                border-color: rgba(239, 68, 68, 0.3);
                transform: translateY(-1px);
            }
            .btn-sm {
                padding: 0.35rem 0.7rem;
                font-size: 0.7rem;
            }

            .form-group {
                margin-bottom: 1rem;
            }
            .form-label {
                display: block;
                font-size: 0.7rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: rgba(255, 255, 255, 0.4);
                margin-bottom: 0.4rem;
            }
            .form-input,
            .form-select,
            .form-textarea {
                width: 100%;
                padding: 0.6rem 0.85rem;
                background: rgba(255, 255, 255, 0.04);
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 6px;
                color: #fff;
                font-size: 0.8rem;
                font-family: inherit;
                outline: none;
                transition: border-color 0.2s;
            }
            .form-input:focus,
            .form-select:focus,
            .form-textarea:focus {
                border-color: rgba(var(--brand-rgb), 0.4);
            }
            .form-textarea {
                min-height: 80px;
                resize: vertical;
            }
            .form-select {
                appearance: none;
                cursor: pointer;
            }
            .form-select option {
                background-color: #1a1a1a;
                color: #ffffff;
            }

            .stat-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                gap: 1rem;
            }
            .stat-card {
                background: rgba(255, 255, 255, 0.02);
                border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 10px;
                padding: 1.1rem;
            }
            .stat-label {
                font-size: 0.6rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                color: rgba(255, 255, 255, 0.3);
                margin-bottom: 0.4rem;
            }
            .stat-value {
                font-family: "Oswald", system-ui, sans-serif;
                font-size: 1.75rem;
                font-weight: 700;
                line-height: 1;
            }
            .stat-change {
                font-size: 0.65rem;
                margin-top: 0.35rem;
            }
            .stat-up {
                color: var(--brand);
            }
            .stat-down {
                color: #f87171;
            }

            .empty-state {
                text-align: center;
                padding: 3rem 1rem;
                color: rgba(255, 255, 255, 0.25);
            }
            .empty-state svg {
                width: 48px;
                height: 48px;
                margin: 0 auto 1rem;
                opacity: 0.3;
            }
            .empty-state h3 {
                font-family: "Oswald", system-ui, sans-serif;
                font-size: 1.1rem;
                margin-bottom: 0.35rem;
                color: rgba(255, 255, 255, 0.4);
            }
            .empty-state p {
                font-size: 0.8rem;
            }

            .modal-overlay {
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.7);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 200;
                padding: 1rem;
            }
            .modal {
                background: #141414;
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 12px;
                width: 100%;
                max-width: 480px;
                max-height: 90vh;
                overflow-y: auto;
                padding: 1.5rem;
            }
            .modal-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 1.25rem;
            }
            .modal-title {
                font-family: "Oswald", system-ui, sans-serif;
                font-size: 1.1rem;
                font-weight: 600;
            }
            .modal-close {
                width: 28px;
                height: 28px;
                display: flex;
                align-items: center;
                justify-content: center;
                background: rgba(255, 255, 255, 0.04);
                border: none;
                border-radius: 6px;
                color: rgba(255, 255, 255, 0.4);
                cursor: pointer;
            }
            .modal-close:hover {
                background: rgba(255, 255, 255, 0.08);
            }
            .modal-actions {
                display: flex;
                gap: 0.5rem;
                justify-content: flex-end;
                margin-top: 1.25rem;
            }

            .toast {
                position: fixed;
                bottom: 5.5rem;
                right: 1.5rem;
                padding: 0.75rem 1.15rem;
                border-radius: 8px;
                font-size: 0.8rem;
                font-weight: 500;
                z-index: 300;
                transform: translateY(20px);
                opacity: 0;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                pointer-events: none;
            }
            .toast.show {
                transform: translateY(0);
                opacity: 1;
            }
            .toast-success {
                background: rgba(var(--brand-rgb), 0.12);
                color: var(--brand);
                border: 1px solid rgba(var(--brand-rgb), 0.2);
            }
            .toast-error {
                background: rgba(239, 68, 68, 0.12);
                color: #f87171;
                border: 1px solid rgba(239, 68, 68, 0.2);
            }

            .pagination {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.35rem;
                margin-top: 1.25rem;
            }
            .page-btn {
                padding: 0.35rem 0.65rem;
                border-radius: 4px;
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid rgba(255, 255, 255, 0.06);
                color: rgba(255, 255, 255, 0.5);
                font-size: 0.75rem;
                cursor: pointer;
                transition: all 0.15s;
            }
            .page-btn:hover {
                background: rgba(255, 255, 255, 0.06);
            }
            .page-btn.active {
                background: rgba(var(--brand-rgb), 0.1);
                color: var(--brand);
                border-color: rgba(var(--brand-rgb), 0.2);
            }

            .search-bar {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.5rem 0.85rem;
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 8px;
                max-width: 300px;
            }
            .search-bar svg {
                width: 15px;
                height: 15px;
                color: rgba(255, 255, 255, 0.2);
                flex-shrink: 0;
            }
            .search-bar input {
                flex: 1;
                background: none;
                border: none;
                color: #fff;
                font-size: 0.8rem;
                outline: none;
            }
            .search-bar input::placeholder {
                color: rgba(255, 255, 255, 0.2);
            }

            .filter-bar {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                flex-wrap: wrap;
                margin-bottom: 1rem;
            }
            .filter-chip {
                padding: 0.3rem 0.65rem;
                border-radius: 20px;
                font-size: 0.7rem;
                font-weight: 500;
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid rgba(255, 255, 255, 0.06);
                color: rgba(255, 255, 255, 0.4);
                cursor: pointer;
                transition: all 0.15s;
            }
            .filter-chip:hover,
            .filter-chip.active {
                background: rgba(var(--brand-rgb), 0.06);
                color: var(--brand);
                border-color: rgba(var(--brand-rgb), 0.15);
            }
        </style>

        <!-- Brand color override — set from admin settings -->
        <style set:html={`
            :root {
                --brand: ${primaryColor};
                --brand-500: ${secondaryColor};
                --brand-rgb: ${brandRgb};
                --ve2-neon: ${primaryColor};
                --ve2-neon-soft: ${secondaryColor};
                --ve2-border-focus: ${primaryColor};
                --ve2-neon-dim: rgba(${brandRgb}, 0.08);
                --ve2-neon-glow: rgba(${brandRgb}, 0.15);
                --ve2-neon-glow-lg: rgba(${brandRgb}, 0.25);
                --ve2-neon-ghost: rgba(${brandRgb}, 0.04);
            }
        `} />
    </head>
    <body>
        <div class="admin-wrapper">
            <!-- Overlay for mobile -->
            <div class="sidebar-overlay" id="sidebar-overlay"></div>

            <!-- Sidebar -->
            <aside class="admin-sidebar" id="admin-sidebar">
                <div class="sidebar-header">
                    <a href="/admin" class="sidebar-brand">
                        <img
                            src={brandLogoUrl}
                            alt="Parra"
                            class="sidebar-brand-mark"
                            loading="eager"
                            decoding="async"
                        />
                        <span>PARRA</span>
                    </a>
                    <div class="sidebar-brand-sub">Administración</div>
                </div>

                <nav class="sidebar-nav">
                    <div class="nav-section-label">General</div>
                    {
                        navItems.slice(0, 1).map((item) => (
                            <a
                                href={item.href}
                                class={`nav-item ${activeSection === item.id ? "active" : ""}`}
                                data-icon={item.icon}
                            >
                                <i data-feather={item.icon} />
                                {item.label}
                            </a>
                        ))
                    }

                    <div class="nav-section-label" style="margin-top: 0.25rem;">
                        Ventas
                    </div>
                    {
                        navItems.slice(1, 4).map((item) => (
                            <a
                                href={item.href}
                                class={`nav-item ${activeSection === item.id ? "active" : ""}`}
                            >
                                <i data-feather={item.icon} />
                                {item.label}
                            </a>
                        ))
                    }

                    <div class="nav-section-label" style="margin-top: 0.25rem;">
                        Catálogo
                    </div>
                    {
                        navItems.slice(4, 7).map((item) => (
                            <a
                                href={item.href}
                                class={`nav-item ${activeSection === item.id ? "active" : ""}`}
                            >
                                <i data-feather={item.icon} />
                                {item.label}
                            </a>
                        ))
                    }

                    <div class="nav-section-label" style="margin-top: 0.25rem;">
                        Sistema
                    </div>
                    {
                        navItems.slice(7).map((item) => (
                            <a
                                href={item.href}
                                class={`nav-item ${activeSection === item.id ? "active" : ""} ${item.id === "editor" ? "desktop-only" : ""}`}
                            >
                                <i data-feather={item.icon} />
                                {item.label}
                            </a>
                        ))
                    }
                </nav>

                <div class="sidebar-footer">
                    <div class="admin-profile">
                        <div class="admin-avatar">
                            {
                                admin.name
                                    ? admin.name.charAt(0).toUpperCase()
                                    : "A"
                            }
                        </div>
                        <div style="min-width:0;">
                            <div class="admin-name">
                                {admin.name || "Admin"}
                            </div>
                            <div class="admin-email">{admin.email}</div>
                        </div>
                    </div>
                    <button
                        class="btn-logout"
                        id="btn-admin-logout"
                        type="button"
                        onclick="handleAdminLogout(event)"
                    >
                        <i data-feather="log-out"></i>
                        Cerrar sesión
                    </button>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="admin-main">
                <div class="admin-topbar">
                    <div style="display:flex;align-items:center;gap:0.75rem;">
                        <button class="sidebar-toggle" id="sidebar-toggle">
                            <i data-feather="menu"></i>
                        </button>
                        <span class="topbar-title">{title}</span>
                    </div>
                    <div class="topbar-actions">
                        <a href="/" class="btn-store" target="_blank">
                            <i data-feather="external-link"></i>
                            <span>Ver tienda</span>
                        </a>
                    </div>
                </div>

                <div class="admin-content">
                    <slot />
                </div>
            </main>
        </div>

        <!-- Toast container -->
        <div id="admin-toast" class="toast"></div>

        <!-- Global Confirm Modal -->
        <div
            id="admin-confirm-modal"
            class="modal-overlay"
            style="display:none; z-index: 1000;"
        >
            <div
                class="modal"
                style="max-width: 400px; padding: 2rem; border-top: 4px solid #f87171;"
            >
                <div
                    style="display: flex; flex-direction: column; align-items: center; text-align: center;"
                >
                    <div
                        style="width: 64px; height: 64px; border-radius: 50%; background: rgba(239, 68, 68, 0.1); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; color: #f87171;"
                    >
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                    </div>
                    <h3
                        style="font-family: 'Oswald', system-ui, sans-serif; font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem;"
                    >
                        Confirmar Acción
                    </h3>
                    <p
                        id="admin-confirm-msg"
                        style="color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-bottom: 1.5rem;"
                    >
                    </p>
                    <div style="display: flex; gap: 0.75rem; width: 100%;">
                        <button
                            id="admin-confirm-cancel"
                            class="btn btn-secondary"
                            style="flex: 1;">Cancelar</button
                        >
                        <button
                            id="admin-confirm-ok"
                            class="btn btn-danger"
                            style="flex: 1;">Aceptar</button
                        >
                    </div>
                </div>
            </div>
        </div>

        <script is:inline>
            // Initialize feather icons
            if (typeof feather !== "undefined") feather.replace();

            // Sidebar drawer (mobile < 1024px)
            (function () {
                var toggle = document.getElementById("sidebar-toggle");
                var sidebar = document.getElementById("admin-sidebar");
                var overlay = document.getElementById("sidebar-overlay");
                var isMobile = function () {
                    return window.innerWidth < 1024;
                };

                function openDrawer() {
                    sidebar.classList.add("open");
                    overlay.classList.add("open");
                    document.body.style.overflow = "hidden";
                }
                function closeDrawer() {
                    sidebar.classList.remove("open");
                    overlay.classList.remove("open");
                    document.body.style.overflow = "";
                }

                if (toggle && sidebar && overlay) {
                    toggle.addEventListener("click", function () {
                        if (sidebar.classList.contains("open")) closeDrawer();
                        else openDrawer();
                    });
                    overlay.addEventListener("click", closeDrawer);

                    // Cerrar con ESC
                    document.addEventListener("keydown", function (e) {
                        if (e.key === "Escape") closeDrawer();
                    });

                    // Swipe-to-close: deslizar izq cierra el drawer
                    var touchStartX = 0;
                    sidebar.addEventListener(
                        "touchstart",
                        function (e) {
                            touchStartX = e.touches[0].clientX;
                        },
                        { passive: true },
                    );
                    sidebar.addEventListener(
                        "touchend",
                        function (e) {
                            var dx = e.changedTouches[0].clientX - touchStartX;
                            if (dx < -60) closeDrawer();
                        },
                        { passive: true },
                    );

                    // Al hacer resize a desktop, limpiar estado
                    window.addEventListener("resize", function () {
                        if (!isMobile()) {
                            closeDrawer();
                        }
                    });
                }
            })();

            // Logout helper invoked from onclick (robust against event binding issues)
            window.handleAdminLogout = async function (e) {
                try {
                    // Visual feedback inmediato para depuración
                    try {
                        window.adminToast("Cerrando sesión...", "success");
                    } catch (e) {}

                    console.log("[logout] clicked");

                    var res = await fetch("/api/auth/logout", {
                        method: "POST",
                        credentials: "same-origin",
                        headers: { "Content-Type": "application/json" },
                    });

                    console.log("[logout] response status", res.status);

                    if (res.ok) {
                        try {
                            var body = await res.json();
                            window.adminToast(
                                body.message || "Sesión cerrada.",
                                "success",
                            );
                        } catch (e) {
                            window.adminToast("Sesión cerrada.", "success");
                        }
                        setTimeout(function () {
                            window.location.replace("/admin/login");
                        }, 400);
                    } else {
                        try {
                            var err = await res.json();
                            window.adminToast(
                                err.message || "No se pudo cerrar la sesión.",
                                "error",
                            );
                        } catch (e) {
                            window.adminToast(
                                "No se pudo cerrar la sesión.",
                                "error",
                            );
                        }
                    }
                } catch (err) {
                    console.error("[logout] error", err);
                    try {
                        window.adminToast(
                            "Error de red al cerrar sesión.",
                            "error",
                        );
                    } catch (e) {}
                }
            };

            // Global admin toast utility
            window.adminToast = function (msg, type) {
                var t = document.getElementById("admin-toast");
                if (!t) return;
                t.textContent = msg;
                t.className = "toast toast-" + (type || "success");
                requestAnimationFrame(function () {
                    t.classList.add("show");
                });
                setTimeout(function () {
                    t.classList.remove("show");
                }, 3500);
            };

            // Global confirm dialog
            window.adminConfirm = function (msg) {
                return new Promise(function (resolve) {
                    var modal = document.getElementById("admin-confirm-modal");
                    var msgEl = document.getElementById("admin-confirm-msg");
                    var btnOk = document.getElementById("admin-confirm-ok");
                    var btnCancel = document.getElementById(
                        "admin-confirm-cancel",
                    );

                    if (!modal) {
                        resolve(confirm(msg));
                        return;
                    }

                    msgEl.textContent = msg;
                    modal.style.display = "flex";

                    function close(result) {
                        modal.style.display = "none";
                        btnOk.removeEventListener("click", onOk);
                        btnCancel.removeEventListener("click", onCancel);
                        resolve(result);
                    }

                    function onOk() {
                        close(true);
                    }
                    function onCancel() {
                        close(false);
                    }

                    btnOk.addEventListener("click", onOk);
                    btnCancel.addEventListener("click", onCancel);
                });
            };

            // Global page search
            document
                .getElementById("page-search")
                ?.addEventListener("input", function (e) {
                    var term = e.target.value.toLowerCase();
                    document
                        .querySelectorAll(".data-table tbody tr")
                        .forEach(function (row) {
                            var dataStr =
                                row.getAttribute("data-search") ||
                                row.innerText;
                            row.style.display = dataStr
                                .toLowerCase()
                                .includes(term)
                                ? ""
                                : "none";
                        });
                });
        </script>
    </body>
</html>
