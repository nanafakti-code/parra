---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import CartDrawer from "../components/CartDrawer.astro";
import { supabaseAdmin } from "../lib/supabase";

// ── Brand color (from settings) ───────────────────────────────────────────
function sanitizeColor(color: string): string {
	return /^#[0-9a-fA-F]{3,8}$/.test(color) ? color : "#39FF14";
}
function hexToRgb(hex: string): string {
	const c = hex.replace("#", "");
	const r = parseInt(c.substring(0, 2), 16);
	const g = parseInt(c.substring(2, 4), 16);
	const b = parseInt(c.substring(4, 6), 16);
	return `${r}, ${g}, ${b}`;
}
function deriveSecondaryColor(hex: string): string {
	const c = hex.replace("#", "");
	const factor = 0.8;
	const r = Math.round(parseInt(c.substring(0, 2), 16) * factor);
	const g = Math.round(parseInt(c.substring(2, 4), 16) * factor);
	const b = Math.round(parseInt(c.substring(4, 6), 16) * factor);
	return `#${r.toString(16).padStart(2, "0")}${g.toString(16).padStart(2, "0")}${b.toString(16).padStart(2, "0")}`;
}

let primaryColor = "#39FF14";
try {
	const { data } = await supabaseAdmin
		.from("site_settings")
		.select("value")
		.eq("key", "brand")
		.single();
	if (data?.value) {
		primaryColor = sanitizeColor((data.value as any).primary_color || primaryColor);
	}
} catch {}

const secondaryColor = deriveSecondaryColor(primaryColor);

const brandRgb = hexToRgb(primaryColor);

interface Props {
	title: string;
	description?: string;
	image?: string;
	robots?: string;
	/** Extra JSON-LD snippets (stringified) injected per-page */
	schemaJson?: string;
	/** Canonical override for specific pages */
	canonicalOverride?: string;
	/** Google Search Console verification code */
	googleVerification?: string;
}

const {
	title,
	description = "Parra GK Gloves – Guantes de portero profesionales con látex alemán de alta adherencia. Envío gratis en España. Compra online guantes de portero élite.",
	image = "https://res.cloudinary.com/djvj32zic/image/upload/f_jpg,q_80,w_1200,h_630,c_fill,g_auto/v1771869186/b6c3767d-ca9e-49a5-8187-b0610793ba75_zgic3i.png",
	robots = "index, follow",
	schemaJson,
	canonicalOverride,
	googleVerification,
} = Astro.props;

const SITE = "https://www.parragkgloves.es";
const canonicalURL =
	canonicalOverride ?? new URL(Astro.url.pathname, SITE).href;
const fullTitle = `${title} | Parra GK Gloves`;

// ── JSON-LD: Organization ─────────────────────────────────────────────────
const orgSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Organization",
	name: "Parra GK Gloves",
	alternateName: ["Parra", "parragkgloves", "Parra Goalkeeper Gloves"],
	url: SITE,
	logo: `${SITE}/favicon.svg`,
	description:
		"Marca española de guantes de portero profesionales con látex alemán de alta adherencia.",
	sameAs: ["https://www.instagram.com/parragkgloves/"],
	contactPoint: {
		"@type": "ContactPoint",
		contactType: "customer service",
		areaServed: "ES",
		availableLanguage: "Spanish",
	},
	address: {
		"@type": "PostalAddress",
		addressCountry: "ES",
	},
});

// ── JSON-LD: WebSite + SearchAction ──────────────────────────────────────
const websiteSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "Parra GK Gloves",
	url: SITE,
	description:
		"Tienda oficial de guantes de portero profesionales Parra GK Gloves.",
	potentialAction: {
		"@type": "SearchAction",
		target: {
			"@type": "EntryPoint",
			urlTemplate: `${SITE}/shop?q={search_term_string}`,
		},
		"query-input": "required name=search_term_string",
	},
});
---

<!doctype html>
<html lang="es" class="dark" style={`--brand:${primaryColor};--brand-500:${secondaryColor};--brand-rgb:${brandRgb};--scrollbar-thumb:${primaryColor};--selection-bg:${primaryColor};--border-hover:rgba(${brandRgb},0.3);--bg-card-hover-shadow:rgba(${brandRgb},0.05);--ve2-neon:${primaryColor};--ve2-neon-soft:${secondaryColor};--ve2-border-focus:${primaryColor};--ve2-neon-dim:rgba(${brandRgb},0.08);--ve2-neon-glow:rgba(${brandRgb},0.15);--ve2-neon-glow-lg:rgba(${brandRgb},0.25);--ve2-neon-ghost:rgba(${brandRgb},0.04)`}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Primary Meta -->
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<meta name="author" content="Parra GK Gloves" />
		<meta
			name="keywords"
			content="parra gk gloves, guantes de portero parra, parra guantes portero, guantes portero profesionales, goalkeeper gloves spain, guantes portero grip, parragkgloves"
		/>
		<link rel="canonical" href={canonicalURL} />

		<!-- Google Search Console verification -->
		{googleVerification && <meta name="google-site-verification" content={googleVerification} />}

		<!-- Open Graph (Facebook / WhatsApp / LinkedIn) -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Parra GK Gloves" />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta
			property="og:image:alt"
			content="Parra GK Gloves – Guantes de portero profesionales"
		/>
		<meta property="og:url" content={canonicalURL} />

		<!-- Twitter / X Cards -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@parragkgloves" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
		<meta
			name="twitter:image:alt"
			content="Parra GK Gloves – Guantes de portero profesionales"
		/>

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/images/brand-mark.png" />
		<link rel="apple-touch-icon" href="/images/brand-mark.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- DNS Prefetch + Preconnect for Fonts & CDN -->
		<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
		<link rel="dns-prefetch" href="https://fonts.gstatic.com" />
		<link rel="dns-prefetch" href="https://res.cloudinary.com" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<!-- Preload LCP hero image — evita el LCP penalty de 49s -->
		<!-- La imagen hero se carga como CSS background-image, el browser no la descubre
		     hasta parsear el CSS. El preload adelanta la descarga al inicio del HTML. -->
		<link
			rel="preload"
			href="https://res.cloudinary.com/djvj32zic/image/upload/f_webp,q_auto,w_1200/v1771850353/wmremove-transformed_qkiglz.png"
			as="image"
			type="image/webp"
			fetchpriority="high"
		/>

		<!-- Google Fonts: Oswald + Inter — non-blocking load -->
		<link
			rel="preload"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Oswald:wght@400;500;600;700&display=swap"
			as="style"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Oswald:wght@400;500;600;700&display=swap"
				rel="stylesheet"
			/>
		</noscript>

		<!-- Theme initialization (FOUC prevention) -->
		<script is:inline>
			(function () {
				const stored = localStorage.getItem("theme");
				if (stored === "light") {
					document.documentElement.classList.remove("dark");
				} else {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>

		<!-- JSON-LD: Organization -->
		<script type="application/ld+json" set:html={orgSchema} />

		<!-- JSON-LD: WebSite + SearchAction -->
		<script type="application/ld+json" set:html={websiteSchema} />

		<!-- JSON-LD: Page-specific schema (product, breadcrumb, etc.) -->
		{
			schemaJson && (
				<script type="application/ld+json" set:html={schemaJson} />
			)
		}

		<ClientRouter />

		<!-- Brand color override — set from admin settings -->
		<style set:html={`
			:root {
				--brand: ${primaryColor};
				--brand-500: ${secondaryColor};
				--brand-rgb: ${brandRgb};
				--scrollbar-thumb: ${primaryColor};
				--selection-bg: ${primaryColor};
				--border-hover: rgba(${brandRgb}, 0.4);
				--bg-card-hover-shadow: rgba(${brandRgb}, 0.06);
				--ve2-neon: ${primaryColor};
				--ve2-neon-soft: ${secondaryColor};
				--ve2-border-focus: ${primaryColor};
				--ve2-neon-dim: rgba(${brandRgb}, 0.08);
				--ve2-neon-glow: rgba(${brandRgb}, 0.15);
				--ve2-neon-glow-lg: rgba(${brandRgb}, 0.25);
				--ve2-neon-ghost: rgba(${brandRgb}, 0.04);
			}
			.dark {
				--brand: ${primaryColor};
				--brand-500: ${secondaryColor};
				--brand-rgb: ${brandRgb};
				--scrollbar-thumb: ${primaryColor};
				--selection-bg: ${primaryColor};
				--border-hover: rgba(${brandRgb}, 0.3);
				--bg-card-hover-shadow: rgba(${brandRgb}, 0.05);
			}
		`} />
	</head>
	<body class="font-body overflow-x-hidden">
		<slot />
		<CartDrawer />

		<!-- Scroll Reveal Observer + Cart Bounce Helper -->
		<script is:inline>
			function initScrollReveal() {
				// Respect reduced motion preference
				if (
					window.matchMedia("(prefers-reduced-motion: reduce)")
						.matches
				) {
					document.querySelectorAll(".reveal").forEach(function (el) {
						el.classList.add("visible");
					});
					return;
				}

				var observer = new IntersectionObserver(
					function (entries) {
						entries.forEach(function (entry) {
							if (entry.isIntersecting) {
								entry.target.classList.add("visible");
								observer.unobserve(entry.target);
							}
						});
					},
					{
						threshold: 0.15,
						rootMargin: "0px 0px -40px 0px",
					},
				);

				document
					.querySelectorAll(".reveal:not(.visible)")
					.forEach(function (el) {
						observer.observe(el);
					});
			}

			// Cart bounce helper — callable from any page
			window.triggerCartBounce = function () {
				var cartIcon = document.querySelector('[aria-label="Carrito"]');
				if (cartIcon) {
					cartIcon.classList.remove("cart-bounce");
					// Force reflow to restart animation
					void cartIcon.offsetWidth;
					cartIcon.classList.add("cart-bounce");
					cartIcon.addEventListener(
						"animationend",
						function () {
							cartIcon.classList.remove("cart-bounce");
						},
						{ once: true },
					);
				}
			};

			document.addEventListener("astro:page-load", initScrollReveal);
			if (document.readyState === "complete") {
				initScrollReveal();
			} else {
				document.addEventListener("DOMContentLoaded", initScrollReveal);
			}
		</script>
	</body>
</html>
