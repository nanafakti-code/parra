---
/**
 * SidebarSections.astro
 * Visual Builder 2026 — Left sidebar with section list
 * Glassmorphism panel with drag-and-drop reordering
 */
---

<div class="vb-sidebar ve2-glass" id="vbSidebar">
    <!-- Sidebar Header -->
    <div class="vb-sidebar-head">
        <div class="vb-sidebar-head-row">
            <div class="vb-sidebar-title-wrap">
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><rect x="3" y="3" width="7" height="7"></rect><rect
                        x="14"
                        y="3"
                        width="7"
                        height="7"></rect><rect
                        x="3"
                        y="14"
                        width="7"
                        height="7"></rect><rect
                        x="14"
                        y="14"
                        width="7"
                        height="7"></rect></svg
                >
                <span class="vb-sidebar-title">Bloques</span>
            </div>
            <span class="ve2-badge ve2-badge-neon" id="vbBlockCount">0</span>
        </div>
        <!-- Search -->
        <div class="vb-sidebar-search">
            <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="11" cy="11" r="8"></circle><line
                    x1="21"
                    y1="21"
                    x2="16.65"
                    y2="16.65"></line></svg
            >
            <input
                type="text"
                class="vb-search-input"
                placeholder="Buscar bloque..."
                id="vbSearchInput"
            />
        </div>
    </div>

    <!-- Section Items -->
    <div class="vb-sidebar-list ve2-scroll" id="vbSectionItems">
        <!-- Rendered by JS -->
    </div>


</div>

<style>
    /* ── Sidebar Container ─────────────────────────── */
    .vb-sidebar {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-height: 0;
        overflow: hidden;
        position: relative;
        z-index: 10;
        flex-shrink: 0;
    }

    /* ── Header ────────────────────────────────────── */
    .vb-sidebar-head {
        padding: 1rem 1rem 0.75rem;
        border-bottom: 1px solid
            var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
        flex-shrink: 0;
    }
    .vb-sidebar-head-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.65rem;
    }
    .vb-sidebar-title-wrap {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--ve2-text-tertiary, rgba(255, 255, 255, 0.4));
    }
    .vb-sidebar-title-wrap svg {
        opacity: 0.5;
    }
    .vb-sidebar-title {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--ve2-text-tertiary, rgba(255, 255, 255, 0.4));
    }

    /* ── Search ────────────────────────────────────── */
    .vb-sidebar-search {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.45rem 0.7rem;
        background: var(--ve2-bg-input, #161616);
        border: 1px solid var(--ve2-border-default, #2a2a2a);
        border-radius: var(--ve2-radius-md, 8px);
        transition:
            border-color 200ms,
            box-shadow 200ms;
    }
    .vb-sidebar-search svg {
        color: var(--ve2-text-muted, rgba(255, 255, 255, 0.2));
        flex-shrink: 0;
    }
    .vb-sidebar-search:focus-within {
        border-color: var(--ve2-neon, #39ff14);
        box-shadow: 0 0 0 3px var(--ve2-neon-dim, rgba(57, 255, 20, 0.08));
    }
    .vb-sidebar-search:focus-within svg {
        color: var(--ve2-neon, #39ff14);
    }
    .vb-search-input {
        flex: 1;
        background: none;
        border: none;
        outline: none;
        color: var(--ve2-text-primary, #fff);
        font-size: 0.78rem;
        font-family: inherit;
    }
    .vb-search-input::placeholder {
        color: var(--ve2-text-muted, rgba(255, 255, 255, 0.2));
    }

    /* ── Section List ──────────────────────────────── */
    .vb-sidebar-list {
        flex: 1;
        overflow-y: auto;
        padding: 0.5rem;
    }

    /* ── Section Item ──────────────────────────────── */
    :global(.vb-block) {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.65rem 0.75rem;
        border-radius: var(--ve2-radius-md, 8px);
        cursor: pointer;
        user-select: none;
        margin-bottom: 2px;
        border: 1px solid transparent;
        border-left: 3px solid transparent;
        position: relative;
        background: transparent;
        transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
    }
    :global(.vb-block:hover) {
        background: var(--ve2-bg-hover, #1a1a1a);
        border-color: var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
        border-left-color: rgba(255, 255, 255, 0.08);
    }
    :global(.vb-block.active) {
        background: var(--ve2-bg-raised, #131313);
        border-color: rgba(57, 255, 20, 0.08);
        border-left-color: var(--ve2-neon, #39ff14);
    }
    :global(.vb-block.active::before) {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: var(--ve2-radius-md, 8px);
        background: linear-gradient(
            90deg,
            rgba(57, 255, 20, 0.03) 0%,
            transparent 50%
        );
        pointer-events: none;
    }
    :global(.vb-block.drag-over) {
        background: var(--ve2-neon-ghost, rgba(57, 255, 20, 0.04));
        border-color: rgba(57, 255, 20, 0.15);
        border-left-color: rgba(57, 255, 20, 0.15);
    }
    :global(.vb-block.dragging) {
        opacity: 0.25;
        transform: scale(0.97);
    }

    /* Drag Handle */
    :global(.vb-block-grip) {
        display: flex;
        align-items: center;
        color: var(--ve2-text-disabled, rgba(255, 255, 255, 0.12));
        cursor: grab;
        flex-shrink: 0;
        transition: color 150ms;
    }
    :global(.vb-block:hover .vb-block-grip) {
        color: var(--ve2-text-tertiary, rgba(255, 255, 255, 0.4));
    }
    :global(.vb-block-grip:active) {
        cursor: grabbing;
    }
    :global(.vb-block-grip-locked) {
        cursor: not-allowed !important;
        color: rgba(57, 255, 20, 0.35) !important;
    }
    :global(.vb-block-locked) {
        opacity: 0.9;
    }

    /* Block Icon */
    :global(.vb-block-icon) {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.04);
        border-radius: var(--ve2-radius-md, 8px);
        flex-shrink: 0;
        transition: all 150ms;
    }
    :global(.vb-block-icon svg) {
        width: 14px;
        height: 14px;
        color: var(--ve2-text-tertiary, rgba(255, 255, 255, 0.4));
        transition: color 150ms;
    }
    :global(.vb-block:hover .vb-block-icon) {
        background: rgba(255, 255, 255, 0.06);
    }
    :global(.vb-block.active .vb-block-icon) {
        background: var(--ve2-neon-dim, rgba(57, 255, 20, 0.08));
    }
    :global(.vb-block.active .vb-block-icon svg) {
        color: var(--ve2-neon, #39ff14);
    }

    /* Block Info */
    :global(.vb-block-info) {
        flex: 1;
        min-width: 0;
    }
    :global(.vb-block-name) {
        font-size: 0.8rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.3;
        transition: color 150ms;
    }
    :global(.vb-block:hover .vb-block-name),
    :global(.vb-block.active .vb-block-name) {
        color: #fff;
    }
    :global(.vb-block-meta) {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 2px;
    }
    :global(.vb-block-key) {
        font-size: 0.6rem;
        color: var(--ve2-text-muted, rgba(255, 255, 255, 0.2));
        font-family: var(--ve2-font-mono, "JetBrains Mono", monospace);
        letter-spacing: 0.02em;
    }
    :global(.vb-block.active .vb-block-key) {
        color: var(--ve2-text-tertiary, rgba(255, 255, 255, 0.4));
    }

    /* Unsaved indicator */
    :global(.vb-block-unsaved) {
        width: 6px;
        height: 6px;
        background: var(--ve2-warning, #ffa400);
        border-radius: 50%;
        flex-shrink: 0;
        display: none;
        animation: ve2-pulse 2s ease-in-out infinite;
    }
    :global(.vb-block-unsaved.show) {
        display: block;
    }

    /* ── Footer ────────────────────────────────────── */
    .vb-sidebar-foot {
        padding: 0.65rem;
        border-top: 1px solid
            var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
        flex-shrink: 0;
    }
    .vb-add-block-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        width: 100%;
        padding: 0.55rem;
        background: transparent;
        border: 1px dashed var(--ve2-border-default, #2a2a2a);
        border-radius: var(--ve2-radius-md, 8px);
        color: var(--ve2-text-tertiary, rgba(255, 255, 255, 0.4));
        font-size: 0.72rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: all 200ms;
    }
    .vb-add-block-btn:hover {
        border-color: rgba(57, 255, 20, 0.3);
        color: var(--ve2-neon, #39ff14);
        background: var(--ve2-neon-ghost, rgba(57, 255, 20, 0.04));
    }

    /* ── Empty state ───────────────────────────────── */
    :global(.vb-sidebar-empty) {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2.5rem 1rem;
        color: var(--ve2-text-muted, rgba(255, 255, 255, 0.2));
        text-align: center;
        gap: 0.5rem;
    }
    :global(.vb-sidebar-empty svg) {
        width: 28px;
        height: 28px;
        opacity: 0.15;
    }
    :global(.vb-sidebar-empty p) {
        font-size: 0.75rem;
    }

    /* ── Responsive ────────────────────────────────── */
    @media (max-width: 1024px) {
        .vb-sidebar-list {
            max-height: 240px;
        }
    }
</style>

<script is:inline>
    /**
     * SidebarSections — Block list rendering + drag-and-drop
     * Emits custom events: vb:select, vb:toggle, vb:reorder
     */
    (function () {
        "use strict";

        var ICON_SVG = {
            hero: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
            featured_products:
                '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
            benefits:
                '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>',
            glove_selector:
                '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>',
            testimonials:
                '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
            cta_banner:
                '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
            newsletter:
                '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
            banner: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>',
            _default:
                '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>',
        };

        function esc(str) {
            if (str == null) return "";
            return String(str)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;");
        }

        function getIcon(key) {
            return ICON_SVG[key] || ICON_SVG._default;
        }

        /**
         * Render the block list.
         * @param {Array} sections — filtered sections for current page
         * @param {string|null} selectedId
         * @param {Set} unsavedIds
         */
        window.VBSidebar = {
            render: function (sections, selectedId, unsavedIds) {
                var container = document.getElementById("vbSectionItems");
                var countEl = document.getElementById("vbBlockCount");
                if (!container) return;

                if (countEl) countEl.textContent = sections.length;

                if (sections.length === 0) {
                    container.innerHTML =
                        '<div class="vb-sidebar-empty">' +
                        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>' +
                        "<p>No hay bloques en esta página</p>" +
                        "</div>";
                    return;
                }

                var html = "";
                sections.forEach(function (s, i) {
                    var isActive = s.id === selectedId;
                    var unsaved = unsavedIds && unsavedIds.has(s.id);
                    var isHero = (s.section_key === 'hero' && i === 0);
                    html +=
                        '<div class="vb-block' +
                        (isActive ? " active" : "") +
                        (isHero ? " vb-block-locked" : "") +
                        '" data-id="' +
                        s.id +
                        '" data-key="' +
                        esc(s.section_key) +
                        '" draggable="' + (isHero ? 'false' : 'true') + '" style="animation-delay:' +
                        i * 30 +
                        'ms">' +
                        (isHero
                            ? '<div class="vb-block-grip vb-block-grip-locked" title="El Hero siempre es el primero"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>'
                            : '<div class="vb-block-grip" title="Arrastrar"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="5" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="19" r="1"/></svg></div>') +
                        "" +
                        '<div class="vb-block-icon">' +
                        getIcon(s.section_key) +
                        "</div>" +
                        '<div class="vb-block-info">' +
                        '<div class="vb-block-name">' +
                        esc(s.label) +
                        "</div>" +
                        '<div class="vb-block-meta">' +
                        '<span class="vb-block-key">' +
                        esc(s.section_key) +
                        "</span>" +
                        '<span class="ve2-badge ' +
                        (s.is_active ? "ve2-badge-neon" : "ve2-badge-muted") +
                        '">' +
                        (s.is_active ? "Activo" : "Oculto") +
                        "</span>" +
                        "</div>" +
                        "</div>" +
                        '<div class="vb-block-unsaved' +
                        (unsaved ? " show" : "") +
                        '"></div>' +
                        '<button class="ve2-toggle ' +
                        (s.is_active ? "on" : "off") +
                        '" data-toggle-id="' +
                        s.id +
                        '"></button>' +
                        "</div>";
                });

                container.innerHTML = html;
                window.VBSidebar._bindDragDrop(container);
            },

            _dragSrcId: null,

            _bindDragDrop: function (container) {
                var self = this;
                container.querySelectorAll(".vb-block").forEach(function (el) {
                    el.addEventListener("dragstart", function (e) {
                        // El Hero nunca se puede mover
                        if (this.dataset.key === 'hero') { e.preventDefault(); return; }
                        self._dragSrcId = this.dataset.id;
                        this.classList.add("dragging");
                        e.dataTransfer.effectAllowed = "move";
                        e.dataTransfer.setData("text/plain", this.dataset.id);
                    });
                    el.addEventListener("dragend", function () {
                        this.classList.remove("dragging");
                        container
                            .querySelectorAll(".vb-block")
                            .forEach(function (b) {
                                b.classList.remove("drag-over");
                            });
                    });
                    el.addEventListener("dragover", function (e) {
                        e.preventDefault();
                        e.dataTransfer.dropEffect = "move";
                        container
                            .querySelectorAll(".vb-block")
                            .forEach(function (b) {
                                b.classList.remove("drag-over");
                            });
                        if (this.dataset.id !== self._dragSrcId)
                            this.classList.add("drag-over");
                    });
                    el.addEventListener("dragleave", function () {
                        this.classList.remove("drag-over");
                    });
                    el.addEventListener("drop", function (e) {
                        e.preventDefault();
                        this.classList.remove("drag-over");
                        var dropId = this.dataset.id;
                        if (self._dragSrcId && self._dragSrcId !== dropId) {
                            document.dispatchEvent(
                                new CustomEvent("vb:reorder", {
                                    detail: {
                                        from: self._dragSrcId,
                                        to: dropId,
                                    },
                                }),
                            );
                        }
                        self._dragSrcId = null;
                    });
                });
            },
        };

        // Event delegation for clicks
        var container = document.getElementById("vbSectionItems");
        if (container) {
            container.addEventListener("click", function (e) {
                var toggleBtn = e.target.closest(".ve2-toggle");
                if (toggleBtn) {
                    e.stopPropagation();
                    var tid = toggleBtn.getAttribute("data-toggle-id");
                    if (tid)
                        document.dispatchEvent(
                            new CustomEvent("vb:toggle", {
                                detail: { id: tid },
                            }),
                        );
                    return;
                }
                if (e.target.closest(".vb-block-grip")) return;
                var block = e.target.closest(".vb-block");
                if (block) {
                    document.dispatchEvent(
                        new CustomEvent("vb:select", {
                            detail: { id: block.dataset.id },
                        }),
                    );
                }
            });
        }

        // Search filter
        var searchInput = document.getElementById("vbSearchInput");
        if (searchInput) {
            searchInput.addEventListener("input", function () {
                var q = this.value.toLowerCase().trim();
                document.querySelectorAll(".vb-block").forEach(function (el) {
                    var name = (
                        el.querySelector(".vb-block-name")?.textContent || ""
                    ).toLowerCase();
                    var key = (
                        el.querySelector(".vb-block-key")?.textContent || ""
                    ).toLowerCase();
                    el.style.display =
                        !q || name.includes(q) || key.includes(q) ? "" : "none";
                });
            });
        }
    })();
</script>
