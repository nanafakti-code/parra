---
/**
 * InspectorPanel.astro
 * Visual Builder 2026 — Right-side contextual inspector
 * Shows editable fields organized by Content / Style / Behavior
 */
---

<div class="vb-inspector ve2-glass" id="vbInspector">
    <!-- Empty State -->
    <div class="vb-inspector-empty" id="vbInspectorEmpty">
        <div class="vb-inspector-empty-icon">
            <svg
                width="36"
                height="36"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"></path><path
                    d="M13 13l6 6"></path></svg
            >
        </div>
        <p class="vb-inspector-empty-title">Selecciona un bloque</p>
        <p class="vb-inspector-empty-sub">
            Haz click en un bloque del panel izquierdo o directamente sobre el
            preview
        </p>
    </div>

    <!-- Active Inspector -->
    <div
        class="vb-inspector-active"
        id="vbInspectorActive"
        style="display:none;"
    >
        <!-- Inspector Header -->
        <div class="vb-inspector-header" id="vbInspectorHeader">
            <div class="vb-inspector-header-left">
                <div class="vb-inspector-icon" id="vbInspectorIcon"></div>
                <div>
                    <div class="vb-inspector-title" id="vbInspectorTitle">
                        —
                    </div>
                    <div class="vb-inspector-key" id="vbInspectorKey">—</div>
                </div>
            </div>
            <div class="vb-inspector-header-actions">
                <button
                    class="ve2-btn ve2-btn-icon ve2-btn-sm"
                    id="vbBtnDuplicate"
                    data-ve2-tooltip="Duplicar"
                >
                    <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><rect x="9" y="9" width="13" height="13" rx="2"
                        ></rect><path
                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                        ></path></svg
                    >
                </button>
                <button
                    class="ve2-btn ve2-btn-icon ve2-btn-sm"
                    id="vbBtnReset"
                    data-ve2-tooltip="Restaurar"
                >
                    <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><polyline points="1 4 1 10 7 10"></polyline><path
                            d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg
                    >
                </button>
                <button
                    class="ve2-btn ve2-btn-icon ve2-btn-sm vb-btn-delete"
                    id="vbBtnDelete"
                    data-ve2-tooltip="Eliminar"
                >
                    <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><polyline points="3 6 5 6 21 6"></polyline><path
                            d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"
                        ></path></svg
                    >
                </button>
            </div>
        </div>

        <!-- Tab Navigation -->
        <div class="vb-inspector-tabs" id="vbInspectorTabs">
            <button class="vb-inspector-tab active" data-tab="content">
                <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path
                        d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                    ></path><polyline points="14 2 14 8 20 8"></polyline><line
                        x1="16"
                        y1="13"
                        x2="8"
                        y2="13"></line><line x1="16" y1="17" x2="8" y2="17"
                    ></line></svg
                >
                Contenido
            </button>
            <button class="vb-inspector-tab" data-tab="style">
                <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><circle cx="13.5" cy="6.5" r="2.5"></circle><path
                        d="M17.08 9.49a6 6 0 0 1-10.16 0"></path><path
                        d="M20.1 5.9a9 9 0 1 1-16.2 0"></path></svg
                >
                Estilo
            </button>
            <button class="vb-inspector-tab" data-tab="behavior">
                <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><circle cx="12" cy="12" r="3"></circle><path
                        d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
                    ></path></svg
                >
                Ajustes
            </button>
        </div>

        <!-- Tab Content Panels -->
        <div class="vb-inspector-body ve2-scroll" id="vbInspectorBody">
            <div
                class="vb-tab-panel active"
                data-panel="content"
                id="vbPanelContent"
            >
                <!-- Rendered by JS -->
            </div>
            <div class="vb-tab-panel" data-panel="style" id="vbPanelStyle">
                <!-- Rendered by JS -->
            </div>
            <div
                class="vb-tab-panel"
                data-panel="behavior"
                id="vbPanelBehavior"
            >
                <!-- Rendered by JS -->
            </div>
        </div>

        <!-- Save Footer -->
        <div class="vb-inspector-footer" id="vbInspectorFooter">
            <button class="ve2-btn-publish" id="vbBtnSave">
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    ><polyline points="20 6 9 17 4 12"></polyline></svg
                >
                Publicar cambios
            </button>
        </div>
    </div>
</div>

<style>
    /* ── Inspector Container ───────────────────────── */
    .vb-inspector {
        width: 340px;
        min-width: 300px;
        max-width: 440px;
        display: flex;
        flex-direction: column;
        border-left: 1px solid
            var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
        overflow: hidden;
        position: relative;
    }

    /* ── Empty State ───────────────────────────────── */
    .vb-inspector-empty {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        text-align: center;
        gap: 0.75rem;
    }
    .vb-inspector-empty-icon {
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
        border-radius: var(--ve2-radius-lg, 12px);
        color: var(--ve2-text-disabled, rgba(255, 255, 255, 0.12));
        margin-bottom: 0.25rem;
    }
    .vb-inspector-empty-title {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--ve2-text-tertiary, rgba(255, 255, 255, 0.4));
    }
    .vb-inspector-empty-sub {
        font-size: 0.72rem;
        color: var(--ve2-text-muted, rgba(255, 255, 255, 0.2));
        max-width: 200px;
        line-height: 1.5;
    }

    /* ── Active Inspector ──────────────────────────── */
    .vb-inspector-active {
        display: flex;
        flex-direction: column;
        flex: 1;
        overflow: hidden;
        animation: ve2-slideInRight 280ms cubic-bezier(0.4, 0, 0.2, 1) both;
    }

    /* ── Header ────────────────────────────────────── */
    .vb-inspector-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.85rem 1rem;
        border-bottom: 1px solid
            var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
        flex-shrink: 0;
        gap: 0.5rem;
    }
    .vb-inspector-header-left {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        min-width: 0;
    }
    .vb-inspector-header-actions {
        display: flex;
        gap: 0.2rem;
        flex-shrink: 0;
    }
    :global(.vb-inspector-icon) {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--ve2-neon-dim, rgba(var(--brand-rgb), 0.08));
        border-radius: var(--ve2-radius-md, 8px);
        flex-shrink: 0;
    }
    :global(.vb-inspector-icon svg) {
        width: 14px;
        height: 14px;
        color: var(--ve2-neon, #39ff14);
    }
    .vb-inspector-title {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--ve2-text-primary, #fff);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.3;
    }
    .vb-inspector-key {
        font-size: 0.6rem;
        font-family: var(--ve2-font-mono, monospace);
        color: var(--ve2-text-muted, rgba(255, 255, 255, 0.2));
        margin-top: 1px;
    }
    .vb-btn-delete {
        color: var(--ve2-danger, #f87171) !important;
    }
    .vb-btn-delete:hover {
        background: var(--ve2-danger-dim, rgba(248, 113, 113, 0.1)) !important;
        border-color: var(
            --ve2-danger-border,
            rgba(248, 113, 113, 0.2)
        ) !important;
    }

    /* ── Tabs ──────────────────────────────────────── */
    .vb-inspector-tabs {
        display: flex;
        border-bottom: 1px solid
            var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
        flex-shrink: 0;
        padding: 0 0.5rem;
        gap: 0;
    }
    .vb-inspector-tab {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        padding: 0.65rem 0.5rem;
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        color: var(--ve2-text-tertiary, rgba(255, 255, 255, 0.4));
        font-size: 0.7rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: all 200ms;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .vb-inspector-tab:hover {
        color: var(--ve2-text-secondary, rgba(255, 255, 255, 0.65));
    }
    .vb-inspector-tab.active {
        color: var(--ve2-neon, #39ff14);
        border-bottom-color: var(--ve2-neon, #39ff14);
    }
    .vb-inspector-tab svg {
        opacity: 0.6;
    }
    .vb-inspector-tab.active svg {
        opacity: 1;
    }

    /* ── Body / Panels ─────────────────────────────── */
    .vb-inspector-body {
        flex: 1;
        overflow-y: auto;
        padding: 1rem;
    }
    :global(.vb-tab-panel) {
        display: none;
    }
    :global(.vb-tab-panel.active) {
        display: block;
        animation: ve2-fadeIn 200ms ease both;
    }

    /* ── Field Styles ──────────────────────────────── */
    :global(.vb-field) {
        margin-bottom: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid
            var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
    }
    :global(.vb-field:last-child) {
        border-bottom: none;
        padding-bottom: 0;
        margin-bottom: 0;
    }
    :global(.vb-field-label) {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.68rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--ve2-text-tertiary, rgba(255, 255, 255, 0.4));
        margin-bottom: 0.4rem;
        user-select: none;
    }
    :global(.vb-field-row) {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.6rem;
    }

    /* Image preview */
    :global(.vb-img-preview) {
        width: 100%;
        height: 80px;
        border-radius: var(--ve2-radius-md, 8px);
        border: 1px solid var(--ve2-border-default, #2a2a2a);
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--ve2-bg-elevated, #161616);
        margin-bottom: 0.5rem;
        position: relative;
    }
    :global(.vb-img-preview img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 300ms;
    }
    :global(.vb-img-preview:hover img) {
        transform: scale(1.04);
    }
    :global(.vb-img-preview .vb-no-img) {
        font-size: 0.7rem;
        color: var(--ve2-text-muted, rgba(255, 255, 255, 0.2));
    }

    /* Tags */
    :global(.vb-tags-wrap) {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
        margin-top: 0.3rem;
    }
    :global(.vb-tag) {
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        padding: 0.22rem 0.5rem;
        background: var(--ve2-bg-elevated, #161616);
        border: 1px solid var(--ve2-border-default, #2a2a2a);
        border-radius: 5px;
        font-size: 0.7rem;
        color: var(--ve2-text-secondary, rgba(255, 255, 255, 0.65));
        transition: border-color 150ms;
    }
    :global(.vb-tag:hover) {
        border-color: var(--ve2-border-hover, rgba(255, 255, 255, 0.12));
    }
    :global(.vb-tag-x) {
        width: 14px;
        height: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        color: var(--ve2-text-muted, rgba(255, 255, 255, 0.2));
        cursor: pointer;
        font-size: 0.85rem;
        line-height: 1;
        padding: 0;
        transition: color 150ms;
    }
    :global(.vb-tag-x:hover) {
        color: var(--ve2-danger, #f87171);
    }
    :global(.vb-tag-add) {
        display: flex;
        gap: 0.3rem;
        margin-top: 0.4rem;
    }
    :global(.vb-tag-add input) {
        flex: 1;
        padding: 0.35rem 0.6rem;
        background: var(--ve2-bg-input, #161616);
        border: 1px solid var(--ve2-border-default, #2a2a2a);
        border-radius: 5px;
        color: #fff;
        font-size: 0.72rem;
        font-family: inherit;
        outline: none;
        transition: border-color 200ms;
    }
    :global(.vb-tag-add input:focus) {
        border-color: var(--ve2-neon, #39ff14);
    }
    :global(.vb-tag-add button) {
        padding: 0.35rem 0.6rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--ve2-border-default, #2a2a2a);
        border-radius: 5px;
        color: var(--ve2-text-tertiary, rgba(255, 255, 255, 0.4));
        font-size: 0.7rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 150ms;
    }
    :global(.vb-tag-add button:hover) {
        border-color: rgba(var(--brand-rgb), 0.3);
        color: var(--ve2-neon, #39ff14);
    }

    /* Repeater */
    :global(.vb-repeater-item) {
        background: var(--ve2-bg-elevated, #161616);
        border: 1px solid var(--ve2-border-default, #2a2a2a);
        border-radius: var(--ve2-radius-md, 8px);
        padding: 0.7rem;
        margin-bottom: 0.4rem;
        transition: border-color 150ms;
    }
    :global(.vb-repeater-item:hover) {
        border-color: var(--ve2-border-hover, rgba(255, 255, 255, 0.12));
    }
    :global(.vb-repeater-head) {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.45rem;
    }
    :global(.vb-repeater-num) {
        font-size: 0.58rem;
        font-weight: 700;
        color: var(--ve2-text-muted, rgba(255, 255, 255, 0.2));
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }
    :global(.vb-repeater-del) {
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--ve2-danger-dim, rgba(248, 113, 113, 0.08));
        border: 1px solid var(--ve2-danger-border, rgba(248, 113, 113, 0.15));
        border-radius: 5px;
        color: var(--ve2-danger, #f87171);
        cursor: pointer;
        transition: all 150ms;
        padding: 0;
    }
    :global(.vb-repeater-del:hover) {
        background: rgba(248, 113, 113, 0.18);
    }
    :global(.vb-repeater-fields) {
        display: grid;
        grid-template-columns: 80px 1fr;
        gap: 0.35rem;
    }
    :global(.vb-repeater-fields .full) {
        grid-column: 1 / -1;
    }

    /* ── Footer ────────────────────────────────────── */
    .vb-inspector-footer {
        padding: 0.85rem 1rem;
        border-top: 1px solid
            var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
        flex-shrink: 0;
        background: var(--ve2-bg-base, #0e0e0e);
    }
    .vb-inspector-footer .ve2-btn-publish {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        border: none;
        cursor: pointer;
        font-family: inherit;
    }

    /* ── Responsive ────────────────────────────────── */
    @media (max-width: 1024px) {
        .vb-inspector {
            width: 100% !important;
            max-width: 100% !important;
            min-width: 0;
            border-left: none;
            border-top: 1px solid
                var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
        }
    }
</style>

<script is:inline>
    /**
     * InspectorPanel — Field rendering + tab switching + form data collection
     * Listens to: vb:select (to show inspector)
     * Exposes: window.VBInspector
     */
    (function () {
        "use strict";

        // ── Tab switching ──
        var tabs = document.querySelectorAll(".vb-inspector-tab");
        tabs.forEach(function (tab) {
            tab.addEventListener("click", function () {
                tabs.forEach(function (t) {
                    t.classList.remove("active");
                });
                this.classList.add("active");
                var target = this.dataset.tab;
                document
                    .querySelectorAll(".vb-tab-panel")
                    .forEach(function (p) {
                        p.classList.toggle(
                            "active",
                            p.dataset.panel === target,
                        );
                    });
            });
        });

        function esc(str) {
            if (str == null) return "";
            return String(str)
                .replace(/&/g, "&amp;")
                .replace(/</, "&lt;")
                .replace(/>/, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#39;");
        }

        // ── Field Renderer ──
        function renderField(field, value) {
            var h = '<div class="vb-field" data-field-key="' + field.key + '">';
            // Usar defaultValue cuando el DB está vacío
            var displayVal = (value !== undefined && value !== null && value !== '') ? value : (field.defaultValue || '');

            if (field.type === "text") {
                h +=
                    '<label class="vb-field-label">' +
                    esc(field.label) +
                    "</label>";
                h +=
                    '<input type="text" class="ve2-input" data-key="' +
                    field.key +
                    '" value="' +
                    esc(displayVal) +
                    '"' +
                    (field.placeholder
                        ? ' placeholder="' + esc(field.placeholder) + '"'
                        : "") +
                    " />";
            } else if (field.type === "textarea") {
                h +=
                    '<label class="vb-field-label">' +
                    esc(field.label) +
                    "</label>";
                h +=
                    '<textarea class="ve2-input" data-key="' +
                    field.key +
                    '">' +
                    esc(displayVal) +
                    "</textarea>";
            } else if (field.type === "color") {
                var colorVal = value || field.defaultValue || "#000000";
                h +=
                    '<label class="vb-field-label">' +
                    esc(field.label) +
                    "</label>";
                h += '<div class="ve2-color-wrap">';
                h +=
                    '<input type="color" class="ve2-color-swatch" data-key="' +
                    field.key +
                    '" value="' +
                    colorVal +
                    '" />';
                h +=
                    '<input type="text" class="ve2-input" data-key="' +
                    field.key +
                    '" value="' +
                    colorVal +
                    '" style="flex:1" />';
                h += "</div>";
            } else if (field.type === "range") {
                var cur = value !== undefined ? value : field.min || 0;
                h +=
                    '<label class="vb-field-label">' +
                    esc(field.label) +
                    "</label>";
                h += '<div class="ve2-range-wrap">';
                h +=
                    '<input type="range" class="ve2-range" data-key="' +
                    field.key +
                    '" value="' +
                    cur +
                    '" min="' +
                    (field.min || 0) +
                    '" max="' +
                    (field.max || 1) +
                    '" step="' +
                    (field.step || 0.1) +
                    '" />';
                h += '<span class="ve2-range-value">' + cur + "</span>";
                h += "</div>";
            } else if (field.type === "image") {
                var imgVal = displayVal;
                h +=
                    '<label class="vb-field-label">' +
                    esc(field.label) +
                    "</label>";
                h += '<div class="vb-img-preview">';
                if (imgVal) {
                    h +=
                        '<img src="' +
                        esc(imgVal) +
                        '" alt="Preview" onerror="this.parentElement.innerHTML=\'<span class=vb-no-img>Error al cargar</span>\'" />';
                } else {
                    h += '<span class="vb-no-img">Sin imagen</span>';
                }
                h += "</div>";
                h +=
                    '<input type="url" class="ve2-input" data-key="' +
                    field.key +
                    '" value="' +
                    esc(imgVal) +
                    '" placeholder="https://..." />';
            } else if (field.type === "tags") {
                var tags = Array.isArray(value) ? value : [];
                h +=
                    '<label class="vb-field-label">' +
                    esc(field.label) +
                    "</label>";
                h += '<div class="vb-tags-wrap" data-key="' + field.key + '">';
                tags.forEach(function (tag) {
                    h +=
                        '<span class="vb-tag">' +
                        esc(tag) +
                        '<button class="vb-tag-x" data-tag="' +
                        esc(tag) +
                        '">&times;</button></span>';
                });
                h += "</div>";
                h += '<div class="vb-tag-add">';
                h +=
                    '<input type="text" placeholder="Añadir slug..." data-key="' +
                    field.key +
                    '-new" />';
                h +=
                    '<button type="button" data-key="' +
                    field.key +
                    '-add">+</button>';
                h += "</div>";
            } else if (field.type === "repeater") {
                var items = Array.isArray(value) ? value : [];
                h +=
                    '<label class="vb-field-label">' +
                    esc(field.label) +
                    "</label>";
                h += '<div class="vb-repeater" data-key="' + field.key + '">';
                items.forEach(function (item, idx) {
                    h +=
                        '<div class="vb-repeater-item" data-idx="' + idx + '">';
                    h += '<div class="vb-repeater-head">';
                    h +=
                        '<span class="vb-repeater-num">Item ' +
                        (idx + 1) +
                        "</span>";
                    h +=
                        '<button class="vb-repeater-del" data-remove-idx="' +
                        idx +
                        '"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>';
                    h += '</div><div class="vb-repeater-fields">';
                    (field.fields || []).forEach(function (sf) {
                        var sv = item[sf.key] || "";
                        var colspan = sf.key === "description" ? " full" : "";
                        h +=
                            '<div class="' +
                            colspan +
                            '"><input type="text" class="ve2-input" data-repeater-key="' +
                            field.key +
                            '" data-sub-key="' +
                            sf.key +
                            '" data-idx="' +
                            idx +
                            '" value="' +
                            esc(sv) +
                            '" placeholder="' +
                            esc(sf.placeholder || sf.label) +
                            '" /></div>';
                    });
                    h += "</div></div>";
                });
                h += "</div>";
            } else if (field.type === "select") {
                h +=
                    '<label class="vb-field-label">' +
                    esc(field.label) +
                    "</label>";
                h += '<select class="ve2-input" data-key="' + field.key + '">';
                (field.options || []).forEach(function (opt) {
                    var sel = opt.value === value ? " selected" : "";
                    h +=
                        '<option value="' +
                        esc(opt.value) +
                        '"' +
                        sel +
                        ">" +
                        esc(opt.label) +
                        "</option>";
                });
                h += "</select>";
            }

            h += "</div>";
            return h;
        }

        // ── Collect form data ──
        function collectData() {
            var body = document.getElementById("vbInspectorBody");
            if (!body) return null;
            var content = {};

            body.querySelectorAll(".vb-field").forEach(function (fieldEl) {
                var key = fieldEl.dataset.fieldKey;
                if (!key) return;

                var repeater = fieldEl.querySelector(".vb-repeater");
                if (repeater) {
                    var items = [];
                    repeater
                        .querySelectorAll(".vb-repeater-item")
                        .forEach(function (itemEl) {
                            var obj = {};
                            itemEl
                                .querySelectorAll(".ve2-input")
                                .forEach(function (inp) {
                                    obj[inp.dataset.subKey] = inp.value;
                                });
                            items.push(obj);
                        });
                    content[key] = items;
                    return;
                }

                var tagsWrap = fieldEl.querySelector(".vb-tags-wrap");
                if (tagsWrap) {
                    var tags = [];
                    tagsWrap
                        .querySelectorAll(".vb-tag-x")
                        .forEach(function (b) {
                            tags.push(b.dataset.tag);
                        });
                    content[key] = tags;
                    return;
                }

                var colorWrap = fieldEl.querySelector(".ve2-color-wrap");
                if (colorWrap) {
                    content[key] =
                        colorWrap.querySelector('input[type="text"]').value;
                    return;
                }

                var rangeInput = fieldEl.querySelector(".ve2-range");
                if (rangeInput) {
                    content[key] = parseFloat(rangeInput.value);
                    return;
                }

                var input = fieldEl.querySelector(".ve2-input");
                if (input) {
                    content[key] =
                        input.tagName === "TEXTAREA"
                            ? input.value
                            : input.value;
                }
            });

            return content;
        }

        // ── Bind events on rendered fields ──
        function bindFieldEvents(sectionId) {
            var body = document.getElementById("vbInspectorBody");
            if (!body) return;

            var markUnsaved = function () {
                document.dispatchEvent(
                    new CustomEvent("vb:unsaved", {
                        detail: { id: sectionId },
                    }),
                );
            };

            body.querySelectorAll(".ve2-input, textarea.ve2-input").forEach(
                function (inp) {
                    inp.addEventListener("input", markUnsaved);
                },
            );

            // Color sync
            body.querySelectorAll(".ve2-color-wrap").forEach(function (wrap) {
                var c = wrap.querySelector('input[type="color"]');
                var t = wrap.querySelector('input[type="text"]');
                c.addEventListener("input", function () {
                    t.value = this.value;
                    markUnsaved();
                });
                t.addEventListener("input", function () {
                    if (/^#[0-9a-fA-F]{6}$/.test(this.value))
                        c.value = this.value;
                    markUnsaved();
                });
            });

            // Range
            body.querySelectorAll(".ve2-range").forEach(function (r) {
                r.addEventListener("input", function () {
                    this.nextElementSibling.textContent = this.value;
                    markUnsaved();
                });
            });

            // Image preview
            body.querySelectorAll(".vb-img-preview + .ve2-input").forEach(
                function (inp) {
                    inp.addEventListener("change", function () {
                        var prev = this.previousElementSibling;
                        prev.innerHTML = this.value
                            ? '<img src="' +
                              esc(this.value) +
                              '" alt="Preview" onerror="this.parentElement.innerHTML=\'<span class=vb-no-img>Error</span>\'" />'
                            : '<span class="vb-no-img">Sin imagen</span>';
                    });
                },
            );

            // Tags
            body.querySelectorAll(".vb-tag-x").forEach(function (b) {
                b.addEventListener("click", function () {
                    this.closest(".vb-tag").remove();
                    markUnsaved();
                });
            });
            body.querySelectorAll(".vb-tag-add button").forEach(function (b) {
                b.addEventListener("click", function () {
                    var inp = this.previousElementSibling;
                    var val = inp.value.trim();
                    if (!val) return;
                    var k = inp.dataset.key.replace("-new", "");
                    var w = body.querySelector(
                        '.vb-tags-wrap[data-key="' + k + '"]',
                    );
                    var tag = document.createElement("span");
                    tag.className = "vb-tag";
                    tag.innerHTML =
                        esc(val) +
                        '<button class="vb-tag-x" data-tag="' +
                        esc(val) +
                        '">&times;</button>';
                    tag.querySelector(".vb-tag-x").addEventListener(
                        "click",
                        function () {
                            this.closest(".vb-tag").remove();
                            markUnsaved();
                        },
                    );
                    w.appendChild(tag);
                    inp.value = "";
                    markUnsaved();
                });
            });
            body.querySelectorAll(".vb-tag-add input").forEach(function (inp) {
                inp.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        this.nextElementSibling.click();
                    }
                });
            });

            // Repeater remove
            body.querySelectorAll(".vb-repeater-del").forEach(function (b) {
                b.addEventListener("click", function () {
                    this.closest(".vb-repeater-item").remove();
                    markUnsaved();
                });
            });
        }

        // ── Public API ──
        window.VBInspector = {
            show: function (section, schema, styleSchema, iconHtml) {
                document.getElementById("vbInspectorEmpty").style.display =
                    "none";
                var active = document.getElementById("vbInspectorActive");
                active.style.display = "flex";

                document.getElementById("vbInspectorTitle").textContent =
                    section.label || "—";
                document.getElementById("vbInspectorKey").textContent =
                    section.section_key || "—";
                var iconEl = document.getElementById("vbInspectorIcon");
                if (iconHtml) iconEl.innerHTML = iconHtml;

                var hasContent = schema && schema.length > 0;

                // Mostrar/ocultar pestaña Contenido según si hay campos
                var tabContent = document.querySelector('.vb-inspector-tab[data-tab="content"]');
                if (tabContent) tabContent.style.display = hasContent ? "" : "none";

                // Reset a la primera pestaña visible
                var firstVisibleTab = hasContent ? "content" : "style";
                document
                    .querySelectorAll(".vb-inspector-tab")
                    .forEach(function (t) {
                        t.classList.toggle("active", t.dataset.tab === firstVisibleTab);
                    });
                document
                    .querySelectorAll(".vb-tab-panel")
                    .forEach(function (p) {
                        p.classList.toggle(
                            "active",
                            p.dataset.panel === firstVisibleTab,
                        );
                    });

                var content = section.content || {};
                // Render content fields
                var contentHtml = "";
                (schema || []).forEach(function (f) {
                    contentHtml += renderField(f, content[f.key]);
                });
                document.getElementById("vbPanelContent").innerHTML = contentHtml;

                // Render style tab — Visibilidad + dynamic style fields
                var styleHtml =
                    '<div class="vb-field"><label class="vb-field-label">Visibilidad</label>' +
                    '<div style="display:flex;gap:0.5rem;align-items:center">' +
                    '<span class="ve2-badge ' +
                    (section.is_active ? "ve2-badge-neon" : "ve2-badge-muted") +
                    '">' +
                    (section.is_active ? "Visible" : "Oculto") +
                    "</span>" +
                    "</div></div>";

                // Dynamic style fields from styleSchema
                var styleFields = styleSchema || [];
                if (styleFields.length > 0) {
                    styleHtml +=
                        '<div class="vb-style-section-divider" style="margin:0.75rem 0 0.5rem;padding-top:0.75rem;border-top:1px solid rgba(255,255,255,0.06);">' +
                        '<label class="vb-field-label" style="margin-bottom:0.6rem;font-size:0.72rem;color:rgba(255,255,255,0.55);display:flex;align-items:center;gap:0.4rem;">' +
                        '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>' +
                        "Personalización de colores</label></div>";
                    styleFields.forEach(function (f) {
                        styleHtml += renderField(f, content[f.key]);
                    });
                }

                document.getElementById("vbPanelStyle").innerHTML = styleHtml;

                // Render behavior tab
                var behaviorHtml =
                    '<div class="vb-field"><label class="vb-field-label">Orden de visualización</label>' +
                    '<input type="number" class="ve2-input" value="' +
                    (section.display_order || 0) +
                    '" data-key="_display_order" min="0" style="width:80px" /></div>';
                document.getElementById("vbPanelBehavior").innerHTML =
                    behaviorHtml;

                bindFieldEvents(section.id);
            },

            hide: function () {
                document.getElementById("vbInspectorEmpty").style.display =
                    "flex";
                document.getElementById("vbInspectorActive").style.display =
                    "none";
            },

            collectData: collectData,

            renderField: renderField,
            bindFieldEvents: bindFieldEvents,
        };
    })();
</script>
