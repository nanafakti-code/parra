---
interface Props {
    content?: {
        title_line1?: string;
        title_line2?: string;
        subtitle?: string;
        subtitle_mobile?: string;
        badge?: string;
        cta_text?: string;
        cta_link?: string;
        secondary_text?: string;
        secondary_link?: string;
        bg_image?: string;
        overlay_color?: string;
        overlay_opacity?: number;
        // Style overrides
        style_badge_bg?: string;
        style_badge_text?: string;
        style_title_line1_color?: string;
        style_title_line2_color?: string;
        style_subtitle_color?: string;
        style_cta_bg?: string;
        style_cta_text?: string;
        style_cta_hover_bg?: string;
        style_secondary_bg?: string;
        style_secondary_text?: string;
        style_secondary_border?: string;
    };
}

const { content = {} } = Astro.props;

// Dynamic values with fallbacks
const titleLine1 = content.title_line1 || "DOMINA";
const titleLine2 = content.title_line2 || "EL ÁREA";
const subtitle =
    content.subtitle ||
    "Siente el agarre absoluto. Diseñados para porteros de elite que no aceptan menos que la perfección.";
const subtitleMobile =
    content.subtitle_mobile ||
    "Agarre absoluto. Para porteros que exigen perfección.";
const badge = content.badge || "Nueva Colección 2026";
const ctaText = content.cta_text || "Comprar Ahora";
const ctaLink = content.cta_link || "/shop";
const secondaryText = content.secondary_text || "Serie Elite";
const secondaryLink = content.secondary_link || "/shop?category=elite";
const bgImage =
    content.bg_image ||
    "https://res.cloudinary.com/djvj32zic/image/upload/f_webp,q_auto,w_1400/v1771850353/wmremove-transformed_qkiglz.png";
const overlayColor = content.overlay_color || "#000000";
const overlayOpacity = content.overlay_opacity ?? 0.4;

// Style overrides with current design defaults
const styleBadgeBg = content.style_badge_bg || "#39FF14";
const styleBadgeText = content.style_badge_text || "#39FF14";
const styleTitleLine1Color = content.style_title_line1_color || "#FFFFFF";
const styleTitleLine2Color = content.style_title_line2_color || "#39FF14";
const styleSubtitleColor = content.style_subtitle_color || "#B0B0B0";
const styleCtaBg = content.style_cta_bg || "#39FF14";
const styleCtaText = content.style_cta_text || "#000000";
const styleCtaHoverBg = content.style_cta_hover_bg || "#2DD60E";
const styleSecondaryBg =
    content.style_secondary_bg || "rgba(255, 255, 255, 0.08)";
const styleSecondaryText = content.style_secondary_text || "#FFFFFF";
const styleSecondaryBorder = content.style_secondary_border || "transparent";
---

<div class="relative overflow-hidden hero-wrapper">
    <section class="hero-section relative h-full w-full bg-black">
        <!-- Background Layer -->
        <div class="absolute inset-0 z-0">
            <div
                class="absolute inset-0 hero-bg"
                style={`background-image: url('${bgImage}');`}
            >
            </div>

            <!-- Unified overlays -->
            <div
                class="absolute inset-0"
                style={`background: ${overlayColor}; opacity: ${overlayOpacity};`}
            >
            </div>
            <div
                class="absolute inset-0"
                style="background: var(--gradient-hero-side);"
            >
            </div>
            <div class="absolute inset-0 hero-overlay-bottom-desktop"></div>
        </div>

        <!-- Vertical accent line (desktop only) -->
        <div
            class="absolute left-8 top-1/4 bottom-1/4 w-[2px] bg-gradient-to-b from-transparent via-brand to-transparent opacity-30 hidden lg:block"
        >
        </div>

        <!-- Content -->
        <div class="hero-content-wrapper relative z-10 w-full mb-12 sm:mb-0">
            <div class="max-w-3xl hero-text-container">
                <span
                    class="inline-block px-5 py-2 hero-badge rounded-sm text-[11px] sm:text-[13px] font-bold uppercase tracking-[0.4em] mb-6 opacity-0 animate-fade-up"
                    style={`background: rgba(13, 31, 13, 0.8); color: ${styleBadgeText}; border: none; font-size: clamp(10px, 1.2vw, 14px);`}
                >
                    {badge}
                </span>

                <h1
                    class="hero-title font-display font-bold uppercase leading-[0.82] tracking-tighter mb-8 opacity-0 animate-fade-up anim-delay-100"
                    style={`color: ${styleTitleLine1Color}; font-size: clamp(4.5rem, 16vw, 11rem);`}
                >
                    {titleLine1}
                    <br />
                    <span style={`color: ${styleTitleLine2Color};`}
                        >{titleLine2}</span
                    >
                </h1>

                <p
                    class="hero-subtitle-desktop hidden text-xs sm:text-sm max-w-[260px] sm:max-w-[340px] mb-6 opacity-0 animate-fade-up anim-delay-200"
                    style={`color: ${styleSubtitleColor}; text-shadow: 0 1px 12px rgba(0,0,0,0.4);`}
                >
                    {subtitle}
                </p>

                <p
                    class="hero-subtitle-mobile opacity-0 animate-fade-up anim-delay-200 mx-auto"
                    style={`color: ${styleSubtitleColor}; text-shadow: 0 1px 12px rgba(0,0,0,0.4); font-size: clamp(1rem, 2.2vw, 1.6rem); max-width: clamp(320px, 65vw, 900px); margin-bottom: 3.5rem; line-height: 1.4;`}
                >
                    {subtitleMobile}
                </p>

                <div
                    class="flex flex-wrap items-center gap-3 opacity-0 animate-fade-up anim-delay-300 hero-btns-container"
                >
                    <a
                        href={ctaLink}
                        class="btn-primary !border-none opacity-0 animate-fade-up anim-delay-300"
                        style={`background: linear-gradient(135deg, ${styleCtaBg} 0%, ${styleCtaHoverBg} 100%); color: ${styleCtaText}; box-shadow: 0 0 25px rgba(57, 255, 20, 0.25); border-radius: 4px; padding: clamp(12px, 1.5vw, 18px) clamp(24px, 3vw, 42px) !important; font-size: clamp(12px, 1.5vw, 18px) !important;`}
                    >
                        <span>{ctaText}</span>
                        <svg
                            class="w-5 h-5 ml-2"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                    <a
                        href={secondaryLink}
                        class="btn-outline !border-none opacity-0 animate-fade-up anim-delay-300"
                        style={`background: ${styleSecondaryBg}; color: ${styleSecondaryText}; border: none; border-radius: 4px; padding: clamp(12px, 1.5vw, 18px) clamp(24px, 3vw, 42px) !important; font-size: clamp(12px, 1.5vw, 18px) !important;`}
                    >
                        {secondaryText}
                    </a>
                </div>
            </div>
        </div>

        <style>
            /* ═══════════════════════════════════════════
           HERO – MOBILE (<768px)
           True-centered editorial. Nike/Off-White.
        ═══════════════════════════════════════════ */

            /* ── Section: Unified Centered (Mobile default) ── */
            .hero-section {
                display: flex;
                align-items: center;
                justify-content: center;
                /* padding-bottom desplaza el centro óptico hacia arriba:
                   el contenido queda en el tercio superior, lejos del watermark PARRA */
                padding-bottom: 18vh;
                min-height: 85vh;
            }

            .hero-text-container {
                text-align: center;
                width: 100%;
                padding: 0 1.5rem;
            }

            .hero-btns-container {
                justify-content: center;
                margin-top: 2rem;
            }

            @media (min-width: 1024px) {
                .hero-section {
                    align-items: flex-start !important;
                    justify-content: flex-start !important;
                    padding-top: 6rem !important;
                    padding-bottom: 0 !important;
                }
                .hero-text-container {
                    text-align: left !important;
                }
                .hero-title {
                    font-size: 6.5rem !important;
                }
                .hero-subtitle-desktop {
                    display: block !important;
                    font-size: 1.15rem !important;
                    max-width: 560px !important;
                }
                .hero-subtitle-mobile {
                    display: none !important;
                }
                .hero-btns-container {
                    justify-content: flex-start !important;
                    margin-top: 1.5rem !important;
                }
            }

            .hero-content-wrapper {
                padding: 0 16px;
                display: flex;
                justify-content: center;
                width: 100%;
            }

            @media (min-width: 1024px) {
                .hero-content-wrapper {
                    justify-content: flex-start;
                    padding-left: 10%;
                }
            }

            @media (max-width: 767px) {
                .hero-wrapper {
                    height: 85vh;
                    height: 85svh;
                }

                .hero-title {
                    font-size: clamp(4.5rem, 20vw, 8rem) !important;
                    line-height: 0.8 !important;
                    text-wrap: balance;
                    margin-bottom: 2rem !important;
                }

                .hero-sub-mobile {
                    font-size: 0.9rem;
                    max-width: 360px;
                    text-align: center;
                    margin-left: auto;
                    margin-right: auto;
                }

                /* Make primary CTA more balanced on mobile */
                .btn-primary {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    gap: 10px;
                    width: auto;
                    min-width: 150px;
                    max-width: 300px;
                    margin: 0 auto;
                    padding: 10px 18px !important;
                    font-size: 13px !important;
                    letter-spacing: 0.12em !important;
                    border-radius: 10px !important;
                    text-align: center;
                    box-shadow:
                        0 6px 18px rgba(0, 0, 0, 0.45),
                        0 0 18px rgba(57, 255, 20, 0.12);
                    background: linear-gradient(
                        180deg,
                        #39ff14 0%,
                        #28c90d 100%
                    ) !important;
                    color: #07110a !important;
                    text-transform: uppercase;
                }

                /* Slightly reduce the glow for very small screens */
                @media (max-width: 420px) {
                    .btn-primary {
                        min-width: 140px;
                        padding: 9px 14px !important;
                        font-size: 12px !important;
                        box-shadow:
                            0 5px 14px rgba(0, 0, 0, 0.5),
                            0 0 12px rgba(57, 255, 20, 0.08);
                    }
                }

                /* Secondary button: small pill under primary */
                .btn-outline {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    padding: 6px 10px !important;
                    font-size: 11px !important;
                    color: #ffffff !important;
                    background: rgba(0, 0, 0, 0.6) !important;
                    border: 1px solid rgba(255, 255, 255, 0.06) !important;
                    border-radius: 999px !important;
                    margin-top: 8px;
                    box-shadow: none !important;
                }

                /* Arrange CTA group vertically on small screens */
                .flex.flex-wrap.items-center.gap-3 {
                    flex-direction: column;
                    gap: 10px;
                    align-items: center;
                }

                .hero-bg {
                    background-position: 50% 40%;
                    background-size: cover;
                }
            }

            /* ── Content wrapper ── */
            .hero-content-wrapper {
                width: 100%;
                padding: 0 20px;
            }

            @media (min-width: 640px) {
                .hero-content-wrapper {
                    padding: 0 1.5rem;
                }
            }

            @media (min-width: 768px) {
                .hero-content-wrapper {
                    max-width: 80rem;
                    margin: 0 auto;
                    padding: 0 1rem;
                }
            }

            @media (min-width: 1024px) {
                .hero-content-wrapper {
                    padding: 0 2rem;
                }
            }

            /* ── Mobile content: optical center correction ── */
            .hero-mobile-content {
                text-align: center;
                transform: translateY(-5%);
                display: flex;
                flex-direction: column;
                align-items: center;
            }

            @media (min-width: 768px) {
                .hero-mobile-content {
                    display: none !important;
                }
            }

            /* ═══════════════════════════════════════
           HERO WRAPPER HEIGHT
        ═══════════════════════════════════════ */
            .hero-wrapper {
                height: 70vh;
                height: 70svh;
            }

            @media (min-width: 768px) {
                .hero-wrapper {
                    height: calc(100svh - 80px);
                }
            }

            /* ═══════════════════════════════════════
           BACKGROUND IMAGE
        ═══════════════════════════════════════ */
            .hero-bg {
                background-size: cover;
                background-position: 50% 30%;
                background-repeat: no-repeat;
            }

            @media (max-width: 767px) {
                .hero-bg {
                    animation: hero-breathe 8s ease-in-out infinite alternate;
                }
            }

            @media (min-width: 768px) {
                .hero-bg {
                    background-size: 160%;
                    background-position: 30% center;
                    background-attachment: fixed;
                    animation: subtle-zoom 25s ease-in-out infinite alternate;
                }
            }

            /* ═══════════════════════════════════════
           MOBILE OVERLAYS
        ═══════════════════════════════════════ */

            /* Radial: dark edges, lighter center → glove visible */
            .hero-overlay-radial {
                background: radial-gradient(
                    ellipse 70% 60% at 50% 40%,
                    rgba(0, 0, 0, 0.35) 0%,
                    rgba(0, 0, 0, 0.55) 50%,
                    rgba(0, 0, 0, 0.75) 100%
                );
            }

            /* Soft bottom: minimal, just enough for text legibility */
            .hero-overlay-bottom-soft {
                background: linear-gradient(
                    to top,
                    rgba(0, 0, 0, 0.4) 0%,
                    rgba(0, 0, 0, 0.15) 30%,
                    transparent 55%
                );
            }

            /* Desktop overlay (unchanged) */
            .hero-overlay-bottom-desktop {
                background: var(--gradient-hero-bottom);
            }

            /* ═══════════════════════════════════════
           MOBILE ELEMENTS
        ═══════════════════════════════════════ */

            /* ── Title ── */
            .hero-title-mobile {
                font-size: clamp(3.25rem, 16vw, 5rem);
                color: #ffffff;
                text-shadow: 0 2px 30px rgba(0, 0, 0, 0.4);
                opacity: 0;
                animation: hero-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.15s
                    forwards;
            }

            /* ── Desktop scaling: make hero headline much larger on wide screens ── */
            @media (min-width: 1280px) {
                .hero-title {
                    /* Use clamp to scale smoothly with viewport, but cap at a large size */
                    font-size: clamp(4.5rem, 6.8vw, 9rem) !important;
                    line-height: 0.82;
                }

                .hero-subtitle {
                    font-size: 1.125rem; /* slightly larger subtitle */
                    max-width: 720px; /* allow subtitle to occupy more horizontal space */
                }

                .hero-wrapper {
                    /* give a little more vertical space on very wide screens */
                    height: calc(100svh - 92px);
                }
            }

            /* Extra-large / ultra-wide screens: emphasize title more */
            @media (min-width: 1600px) {
                .hero-title {
                    font-size: clamp(5rem, 6.5vw, 10rem) !important;
                    line-height: 0.8;
                }

                .hero-subtitle {
                    font-size: 1.25rem;
                    max-width: 880px;
                }
            }

            /* ── Subtitle ── */
            .hero-sub-mobile {
                color: rgba(255, 255, 255, 0.8);
                text-shadow: 0 1px 15px rgba(0, 0, 0, 0.3);
                opacity: 0;
                animation: hero-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.35s
                    forwards;
            }

            /* ── Badge ── */
            .hero-badge-mobile {
                opacity: 0;
                animation: hero-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0s
                    forwards;
            }

            /* ── CTA group ── */
            .hero-cta-mobile {
                display: flex;
                flex-direction: column;
                align-items: center;
                width: 100%;
                opacity: 0;
                animation: hero-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.5s
                    forwards;
            }

            /* ── Primary button with glow pulse ── */
            .hero-btn-primary {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 11px 20px;
                background: linear-gradient(135deg, #39ff14 0%, #2dd60e 100%);
                color: #000;
                font-family: "Oswald", system-ui, sans-serif;
                font-weight: 700;
                font-size: 11px;
                text-transform: uppercase;
                letter-spacing: 0.15em;
                border-radius: 6px;
                border: none;
                transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
                box-shadow:
                    0 0 20px rgba(57, 255, 20, 0.2),
                    0 0 60px rgba(57, 255, 20, 0.06);
                text-decoration: none;
                animation: hero-glow-pulse 3s ease-in-out infinite;
            }

            .hero-btn-primary:active {
                transform: scale(0.97);
                box-shadow: 0 0 10px rgba(57, 255, 20, 0.15);
            }

            @media (hover: hover) {
                .hero-btn-primary:hover {
                    transform: translateY(-1px) scale(1.01);
                    box-shadow:
                        0 0 35px rgba(57, 255, 20, 0.4),
                        0 0 80px rgba(57, 255, 20, 0.12);
                }
            }

            /* ── Secondary link ── */
            .hero-link-secondary {
                display: inline-flex;
                align-items: center;
                color: rgba(255, 255, 255, 0.45);
                font-family: "Oswald", system-ui, sans-serif;
                font-weight: 500;
                font-size: 11px;
                text-transform: uppercase;
                letter-spacing: 0.2em;
                text-decoration: none;
                transition: color 0.3s ease;
                padding: 4px 0;
            }

            .hero-link-secondary:active,
            .hero-link-secondary:hover {
                color: #39ff14;
            }

            /* ═══════════════════════════════════════
           DESKTOP TYPOGRAPHY (unchanged)
        ═══════════════════════════════════════ */
            .hero-title {
                color: var(--text-primary);
            }

            .hero-subtitle {
                color: var(--text-muted);
            }

            /* ═══════════════════════════════════════
           KEYFRAMES
        ═══════════════════════════════════════ */

            @keyframes hero-breathe {
                0% {
                    transform: scale(1);
                }
                100% {
                    transform: scale(1.05);
                }
            }

            @keyframes subtle-zoom {
                0% {
                    transform: scale(1);
                }
                100% {
                    transform: scale(1.14);
                }
            }

            @keyframes hero-fade-up {
                0% {
                    opacity: 0;
                    transform: translateY(20px);
                }
                100% {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @keyframes hero-glow-pulse {
                0%,
                100% {
                    box-shadow:
                        0 0 20px rgba(57, 255, 20, 0.2),
                        0 0 60px rgba(57, 255, 20, 0.06);
                }
                50% {
                    box-shadow:
                        0 0 28px rgba(57, 255, 20, 0.3),
                        0 0 70px rgba(57, 255, 20, 0.1);
                }
            }

            @keyframes float {
                0%,
                100% {
                    transform: translateY(0);
                }
                50% {
                    transform: translateY(-30px);
                }
            }

            .animate-float {
                animation: float 6s ease-in-out infinite;
            }
        </style>
    </section>

    <!-- Marquee -->
    <div
        class="absolute bottom-0 left-0 w-full whitespace-nowrap pointer-events-none leading-none overflow-hidden marquee-wrapper"
    >
        <div class="flex animate-marquee">
            <span
                class="marquee-text text-[5rem] sm:text-[7rem] md:text-[12rem] font-display font-bold uppercase tracking-tighter leading-[0.85] shrink-0 block"
            >
                PARRA&nbsp;PARRA&nbsp;PARRA&nbsp;PARRA&nbsp;PARRA&nbsp;
            </span>
            <span
                class="marquee-text text-[5rem] sm:text-[7rem] md:text-[12rem] font-display font-bold uppercase tracking-tighter leading-[0.85] shrink-0 block"
            >
                PARRA&nbsp;PARRA&nbsp;PARRA&nbsp;PARRA&nbsp;PARRA&nbsp;
            </span>
        </div>
    </div>
</div>

<style>
    /* ── Marquee: shimmer + pulse ── */
    .marquee-wrapper {
        --mq-low: 0.25;
        --mq-high: 0.4;
        animation: marquee-pulse 4s ease-in-out infinite;
    }

    @media (min-width: 768px) {
        .marquee-wrapper {
            --mq-low: 0.15;
            --mq-high: 0.3;
        }
    }

    .marquee-text {
        background: linear-gradient(
            90deg,
            rgba(255, 255, 255, 0.1) 0%,
            rgba(255, 255, 255, 0.1) 40%,
            rgba(57, 255, 20, 0.6) 50%,
            rgba(255, 255, 255, 0.1) 60%,
            rgba(255, 255, 255, 0.1) 100%
        );
        background-size: 300% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: marquee-shimmer 5s linear infinite;
    }

    @keyframes marquee-shimmer {
        0% {
            background-position: 200% center;
        }
        100% {
            background-position: -100% center;
        }
    }

    @keyframes marquee-pulse {
        0%,
        100% {
            opacity: var(--mq-low);
        }
        50% {
            opacity: var(--mq-high);
        }
    }
</style>
