                            ></path></svg
                        >
                    </a>
                    <a
                        href="https://www.tiktok.com/@andleko?_r=1&_t=ZN-94gHQNfOn5i"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="social-icon w-10 h-10 flex items-center justify-center hover:border-brand hover:text-brand transition-all duration-300 group"
                        aria-label="TikTok"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"
                            ></path></svg
                        >
                    </a>
                </div>
            </div>

            <!-- Shop Links -->
            <div>
                <h4
                    class="footer-heading font-display uppercase tracking-[0.15em] text-sm font-semibold mb-6"
                >
                    Tienda
                </h4>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="/shop"
                            class="footer-link text-sm hover:text-brand transition-colors duration-200"
                            >Todos los Guantes</a
                        >
                    </li>
                    <li>
                        <a
                            href="/shop?category=elite"
                            class="footer-link text-sm hover:text-brand transition-colors duration-200"
                            >Serie Elite</a
                        >
                    </li>
                    <li>
                        <a
                            href="/shop?category=entrenamiento"
                            class="footer-link text-sm hover:text-brand transition-colors duration-200"
                            >Entrenamiento</a
                        >
                    </li>
                    <li>
                        <a
                            href="/shop?category=infantil"
                            class="footer-link text-sm hover:text-brand transition-colors duration-200"
                            >Infantil</a
                        >
                    </li>
                    <li>
                        <a
                            href="/shop?category=accesorios"
                            class="footer-link text-sm hover:text-brand transition-colors duration-200"
                            >Accesorios</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Help Links -->
            <div>
                <h4
                    class="footer-heading font-display uppercase tracking-[0.15em] text-sm font-semibold mb-6"
                >
                    Ayuda
                </h4>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="/contacto"
                            class="footer-link text-sm hover:text-brand transition-colors duration-200"
                            >Contacto</a
                        >
                    </li>
                    <li>
                        <a
                            href="/envios-y-devoluciones"
                            class="footer-link text-sm hover:text-brand transition-colors duration-200"
                            >Envíos y Devoluciones</a
                        >
                    </li>
                    <li>
                        <a
                            href="/guia-de-tallas"
                            class="footer-link text-sm hover:text-brand transition-colors duration-200"
                            >Guía de Tallas</a
                        >
                    </li>
                    <li>
                        <a
                            href="/preguntas-frecuentes"
                            class="footer-link text-sm hover:text-brand transition-colors duration-200"
                            >Preguntas Frecuentes</a
                        >
                    </li>
                    <li>
                        <a
                            href="/sobre-nosotros"
                            class="footer-link text-sm hover:text-brand transition-colors duration-200"
                            >Sobre Nosotros</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Newsletter -->
            <div>
                <h4
                    class="footer-heading font-display uppercase tracking-[0.15em] text-sm font-semibold mb-6"
                >
                    Newsletter
                </h4>
                <p class="footer-text text-sm mb-4">
                    Suscríbete y obtén un 10% en tu primera compra.
                </p>
                <form class="flex flex-col gap-3">
                    <input
                        type="email"
                        placeholder="tu@email.com"
                        class="input !text-xs"
                        required
                    />
                    <button type="submit" class="btn-primary !py-2.5 !text-xs">
                        Suscribirse
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Bottom Bar -->
    <div style="border-top: 1px solid var(--border-color);">
        <div
            class="container py-6 flex flex-col items-center gap-4 text-center md:flex-row md:justify-between md:text-left"
        >
            <p class="footer-copyright text-xs uppercase tracking-[0.15em]">
                &copy; {year} {brandName}. Todos los derechos reservados.
            </p>

            <!-- Legal Links -->
            <div
                class="flex gap-6 text-xs footer-copyright uppercase tracking-[0.15em]"
            >
                <a href="/privacidad" class="hover:opacity-70 transition-opacity"
                    >Privacidad</a
                >
                <a href="/terminos" class="hover:opacity-70 transition-opacity"
                    >Términos</a
                >
            </div>
        </div>
    </div>
</footer>

<style>
    .footer-heading {
        color: var(--text-primary);
    }
    .footer-text {
        color: var(--text-muted);
    }
    .footer-link {
        color: var(--text-muted);
    }
    .footer-copyright {
        color: var(--text-muted);
        opacity: 0.6;
    }
    .social-icon {
        border: 1px solid var(--border-color);
        color: var(--text-muted);
    }

    /* Mobile footer tweaks */
    @media (max-width: 767px) {
        .footer-wrapper .container { padding-top: 8px; padding-bottom: 8px; }
        .footer-wrapper .grid { gap: 10px; }
        .social-icon { width: 36px; height: 36px; }
        .footer-text { font-size: 12px; }
        .footer-wrapper input[type="email"], .footer-wrapper .btn-primary { width: 100%; }
    }
</style>
