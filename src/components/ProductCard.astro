---
interface Props {
    product: {
        id: string;
        name: string;
        slug: string;
        price: number;
        compare_price?: number | null;
        image: string;
        stock: number;
        is_featured?: boolean;
        categories?: { name: string; slug: string } | null;
    };
    index?: number;
}

const { product, index = 0 } = Astro.props;
const category = product.categories?.name || "Guantes";
const hasDiscount =
    product.compare_price && product.compare_price > product.price;
const discountPercent = hasDiscount
    ? Math.round(
          ((product.compare_price! - product.price) / product.compare_price!) *
              100,
      )
    : 0;
---

<article
    class={`card-product group reveal stagger-${(index % 4) + 1}`}
    style="background-color: var(--card-bg-color, transparent); border: 1px solid var(--card-border-color, transparent); border-radius: 8px;"
>
    <!-- Image Container -->
    <a
        href={`/product/${product.slug}`}
        class="block aspect-square sm:aspect-[3/4] overflow-hidden relative rounded-t-[7px]"
        style="background-color: transparent;"
    >
        <img
            src={product.image}
            alt={product.name}
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
            onerror="this.onerror=null;this.src='/images/placeholder-product.svg';this.classList.add('opacity-30')"
        />

        <!-- Badges -->
        <div
            class="absolute top-2 left-2 sm:top-4 sm:left-4 flex flex-col gap-1.5 sm:gap-2 z-10"
        >
            {
                hasDiscount && (
                    <span class="badge-sale text-[8px] sm:text-[10px]">
                        -{discountPercent}%
                    </span>
                )
            }
            {
                product.stock < 5 && product.stock > 0 && (
                    <span class="badge bg-red-600 text-white">Últimas</span>
                )
            }
        </div>

        <!-- Hover Overlay -->
        <div
            class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-all duration-500"
        >
        </div>
    </a>

    <!-- Info -->
    <div class="p-3 sm:p-5">
        <div class="flex justify-between items-start mb-1">
            <span
                class="text-[8px] sm:text-[10px] font-bold uppercase tracking-[0.15em] sm:tracking-[0.2em]"
                style="color: var(--section-accent-color, var(--brand));"
            >
                {category}
            </span>
        </div>
        <a href={`/product/${product.slug}`}>
            <h3
                class="font-display text-xs sm:text-base font-semibold uppercase tracking-tight group-hover:text-brand transition-colors duration-300 mb-1.5 sm:mb-2 line-clamp-2"
                style="color: var(--card-name-color, inherit);"
            >
                {product.name}
            </h3>
        </a>
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5 sm:gap-3">
                <span
                    class="text-sm sm:text-lg font-bold"
                    style="color: var(--card-price-color, var(--text-primary));"
                    >{product.price.toFixed(2)}€</span
                >
                {
                    hasDiscount && (
                        <span
                            class="text-[10px] sm:text-sm line-through"
                            style="color: var(--text-muted);"
                        >
                            {product.compare_price!.toFixed(2)}€
                        </span>
                    )
                }
            </div>

            <div></div>
        </div>
    </div>
</article>

<script>
    import { addItem } from "../lib/cart";

    function initProductCard() {
        document
            .querySelectorAll<HTMLButtonElement>(".add-to-cart-quick")
            .forEach((btn) => {
                if (btn.dataset.bound === "1") return;
                btn.dataset.bound = "1";

                btn.addEventListener("click", async (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    if (btn.disabled) return;

                    const iconAdd =
                        btn.querySelector<SVGElement>(".btn-icon-add");
                    const iconSpin =
                        btn.querySelector<SVGElement>(".btn-icon-spin");

                    // Loading state
                    btn.disabled = true;
                    iconAdd?.classList.add("hidden");
                    iconSpin?.classList.remove("hidden");

                    try {
                        const ok = await addItem({
                            id: btn.dataset.id!,
                            name: btn.dataset.name!,
                            price: parseFloat(btn.dataset.price!),
                            image: btn.dataset.image!,
                            stock: parseInt(btn.dataset.stock!),
                            slug: btn.dataset.slug!,
                        });
                    } finally {
                        // Restore button
                        iconSpin?.classList.add("hidden");
                        iconAdd?.classList.remove("hidden");
                        const stock = parseInt(btn.dataset.stock!);
                        btn.disabled = stock <= 0;
                    }
                });
            });
    }

    document.addEventListener("astro:page-load", initProductCard);
</script>

<style>
    /* Make product cards more compact on small screens */
    @media (max-width: 767px) {
        .card-product {
            border-radius: 8px;
        }
        .card-product a {
            aspect-ratio: 4 / 5;
        }
        .card-product .p-3 {
            padding: 8px;
        }
        .card-product h3 {
            font-size: 0.95rem;
        }
        .card-product .badge-sale {
            font-size: 9px;
        }
    }
</style>
