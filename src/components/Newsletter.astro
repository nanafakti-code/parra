---

---

<section
    class="relative py-14 sm:py-20 md:py-24"
>
    <div class="container relative">
        <div class="max-w-2xl mx-auto text-center reveal">
            <div
                class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 border border-brand/20 text-brand text-[10px] sm:text-xs font-bold uppercase tracking-[0.3em] mb-4 sm:mb-6"
            >
                Exclusivo
            </div>

            <h2 class="section-title mb-4">
                Únete al <span class="text-brand">Club</span>
            </h2>

            <p class="mb-8 sm:mb-10 max-w-md mx-auto" style="color: var(--text-muted);">
                Recibe ofertas exclusivas, novedades y un <strong
                    class="text-brand">10% de descuento</strong
                > en tu primera compra.
            </p>

            <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
                <input
                    type="email"
                    placeholder="Tu email..."
                    class="input flex-1 text-center sm:text-left"
                    required
                />
                <button type="submit" class="btn-glow whitespace-nowrap">
                    Suscribirme
                </button>
            </form>

            <p
                class="text-xs mt-4 tracking-wider"
                style="color: var(--text-muted); opacity: 0.6;"
            >
                Sin spam. Cancela cuando quieras.
            </p>
        </div>
    </div>
</section>
