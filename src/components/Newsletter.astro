---
interface Props {
    content?: Record<string, any>;
}
const { content = {} } = Astro.props;
---

<section
    class="relative py-14 sm:py-20 md:py-24"
    style={`background-color: ${content.style_section_bg || "transparent"};`}
>
    <div class="container relative">
        <div class="max-w-2xl mx-auto text-center reveal">
            <div
                class="inline-block px-3 py-1 sm:px-4 sm:py-1.5 border text-[10px] sm:text-xs font-bold uppercase tracking-[0.3em] mb-4 sm:mb-6"
                style={`color: ${content.style_btn_bg || "var(--brand)"}; border-color: ${content.style_btn_bg || "var(--brand)"}; opacity: 0.8;`}
            >
                Exclusivo
            </div>

            <h2
                class="section-title mb-4"
                style={`color: ${content.style_title_color || "#FFFFFF"};`}
            >
                Únete al <span
                    style={`color: ${content.style_btn_bg || "var(--brand)"};`}
                    >Club</span
                >
            </h2>

            <p
                class="mb-8 sm:mb-10 max-w-md mx-auto"
                style={`color: ${content.style_subtitle_color || "var(--text-muted)"};`}
            >
                Recibe ofertas exclusivas, novedades y un <strong
                    style={`color: ${content.style_btn_bg || "var(--brand)"};`}
                    >10% de descuento</strong
                > en tu primera compra.
            </p>

            <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
                <input
                    type="email"
                    placeholder="Tu email..."
                    class="input flex-1 text-center sm:text-left"
                    style={`background-color: ${content.style_input_bg || "#111827"}; border-color: ${content.style_input_border || "#1F2937"}; color: ${content.style_input_text || "#FFFFFF"};`}
                    required
                />
                <button
                    type="submit"
                    class="btn-glow whitespace-nowrap"
                    style={`background: ${content.style_btn_bg || "var(--brand)"}; color: ${content.style_btn_text || "#000000"}; --glow-color: ${content.style_btn_bg || "var(--brand)"};`}
                >
                    Suscribirme
                </button>
            </form>

            <p
                class="text-xs mt-4 tracking-wider"
                style="color: var(--text-muted); opacity: 0.6;"
            >
                Sin spam. Cancela cuando quieras.
            </p>
        </div>
    </div>
</section>
