---
interface Props {
    content?: Record<string, any>;
}
const { content = {} } = Astro.props;

const testimonials = [
    {
        name:   content.item1_name   || "Carlos Martínez",
        team:   content.item1_team   || "Real Betis Juvenil A",
        rating: 5,
        quote:  content.item1_quote  || "Los mejores guantes que he probado. El agarre del Titan Pro es increíble, incluso en condiciones de lluvia.",
        avatar: content.item1_avatar || "CM",
    },
    {
        name:   content.item2_name   || "Laura Sánchez",
        team:   content.item2_team   || "Selección Sub-19",
        rating: 5,
        quote:  content.item2_quote  || "Llevo toda la temporada con los Viper Grip y siguen como el primer día. La durabilidad es otro nivel.",
        avatar: content.item2_avatar || "LS",
    },
    {
        name:   content.item3_name   || "Miguel Ángel Torres",
        team:   content.item3_team   || "Entrenador de porteros",
        rating: 5,
        quote:  content.item3_quote  || "Recomiendo PARRA a todos mis alumnos. Calidad profesional a un precio accesible. Sin duda la mejor marca.",
        avatar: content.item3_avatar || "MT",
    },
];
---

<section
    class="section relative"
    style={`background-color: ${content.style_section_bg || "transparent"};`}
>
    <div class="container relative">
        <div class="text-center mb-10 md:mb-16 reveal">
            <h2
                class="section-title"
                style={`color: ${content.style_title_color || "#FFFFFF"};`}
            >
                {content.title_main || "Lo Que Dicen"} <span
                    style={`color: ${content.style_stars_color || "#39FF14"};`}
                    >{content.title_accent || "Nuestros Porteros"}</span
                >
            </h2>
            <p
                class="section-subtitle mx-auto"
                style={`color: ${content.style_subtitle_color || "#737373"};`}
            >
                {content.subtitle || "Porteros de todos los niveles confían en PARRA."}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 sm:gap-8">
            {
                testimonials.map((t, i) => (
                    <div
                        class={`card p-6 sm:p-8 reveal stagger-${i + 1} relative`}
                        style={`background-color: ${content.style_card_bg || "#111827"}; border-color: ${content.style_card_border || "#1F2937"};`}
                    >
                        {/* Quote mark */}
                        <div
                            class="text-[6rem] font-display font-bold absolute top-4 right-6 leading-none"
                            style={`color: ${content.style_stars_color || "#39FF14"}; opacity: 0.1;`}
                        >
                            "
                        </div>

                        {/* Stars */}
                        <div class="flex gap-1 mb-5">
                            {Array.from({ length: t.rating }).map(() => (
                                <svg
                                    class="w-4 h-4"
                                    style={`color: ${content.style_stars_color || "#FBBF24"};`}
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            ))}
                        </div>

                        {/* Quote */}
                        <p
                            class="text-sm leading-relaxed mb-6 relative z-10"
                            style={`color: ${content.style_text_color || "var(--text-secondary)"};`}
                        >
                            "{t.quote}"
                        </p>

                        {/* Author */}
                        <div class="flex items-center gap-3">
                            <div
                                class="w-10 h-10 border flex items-center justify-center text-xs font-bold"
                                style={`background-color: rgba(0,0,0,0.2); border-color: ${content.style_stars_color || "#39FF14"}; color: ${content.style_stars_color || "#39FF14"};`}
                            >
                                {t.avatar}
                            </div>
                            <div>
                                <div
                                    class="text-sm font-semibold"
                                    style={`color: ${content.style_name_color || "#FFFFFF"};`}
                                >
                                    {t.name}
                                </div>
                                <div
                                    class="text-xs"
                                    style="color: var(--text-muted);"
                                >
                                    {t.team}
                                </div>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
