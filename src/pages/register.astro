<style>
    /* ── Layout ────────────────────────────────────────────────── */
    .reg-main {
        min-height: calc(100vh - 140px);
        display: grid;
        grid-template-columns: 1fr 1fr;
        background-color: #0a0a0a;
        position: relative;
    }
    .reg-main::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 600px;
        height: 600px;
        background: radial-gradient(
            circle,
            rgba(57, 255, 20, 0.05) 0%,
            transparent 70%
        );
        pointer-events: none;
        z-index: 0;
