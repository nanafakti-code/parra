</style>

<script is:inline>
    (function () {
        var state = {
            name: "",
            email: "",
            phone: "",
            pass: "",
            addrName: "",
            street: "",
            city: "",
            postal: "",
            stateProv: "",
            country: "España",
            addrPhone: "",
        };
        var currentStep = 1;

        // ── Helpers ──────────────────────────────────────────────
        function gid(id) {
            return document.getElementById(id);
        }
        function val(id) {
            var e = gid(id);
            return e ? e.value.trim() : "";
        }
        function setv(id, v) {
            var e = gid(id);
            if (e) e.value = v;
        }
        function txt(id, t) {
            var e = gid(id);
            if (e) e.textContent = t;
        }
        function show(id) {
            var e = gid(id);
            if (e) e.style.display = "";
        }
        function hide(id) {
            var e = gid(id);
            if (e) e.style.display = "none";
        }
        function showFlex(id) {
            var e = gid(id);
            if (e) e.style.display = "flex";
        }

        function showErr(id, msg) {
            var e = gid(id);
            if (!e) return;
            if (msg) e.textContent = msg;
            e.style.display = "block";
        }
        function hideErr(id) {
            var e = gid(id);
            if (e) e.style.display = "none";
        }

        // ── Step UI ──────────────────────────────────────────────
        function setStepUI(n, active, done) {
            var el = gid("rs-" + n);
            if (!el) return;
            el.classList.toggle("active", active);
            el.classList.toggle("done", done);
            var num = el.querySelector(".rs-num");
            var check = el.querySelector(".rs-check");
            if (num) num.style.display = done ? "none" : "";
            if (check) check.style.display = done ? "block" : "none";
            if (n < 3) {
                var conn = gid("rsc-" + n);
                if (conn) conn.classList.toggle("done", done);
            }
        }

        function goTo(step) {
            hide("panel-" + currentStep);
            currentStep = step;
            var panel = gid("panel-" + step);
            if (panel) {
                panel.style.display = "";
                panel.style.animation = "none";
                panel.offsetHeight;
                panel.style.animation = "";
            }
            var col = document.querySelector(".reg-form-col");
            if (col) col.scrollTop = 0;
            for (var i = 1; i <= 3; i++) setStepUI(i, i === step, i < step);
        }

        // ── Fuerza contraseña ────────────────────────────────────
        var SLABELS = [
            "",
            "Muy débil",
            "Débil",
            "Regular",
            "Fuerte",
            "Muy fuerte",
        ];
        var SCOLORS = [
            "",
            "#ef4444",
            "#f97316",
            "#eab308",
            "#22c55e",
            "#39FF14",
        ];

        function checkStr(pw) {
            var s = 0,
                h = { len: false, upper: false, num: false, special: false };
            if (pw.length >= 8) {
                s++;
                h.len = true;
            }
            if (/[A-Z]/.test(pw)) {
                s++;
                h.upper = true;
            }
            if (/[0-9]/.test(pw)) {
                s++;
                h.num = true;
            }
            if (/[^A-Za-z0-9]/.test(pw)) {
                s++;
                h.special = true;
            }
            return { score: s, hints: h };
        }

        function updateStrUI(pw) {
            var r = checkStr(pw);
            var fill = gid("strength-fill"),
                lbl = gid("strength-label");
            if (fill) {
                fill.style.width =
                    (pw.length === 0 ? 0 : (r.score / 4) * 100) + "%";
                fill.style.background = SCOLORS[r.score] || "#ef4444";
            }
            if (lbl)
                lbl.textContent =
                    pw.length === 0
                        ? "Introduce una contraseña"
                        : SLABELS[r.score] || "";
            ["len", "upper", "num", "special"].forEach(function (h) {
                var el = gid("hint-" + h);
                if (!el) return;
                if (r.hints[h]) {
                    el.classList.add("ok");
                    el.textContent = el.textContent.replace("✗", "✓");
                } else {
                    el.classList.remove("ok");
                    el.textContent = el.textContent.replace("✓", "✗");
                }
            });
            return r;
        }

        // ── Toggle ojos ─────────────────────────────────────────
        var EYE_ON =
            '<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>';
        var EYE_OFF =
            '<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>';

        // ── Validaciones ─────────────────────────────────────────
        function v1() {
            var ok = true;
            hideErr("err-name");
            hideErr("err-email");
            var n = val("r-name"),
                e = val("r-email");
            if (!n) {
                showErr("err-name");
                ok = false;
            }
            if (!e || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)) {
                showErr("err-email");
                ok = false;
            }
            if (ok) {
                state.name = n;
                state.email = e;
                state.phone = val("r-phone");
            }
            return ok;
        }
        function v2() {
            var ok = true;
            hideErr("err-pass");
            hideErr("err-pass2");
            var p = val("r-pass"),
                p2 = val("r-pass2");
            if (p.length < 8) {
                showErr(
                    "err-pass",
                    "La contraseña debe tener al menos 8 caracteres",
                );
                ok = false;
            } else if (p !== p2) {
                showErr("err-pass2", "Las contraseñas no coinciden");
                ok = false;
            }
            if (ok) state.pass = p;
            return ok;
        }
        function v3() {
            var ok = true;
            ["err-addr-name", "err-street", "err-city", "err-postal"].forEach(
                hideErr,
            );
            var an = val("r-addr-name"),
                st = val("r-street"),
                ci = val("r-city"),
                po = val("r-postal");
            if (!an) {
                showErr("err-addr-name");
                ok = false;
            }
            if (!st) {
                showErr("err-street");
                ok = false;
            }
            if (!ci) {
                showErr("err-city");
                ok = false;
            }
            if (!po) {
                showErr("err-postal");
                ok = false;
            }
            if (ok) {
                state.addrName = an;
                state.street = st;
                state.city = ci;
                state.postal = po;
                state.stateProv = val("r-state");
                state.country = val("r-country") || "España";
                state.addrPhone = val("r-addr-phone");
            }
            return ok;
        }

        // ── Rellenar resumen ─────────────────────────────────────
        function fillSummary() {
            txt("sum-name", state.name || "—");
            txt("sum-email", state.email || "—");
            txt("sum-phone", state.phone || "No indicado");
            txt("sum-addr-name", state.addrName || "—");
            txt("sum-street", state.street || "—");
            txt("sum-city", state.city || "—");
            txt("sum-postal", state.postal || "—");
            txt("sum-country", state.country || "España");
            var r = checkStr(state.pass);
            txt("sum-strength", SLABELS[r.score] || "—");
        }

        // ── Pre-relleno paso 3 ───────────────────────────────────
        function prefill3() {
            if (!val("r-addr-name") && state.name)
                setv("r-addr-name", state.name);
            if (!val("r-addr-phone") && state.phone)
                setv("r-addr-phone", state.phone);
            if (!val("r-country")) setv("r-country", "España");
        }

        // ── Submit ───────────────────────────────────────────────
        async function doSubmit() {
            hide("reg-global-error");
            var btn = gid("submit-reg"),
                btext = gid("reg-btn-text"),
                bload = gid("reg-btn-loader");
            if (btext) btext.style.display = "none";
            if (bload) bload.style.display = "flex";
            if (btn) btn.disabled = true;
            try {
                var res = await fetch("/api/auth/register", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        name: state.name,
                        email: state.email,
                        phone: state.phone,
                        password: state.pass,
                        address: {
                            full_name: state.addrName,
                            street: state.street,
                            city: state.city,
                            postal_code: state.postal,
                            state: state.stateProv,
                            country: state.country,
                            phone: state.addrPhone,
                            label: "Casa",
                            is_default: true,
                        },
                    }),
                });
                var data = await res.json();
                if (res.ok) {
                    window.location.href = "/login?registered=1";
                } else {
                    var etxt = gid("reg-error-text"),
                        eerr = gid("reg-global-error");
                    if (etxt)
                        etxt.textContent =
                            data.message ||
                            data.error ||
                            "Error al crear la cuenta";
                    if (eerr) eerr.style.display = "flex";
                }
            } catch (e) {
                var etxt2 = gid("reg-error-text"),
                    eerr2 = gid("reg-global-error");
                if (etxt2)
                    etxt2.textContent =
                        "Error de conexión. Inténtalo de nuevo.";
                if (eerr2) eerr2.style.display = "flex";
            } finally {
                if (btext) btext.style.display = "";
                if (bload) bload.style.display = "none";
                if (btn) btn.disabled = false;
            }
        }

        // ── Init ─────────────────────────────────────────────────
        function init() {
            var main = document.querySelector(".reg-main");
            if (!main || main.dataset.initialized) return;
            main.dataset.initialized = "true";

            bindEye("toggle-pass", "r-pass", "eye-pass");
            bindEye("toggle-pass2", "r-pass2", "eye-pass2");

            function bindEye(btnId, inputId, iconId) {
                var btn = gid(btnId),
                    inp = gid(inputId),
                    icon = gid(iconId);
                if (!btn || !inp || !icon) return;
                btn.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var s = inp.type === "password";
                    inp.type = s ? "text" : "password";
                    icon.innerHTML = s ? EYE_OFF : EYE_ON;
                });
            }

            var pi = gid("r-pass");
            if (pi)
                pi.addEventListener("input", function () {
                    updateStrUI(this.value);
                });

            function on(id, fn) {
                var e = gid(id);
                if (e) e.addEventListener("click", fn);
            }

            on("next-1", function () {
                if (v1()) goTo(2);
            });
            on("back-2", function () {
                goTo(1);
            });
            on("next-2", function () {
                if (v2()) {
                    prefill3();
                    goTo(3);
                }
            });
            on("back-3", function () {
                goTo(2);
            });
            on("next-3", function () {
                if (v3()) {
                    fillSummary();
                    goTo(4);
                }
            });
            on("back-4", function () {
                goTo(3);
            });
            on("submit-reg", doSubmit);

            document.querySelectorAll(".rsum-edit").forEach(function (b) {
                b.addEventListener("click", function () {
                    goTo(parseInt(this.getAttribute("data-goto")));
                });
            });

            if (!val("r-country")) setv("r-country", "España");
            goTo(1);
        }

        document.addEventListener("astro:page-load", init);
        if (document.readyState !== "loading") init();
        else document.addEventListener("DOMContentLoaded", init);
    })();
</script>
