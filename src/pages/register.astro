---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { user } = Astro.locals;
if (user) return Astro.redirect("/");
---

<Layout title="Crear Cuenta | PARRA">
    <Header />
    <main class="reg-main">
        <!-- ── Columna izquierda: branding + timeline ── -->
        <div class="reg-brand-col">
            <div class="reg-brand-inner">
                <p class="reg-eyebrow">Únete a PARRA</p>
                <h1 class="reg-brand-title">PARRA</h1>
                <p class="reg-brand-sub">GOALKEEPER GLOVES</p>
                <div class="reg-brand-div"></div>

                <div class="reg-steps">
                    <!-- Step 1 -->
                    <div class="reg-step active" id="rs-1">
                        <div class="rs-dot">
                            <span class="rs-num">1</span>
                            <svg
                                class="rs-check"
                                width="12"
                                height="12"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="3"
                                viewBox="0 0 24 24"
                                style="display:none"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <div class="rs-info">
                            <p class="rs-label">Paso 1</p>
                            <p class="rs-desc">Datos personales</p>
                        </div>
                    </div>
                    <div class="rs-connector" id="rsc-1"></div>
                    <!-- Step 2 -->
                    <div class="reg-step" id="rs-2">
                        <div class="rs-dot">
                            <span class="rs-num">2</span>
                            <svg
                                class="rs-check"
                                width="12"
                                height="12"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="3"
                                viewBox="0 0 24 24"
                                style="display:none"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <div class="rs-info">
                            <p class="rs-label">Paso 2</p>
                            <p class="rs-desc">Contraseña</p>
                        </div>
                    </div>
                    <div class="rs-connector" id="rsc-2"></div>
                    <!-- Step 3 -->
                    <div class="reg-step" id="rs-3">
                        <div class="rs-dot">
                            <span class="rs-num">3</span>
                            <svg
                                class="rs-check"
                                width="12"
                                height="12"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="3"
                                viewBox="0 0 24 24"
                                style="display:none"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <div class="rs-info">
                            <p class="rs-label">Paso 3</p>
                            <p class="rs-desc">Dirección</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Columna derecha: paneles ── -->
        <div class="reg-form-col">
            <div class="reg-form-inner">
                <!-- ======== PASO 1: DATOS PERSONALES ======== -->
                <div class="rpanel" id="panel-1">
                    <div class="rpanel-head">
                        <p class="rpanel-step">PASO 1 DE 3</p>
                        <h2 class="rpanel-title">Datos Personales</h2>
                        <p class="rpanel-sub">Cuéntanos quién eres</p>
                    </div>
                    <div class="rfields">
                        <div class="rfield">
                            <label class="rlabel" for="r-name"
                                >Nombre completo *</label
                            >
                            <div class="rinput-wrap">
                                <svg
                                    class="rinput-icon"
                                    width="15"
                                    height="15"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                    ></path></svg
                                >
                                <input
                                    type="text"
                                    id="r-name"
                                    class="input rinput"
                                    placeholder="Tu nombre completo"
                                    autocomplete="name"
                                />
                            </div>
                            <p
                                class="rfield-err"
                                id="err-name"
                                style="display:none"
                            >
                                El nombre es obligatorio
                            </p>
                        </div>
                        <div class="rfield">
                            <label class="rlabel" for="r-email">Email *</label>
                            <div class="rinput-wrap">
                                <svg
                                    class="rinput-icon"
                                    width="15"
                                    height="15"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                    ></path></svg
                                >
                                <input
                                    type="email"
                                    id="r-email"
                                    class="input rinput"
                                    placeholder="tu@email.com"
                                    autocomplete="email"
                                />
                            </div>
                            <p
                                class="rfield-err"
                                id="err-email"
                                style="display:none"
                            >
                                Introduce un email válido
                            </p>
                        </div>
                        <div class="rfield">
                            <label class="rlabel" for="r-phone">Teléfono</label>
                            <div class="rinput-wrap">
                                <svg
                                    class="rinput-icon"
                                    width="15"
                                    height="15"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                    ></path></svg
                                >
                                <input
                                    type="tel"
                                    id="r-phone"
                                    class="input rinput"
                                    placeholder="+34 600 000 000"
                                    autocomplete="tel"
                                />
                            </div>
                        </div>
                    </div>
                    <div class="reg-actions">
                        <button
                            type="button"
                            class="btn-glow reg-next-btn"
                            id="next-1"
                        >
                            Continuar
                            <svg
                                width="14"
                                height="14"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9 5l7 7-7 7"></path></svg
                            >
                        </button>
                    </div>
                    <div class="reg-foot">
                        <span>¿Ya tienes cuenta?</span>
                        <a href="/login" class="reg-foot-link">Inicia sesión</a>
                    </div>
                </div>

                <!-- ======== PASO 2: CONTRASEÑA ======== -->
                <div class="rpanel" id="panel-2" style="display:none">
                    <div class="rpanel-head">
                        <p class="rpanel-step">PASO 2 DE 3</p>
                        <h2 class="rpanel-title">Contraseña</h2>
                        <p class="rpanel-sub">Elige una contraseña segura</p>
                    </div>
                    <div class="rfields">
                        <div class="rfield">
                            <label class="rlabel" for="r-pass"
                                >Contraseña *</label
                            >
                            <div class="rinput-wrap">
                                <svg
                                    class="rinput-icon"
                                    width="15"
                                    height="15"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                                    ></path></svg
                                >
                                <input
                                    type="password"
                                    id="r-pass"
                                    class="input rinput"
                                    placeholder="Mínimo 8 caracteres"
                                    autocomplete="new-password"
                                />
                                <button
                                    type="button"
                                    class="rpw-toggle"
                                    id="toggle-pass"
                                    tabindex="-1"
                                    aria-label="Ver contraseña"
                                >
                                    <svg
                                        id="eye-pass"
                                        width="15"
                                        height="15"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                        ></path><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                        ></path></svg
                                    >
                                </button>
                            </div>
                            <!-- Barra de seguridad -->
                            <div class="pstrength">
                                <div class="pstrength-bar">
                                    <div
                                        class="pstrength-fill"
                                        id="strength-fill"
                                    >
                                    </div>
                                </div>
                                <span
                                    class="pstrength-label"
                                    id="strength-label"
                                    >Introduce una contraseña</span
                                >
                            </div>
                            <div class="pstrength-hints">
                                <span class="phint" id="hint-len"
                                    >✗ Mínimo 8 chars</span
                                >
                                <span class="phint" id="hint-upper"
                                    >✗ Mayúscula</span
                                >
                                <span class="phint" id="hint-num">✗ Número</span
                                >
                                <span class="phint" id="hint-special"
                                    >✗ Símbolo</span
                                >
                            </div>
                            <p
                                class="rfield-err"
                                id="err-pass"
                                style="display:none"
                            >
                                La contraseña debe tener al menos 8 caracteres
                            </p>
                        </div>
                        <div class="rfield">
                            <label class="rlabel" for="r-pass2"
                                >Confirmar contraseña *</label
                            >
                            <div class="rinput-wrap">
                                <svg
                                    class="rinput-icon"
                                    width="15"
                                    height="15"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                    ></path></svg
                                >
                                <input
                                    type="password"
                                    id="r-pass2"
                                    class="input rinput"
                                    placeholder="Repite la contraseña"
                                    autocomplete="new-password"
                                />
                                <button
                                    type="button"
                                    class="rpw-toggle"
                                    id="toggle-pass2"
                                    tabindex="-1"
                                    aria-label="Ver contraseña"
                                >
                                    <svg
                                        id="eye-pass2"
                                        width="15"
                                        height="15"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                        ></path><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                        ></path></svg
                                    >
                                </button>
                            </div>
                            <p
                                class="rfield-err"
                                id="err-pass2"
                                style="display:none"
                            >
                                Las contraseñas no coinciden
                            </p>
                        </div>
                    </div>
                    <div class="reg-actions reg-actions-split">
                        <button type="button" class="reg-back-btn" id="back-2">
                            <svg
                                width="14"
                                height="14"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15 19l-7-7 7-7"></path></svg
                            >
                            Atrás
                        </button>
                        <button
                            type="button"
                            class="btn-glow reg-next-btn reg-next-half"
                            id="next-2"
                        >
                            Continuar
                            <svg
                                width="14"
                                height="14"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9 5l7 7-7 7"></path></svg
                            >
                        </button>
                    </div>
                </div>

                <!-- ======== PASO 3: DIRECCIÓN ======== -->
                <div class="rpanel" id="panel-3" style="display:none">
                    <div class="rpanel-head">
                        <p class="rpanel-step">PASO 3 DE 3</p>
                        <h2 class="rpanel-title">Dirección</h2>
                        <p class="rpanel-sub">
                            Dirección de entrega predeterminada
                        </p>
                    </div>
                    <div class="rfields rfields-grid">
                        <div class="rfield rfield-full">
                            <label class="rlabel" for="r-addr-name"
                                >Nombre para la entrega *</label
                            >
                            <input
                                type="text"
                                id="r-addr-name"
                                class="input"
                                placeholder="Nombre completo"
                                autocomplete="name"
                            />
                            <p
                                class="rfield-err"
                                id="err-addr-name"
                                style="display:none"
                            >
                                El nombre es obligatorio
                            </p>
                        </div>
                        <div class="rfield rfield-full">
                            <label class="rlabel" for="r-street"
                                >Calle y número *</label
                            >
                            <input
                                type="text"
                                id="r-street"
                                class="input"
                                placeholder="Calle Mayor, 42, 2ºA"
                                autocomplete="street-address"
                            />
                            <p
                                class="rfield-err"
                                id="err-street"
                                style="display:none"
                            >
                                La dirección es obligatoria
                            </p>
                        </div>
                        <div class="rfield">
                            <label class="rlabel" for="r-city">Ciudad *</label>
                            <input
                                type="text"
                                id="r-city"
                                class="input"
                                placeholder="Madrid"
                                autocomplete="address-level2"
                            />
                            <p
                                class="rfield-err"
                                id="err-city"
                                style="display:none"
                            >
                                La ciudad es obligatoria
                            </p>
                        </div>
                        <div class="rfield">
                            <label class="rlabel" for="r-postal"
                                >Código postal *</label
                            >
                            <input
                                type="text"
                                id="r-postal"
                                class="input"
                                placeholder="28001"
                                autocomplete="postal-code"
                                maxlength="10"
                            />
                            <p
                                class="rfield-err"
                                id="err-postal"
                                style="display:none"
                            >
                                El código postal es obligatorio
                            </p>
                        </div>
                        <div class="rfield">
                            <label class="rlabel" for="r-state">Provincia</label
                            >
                            <input
                                type="text"
                                id="r-state"
                                class="input"
                                placeholder="Comunidad de Madrid"
                                autocomplete="address-level1"
                            />
                        </div>
                        <div class="rfield">
                            <label class="rlabel" for="r-country">País</label>
                            <input
                                type="text"
                                id="r-country"
                                class="input"
                                placeholder="España"
                                autocomplete="country-name"
                            />
                        </div>
                        <div class="rfield rfield-full">
                            <label class="rlabel" for="r-addr-phone"
                                >Teléfono de contacto</label
                            >
                            <input
                                type="tel"
                                id="r-addr-phone"
                                class="input"
                                placeholder="+34 600 000 000"
                                autocomplete="tel"
                            />
                        </div>
                    </div>
                    <div class="reg-actions reg-actions-split">
                        <button type="button" class="reg-back-btn" id="back-3">
                            <svg
                                width="14"
                                height="14"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15 19l-7-7 7-7"></path></svg
                            >
                            Atrás
                        </button>
                        <button
                            type="button"
                            class="btn-glow reg-next-btn reg-next-half"
                            id="next-3"
                        >
                            Ver resumen
                            <svg
                                width="14"
                                height="14"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9 5l7 7-7 7"></path></svg
                            >
                        </button>
                    </div>
                </div>

                <!-- ======== RESUMEN ======== -->
                <div class="rpanel" id="panel-4" style="display:none">
                    <div class="rpanel-head">
                        <p class="rpanel-step">RESUMEN</p>
                        <h2 class="rpanel-title">Confirmar datos</h2>
                        <p class="rpanel-sub">
                            Revisa tu información antes de crear la cuenta
                        </p>
                    </div>
                    <div class="rsummary">
                        <div class="rsum-block">
                            <div class="rsum-block-head">
                                <svg
                                    width="13"
                                    height="13"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                    ></path></svg
                                >
                                DATOS PERSONALES
                                <button
                                    type="button"
                                    class="rsum-edit"
                                    data-goto="1">Editar</button
                                >
                            </div>
                            <div class="rsum-rows">
                                <div class="rsum-row">
                                    <span class="rsum-key">Nombre</span><span
                                        class="rsum-val"
                                        id="sum-name">—</span
                                    >
                                </div>
                                <div class="rsum-row">
                                    <span class="rsum-key">Email</span><span
                                        class="rsum-val"
                                        id="sum-email">—</span
                                    >
                                </div>
                                <div class="rsum-row">
                                    <span class="rsum-key">Teléfono</span><span
                                        class="rsum-val"
                                        id="sum-phone">—</span
                                    >
                                </div>
                            </div>
                        </div>
                        <div class="rsum-block">
                            <div class="rsum-block-head">
                                <svg
                                    width="13"
                                    height="13"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                                    ></path></svg
                                >
                                CONTRASEÑA
                                <button
                                    type="button"
                                    class="rsum-edit"
                                    data-goto="2">Editar</button
                                >
                            </div>
                            <div class="rsum-rows">
                                <div class="rsum-row">
                                    <span class="rsum-key">Contraseña</span
                                    ><span class="rsum-val">●●●●●●●●</span>
                                </div>
                                <div class="rsum-row">
                                    <span class="rsum-key">Seguridad</span><span
                                        class="rsum-val"
                                        id="sum-strength">—</span
                                    >
                                </div>
                            </div>
                        </div>
                        <div class="rsum-block">
                            <div class="rsum-block-head">
                                <svg
                                    width="13"
                                    height="13"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                    ></path><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                    ></path></svg
                                >
                                DIRECCIÓN DE ENVÍO
                                <button
                                    type="button"
                                    class="rsum-edit"
                                    data-goto="3">Editar</button
                                >
                            </div>
                            <div class="rsum-rows">
                                <div class="rsum-row">
                                    <span class="rsum-key">Nombre</span><span
                                        class="rsum-val"
                                        id="sum-addr-name">—</span
                                    >
                                </div>
                                <div class="rsum-row">
                                    <span class="rsum-key">Dirección</span><span
                                        class="rsum-val"
                                        id="sum-street">—</span
                                    >
                                </div>
                                <div class="rsum-row">
                                    <span class="rsum-key">Ciudad</span><span
                                        class="rsum-val"
                                        id="sum-city">—</span
                                    >
                                </div>
                                <div class="rsum-row">
                                    <span class="rsum-key">C. Postal</span><span
                                        class="rsum-val"
                                        id="sum-postal">—</span
                                    >
                                </div>
                                <div class="rsum-row">
                                    <span class="rsum-key">País</span><span
                                        class="rsum-val"
                                        id="sum-country">—</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                    <div
                        id="reg-global-error"
                        class="reg-error"
                        style="display:none"
                    >
                        <svg
                            width="13"
                            height="13"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                            style="flex-shrink:0"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path></svg
                        >
                        <span id="reg-error-text"></span>
                    </div>
                    <div class="reg-actions reg-actions-split">
