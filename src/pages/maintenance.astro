<style>
    /* ── Reset & Base ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
        width: 100%; min-height: 100%;
        background: #020202;
        color: #fff;
        font-family: "Inter", system-ui, sans-serif;
        overflow-x: hidden;
    }

    /* ── Background ──────────────────────────────────────────── */
    .bg-grid {
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background-size: 48px 48px;
        background-image:
            linear-gradient(to right,  rgba(255,255,255,0.025) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255,255,255,0.025) 1px, transparent 1px);
        -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 80%);
        mask-image:         radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 80%);
    }

    .bg-glow {
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background: radial-gradient(ellipse 70% 60% at 50% 40%, rgba(var(--brand-rgb), 0.07) 0%, transparent 70%);
        animation: glow-pulse 10s ease-in-out infinite alternate;
    }
    @keyframes glow-pulse {
        0%   { opacity: 0.6; transform: scale(0.95); }
        100% { opacity: 1;   transform: scale(1.05); }
    }

    .bg-noise {
        position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.018;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-size: 200px 200px;
    }

    .scanline {
        position: fixed; left: 0; right: 0; height: 2px; z-index: 1; pointer-events: none;
        background: linear-gradient(to right, transparent, rgba(var(--brand-rgb), 0.35), transparent);
        animation: scan 6s linear infinite;
        opacity: 0.5;
    }
    @keyframes scan {
        0%   { top: -4px; }
        100% { top: 100vh; }
    }

    /* ── Layout ──────────────────────────────────────────────── */
    .page {
        position: relative; z-index: 2;
        min-height: 100vh;
        display: flex; flex-direction: column;
        align-items: center;
        padding: 0 1.5rem;
    }

    /* ── Main ────────────────────────────────────────────────── */
    .main {
        flex: 1; display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center;
        gap: 0;
        width: 100%; max-width: 700px;
        padding: 3.5rem 0 2rem;
    }

    /* ── Brand block ──────────────────────────────────────────── */
    .brand-block {
        display: flex; align-items: center; gap: 14px;
        margin-bottom: 3rem;
    }
    .brand-logo {
        width: clamp(44px, 7vw, 64px); height: auto;
        filter: drop-shadow(0 0 14px rgba(var(--brand-rgb), 0.5));
    }
    .brand-name {
        font-family: "Oswald", sans-serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700; letter-spacing: 0.08em;
        color: var(--brand);
        text-shadow: 0 0 28px rgba(var(--brand-rgb), 0.4);
    }

    /* ── Headline block ───────────────────────────────────────── */
    .headline-block { margin-bottom: 3rem; }

    .eyebrow {
        font-size: 10px; font-weight: 600; letter-spacing: 0.28em;
        color: rgba(var(--brand-rgb), 0.7);
        text-transform: uppercase; margin-bottom: 1rem;
    }

    .headline {
        font-family: "Oswald", sans-serif;
        font-size: clamp(3.2rem, 10vw, 6.5rem);
        font-weight: 700; letter-spacing: 0.04em; line-height: 0.95;
        color: #fff;
        position: relative; display: inline-block;
        margin-bottom: 1.5rem;
    }
    .subline {
        font-size: clamp(0.85rem, 2vw, 1rem);
        line-height: 1.7; color: rgba(255,255,255,0.45);
    }

    /* ── Terminal ────────────────────────────────────────────── */
    @keyframes blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0; }
    }
    .terminal {
        width: 100%; max-width: 520px;
        background: rgba(255,255,255,0.025);
        border: 1px solid rgba(255,255,255,0.07);
        border-top: 2px solid var(--brand);
        border-radius: 6px;
        margin-bottom: 2.5rem;
        overflow: hidden;
    }
    .terminal-header {
        display: flex; align-items: center; gap: 6px;
        padding: 10px 14px;
        background: rgba(255,255,255,0.03);
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .t-dot {
        width: 10px; height: 10px; border-radius: 50%;
    }
    .t-dot.red    { background: #ff5f57; }
    .t-dot.yellow { background: #febc2e; }
    .t-dot.green  { background: #28c840; }
    .t-title {
        font-size: 10px; color: rgba(255,255,255,0.3);
        letter-spacing: 0.06em; margin-left: 6px;
        font-family: "Courier New", monospace;
    }
    .terminal-body {
        padding: 14px 18px;
        font-family: "Courier New", monospace;
        font-size: 12px; line-height: 1.9;
    }
    .t-line { color: rgba(255,255,255,0.4); }
    .t-line.t-active { color: rgba(255,255,255,0.7); }
    .t-prompt { color: var(--brand); margin-right: 8px; }
    .t-ok { color: var(--brand); }
    .t-cursor {
        display: inline-block;
        color: var(--brand);
        animation: blink 1s step-end infinite;
    }
    .progress-section {
        padding: 12px 18px 16px;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    .progress-meta {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 8px;
        font-size: 10px; font-family: "Oswald", sans-serif; letter-spacing: 0.12em;
        color: rgba(255,255,255,0.35);
    }
    .progress-pct { color: var(--brand); }
    .progress-track {
        width: 100%; height: 4px;
        background: rgba(255,255,255,0.06);
        border-radius: 99px; position: relative; overflow: hidden;
    }
    .progress-fill {
        height: 100%; width: 0%;
        background: linear-gradient(to right, rgba(var(--brand-rgb),0.7), var(--brand));
        border-radius: 99px;
        box-shadow: 0 0 10px rgba(var(--brand-rgb), 0.6);
        animation: fill 2.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards 0.8s;
    }
    @keyframes fill {
        0%   { width: 0%; }
        100% { width: 82%; }
    }

    /* ── CTA row ──────────────────────────────────────────────── */
    .cta-row {
        display: flex; gap: 12px; justify-content: center;
        flex-wrap: wrap;
    }
    .btn {
        display: inline-flex; align-items: center; gap: 9px;
        padding: 12px 28px;
        font-family: "Oswald", sans-serif;
        font-size: clamp(0.9rem, 2.5vw, 1rem);
        font-weight: 600; letter-spacing: 0.1em;
        text-decoration: none;
        border-radius: 3px;
        transition: all 0.25s ease;
        min-width: 160px; justify-content: center;
    }
    .btn-outline {
        background: transparent;
        color: rgba(255,255,255,0.75);
        border: 1px solid rgba(255,255,255,0.15);
    }
    .btn-outline:hover {
        border-color: var(--brand);
        color: var(--brand);
        background: rgba(var(--brand-rgb), 0.04);
        transform: translateY(-2px);
    }
    .btn-solid {
        background: var(--brand);
        color: #000;
        border: 1px solid var(--brand);
        box-shadow: 0 0 18px rgba(var(--brand-rgb), 0.2);
        font-weight: 700;
    }
    .btn-solid:hover {
        background: #ffffff;
        border-color: #ffffff;
        box-shadow: 0 0 28px rgba(var(--brand-rgb), 0.35);
        transform: translateY(-2px);
    }

    /* ── Footer ──────────────────────────────────────────────── */
    .foot {
        width: 100%; max-width: 860px;
        padding: 1.5rem 0 1.75rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 12px;
    }
    .foot-copy {
        font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
        color: rgba(255,255,255,0.2);
    }
    .foot-social {
        display: flex; gap: 16px; align-items: center;
    }
    .social-link {
        color: rgba(255,255,255,0.2);
        transition: color 0.2s;
        display: flex; align-items: center;
    }
    .social-link:hover { color: var(--brand); }

    /* ── Animations ──────────────────────────────────────────── */
    .anim-up {
        opacity: 0;
        transform: translateY(24px);
        animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .d1 { animation-delay: 0.1s; }
    .d2 { animation-delay: 0.25s; }
    .d3 { animation-delay: 0.4s; }
    .d4 { animation-delay: 0.55s; }
    @keyframes fadeUp {
        to { opacity: 1; transform: translateY(0); }
    }

    /* ── Reduced motion ──────────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
        *, ::before, ::after { animation: none !important; transition: none !important; }
        .anim-up { opacity: 1; transform: none; }
        .progress-fill { width: 82%; }
    }

    /* ── Mobile ──────────────────────────────────────────────── */
    @media (max-width: 600px) {
        .main { padding: 2.5rem 0 1.5rem; gap: 0; }
        .brand-block { margin-bottom: 2rem; }
        .headline-block { margin-bottom: 2rem; }
        .terminal { margin-bottom: 2rem; }
        .cta-row { flex-direction: column; width: 100%; max-width: 280px; }
        .btn { width: 100%; }
        .foot { justify-content: center; text-align: center; }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Year in footer
        const yearEl = document.getElementById("year");
        if (yearEl) yearEl.textContent = String(new Date().getFullYear());

        // Progress counter
        const pctEl = document.getElementById("pct");
        if (!pctEl) return;

        const target = 82;
        const duration = 2500;
        const delay = 800;
        const fps = 60;
        const frames = (duration / 1000) * fps;
        let frame = 0;
        const ease = (x: number) => 1 - Math.pow(1 - x, 3);

        setTimeout(() => {
            const tick = setInterval(() => {
                frame++;
                const pct = Math.min(Math.round(ease(frame / frames) * target), target);
                if (pctEl) pctEl.textContent = pct + "%";
                if (frame >= frames) { clearInterval(tick); if (pctEl) pctEl.textContent = target + "%"; }
            }, 1000 / fps);
        }, delay);
    });
</script>
