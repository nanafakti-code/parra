<style>
    :root {
        --color-bg: #030303;
        --color-green: var(--brand);
        --color-green-glow: rgba(var(--brand-rgb),0.4);
        --color-green-dim: rgba(var(--brand-rgb),0.08);
        --color-text: #ffffff;
        --color-text-muted: #a1a1aa;
        --font-heading: "Bebas Neue", Impact, sans-serif;
        --font-body: "Inter", system-ui, sans-serif;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html {
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    body {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-body);
        height: 100%;
        width: 100%;
        margin: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        position: fixed;
    }

    /* Background effects */
    .maintenance-wrapper {
        width: 100%;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
        z-index: 1;
        padding: 2rem;
    }

    .bg-grid {
        position: absolute;
        inset: 0;
        z-index: -2;
        background-size: 50px 50px;
        background-image:
            linear-gradient(
                to right,
                rgba(255, 255, 255, 0.02) 1px,
                transparent 1px
            ),
            linear-gradient(
                to bottom,
                rgba(255, 255, 255, 0.02) 1px,
                transparent 1px
            );
        -webkit-mask-image: radial-gradient(
            circle at center,
            black 40%,
            transparent 80%
        );
        mask-image: radial-gradient(
            circle at center,
            black 40%,
            transparent 80%
        );
    }

    .bg-glow {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 60vw;
        height: 60vw;
        max-width: 800px;
        max-height: 800px;
        background: radial-gradient(
            circle,
            var(--color-green-dim) 0%,
            transparent 70%
        );
        border-radius: 50%;
        z-index: -1;
        pointer-events: none;
        animation: pulse-glow 8s ease-in-out infinite alternate;
    }

    @keyframes pulse-glow {
        0% {
            transform: translate(-50%, -50%) scale(0.8);
            opacity: 0.5;
        }
        100% {
            transform: translate(-50%, -50%) scale(1.1);
            opacity: 1;
        }
    }

    .content-container {
        max-width: 700px;
        width: 100%;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* Typography & Brand */
    .logo {
        font-family: var(--font-heading);
        font-size: clamp(6rem, 15vw, 10rem);
        line-height: 0.9;
        letter-spacing: 0.05em;
        color: var(--color-green);
        text-shadow:
            0 0 20px var(--color-green-glow),
            0 0 50px var(--color-green-dim);
        margin-bottom: 2rem;
    }

    .logo-mark {
        width: clamp(180px, 24vw, 260px);
        height: auto;
        filter: drop-shadow(0 0 16px rgba(var(--brand-rgb), 0.4));
        margin-bottom: 2rem;
    }

    .title {
        font-family: var(--font-heading);
        font-size: clamp(3rem, 8vw, 4.5rem);
        letter-spacing: 0.05em;
        color: var(--color-text);
        margin-bottom: 1rem;
        position: relative;
        display: inline-block;
    }

    .message {
        font-size: clamp(1rem, 2.5vw, 1.15rem);
        line-height: 1.6;
        color: var(--color-text-muted);
        max-width: 540px;
        margin: 0 auto;
        white-space: pre-wrap;
    }

    .message-container {
        margin-bottom: 3.5rem;
    }

    /* Progress Section */
    .progress-wrapper {
        width: 100%;
        max-width: 500px;
        margin-bottom: 3.5rem;
    }

    .progress-details {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.75rem;
        font-family: var(--font-heading);
        letter-spacing: 0.08em;
        font-size: clamp(1.1rem, 3vw, 1.4rem);
        color: rgba(255, 255, 255, 0.7);
    }

    .progress-value {
        color: var(--color-green);
    }

    .progress-track {
        width: 100%;
        height: 6px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 99px;
        position: relative;
        overflow: hidden;
    }

    .progress-fill {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 0%;
        background: var(--color-green);
        border-radius: 99px;
        box-shadow: 0 0 10px var(--color-green-glow);
        animation: fill-bar 2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards 1s;
    }

    @keyframes fill-bar {
        0% {
            width: 0%;
        }
        100% {
            width: 78%;
        }
    }

    /* Action Buttons */
    .actions-wrapper {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        width: 100%;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1.1rem 2.5rem;
        font-family: var(--font-heading);
        font-size: clamp(1.2rem, 3vw, 1.4rem);
        letter-spacing: 0.08em;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
        position: relative;
        overflow: hidden;
        border-radius: 2px;
        min-width: 200px;
    }

    .btn-solid {
        background: var(--color-green);
        color: var(--color-bg);
        border: 1px solid var(--color-green);
        box-shadow: 0 0 20px rgba(var(--brand-rgb),0.15);
    }

    .btn-solid:hover {
        background: #4bff20;
        border-color: #4bff20;
        box-shadow: 0 0 30px rgba(var(--brand-rgb),0.3);
        transform: translateY(-2px);
    }

    .btn-outline {
        background: transparent;
        color: var(--color-text);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .btn-outline:hover {
        border-color: var(--color-green);
        color: var(--color-green);
        background: rgba(var(--brand-rgb),0.05);
        transform: translateY(-2px);
    }

    /* Animations */
    .fade-in-up {
        opacity: 0;
        transform: translateY(20px);
        animation: fadeInUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    .delay-1 {
        animation-delay: 0.2s;
    }
    .delay-2 {
        animation-delay: 0.4s;
    }
    .delay-3 {
        animation-delay: 0.6s;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Reduced Motion */
    @media (prefers-reduced-motion: reduce) {
        *,
        ::before,
        ::after {
            animation: none !important;
            transition: none !important;
        }
        .fade-in-up {
            opacity: 1;
            transform: translateY(0);
        }
        .progress-fill {
            width: 78%;
        }
    }

    /* Mobile adjustments */
    @media (max-width: 640px) {
        .btn {
            width: 100%;
        }
        .actions-wrapper {
            flex-direction: column;
            max-width: 320px;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const progressText = document.getElementById("progress-text");
        const prefersReducedMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
        ).matches;

        if (prefersReducedMotion) {
            if (progressText) progressText.innerText = "78%";
            return;
        }

        if (progressText) {
            const targetPercent = 78;
            const duration = 2000;
            const delay = 1000;
            const fps = 60;
            const totalFrames = (duration / 1000) * fps;
            let currentFrame = 0;

            const easeOutCubic = (x: number) => 1 - Math.pow(1 - x, 3);

            setTimeout(() => {
                const interval = setInterval(() => {
                    currentFrame++;
                    const progress = currentFrame / totalFrames;
                    const easedProgress = easeOutCubic(progress);
                    const currentPercent = Math.min(
                        Math.round(easedProgress * targetPercent),
                        targetPercent,
                    );

                    if (progressText)
                        progressText.innerText = currentPercent + "%";

                    if (currentFrame >= totalFrames) {
                        clearInterval(interval);
                        if (progressText)
                            progressText.innerText = targetPercent + "%";
                    }
                }, 1000 / fps);
            }, delay);
        }
    });
</script>
