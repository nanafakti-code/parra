---
// src/pages/maintenance.astro
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Mantenimiento | PARRA</title>
        <meta
            name="description"
            content="Estamos trabajando en mejoras importantes para ofrecerte un mejor rendimiento. Volveremos muy pronto."
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="theme-color" content="#000000" />

        <!-- Bold athletic fonts (Bebas Neue for strong uppercase headings, Inter for body) -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <div class="maintenance-container">
            <!-- Subtle green center cinematic glow -->
            <div class="glow-bg"></div>

            <div class="content">
                <div class="glass-card fade-in-up">
                    <a href="/" class="btn-shop" aria-label="Ver tienda"
                        >VER TIENDA</a
                    >

                    <!-- Bold Logo -->
                    <div class="logo-container">
                        <span class="logo-text">PARRA</span>
                    </div>

                    <!-- Compact maintenance card (admin-like visual) -->
                    <main class="main-content">
                        <div class="maintenance-card fade-in-up">
                            <header class="maintenance-header">
                                <div class="header-left">
                                    <svg
                                        width="36"
                                        height="36"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.5"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        ><path d="M12 2v6"></path><path
                                            d="M12 22v-6"></path><path
                                            d="M4.9 4.9l4.2 4.2"></path><path
                                            d="M19.1 19.1l-4.2-4.2"></path></svg
                                    >
                                    <div class="header-title">
                                        <h2 class="maintenance-title">
                                            Modo Mantenimiento
                                        </h2>
                                        <p class="maintenance-sub">
                                            Estamos realizando mejoras. Disculpa
                                            las molestias.
                                        </p>
                                    </div>
                                </div>
                                <div class="status-pill status-on">
                                    <span class="dot"></span> Tienda en mantenimiento
                                </div>
                            </header>

                            <div class="alert alert-danger">
                                <svg
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        d="M10.29 3.86L1.82 18a1.75 1.75 0 0 0 1.51 2.64h16.34A1.75 1.75 0 0 0 22.18 18L13.71 3.86a1.75 1.75 0 0 0-3.42 0z"
                                    ></path><path d="M12 9v4"></path><path
                                        d="M12 17h.01"></path></svg
                                >
                                <div>
                                    La tienda está en modo mantenimiento. Los
                                    clientes no pueden acceder a ninguna página
                                    excepto la de mantenimiento.
                                </div>
                            </div>

                            <div class="card-body">
                                <p class="public-message">
                                    Volvemos en breve — gracias por tu
                                    paciencia.
                                </p>
                            </div>

                            <div class="actions" style="margin-top:1rem;">
                                <a
                                    href="mailto:raafaablanco@gmail.com"
                                    class="btn">Contactar</a
                                >
                                <a
                                    href="https://wa.me/34658823543"
                                    target="_blank"
                                    rel="noopener"
                                    class="btn">WhatsApp</a
                                >
                            </div>
                        </div>
                    </main>
                </div>
            </div>
        </div>
    </body>
</html>

<style>
    /* PARRA Brand Variables */
    :root {
        --color-black: #000000;
        --color-neon-green: #39ff14;
        --color-dark-gray: #1a1a1a;
        --color-charcoal: #2d2d2d;
        --color-text-main: #ffffff;
        --color-text-muted: #a0a0a0;

        --font-heading: "Bebas Neue", Impact, sans-serif;
        --font-body: "Inter", system-ui, sans-serif;

        --transition-base: cubic-bezier(0.16, 1, 0.3, 1);
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        margin: 0;
        min-height: 100vh;
        background-color: var(--color-black);
        font-family: var(--font-body);
        color: var(--color-text-main);
        overflow-x: hidden;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .maintenance-container {
        position: relative;
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 2rem;
        z-index: 1;
    }

    /* Cinematic green background glow */
    .glow-bg {
        position: absolute;
        width: 100vw;
        height: 100vh;
        background: radial-gradient(
            circle at center,
            rgba(57, 255, 20, 0.04) 0%,
            transparent 60%
        );
        top: 0;
        left: 0;
        z-index: -1;
        pointer-events: none;
        animation: breathingGlow 8s ease-in-out infinite alternate;
    }

    @keyframes breathingGlow {
        0% {
            opacity: 0.5;
            transform: scale(1);
        }
        100% {
            opacity: 1;
            transform: scale(1.05);
        }
    }

    .content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        max-width: 800px;
        width: 100%;
    }

    /* Glass card to align with site admin aesthetic */
    .glass-card {
        position: relative;
        width: 100%;
        background: linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.02),
            rgba(255, 255, 255, 0.01)
        );
        border: 1px solid rgba(255, 255, 255, 0.04);
        box-shadow:
            0 10px 40px rgba(0, 0, 0, 0.6),
            0 0 40px rgba(57, 255, 20, 0.03);
        backdrop-filter: blur(6px) saturate(120%);
        padding: 2.5rem;
        border-radius: 12px;
        overflow: hidden;
    }

    /* Shop button styled to match neon brand */
    .btn-shop {
        position: absolute;
        right: 1.25rem;
        top: 1.25rem;
        text-decoration: none;
        padding: 0.5rem 0.85rem;
        background: var(--color-neon-green);
        color: #000000;
        font-weight: 700;
        letter-spacing: 0.12em;
        border-radius: 6px;
        box-shadow:
            0 4px 18px rgba(57, 255, 20, 0.25),
            0 0 10px rgba(57, 255, 20, 0.08) inset;
        text-transform: uppercase;
        font-family: var(--font-body);
        font-size: 0.85rem;
        transition:
            transform 160ms var(--transition-base),
            box-shadow 160ms var(--transition-base);
    }

    .btn-shop:hover {
        transform: translateY(-3px);
        box-shadow:
            0 10px 30px rgba(57, 255, 20, 0.35),
            0 0 18px rgba(57, 255, 20, 0.12) inset;
    }

    /* Decorative neon left accent */
    .glass-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        height: 100%;
        width: 6px;
        background: linear-gradient(
            180deg,
            rgba(57, 255, 20, 0.9),
            rgba(57, 255, 20, 0.25)
        );
        box-shadow: 0 0 24px rgba(57, 255, 20, 0.12);
        border-top-left-radius: 12px;
        border-bottom-left-radius: 12px;
        pointer-events: none;
    }

    /* Public message small box */
    .public-message-box {
        margin: 0 auto 1.25rem auto;
        max-width: 720px;
    }

    .public-message {
        display: inline-block;
        padding: 0.5rem 1rem;
        background: rgba(255, 255, 255, 0.02);
        color: var(--color-text-muted);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 8px;
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        text-transform: none;
    }

    /* Title underline accent */
    .title-container {
        position: relative;
        display: inline-block;
    }
    .title-container::after {
        content: "";
        display: block;
        height: 6px;
        width: 60%;
        margin: 0.6rem auto 0;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(57, 255, 20, 0.35),
            transparent
        );
        border-radius: 6px;
        filter: blur(6px);
        opacity: 0.9;
    }

    /* Brand Logo Text */
    .logo-container {
        margin-bottom: 3.5rem;
    }

    .logo-text {
        font-family: var(--font-heading);
        font-size: clamp(4rem, 10vw, 7rem);
        font-weight: 400; /* Bebas Neue is bold natively */
        letter-spacing: 0.05em;
        color: var(--color-neon-green);
        line-height: 1;
        will-change: opacity, text-shadow;
        /* Premium neon elite animation */
        animation:
            premiumNeonPulse 4.5s ease-in-out infinite alternate,
            neonFlicker 12s linear infinite;
    }

    /* Constant Neon Pulse & Shadow Layering */
    @keyframes premiumNeonPulse {
        0% {
            text-shadow:
                0 0 2px rgba(57, 255, 20, 0.5),
                0 0 10px rgba(57, 255, 20, 0.15),
                0 0 25px rgba(57, 255, 20, 0.02);
        }
        100% {
            text-shadow:
                0 0 3px rgba(57, 255, 20, 0.8),
                0 0 15px rgba(57, 255, 20, 0.35),
                0 0 40px rgba(57, 255, 20, 0.15);
        }
    }

    /* Subtle Neon Flicker (Very Premium) 
       Occurs rarely like a high-end LED voltage shift */
    @keyframes neonFlicker {
        0%,
        93%,
        94%,
        95.5%,
        97%,
        100% {
            opacity: 1;
        }
        93.5% {
            opacity: 0.85;
        }
        96% {
            opacity: 0.9;
        }
    }

    /* Primary Heading & Subtext */
    .main-content {
        width: 100%;
        max-width: 760px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    .title-container {
        margin: 0;
    }

    .block {
        display: block;
    }

    h1 {
        font-family: var(--font-heading);
        font-size: clamp(3rem, 7vw, 5.5rem);
        line-height: 1.05;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: var(--color-text-main);
    }

    .accent-text {
        color: var(--color-neon-green);
    }

    /* Subtle neon pulse for green elements */
    .glow-text {
        display: inline-block;
        animation: neonPulse 3.5s ease-in-out infinite alternate 0.8s;
    }

    @keyframes neonPulse {
        0% {
            text-shadow: 0 0 4px rgba(57, 255, 20, 0.1);
        }
        100% {
            text-shadow: 0 0 16px rgba(57, 255, 20, 0.4);
        }
    }

    .description {
        font-size: clamp(1rem, 2.5vw, 1.25rem);
        color: var(--color-text-muted);
        line-height: 1.6;
        max-width: 600px;
        margin: 0 auto;
        font-weight: 400;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* Slightly brighter description for readability */
    .description {
        color: #d6d6d6;
    }

    /* Progress Mechanics */
    .progress-section {
        width: 100%;
        max-width: 500px;
        margin: 2.5rem 0;
    }

    .progress-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.6rem;
        font-family: var(--font-heading);
        font-size: clamp(1.2rem, 3vw, 1.5rem);
        color: var(--color-text-muted);
        letter-spacing: 0.1em;
    }

    .progress-percentage {
        color: var(--color-neon-green);
    }

    .progress-track {
        width: 100%;
        height: 6px;
        background-color: var(--color-dark-gray);
        position: relative;
        overflow: hidden; /* Important for tail effect */
    }

    .progress-bar {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 0%;
        background-color: var(--color-neon-green);
        box-shadow: 0 0 10px rgba(57, 255, 20, 0.4);
        /* Elegant smooth acceleration */
        animation: fill-progress 2s cubic-bezier(0.22, 1, 0.36, 1) forwards 1s;
        will-change: width;
        overflow: hidden; /* Contains the sweep effect */
    }

    /* Infinite premium neon sweep effect over the filled bar */
    .progress-bar::before {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        height: 100%;
        width: 100%;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(255, 255, 255, 0.4),
            rgba(57, 255, 20, 0.8),
            rgba(255, 255, 255, 0.4),
            transparent
        );
        animation: active-sweep 2.5s linear infinite 3s; /* Starts after fill finishes */
        will-change: transform;
    }

    @keyframes active-sweep {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(200%);
        } /* Sweeps entirely across and disappears before looping */
    }

    /* Tail glow effect for progress bar during initial fill */
    .progress-bar::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        height: 100%;
        width: 30px;
        background: linear-gradient(
            to right,
            transparent,
            rgba(255, 255, 255, 0.8)
        );
        box-shadow: 5px 0 15px rgba(57, 255, 20, 0.9);
        opacity: 0;
        animation: progress-trail 2s cubic-bezier(0.22, 1, 0.36, 1) forwards 1s;
    }

    @keyframes progress-trail {
        0% {
            opacity: 0;
            transform: translateX(-10px);
        }
        15% {
            opacity: 1;
            transform: translateX(0);
        }
        85% {
            opacity: 1;
        }
        100% {
            opacity: 0;
        }
    }

    @keyframes fill-progress {
        0% {
            width: 0%;
        }
        100% {
            width: 65%;
        }
    }

    /* Action Buttons - Athletic & Rectangular */
    .actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
        width: 100%;
        margin-top: 1.5rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1.1rem 2rem;
        font-family: var(--font-heading);
        font-size: clamp(1.2rem, 3vw, 1.4rem);
        letter-spacing: 0.05em;
        text-decoration: none;
        text-transform: uppercase;
        cursor: pointer;

        /* Core Athletic Button Styles with 200ms transition */
        background-color: var(--color-black);
        color: var(--color-neon-green);
        border: 1px solid rgba(57, 255, 20, 0.4);
        border-radius: 0; /* Sharp edges */
        box-shadow: inset 0 0 0 transparent;
        transition: all 200ms var(--transition-base);
        will-change: transform, box-shadow, border-color;
    }

    .btn:hover {
        border-color: var(--color-neon-green);
        box-shadow:
            inset 0 0 15px rgba(57, 255, 20, 0.15),
            0 0 15px rgba(57, 255, 20, 0.2);
        transform: translateY(-2px);
    }

    /* Admin Access Button */
    .admin-access {
        display: flex;
        justify-content: center;
        width: 100%;
        margin-top: 2rem;
    }

    .btn-admin {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.7rem 1.5rem;
        font-family: var(--font-body);
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-decoration: none;
        text-transform: uppercase;
        cursor: pointer;
        background-color: transparent;
        color: rgba(255, 255, 255, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 0;
        transition: all 300ms var(--transition-base);
    }

    .btn-admin:hover {
        color: rgba(255, 255, 255, 0.6);
        border-color: rgba(255, 255, 255, 0.2);
        transform: translateY(-1px);
    }

    /* Elegant Fade In Up Animations */
    .fade-in-up {
        opacity: 0;
        transform: translateY(15px);
        animation: fadeInUp 0.8s var(--transition-base) forwards;
    }

    .delay-1 {
        animation-delay: 0.15s;
    }
    .delay-2 {
        animation-delay: 0.3s;
    }
    .delay-3 {
        animation-delay: 0.45s;
    }
    .delay-4 {
        animation-delay: 0.6s;
    }
    .delay-5 {
        animation-delay: 0.75s;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(15px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Accessibility: Prefers Reduced Motion */
    @media (prefers-reduced-motion: reduce) {
        *,
        ::before,
        ::after {
            animation: none !important;
            transition: none !important;
            scroll-behavior: auto !important;
        }

        /* Reset initial states for elements that use forwards animation */
        .fade-in-up {
            opacity: 1 !important;
            transform: translateY(0) !important;
        }

        .progress-bar {
            width: 50% !important;
        }

        .progress-bar::after,
        .progress-bar::before {
            display: none !important;
        }
    }

    /* Responsive Mobile Layout */
    @media (max-width: 640px) {
        .actions {
            flex-direction: column;
            width: 100%;
            max-width: 340px;
        }

        .btn {
            width: 100%;
        }

        .logo-container {
            margin-bottom: 1.25rem;
        }

        .glass-card {
            padding: 1.2rem;
        }

        .logo-text {
            font-size: clamp(2.2rem, 12vw, 4rem);
        }

        .btn-shop {
            right: 0.75rem;
            top: 0.75rem;
            padding: 0.45rem 0.7rem;
            font-size: 0.75rem;
        }

        .progress-section {
            padding: 0;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const progressText = document.getElementById("progress-text");

        // Handles user disabling animations
        const prefersReducedMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
        ).matches;

        if (prefersReducedMotion) {
            if (progressText) progressText.innerText = "50%";
            return;
        }

        if (progressText) {
            const targetPercent = 50;
            const duration = 2000; // 2s duration to match CSS
            const delay = 1000; // 1s delay to match CSS
            const fps = 60;
            const totalFrames = (duration / 1000) * fps;
            let currentFrame = 0;

            // Premium fast-start slow-end easing function (outCubic)
            const easeOutCubic = (x: number) => {
                return 1 - Math.pow(1 - x, 3);
            };

            setTimeout(() => {
                const interval = setInterval(() => {
                    currentFrame++;
                    const progress = currentFrame / totalFrames;
                    const easedProgress = easeOutCubic(progress);
                    const currentPercent = Math.min(
                        Math.round(easedProgress * targetPercent),
                        targetPercent,
                    );

                    progressText.innerText = currentPercent + "%";

                    if (currentFrame >= totalFrames) {
                        clearInterval(interval);
                        progressText.innerText = targetPercent + "%";
                    }
                }, 1000 / fps);
            }, delay);
        }
    });
</script>
