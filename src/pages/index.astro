---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ProductCard from "../components/ProductCard.astro";
import Benefits from "../components/Benefits.astro";
import GloveSelector from "../components/GloveSelector.astro";
import Testimonials from "../components/Testimonials.astro";
import Newsletter from "../components/Newsletter.astro";
import Footer from "../components/Footer.astro";
import { supabase } from "../lib/supabase";

// Cache pública: CDN guarda 5 min, navegador 2 min
Astro.response.headers.set("Cache-Control", "public, s-maxage=300, stale-while-revalidate=600");

// ── Fetch page sections from DB ──
let homeSections: Record<string, any> = {};
try {
	const { data: sectionsData } = await supabase
		.from('page_sections')
		.select('*')
		.eq('page_name', 'home')
		.order('display_order', { ascending: true });

	if (sectionsData) {
		sectionsData.forEach((s: any) => { homeSections[s.section_key] = s; });
	}
} catch (e) {
	console.error('Error loading page sections:', e);
}

// Helpers
function isActive(key: string): boolean {
	return homeSections[key]?.is_active !== false;
}
function getContent(key: string): Record<string, any> {
	return homeSections[key]?.content || {};
}

// ── Products: use slugs from editor or fallback ──
const fpContent = getContent('featured_products');
const FEATURED_SLUGS: string[] = Array.isArray(fpContent.product_slugs) && fpContent.product_slugs.length > 0
	? fpContent.product_slugs
	: ['parra-kids', 'parra-classic-pro', 'future-black-fantasy'];

let products: any[] = [];

try {
	// 1. Cargar exactamente los productos de la lista de destacados por slug
	const { data: bySlug, error: slugError } = await supabase
		.from("products")
		.select("*, categories(name, slug)")
		.in("slug", FEATURED_SLUGS)
		.eq("is_active", true);

	if (slugError) {
		console.error("Error cargando destacados por slug:", slugError.message);
	}

	if (bySlug && bySlug.length > 0) {
		// Ordenar según el orden definido en FEATURED_SLUGS
		products = FEATURED_SLUGS
			.map(s => bySlug.find((p: any) => p.slug === s))
			.filter(Boolean);
	}

	// 2. Fallback: si no se encontraron, cargar los 4 más recientes activos
	if (products.length === 0) {
		const { data: recentData, error: recentError } = await supabase
			.from("products")
			.select("*, categories(name, slug)")
			.eq("is_active", true)
			.order("created_at", { ascending: false })
			.limit(4);

		if (recentError) {
			console.error("Error cargando productos fallback:", recentError.message);
		}
		products = recentData || [];
	}
} catch (e) {
	console.error("Error crítico en home SSR:", e);
}

// Section content objects
const heroContent = getContent('hero');
const fpData = getContent('featured_products');
const ctaContent = getContent('cta_banner');

// Get ordered section keys for dynamic rendering
const orderedSections = Object.values(homeSections)
	.sort((a: any, b: any) => a.display_order - b.display_order)
	.map((s: any) => s.section_key);
---

<Layout
	title="Inicio"
	description="PARRA — Guantes de portero profesionales. Agarre extremo, tecnología alemana, diseño premium."
>
	<Header />
	<main>
		<!-- Hero -->
		{isActive('hero') && <Hero content={heroContent} />}

		<!-- Featured Products -->
		{isActive('featured_products') && (
		<section class="py-10 sm:py-14 md:py-20 lg:py-28">
			<div class="container">
				<div
					class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 md:mb-14 gap-4 md:gap-6"
				>
					<div>
						<h2 class="section-title">
							{fpData.title || 'Productos'} <span class="text-brand">{fpData.title_accent || 'Destacados'}</span>
						</h2>
						<p class="section-subtitle">
							{fpData.subtitle || 'Nuestra selección de los guantes más vendidos. Tecnología de vanguardia para porteros exigentes.'}
						</p>
					</div>
					<a href={fpData.cta_link || '/shop'} class="btn-outline group shrink-0">
						{fpData.cta_text || 'Ver toda la tienda'}
						<svg
							class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
						</svg>
					</a>
				</div>

				<div
					class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 lg:gap-8"
				>
					{
						(products || []).map((product: any, i: number) => (
							<ProductCard product={product} index={i} />
						))
					}
				</div>
			</div>
		</section>
		)}

		<!-- Benefits -->
		{isActive('benefits') && <Benefits />}

		<!-- Glove Selector -->
		{isActive('glove_selector') && <GloveSelector />}

		<!-- Testimonials -->
		{isActive('testimonials') && <Testimonials />}

		<!-- CTA Banner -->
		{isActive('cta_banner') && (
		<section
			class="relative h-[35vh] sm:h-[40vh] md:h-[50vh] lg:h-[60vh] flex items-center overflow-hidden"
		>
			<div
				class="absolute inset-0 bg-cover bg-scroll md:bg-fixed bg-center"
				style={`background-image: url('${ctaContent.bg_image || 'https://res.cloudinary.com/djvj32zic/image/upload/v1771869186/b6c3767d-ca9e-49a5-8187-b0610793ba75_zgic3i.png'}');`}
			>
				<div class="absolute inset-0" style={`background: rgba(0,0,0,${ctaContent.overlay_opacity ?? 0.7});`}></div>
			</div>
			<div class="container relative z-10 text-center reveal">
				<h2
					class="text-2xl sm:text-3xl md:text-5xl lg:text-8xl font-display font-bold uppercase tracking-tighter mb-4 sm:mb-6 md:mb-8"
				>
					{ctaContent.title_line1 || '¿LISTO PARA'}<br />
					<span class="text-brand">{ctaContent.title_line2 || 'VOLAR?'}</span>
				</h2>
				<a href={ctaContent.cta_link || '/register'} class="btn-glow inline-flex">
					{ctaContent.cta_text || 'Únete al Club PARRA'}
					<svg
						class="w-4 h-4 ml-2"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
					</svg>
				</a>
			</div>
		</section>
		)}

		<!-- Newsletter -->
		{isActive('newsletter') && <Newsletter />}
	</main>
	<Footer />
</Layout>
