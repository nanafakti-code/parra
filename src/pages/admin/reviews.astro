---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin';
import { supabaseAdmin } from '../../lib/supabase';

const adminResult = await requireAdmin(Astro);
if (adminResult instanceof Response) return adminResult;
const admin = adminResult;

/* ---------- Counts for filter chips ---------- */
const { count: totalCount } = await supabaseAdmin.from('reviews').select('*', { count: 'exact', head: true });
const { count: pendingCount } = await supabaseAdmin.from('reviews').select('*', { count: 'exact', head: true }).eq('is_approved', false);
const { count: approvedCount } = await supabaseAdmin.from('reviews').select('*', { count: 'exact', head: true }).eq('is_approved', true);

/* ---------- Current filter ---------- */
const url = new URL(Astro.request.url);
const approved = url.searchParams.get('approved'); // null | 'true' | 'false'
const page = parseInt(url.searchParams.get('page') || '1');
const limit = 20;
const offset = (page - 1) * limit;

let query = supabaseAdmin
    .from('reviews')
    .select('*, products(name, slug), users(name, email)', { count: 'exact' })
    .order('created_at', { ascending: false })
    .range(offset, offset + limit - 1);

if (approved === 'true') query = query.eq('is_approved', true);
if (approved === 'false') query = query.eq('is_approved', false);

const { data: reviews, count } = await query;
const totalPages = Math.ceil((count || 0) / limit);
---

<AdminLayout title="Reseñas" activeSection="reviews" admin={admin}>
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-white">Reseñas</h1>
            <p class="text-gray-400 text-sm mt-1">Modera y gestiona las reseñas de productos</p>
        </div>
    </div>

    <!-- Filter chips -->
    <div class="filter-bar mb-6">
        <a href="/admin/reviews" class={`filter-chip ${!approved ? 'active' : ''}`}>Todas <span class="ml-1 opacity-60">({totalCount || 0})</span></a>
        <a href="/admin/reviews?approved=false" class={`filter-chip ${approved === 'false' ? 'active' : ''}`}>Pendientes <span class="ml-1 opacity-60">({pendingCount || 0})</span></a>
        <a href="/admin/reviews?approved=true" class={`filter-chip ${approved === 'true' ? 'active' : ''}`}>Aprobadas <span class="ml-1 opacity-60">({approvedCount || 0})</span></a>
    </div>

    {(!reviews || reviews.length === 0) ? (
        <div class="empty-state">
            <i data-feather="message-square" class="w-12 h-12 mx-auto mb-3 text-gray-500"></i>
            <p class="text-gray-400">No hay reseñas en esta categoría</p>
        </div>
    ) : (
        <>
            <!-- Reviews cards -->
            <div class="space-y-4" id="reviewsList">
                {reviews.map(r => (
                    <div class="card p-5" data-review-id={r.id}>
                        <div class="flex flex-col sm:flex-row sm:items-start gap-4">
                            <!-- Left: User + Product + Date -->
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="font-semibold text-white">{r.users?.name || 'Usuario desconocido'}</span>
                                    <span class="text-xs text-gray-500">{r.users?.email || ''}</span>
                                </div>
                                <div class="text-sm text-gray-400 mb-2">
                                    Producto: <span class="text-[var(--brand)]">{r.products?.name || 'Producto eliminado'}</span>
                                </div>
                                <!-- Stars -->
                                <div class="flex items-center gap-0.5 mb-2">
                                    {[1,2,3,4,5].map(s => (
                                        <svg class={`w-4 h-4 ${s <= r.rating ? 'text-yellow-400' : 'text-gray-600'}`} fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                        </svg>
                                    ))}
                                    <span class="ml-1 text-xs text-gray-400">{r.rating}/5</span>
                                </div>
                                <!-- Comment -->
                                <p class="text-gray-300 text-sm leading-relaxed">{r.comment || '(Sin comentario)'}</p>
                                <p class="text-xs text-gray-500 mt-2">{new Date(r.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}</p>
                            </div>

                            <!-- Right: Status + Actions -->
                            <div class="flex sm:flex-col items-center sm:items-end gap-2 shrink-0">
                                <span class={`badge-${r.is_approved ? 'success' : 'warning'}`}>
                                    {r.is_approved ? 'Aprobada' : 'Pendiente'}
                                </span>
                                <div class="flex gap-1 mt-1">
                                    {!r.is_approved && (
                                        <button class="btn-sm btn-success" onclick={`approveReview('${r.id}')`} title="Aprobar">
                                            <i data-feather="check" class="w-4 h-4"></i>
                                        </button>
                                    )}
                                    {r.is_approved && (
                                        <button class="btn-sm btn-warning" onclick={`rejectReview('${r.id}')`} title="Rechazar">
                                            <i data-feather="x" class="w-4 h-4"></i>
                                        </button>
                                    )}
                                    <button class="btn-sm btn-danger" onclick={`deleteReview('${r.id}')`} title="Eliminar">
                                        <i data-feather="trash-2" class="w-4 h-4"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            <!-- Pagination -->
            {totalPages > 1 && (
                <div class="pagination mt-6">
                    {page > 1 && (
                        <a href={`/admin/reviews?${approved ? `approved=${approved}&` : ''}page=${page - 1}`} class="pagination-btn">Anterior</a>
                    )}
                    <span class="pagination-info">Página {page} de {totalPages}</span>
                    {page < totalPages && (
                        <a href={`/admin/reviews?${approved ? `approved=${approved}&` : ''}page=${page + 1}`} class="pagination-btn">Siguiente</a>
                    )}
                </div>
            )}
        </>
    )}
</AdminLayout>

<style>
    .btn-sm {
        @apply p-1.5 rounded-lg transition-colors cursor-pointer;
    }
    .btn-success {
        @apply bg-green-500/20 text-green-400 hover:bg-green-500/30;
    }
    .btn-warning {
        @apply bg-yellow-500/20 text-yellow-400 hover:bg-yellow-500/30;
    }
    .btn-danger {
        @apply bg-red-500/20 text-red-400 hover:bg-red-500/30;
    }
</style>

<script is:inline>
    async function approveReview(id) {
        const res = await fetch('/api/admin/reviews', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reviewId: id, isApproved: true })
        });
        const data = await res.json();
        if (res.ok) {
            window.adminToast?.('Reseña aprobada', 'success');
            setTimeout(() => location.reload(), 600);
        } else {
            window.adminToast?.(data.error || 'Error', 'error');
        }
    }

    async function rejectReview(id) {
        const ok = await window.adminConfirm?.('¿Rechazar esta reseña? Dejará de ser visible en la tienda.');
        if (!ok) return;
        const res = await fetch('/api/admin/reviews', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reviewId: id, isApproved: false })
        });
        const data = await res.json();
        if (res.ok) {
            window.adminToast?.('Reseña rechazada', 'success');
            setTimeout(() => location.reload(), 600);
        } else {
            window.adminToast?.(data.error || 'Error', 'error');
        }
    }

    async function deleteReview(id) {
        const ok = await window.adminConfirm?.('¿Eliminar esta reseña permanentemente? Esta acción no se puede deshacer.');
        if (!ok) return;
        const res = await fetch(`/api/admin/reviews?id=${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (res.ok) {
            window.adminToast?.('Reseña eliminada', 'success');
            setTimeout(() => location.reload(), 600);
        } else {
            window.adminToast?.(data.error || 'Error', 'error');
        }
    }
</script>
