---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin';
import { supabaseAdmin } from '../../lib/supabase';

const adminResult = await requireAdmin(Astro);
if (adminResult instanceof Response) return adminResult;
const admin = adminResult;

/* ---------- Counts for filter chips ---------- */
const { count: totalCount } = await supabaseAdmin.from('reviews').select('*', { count: 'exact', head: true });
const { count: pendingCount } = await supabaseAdmin.from('reviews').select('*', { count: 'exact', head: true }).eq('is_approved', false);
const { count: approvedCount } = await supabaseAdmin.from('reviews').select('*', { count: 'exact', head: true }).eq('is_approved', true);
const { count: featuredCount } = await supabaseAdmin.from('reviews').select('*', { count: 'exact', head: true }).eq('is_featured', true);

/* ---------- Current filter ---------- */
const url = new URL(Astro.request.url);
const approved = url.searchParams.get('approved'); // null | 'true' | 'false'
const page = parseInt(url.searchParams.get('page') || '1');
const limit = 20;
const offset = (page - 1) * limit;

let query = supabaseAdmin
    .from('reviews')
    .select('*, products(name, slug), users(name, email)', { count: 'exact' })
    .order('is_featured', { ascending: false })
    .order('created_at', { ascending: false })
    .range(offset, offset + limit - 1);

if (approved === 'true') query = query.eq('is_approved', true);
if (approved === 'false') query = query.eq('is_approved', false);

const { data: reviews, count } = await query;
const totalPages = Math.ceil((count || 0) / limit);
const currentFeatured = featuredCount || 0;
---

<AdminLayout title="Reseñas" activeSection="reviews" admin={admin}>
    <section class="reviews-hero mb-6">
        <div class="reviews-hero__left">
            <p class="reviews-kicker">Control editorial</p>
            <h1 class="reviews-title">Reseñas</h1>
            <p class="reviews-subtitle">Modera el contenido y decide qué opiniones destacas en portada.</p>
        </div>
        <div class="featured-meter" aria-label="Reseñas destacadas en portada">
            <div class="featured-meter__head">
                <span class="featured-meter__label">Portada</span>
                <span class="featured-meter__value" id="featured-counter">{currentFeatured}/3</span>
            </div>
            <div class="featured-meter__track">
                <span class="featured-meter__fill" style={`width:${Math.min(((currentFeatured || 0) / 3) * 100, 100)}%`}></span>
            </div>
            <p class="featured-meter__hint">Selecciona reseñas aprobadas para aumentar conversión.</p>
        </div>
    </section>

    <div class="reviews-stats mb-6">
        <article class="reviews-stat-card">
            <p class="reviews-stat-card__label">Total</p>
            <p class="reviews-stat-card__value">{totalCount || 0}</p>
        </article>
        <article class="reviews-stat-card">
            <p class="reviews-stat-card__label">Pendientes</p>
            <p class="reviews-stat-card__value text-yellow-300">{pendingCount || 0}</p>
        </article>
        <article class="reviews-stat-card">
            <p class="reviews-stat-card__label">Aprobadas</p>
            <p class="reviews-stat-card__value text-[var(--brand)]">{approvedCount || 0}</p>
        </article>
    </div>

    <div class="filter-bar mb-6 reviews-filter-bar">
        <a href="/admin/reviews" class={`filter-chip reviews-filter-chip ${!approved ? 'active' : ''}`}>Todas <span class="ml-1 opacity-60">({totalCount || 0})</span></a>
        <a href="/admin/reviews?approved=false" class={`filter-chip reviews-filter-chip ${approved === 'false' ? 'active' : ''}`}>Pendientes <span class="ml-1 opacity-60">({pendingCount || 0})</span></a>
        <a href="/admin/reviews?approved=true" class={`filter-chip reviews-filter-chip ${approved === 'true' ? 'active' : ''}`}>Aprobadas <span class="ml-1 opacity-60">({approvedCount || 0})</span></a>
    </div>

    {(!reviews || reviews.length === 0) ? (
        <div class="empty-state">
            <i data-feather="message-square" class="w-12 h-12 mx-auto mb-3 text-gray-500"></i>
            <p class="text-gray-400">No hay reseñas en esta categoría</p>
        </div>
    ) : (
        <>
            <div class="space-y-4" id="reviewsList">
                {reviews.map((r: any) => (
                    <article class="card review-card" data-review-id={r.id}>
                        <div class="review-card__content">
                            <header class="review-card__header">
                                <div class="review-user">
                                    <div class="review-user__avatar">{(r.users?.name || 'U').charAt(0).toUpperCase()}</div>
                                    <div>
                                        <p class="review-user__name">{r.users?.name || 'Usuario desconocido'}</p>
                                        <p class="review-user__mail">{r.users?.email || 'Sin email'}</p>
                                    </div>
                                </div>
                                <div class="review-meta-badges">
                                    <span class={`badge-${r.is_approved ? 'success' : 'warning'} review-status`}>
                                        {r.is_approved ? 'Aprobada' : 'Pendiente'}
                                    </span>
                                    {r.is_featured && (
                                        <span class="review-featured-badge">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                            Portada
                                        </span>
                                    )}
                                </div>
                            </header>

                            <div class="review-product-row">
                                <span class="review-product-label">Producto</span>
                                <span class="review-product-name">{r.products?.name || 'Producto eliminado'}</span>
                            </div>

                            <div class="review-rating-row">
                                <div class="flex items-center gap-0.5">
                                    {[1,2,3,4,5].map((s: number) => (
                                        <svg class={`w-4 h-4 ${s <= r.rating ? 'text-yellow-400' : 'text-gray-700'}`} fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                        </svg>
                                    ))}
                                </div>
                                <span class="review-rating-value">{r.rating}/5</span>
                            </div>

                            {r.title && <p class="review-title">"{r.title}"</p>}
                            <p class="review-comment">{r.comment || '(Sin comentario)'}</p>
                            <p class="review-date">{new Date(r.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}</p>
                        </div>

                        <aside class="review-card__actions">
                            <div class="review-actions-grid">
                                    {/* Botón destacar en portada (solo reseñas aprobadas) */}
                                    {r.is_approved && (
                                        <button
                                            class={`btn-sm ${r.is_featured ? 'btn-featured-active' : 'btn-featured'}`}
                                            onclick={`toggleFeatured('${r.id}', ${r.is_featured})`}
                                            title={r.is_featured ? 'Quitar de portada' : 'Destacar en portada'}
                                        >
                                            <svg class="w-4 h-4" fill={r.is_featured ? 'currentColor' : 'none'} stroke="currentColor" stroke-width={r.is_featured ? '0' : '1.5'} viewBox="0 0 20 20">
                                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                            </svg>
                                        </button>
                                    )}
                                    {!r.is_approved && (
                                        <button class="btn-sm btn-success review-action-btn" onclick={`approveReview('${r.id}')`} title="Aprobar">
                                            <i data-feather="check" class="w-4 h-4"></i>
                                        </button>
                                    )}
                                    {r.is_approved && (
                                        <button class="btn-sm btn-warning review-action-btn" onclick={`rejectReview('${r.id}')`} title="Rechazar">
                                            <i data-feather="x" class="w-4 h-4"></i>
                                        </button>
                                    )}
                                    <button class="btn-sm btn-danger review-action-btn" onclick={`deleteReview('${r.id}')`} title="Eliminar">
                                        <i data-feather="trash-2" class="w-4 h-4"></i>
                                    </button>
                            </div>
                        </aside>
                    </article>
                ))}
            </div>

            <!-- Pagination -->
            {totalPages > 1 && (
                <div class="pagination mt-6">
                    {page > 1 && (
                        <a href={`/admin/reviews?${approved ? 'approved=' + approved + '&' : ''}page=${page - 1}`} class="pagination-btn">Anterior</a>
                    )}
                    <span class="pagination-info">Página {page} de {totalPages}</span>
                    {page < totalPages && (
                        <a href={`/admin/reviews?${approved ? 'approved=' + approved + '&' : ''}page=${page + 1}`} class="pagination-btn">Siguiente</a>
                    )}
                </div>
            )}
        </>
    )}
</AdminLayout>

<style>
    .reviews-hero {
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        align-items: stretch;
        background:
            radial-gradient(circle at 12% 16%, rgba(var(--brand-rgb), 0.12), transparent 55%),
            linear-gradient(140deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        padding: 1rem 1.1rem;
    }
    .reviews-hero__left {
        min-width: 0;
    }
    .reviews-kicker {
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 0.4rem;
    }
    .reviews-title {
        font-size: 1.85rem;
        line-height: 1;
        margin-bottom: 0.45rem;
        color: #ffffff;
        font-family: "Oswald", system-ui, sans-serif;
    }
    .reviews-subtitle {
        font-size: 0.82rem;
        color: rgba(255, 255, 255, 0.62);
        max-width: 50ch;
    }
    .featured-meter {
        width: min(260px, 100%);
        border: 1px solid rgba(251, 191, 36, 0.25);
        background: linear-gradient(135deg, rgba(251, 191, 36, 0.08), rgba(251, 191, 36, 0.02));
        border-radius: 12px;
        padding: 0.8rem;
    }
    .featured-meter__head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.55rem;
    }
    .featured-meter__label {
        font-size: 0.66rem;
        text-transform: uppercase;
        letter-spacing: 0.11em;
        color: #fcd34d;
        font-weight: 700;
    }
    .featured-meter__value {
        font-size: 1.05rem;
        color: #facc15;
        font-weight: 700;
    }
    .featured-meter__track {
        width: 100%;
        height: 7px;
        border-radius: 999px;
        background: rgba(251, 191, 36, 0.18);
        overflow: hidden;
    }
    .featured-meter__fill {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #f59e0b, #facc15);
    }
    .featured-meter__hint {
        margin-top: 0.55rem;
        font-size: 0.7rem;
        color: rgba(255, 255, 255, 0.62);
    }

    .reviews-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.65rem;
    }
    .reviews-stat-card {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 12px;
        padding: 0.85rem 0.95rem;
    }
    .reviews-stat-card__label {
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(255, 255, 255, 0.45);
        margin-bottom: 0.4rem;
    }
    .reviews-stat-card__value {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1;
        color: #fff;
        font-family: "Oswald", system-ui, sans-serif;
    }

    .reviews-filter-bar {
        gap: 0.6rem;
    }
    .reviews-filter-chip {
        padding: 0.42rem 0.85rem;
        border-radius: 999px;
    }

    .review-card {
        padding: 1rem;
        border-radius: 14px;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015));
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .review-card:hover {
        border-color: rgba(var(--brand-rgb), 0.28);
        transform: translateY(-1px);
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
    }
    .review-card__content {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        min-width: 0;
        flex: 1;
    }
    .review-card__header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .review-user {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        min-width: 0;
    }
    .review-user__avatar {
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        display: grid;
        place-items: center;
        font-size: 0.78rem;
        font-weight: 700;
        background: rgba(var(--brand-rgb), 0.14);
        color: var(--brand);
        flex-shrink: 0;
    }
    .review-user__name {
        color: #fff;
        font-weight: 600;
        font-size: 0.95rem;
        line-height: 1.2;
    }
    .review-user__mail {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.72rem;
        word-break: break-all;
    }
    .review-meta-badges {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        flex-wrap: wrap;
    }
    .review-status {
        font-weight: 700;
        border-radius: 999px;
        padding-inline: 0.65rem;
    }
    .review-featured-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.2rem 0.5rem;
        border-radius: 999px;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        background: rgba(251, 191, 36, 0.14);
        border: 1px solid rgba(251, 191, 36, 0.28);
        color: #facc15;
    }
    .review-product-row {
        display: flex;
        align-items: center;
        gap: 0.45rem;
    }
    .review-product-label {
        font-size: 0.67rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.46);
    }
    .review-product-name {
        font-size: 0.8rem;
        color: var(--brand);
        font-weight: 600;
    }
    .review-rating-row {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .review-rating-value {
        font-size: 0.72rem;
        color: rgba(255, 255, 255, 0.64);
        font-weight: 600;
    }
    .review-title {
        font-size: 0.9rem;
        color: #ffffff;
        font-weight: 600;
    }
    .review-comment {
        color: rgba(255, 255, 255, 0.78);
        font-size: 0.85rem;
        line-height: 1.5;
    }
    .review-date {
        margin-top: 0.15rem;
        font-size: 0.7rem;
        color: rgba(255, 255, 255, 0.42);
    }
    .review-card {
        display: flex;
        justify-content: space-between;
        gap: 0.9rem;
    }
    .review-card__actions {
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }
    .review-actions-grid {
        display: flex;
        gap: 0.38rem;
        align-items: center;
        flex-wrap: wrap;
        justify-content: flex-end;
        max-width: 128px;
    }

    .btn-sm {
        @apply p-1.5 rounded-lg transition-colors cursor-pointer;
        border: 1px solid transparent;
    }
    .review-action-btn,
    .btn-featured,
    .btn-featured-active {
        width: 2rem;
        height: 2rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .btn-success {
        @apply bg-green-500/20 text-green-400 hover:bg-green-500/30;
        border-color: rgba(34, 197, 94, 0.25);
    }
    .btn-warning {
        @apply bg-yellow-500/20 text-yellow-400 hover:bg-yellow-500/30;
        border-color: rgba(250, 204, 21, 0.25);
    }
    .btn-danger {
        @apply bg-red-500/20 text-red-400 hover:bg-red-500/30;
        border-color: rgba(248, 113, 113, 0.25);
    }
    .btn-featured {
        @apply bg-yellow-500/10 text-yellow-600 hover:bg-yellow-500/25 hover:text-yellow-400;
        border-color: rgba(250, 204, 21, 0.24);
    }
    .btn-featured-active {
        @apply bg-yellow-500/25 text-yellow-400 hover:bg-yellow-500/10 hover:text-yellow-600;
        border-color: rgba(250, 204, 21, 0.34);
    }

    .pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.65rem;
    }
    .pagination-btn {
        padding: 0.42rem 0.8rem;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
        text-decoration: none;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.03);
        transition: all 0.2s;
    }
    .pagination-btn:hover {
        border-color: rgba(var(--brand-rgb), 0.3);
        color: var(--brand);
        background: rgba(var(--brand-rgb), 0.08);
    }
    .pagination-info {
        font-size: 0.72rem;
        color: rgba(255, 255, 255, 0.55);
    }

    @media (max-width: 900px) {
        .reviews-hero {
            flex-direction: column;
        }
        .featured-meter {
            width: 100%;
        }
        .reviews-stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .review-card {
            flex-direction: column;
        }
        .review-card__actions {
            width: 100%;
            justify-content: flex-end;
        }
        .review-actions-grid {
            max-width: 100%;
        }
    }
    @media (max-width: 560px) {
        .reviews-stats {
            grid-template-columns: 1fr;
        }
        .reviews-title {
            font-size: 1.55rem;
        }
    }
</style>

<script is:inline>
    async function approveReview(id) {
        const res = await fetch('/api/admin/reviews', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reviewId: id, isApproved: true })
        });
        const data = await res.json();
        if (res.ok) {
            window.adminToast?.('Reseña aprobada', 'success');
            setTimeout(() => location.reload(), 600);
        } else {
            window.adminToast?.(data.error || 'Error', 'error');
        }
    }

    async function rejectReview(id) {
        const ok = await window.adminConfirm?.('¿Rechazar esta reseña? Dejará de ser visible en la tienda.');
        if (!ok) return;
        const res = await fetch('/api/admin/reviews', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reviewId: id, isApproved: false })
        });
        const data = await res.json();
        if (res.ok) {
            window.adminToast?.('Reseña rechazada', 'success');
            setTimeout(() => location.reload(), 600);
        } else {
            window.adminToast?.(data.error || 'Error', 'error');
        }
    }

    async function deleteReview(id) {
        const ok = await window.adminConfirm?.('¿Eliminar esta reseña permanentemente? Esta acción no se puede deshacer.');
        if (!ok) return;
        try {
            const res = await fetch(`/api/admin/reviews?id=${id}`, { method: 'DELETE' });
            if (res.ok) {
                window.adminToast?.('Reseña eliminada', 'success');
                setTimeout(() => location.reload(), 600);
            } else {
                let msg = 'Error al eliminar';
                try { const d = await res.json(); msg = d.error || msg; } catch {}
                window.adminToast?.(msg, 'error');
            }
        } catch {
            window.adminToast?.('Error de conexión', 'error');
        }
    }

    async function toggleFeatured(id, currentlyFeatured) {
        const res = await fetch('/api/admin/reviews', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reviewId: id, isFeatured: !currentlyFeatured })
        });
        const data = await res.json();
        if (res.ok) {
            window.adminToast?.(data.message, 'success');
            setTimeout(() => location.reload(), 600);
        } else {
            window.adminToast?.(data.error || 'Error', 'error');
        }
    }
</script>
