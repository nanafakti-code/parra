---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/admin";
import { supabaseAdmin } from "../../lib/supabase";

const adminResult = await requireAdmin(Astro);
if (adminResult instanceof Response) return adminResult;
const admin = adminResult;

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") || "all";

let query = supabaseAdmin
    .from("returns")
    .select("*, orders(id, total), users(name, email)")
    .order("created_at", { ascending: false });

if (statusFilter !== "all") {
    query = query.eq("status", statusFilter);
}

const { data: returns } = await query;

const statuses = [
    { key: "all", label: "Todas" },
    { key: "pending", label: "Pendientes" },
    { key: "approved", label: "Aprobadas" },
    { key: "rejected", label: "Rechazadas" },
    { key: "refunded", label: "Reembolsadas" },
];

function formatStatus(s: string) {
    const map: Record<string, string> = {
        pending: "Pendiente",
        approved: "Aprobada",
        rejected: "Rechazada",
        refunded: "Reembolsada",
    };
    return map[s] || s;
}
function statusBadge(s: string) {
    const map: Record<string, string> = {
        pending: "badge-warning",
        approved: "badge-success",
        rejected: "badge-danger",
        refunded: "badge-info",
    };
    return map[s] || "badge-neutral";
}
---

<AdminLayout title="Devoluciones" activeSection="returns" admin={admin}>
    <div class="filter-bar">
        {
            statuses.map((s) => (
                <a
                    href={`/admin/returns${s.key !== "all" ? `?status=${s.key}` : ""}`}
                    class={`filter-chip ${statusFilter === s.key ? "active" : ""}`}
                >
                    {s.label}
                </a>
            ))
        }
    </div>

    <!-- Search Bar -->
    <div style="margin-bottom: 1rem; max-width: 400px; position: relative;">
        <svg
            style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4);"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
            type="text"
            id="page-search"
            class="form-input"
            placeholder="Buscar por ID, nombre o email..."
            style="padding-left: 2.5rem;"
        />
    </div>

    <div class="card">
        {
            !returns || returns.length === 0 ? (
                <div class="empty-state">
                    <h3>Sin devoluciones</h3>
                    <p>No hay solicitudes de devolución con este filtro.</p>
                </div>
            ) : (
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Pedido</th>
                            <th>Cliente</th>
                            <th>Motivo</th>
                            <th>Importe</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {returns.map((ret: any) => (
                            <tr
                                data-search={`${ret.order_id || ""} ${ret.users?.name || ""} ${ret.users?.email || ""}`}
                            >
                                <td
                                    data-label="ID"
                                    style="font-family:monospace;font-size:0.7rem;"
                                >
                                    #{ret.id?.slice(0, 8)}
                                </td>
                                <td
                                    data-label="Pedido"
                                    style="font-family:monospace;font-size:0.7rem;"
                                >
                                    <a
                                        href="/admin/orders"
                                        style="color:#60a5fa;text-decoration:none;"
                                    >
                                        #{ret.orders?.id?.slice(0, 8)}
                                    </a>
                                </td>
                                <td data-label="Cliente">
                                    <div style="font-size:0.8rem;">
                                        {ret.users?.name || "—"}
                                    </div>
                                    <div style="font-size:0.65rem;color:rgba(255,255,255,0.3);">
                                        {ret.users?.email}
                                    </div>
                                </td>
                                <td
                                    data-label="Motivo"
                                    style="font-size:0.75rem;max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"
                                >
                                    {ret.reason || "—"}
                                </td>
                                <td
                                    data-label="Importe"
                                    style="font-weight:600;"
                                >
                                    {ret.refund_amount
                                        ? `€${parseFloat(ret.refund_amount).toFixed(2)}`
                                        : "—"}
                                </td>
                                <td data-label="Estado">
                                    <span
                                        class={`badge ${statusBadge(ret.status)}`}
                                    >
                                        {formatStatus(ret.status)}
                                    </span>
                                </td>
                                <td
                                    data-label="Fecha"
                                    style="font-size:0.7rem;color:rgba(255,255,255,0.4);"
                                >
                                    {new Date(
                                        ret.created_at,
                                    ).toLocaleDateString("es-ES", {
                                        day: "2-digit",
                                        month: "short",
                                    })}
                                </td>
                                <td>
                                    <button
                                        class="btn btn-secondary btn-sm btn-return-manage"
                                        data-id={ret.id}
                                        data-status={ret.status}
                                        data-reason={ret.reason || ""}
                                        data-notes={ret.admin_notes || ""}
                                        data-amount={ret.refund_amount || ""}
                                        data-order-total={
                                            ret.orders?.total || "0"
                                        }
                                    >
                                        Gestionar
                                    </button>
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            )
        }
    </div>

    <!-- Return Management Modal -->
    <div id="return-modal" class="modal-overlay" style="display:none;">
        <div class="modal" style="max-width:500px;">
            <div class="modal-header">
                <div class="modal-title">Gestionar Devolución</div>
                <button
                    class="modal-close"
                    onclick="document.getElementById('return-modal').style.display='none'"
                >
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="18" y1="6" x2="6" y2="18"></line><line
                            x1="6"
                            y1="6"
                            x2="18"
                            y2="18"></line></svg
                    >
                </button>
            </div>
            <div
                id="return-reason"
                style="font-size:0.8rem;color:rgba(255,255,255,0.5);margin-bottom:1rem;padding:0.6rem;background:rgba(255,255,255,0.02);border-radius:6px;border:1px solid rgba(255,255,255,0.04);"
            >
            </div>
            <div id="return-amount-display" style="font-size:0.85rem;color:rgba(255,255,255,0.6);margin-bottom:1rem;padding:0.8rem;background:rgba(57,255,20,0.08);border-radius:6px;border-left:3px solid #39FF14;">
                <strong>Monto a reembolsar (solo producto):</strong>
                <div id="return-amount-text" style="font-size:1.1rem;font-weight:700;color:#39FF14;margin-top:0.3rem;">€0.00</div>
            </div>
            <div class="form-group">
                <label class="form-label">Notas Admin (Motivo del rechazo si aplica)</label>
                <textarea
                    class="form-textarea"
                    id="return-notes"
                    placeholder="Notas internas..."></textarea>
            </div>
            <div class="modal-actions">
                <button
                    type="button"
                    class="btn btn-secondary"
                    onclick="document.getElementById('return-modal').style.display='none'"
                    >Cancelar</button
                >
                <button type="button" class="btn" id="return-reject-btn"
                    style="background:rgba(239,68,68,0.2);border:1px solid rgba(239,68,68,0.3);color:#ef4444;"
                    >Rechazar</button
                >
                <button type="button" class="btn btn-primary" id="return-approve-btn"
                    >Aprobar & Reembolsar</button
                >
            </div>
            <input type="hidden" id="return-id" />
            <input type="hidden" id="return-order-id" />
        </div>
    </div>

    <script is:inline>
        (function () {
            document
                .querySelectorAll(".btn-return-manage")
                .forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        const returnId = this.getAttribute("data-id");
                        const orderTotal = this.getAttribute("data-order-total");
                        const status = this.getAttribute("data-status");

                        document.getElementById("return-id").value = returnId;
                        document.getElementById("return-notes").value = this.getAttribute("data-notes") || "";
                        document.getElementById("return-reason").textContent = "Motivo: " + (this.getAttribute("data-reason") || "Sin especificar");

                        // Mostrar el monto de reembolso (solo para pending)
                        if (status === "pending") {
                            document.getElementById("return-amount-text").textContent = "€" + parseFloat(orderTotal || "0").toFixed(2);
                            document.getElementById("return-amount-display").style.display = "block";
                            document.getElementById("return-approve-btn").style.display = "inline-block";
                            document.getElementById("return-reject-btn").style.display = "inline-block";
                        } else {
                            document.getElementById("return-amount-display").style.display = "none";
                            document.getElementById("return-approve-btn").style.display = "none";
                            document.getElementById("return-reject-btn").style.display = "none";
                        }

                        document.getElementById("return-modal").style.display = "flex";
                    });
                });

            // Botón Aprobar
            document.getElementById("return-approve-btn").addEventListener("click", async function () {
                const returnId = document.getElementById("return-id").value;
                const notes = document.getElementById("return-notes").value;

                if (!confirm("¿Confirmas que deseas aprobar esta devolución y procesar el reembolso?")) {
                    return;
                }

                this.disabled = true;
                const originalText = this.textContent;
                this.textContent = "Procesando...";

                try {
                    const res = await fetch(`/api/admin/returns/${returnId}/approve`, {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ adminNotes: notes || undefined }),
                    });

                    if (res.ok) {
                        window.adminToast("✓ Devolución aprobada. Reembolso procesado.", "success");
                        document.getElementById("return-modal").style.display = "none";
                        setTimeout(() => window.location.reload(), 1000);
                    } else {
                        const data = await res.json();
                        window.adminToast(data.message || "Error al aprobar", "error");
                    }
                } catch (err) {
                    window.adminToast("Error de conexión", "error");
                } finally {
                    this.disabled = false;
                    this.textContent = originalText;
                }
            });

            // Botón Rechazar
            document.getElementById("return-reject-btn").addEventListener("click", async function () {
                const returnId = document.getElementById("return-id").value;
                const notes = document.getElementById("return-notes").value;

                if (!notes.trim()) {
                    window.adminToast("Por favor indica la razón del rechazo en las notas", "error");
                    return;
                }

                if (!confirm("¿Confirmas que deseas rechazar esta devolución?")) {
                    return;
                }

                this.disabled = true;
                const originalText = this.textContent;
                this.textContent = "Procesando...";

                try {
                    const res = await fetch(`/api/admin/returns/${returnId}/reject`, {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ adminNotes: notes }),
                    });

                    if (res.ok) {
                        window.adminToast("✓ Devolución rechazada. Se notificó al cliente.", "success");
                        document.getElementById("return-modal").style.display = "none";
                        setTimeout(() => window.location.reload(), 1000);
                    } else {
                        const data = await res.json();
                        window.adminToast(data.message || "Error al rechazar", "error");
                    }
                } catch (err) {
                    window.adminToast("Error de conexión", "error");
                } finally {
                    this.disabled = false;
                    this.textContent = originalText;
                }
            });
        })();
    </script>
</AdminLayout>
