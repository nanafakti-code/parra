---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/admin";
import { supabaseAdmin } from "../../lib/supabase";

const adminResult = await requireAdmin(Astro);
if (adminResult instanceof Response) return adminResult;
const admin = adminResult;

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") || "all";

let query = supabaseAdmin
    .from("returns")
    .select("*, orders(id, total, subtotal, discount), users(name, email)")
    .order("created_at", { ascending: false });

if (statusFilter !== "all") {
    query = query.eq("status", statusFilter);
}

const { data: returns } = await query;

const statuses = [
    { key: "all", label: "Todas" },
    { key: "pending", label: "Pendientes" },
    { key: "approved", label: "Aprobadas" },
    { key: "rejected", label: "Rechazadas" },
    { key: "refunded", label: "Reembolsadas" },
];

function formatStatus(s: string) {
    const map: Record<string, string> = {
        pending: "Pendiente",
        approved: "Aprobada",
        rejected: "Rechazada",
        refunded: "Reembolsada",
    };
    return map[s] || s;
}
function statusBadge(s: string) {
    const map: Record<string, string> = {
        pending: "badge-warning",
        approved: "badge-success",
        rejected: "badge-danger",
        refunded: "badge-info",
    };
    return map[s] || "badge-neutral";
}
---

<AdminLayout title="Devoluciones" activeSection="returns" admin={admin}>
    <div class="filter-bar">
        {
            statuses.map((s) => (
                <a
                    href={`/admin/returns${s.key !== "all" ? `?status=${s.key}` : ""}`}
                    class={`filter-chip ${statusFilter === s.key ? "active" : ""}`}
                >
                    {s.label}
                </a>
            ))
        }
    </div>

    <!-- Search Bar -->
    <div style="margin-bottom: 1rem; max-width: 400px; position: relative;">
        <svg
            style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4);"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
            type="text"
            id="page-search"
            class="form-input"
            placeholder="Buscar por ID, nombre o email..."
            style="padding-left: 2.5rem;"
        />
    </div>

    <div class="card">
        {
            !returns || returns.length === 0 ? (
                <div class="empty-state">
                    <h3>Sin devoluciones</h3>
                    <p>No hay solicitudes de devolución con este filtro.</p>
                </div>
            ) : (
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Pedido</th>
                            <th>Cliente</th>
                            <th>Motivo</th>
                            <th>Importe</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {returns.map((ret: any) => (
                            <tr
                                data-search={`${ret.order_id || ""} ${ret.users?.name || ""} ${ret.users?.email || ""}`}
                            >
                                <td
                                    data-label="ID"
                                    style="font-family:monospace;font-size:0.7rem;"
                                >
                                    #{ret.id?.slice(0, 8)}
                                </td>
                                <td
                                    data-label="Pedido"
                                    style="font-family:monospace;font-size:0.7rem;"
                                >
                                    <a
                                        href="/admin/orders"
                                        style="color:#60a5fa;text-decoration:none;"
                                    >
                                        #{ret.orders?.id?.slice(0, 8)}
                                    </a>
                                </td>
                                <td data-label="Cliente">
                                    <div style="font-size:0.8rem;">
                                        {ret.users?.name || "—"}
                                    </div>
                                    <div style="font-size:0.65rem;color:rgba(255,255,255,0.3);">
                                        {ret.users?.email}
                                    </div>
                                </td>
                                <td
                                    data-label="Motivo"
                                    style="font-size:0.75rem;max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"
                                >
                                    {ret.reason || "—"}
                                </td>
                                <td
                                    data-label="Importe"
                                    style="font-weight:600;"
                                >
                                    {ret.refund_amount
                                        ? `€${parseFloat(ret.refund_amount).toFixed(2)}`
                                        : ret.orders?.subtotal != null
                                            ? `€${(parseFloat(ret.orders.subtotal) - parseFloat(ret.orders?.discount || 0)).toFixed(2)}`
                                            : "—"}
                                </td>
                                <td data-label="Estado">
                                    <span
                                        class={`badge ${statusBadge(ret.status)}`}
                                    >
                                        {formatStatus(ret.status)}
                                    </span>
                                </td>
                                <td
                                    data-label="Fecha"
                                    style="font-size:0.7rem;color:rgba(255,255,255,0.4);"
                                >
                                    {new Date(
                                        ret.created_at,
                                    ).toLocaleDateString("es-ES", {
                                        day: "2-digit",
                                        month: "short",
                                    })}
                                </td>
                                <td>
                                    <button
                                        class="btn btn-secondary btn-sm btn-return-manage"
                                        data-id={ret.id}
                                        data-id-short={ret.id?.slice(0, 8)}
                                        data-status={ret.status}
                                        data-reason={ret.reason || ""}
                                        data-notes={ret.admin_notes || ""}
                                        data-amount={ret.refund_amount || ""}
                                        data-order-subtotal={ret.orders?.subtotal || "0"}
                                        data-order-discount={ret.orders?.discount || "0"}
                                        data-order-id-short={ret.orders?.id?.slice(0, 8) || ""}
                                        data-customer-name={ret.users?.name || ""}
                                        data-customer-email={ret.users?.email || ""}
                                    >
                                        Gestionar
                                    </button>
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            )
        }
    </div>

    <!-- Return Management Modal -->
    <div id="return-modal" class="modal-overlay" style="display:none;">
        <div class="modal" style="max-width:480px;">

            <!-- Header -->
            <div class="modal-header">
                <div style="display:flex;align-items:center;gap:0.6rem;">
                    <div style="width:32px;height:32px;border-radius:8px;background:rgba(255,164,0,0.1);border:1px solid rgba(255,164,0,0.2);display:flex;align-items:center;justify-content:center;color:#FFA400;flex-shrink:0;">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="1 4 1 10 7 10"></polyline>
                            <path d="M3.51 15a9 9 0 1 0 .49-3.51"></path>
                        </svg>
                    </div>
                    <div class="modal-title">Gestionar Devolución</div>
                </div>
                <button class="modal-close" onclick="document.getElementById('return-modal').style.display='none'">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>

            <!-- Metadata grid -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;margin-bottom:1rem;padding:0.75rem;background:rgba(255,255,255,0.02);border-radius:8px;border:1px solid rgba(255,255,255,0.05);">
                <div>
                    <div style="font-size:0.6rem;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">ID Devolución</div>
                    <div id="modal-return-id-display" style="font-family:monospace;font-size:0.75rem;color:rgba(255,255,255,0.7);">—</div>
                </div>
                <div>
                    <div style="font-size:0.6rem;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">Estado</div>
                    <div id="modal-return-status-display" style="font-size:0.75rem;">—</div>
                </div>
                <div>
                    <div style="font-size:0.6rem;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.25rem;">Cliente</div>
                    <div id="modal-customer-name" style="font-size:0.8rem;font-weight:500;">—</div>
                    <div id="modal-customer-email" style="font-size:0.65rem;color:rgba(255,255,255,0.3);">—</div>
                </div>
                <div>
                    <div style="font-size:0.6rem;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">Pedido</div>
                    <div id="modal-order-id-display" style="font-family:monospace;font-size:0.75rem;color:#60a5fa;">—</div>
                </div>
            </div>

            <!-- Reason -->
            <div style="margin-bottom:1rem;">
                <div style="font-size:0.6rem;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.35rem;">Motivo del cliente</div>
                <div id="return-reason" style="font-size:0.8rem;color:rgba(255,255,255,0.6);padding:0.65rem 0.75rem;background:rgba(255,255,255,0.02);border-radius:6px;border:1px solid rgba(255,255,255,0.05);line-height:1.5;">—</div>
            </div>

            <!-- Refund amount -->
            <div id="return-amount-display" style="display:none;margin-bottom:1rem;">
                <div id="return-amount-label" style="font-size:0.6rem;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.35rem;">Monto a reembolsar (solo producto)</div>
                <div style="display:flex;align-items:center;justify-content:space-between;padding:0.85rem 1rem;background:rgba(57,255,20,0.05);border-radius:8px;border:1px solid rgba(57,255,20,0.15);">
                    <div style="font-size:0.75rem;color:rgba(255,255,255,0.35);">Subtotal sin envío</div>
                    <div id="return-amount-text" style="font-size:1.3rem;font-weight:700;font-family:'Oswald',sans-serif;color:#39FF14;letter-spacing:0.02em;">€0.00</div>
                </div>
            </div>

            <!-- Admin notes -->
            <div id="return-notes-section" class="form-group">
                <label class="form-label">Notas admin</label>
                <textarea class="form-textarea" id="return-notes" rows="2" placeholder="Notas internas o motivo del rechazo..."></textarea>
            </div>

            <!-- Actions -->
            <div class="modal-actions" style="padding-top:0.25rem;border-top:1px solid rgba(255,255,255,0.05);margin-top:1rem;">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('return-modal').style.display='none'">Cancelar</button>
                <button type="button" class="btn" id="return-reject-btn"
                    style="background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.25);color:#f87171;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3rem;">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                    Rechazar
                </button>
                <button type="button" class="btn btn-primary" id="return-approve-btn">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3rem;">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    Aprobar &amp; Reembolsar
                </button>
            </div>

            <input type="hidden" id="return-id" />
            <input type="hidden" id="return-order-id" />
        </div>
    </div>

    <script is:inline>
        (function () {
            var statusConfig = {
                pending:  { label: "Pendiente",    color: "#fbbf24", bg: "rgba(251,191,36,0.1)",  border: "rgba(251,191,36,0.2)"  },
                approved: { label: "Aprobada",     color: "#4ade80", bg: "rgba(74,222,128,0.1)",  border: "rgba(74,222,128,0.2)"  },
                rejected: { label: "Rechazada",    color: "#f87171", bg: "rgba(248,113,113,0.1)", border: "rgba(248,113,113,0.2)" },
                refunded: { label: "Reembolsada",  color: "#60a5fa", bg: "rgba(96,165,250,0.1)",  border: "rgba(96,165,250,0.2)"  },
            };

            document.querySelectorAll(".btn-return-manage").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    var returnId      = this.getAttribute("data-id");
                    var idShort       = this.getAttribute("data-id-short");
                    var status        = this.getAttribute("data-status");
                    var reason        = this.getAttribute("data-reason") || "Sin especificar";
                    var notes         = this.getAttribute("data-notes") || "";
                    var amount        = this.getAttribute("data-amount");
                    var subtotal      = this.getAttribute("data-order-subtotal");
                    var discount      = this.getAttribute("data-order-discount");
                    var orderIdShort  = this.getAttribute("data-order-id-short");
                    var customerName  = this.getAttribute("data-customer-name");
                    var customerEmail = this.getAttribute("data-customer-email");

                    // Hidden fields
                    document.getElementById("return-id").value = returnId;

                    // Metadata grid
                    document.getElementById("modal-return-id-display").textContent = "#" + idShort;
                    document.getElementById("modal-order-id-display").textContent  = "#" + orderIdShort;
                    document.getElementById("modal-customer-name").textContent     = customerName || "—";
                    document.getElementById("modal-customer-email").textContent    = customerEmail || "—";

                    var sc = statusConfig[status] || { label: status, color: "rgba(255,255,255,0.6)", bg: "rgba(255,255,255,0.05)", border: "rgba(255,255,255,0.1)" };
                    var statusEl = document.getElementById("modal-return-status-display");
                    statusEl.textContent = sc.label;
                    statusEl.style.cssText = "display:inline-block;font-size:0.7rem;font-weight:600;padding:0.2rem 0.5rem;border-radius:4px;background:" + sc.bg + ";color:" + sc.color + ";border:1px solid " + sc.border + ";";

                    // Reason
                    document.getElementById("return-reason").textContent = reason;

                    // Notes
                    document.getElementById("return-notes").value = notes;

                    // Refund amount & buttons
                    var approveBtn = document.getElementById("return-approve-btn");
                    var rejectBtn  = document.getElementById("return-reject-btn");
                    var amountBox  = document.getElementById("return-amount-display");
                    var amountLabel = document.getElementById("return-amount-label");
                    var amountText = document.getElementById("return-amount-text");

                    if (status === "pending") {
                        var refundAmount = parseFloat(subtotal || "0") - parseFloat(discount || "0");
                        amountLabel.textContent = "Monto a reembolsar (solo producto)";
                        amountText.textContent  = "€" + refundAmount.toFixed(2);
                        amountBox.style.display = "block";
                        approveBtn.style.display = "inline-flex";
                        rejectBtn.style.display  = "inline-flex";
                    } else if (status === "refunded" && amount) {
                        amountLabel.textContent = "Monto reembolsado";
                        amountText.textContent  = "€" + parseFloat(amount).toFixed(2);
                        amountBox.style.display = "block";
                        approveBtn.style.display = "none";
                        rejectBtn.style.display  = "none";
                    } else {
                        amountBox.style.display  = "none";
                        approveBtn.style.display = "none";
                        rejectBtn.style.display  = "none";
                    }

                    document.getElementById("return-modal").style.display = "flex";
                });
            });

            // Botón Aprobar
            document.getElementById("return-approve-btn").addEventListener("click", async function () {
                var returnId = document.getElementById("return-id").value;
                var notes    = document.getElementById("return-notes").value;
                var btn      = this;

                var confirmed = await window.adminConfirm("¿Aprobar esta devolución y procesar el reembolso al método de pago del cliente?");
                if (!confirmed) return;
                await doApprove(returnId, notes, btn);
            });

            async function doApprove(returnId, notes, btn) {
                btn.disabled = true;
                var orig = btn.innerHTML;
                btn.innerHTML = "Procesando...";
                try {
                    var res = await fetch("/api/admin/returns/" + returnId + "/approve", {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ adminNotes: notes || undefined }),
                    });
                    if (res.ok) {
                        window.adminToast("✓ Devolución aprobada. Reembolso procesado.", "success");
                        document.getElementById("return-modal").style.display = "none";
                        setTimeout(() => window.location.reload(), 1000);
                    } else {
                        var data = await res.json();
                        window.adminToast(data.message || "Error al aprobar", "error");
                    }
                } catch (err) {
                    window.adminToast("Error de conexión", "error");
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = orig;
                }
            }

            // Botón Rechazar
            document.getElementById("return-reject-btn").addEventListener("click", async function () {
                var returnId = document.getElementById("return-id").value;
                var notes    = document.getElementById("return-notes").value;
                var btn      = this;

                if (!notes.trim()) {
                    window.adminToast("Por favor indica la razón del rechazo en las notas", "error");
                    return;
                }

                var confirmed = await window.adminConfirm("¿Rechazar esta devolución? Se notificará al cliente con el motivo indicado.");
                if (!confirmed) return;
                await doReject(returnId, notes, btn);
            });

            async function doReject(returnId, notes, btn) {
                btn.disabled = true;
                var orig = btn.innerHTML;
                btn.innerHTML = "Procesando...";
                try {
                    var res = await fetch("/api/admin/returns/" + returnId + "/reject", {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ adminNotes: notes }),
                    });
                    if (res.ok) {
                        window.adminToast("✓ Devolución rechazada. Se notificó al cliente.", "success");
                        document.getElementById("return-modal").style.display = "none";
                        setTimeout(() => window.location.reload(), 1000);
                    } else {
                        var data = await res.json();
                        window.adminToast(data.message || "Error al rechazar", "error");
                    }
                } catch (err) {
                    window.adminToast("Error de conexión", "error");
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = orig;
                }
            }
        })();
    </script>
</AdminLayout>
