---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin';
import { supabaseAdmin } from '../../lib/supabase';

const adminResult = await requireAdmin(Astro);
if (adminResult instanceof Response) return adminResult;
const admin = adminResult;

// ── KPI Queries ────────────────────────────────────────────────────────────────

// Total revenue
const { data: allOrders } = await supabaseAdmin
    .from('orders')
    .select('total, status, created_at');

const totalRevenue = (allOrders || []).reduce((s, o) => s + parseFloat(o.total || 0), 0);

// This month's revenue
const now = new Date();
const firstOfMonth = new Date(now.getFullYear(), now.getMonth(), 1).toISOString();
const monthOrders = (allOrders || []).filter(o => o.created_at >= firstOfMonth);
const monthRevenue = monthOrders.reduce((s, o) => s + parseFloat(o.total || 0), 0);

// Previous month for comparison
const firstOfPrevMonth = new Date(now.getFullYear(), now.getMonth() - 1, 1).toISOString();
const endOfPrevMonth = new Date(now.getFullYear(), now.getMonth(), 0, 23, 59, 59).toISOString();
const prevMonthOrders = (allOrders || []).filter(o => o.created_at >= firstOfPrevMonth && o.created_at <= endOfPrevMonth);
const prevMonthRevenue = prevMonthOrders.reduce((s, o) => s + parseFloat(o.total || 0), 0);
const revenueChange = prevMonthRevenue > 0 ? ((monthRevenue - prevMonthRevenue) / prevMonthRevenue * 100).toFixed(1) : '0';

// Order counts
const totalOrderCount = allOrders?.length || 0;
const monthOrderCount = monthOrders.length;
const prevMonthOrderCount = prevMonthOrders.length;
const ordersChange = prevMonthOrderCount > 0 ? ((monthOrderCount - prevMonthOrderCount) / prevMonthOrderCount * 100).toFixed(1) : '0';

// Average ticket
const avgTicket = totalOrderCount > 0 ? (totalRevenue / totalOrderCount) : 0;

// Total customers
const { count: totalCustomers } = await supabaseAdmin
    .from('users')
    .select('*', { count: 'exact', head: true })
    .eq('role', 'customer');

// New customers this month
const { count: newCustomersMonth } = await supabaseAdmin
    .from('users')
    .select('*', { count: 'exact', head: true })
    .gte('created_at', firstOfMonth)
    .eq('role', 'customer');

// Pending orders
const pendingOrders = (allOrders || []).filter(o => o.status === 'pending' || o.status === 'processing');

// Orders by status
const statusCounts: Record<string, number> = {};
(allOrders || []).forEach(o => {
    statusCounts[o.status] = (statusCounts[o.status] || 0) + 1;
});

// ── Recent orders ──────────────────────────────────────────────────────────────
const { data: recentOrders } = await supabaseAdmin
    .from('orders')
    .select('id, total, status, created_at, users(name, email)')
    .order('created_at', { ascending: false })
    .limit(8);

// ── Monthly revenue for chart (last 6 months) ──────────────────────────────────
const monthlyData: { label: string; revenue: number; orders: number }[] = [];
const monthNames = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
for (let i = 5; i >= 0; i--) {
    const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    const dEnd = new Date(now.getFullYear(), now.getMonth() - i + 1, 0, 23, 59, 59);
    const mOrders = (allOrders || []).filter(o => o.created_at >= d.toISOString() && o.created_at <= dEnd.toISOString());
    monthlyData.push({
        label: monthNames[d.getMonth()],
        revenue: mOrders.reduce((s, o) => s + parseFloat(o.total || 0), 0),
        orders: mOrders.length,
    });
}

// ── Top products ───────────────────────────────────────────────────────────────
const { data: topItems } = await supabaseAdmin
    .from('order_items')
    .select('product_id, quantity, products(name)')
    .limit(500);

const productSales: Record<string, { name: string; qty: number }> = {};
(topItems || []).forEach((item: any) => {
    const pid = item.product_id;
    if (!productSales[pid]) productSales[pid] = { name: item.products?.name || 'Desconocido', qty: 0 };
    productSales[pid].qty += item.quantity || 1;
});
const topProducts = Object.values(productSales).sort((a, b) => b.qty - a.qty).slice(0, 5);

// ── Daily revenue last 30 days ─────────────────────────────────────────────────
const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000).toISOString();
const recentAllOrders = (allOrders || []).filter(o => o.created_at >= thirtyDaysAgo);
const dailyRevenue: { day: string; revenue: number }[] = [];
for (let i = 29; i >= 0; i--) {
    const d = new Date(now.getTime() - i * 24 * 60 * 60 * 1000);
    const dayStr = d.toISOString().slice(0, 10);
    const dayOrders = recentAllOrders.filter(o => o.created_at.slice(0, 10) === dayStr);
    dailyRevenue.push({
        day: `${d.getDate()}/${d.getMonth() + 1}`,
        revenue: dayOrders.reduce((s, o) => s + parseFloat(o.total || 0), 0),
    });
}

function formatStatusLabel(status: string): string {
    const map: Record<string, string> = {
        pending: 'Pendiente',
        processing: 'Procesando',
        shipped: 'Enviado',
        delivered: 'Entregado',
        cancelled: 'Cancelado',
        refunded: 'Reembolsado',
    };
    return map[status] || status;
}

function statusBadgeClass(status: string): string {
    const map: Record<string, string> = {
        pending: 'badge-warning',
        processing: 'badge-info',
        shipped: 'badge-info',
        delivered: 'badge-success',
        cancelled: 'badge-danger',
        refunded: 'badge-danger',
    };
    return map[status] || 'badge-neutral';
}

// Serialize chart data
const chartData = JSON.stringify({
    monthly: monthlyData,
    statusCounts,
    topProducts,
    dailyRevenue,
});
---

<AdminLayout title="Dashboard" activeSection="dashboard" admin={admin}>
    <!-- KPI Grid -->
    <div class="stat-grid" style="margin-bottom: 1.5rem;">
        <div class="stat-card">
            <div class="stat-label">Ingresos Totales</div>
            <div class="stat-value">{totalRevenue.toFixed(0)}€</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Ventas este mes</div>
            <div class="stat-value">{monthRevenue.toFixed(0)}€</div>
            <div class={`stat-change ${parseFloat(revenueChange as string) >= 0 ? 'stat-up' : 'stat-down'}`}>
                {Math.abs(parseFloat(revenueChange as string))}% vs mes anterior
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Pedidos este mes</div>
            <div class="stat-value">{monthOrderCount}</div>
            <div class={`stat-change ${parseFloat(ordersChange as string) >= 0 ? 'stat-up' : 'stat-down'}`}>
                {Math.abs(parseFloat(ordersChange as string))}% vs mes anterior
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Ticket Medio</div>
            <div class="stat-value">{avgTicket.toFixed(2)}€</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Clientes</div>
            <div class="stat-value">{totalCustomers || 0}</div>
            <div class="stat-change stat-up">+{newCustomersMonth || 0} este mes</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Pedidos Pendientes</div>
            <div class="stat-value" style={pendingOrders.length > 0 ? 'color:#FFA400;' : ''}>
                {pendingOrders.length}
            </div>
        </div>
    </div>

    <!-- Charts Row 1 -->
    <div style="display:grid; grid-template-columns: 2fr 1fr; gap: 1rem; margin-bottom: 1rem;">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Ingresos Mensuales</div>
            </div>
            <div style="position:relative; height:220px; padding: 0 1rem 1rem;">
                <canvas id="chart-revenue"></canvas>
            </div>
        </div>
        <div class="card">
            <div class="card-header">
                <div class="card-title">Pedidos por Estado</div>
            </div>
            <div style="position:relative; height:220px; padding: 0 1rem 1rem;">
                <canvas id="chart-status"></canvas>
            </div>
        </div>
    </div>

    <!-- Charts Row 2 -->
    <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Top Productos</div>
            </div>
            <div style="position:relative; height:200px; padding: 0 1rem 1rem;">
                <canvas id="chart-products"></canvas>
            </div>
        </div>
        <div class="card">
            <div class="card-header">
                <div class="card-title">Evolución 30 Días</div>
            </div>
            <div style="position:relative; height:200px; padding: 0 1rem 1rem;">
                <canvas id="chart-daily"></canvas>
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="card">
        <div class="card-header">
            <div class="card-title">Últimos Pedidos</div>
            <a href="/admin/orders" class="btn btn-secondary btn-sm">Ver todos</a>
        </div>
        {(!recentOrders || recentOrders.length === 0) ? (
            <div class="empty-state">
                <h3>Sin pedidos aún</h3>
                <p>Los pedidos aparecerán aquí cuando se realicen.</p>
            </div>
        ) : (
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    {recentOrders.map((order: any) => (
                        <tr>
                            <td data-label="ID" style="font-family: monospace; font-size: 0.7rem;">
                                #{order.id?.slice(0, 8)}
                            </td>
                            <td data-label="Cliente">
                                <div style="font-weight: 500;">{order.users?.name || '—'}</div>
                                <div style="font-size: 0.65rem; color: rgba(255,255,255,0.3);">{order.users?.email || ''}</div>
                            </td>
                            <td data-label="Total" style="font-weight: 600;">{parseFloat(order.total).toFixed(2)}€</td>
                            <td data-label="Estado">
                                <span class={`badge ${statusBadgeClass(order.status)}`}>
                                    {formatStatusLabel(order.status)}
                                </span>
                            </td>
                            <td data-label="Fecha" style="font-size: 0.7rem; color: rgba(255,255,255,0.4);">
                                {new Date(order.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' })}
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
        )}
    </div>

    <!-- Chart.js: carga diferida para no bloquear el renderizado del dashboard -->
    <script is:inline define:vars={{ chartData }}>
        (function() {
            var s = document.createElement('script');
            s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js';
            s.onload = function() {
            var data = JSON.parse(chartData);

            var styles = getComputedStyle(document.documentElement);
            var brandColor = styles.getPropertyValue('--brand').trim() || '#39FF14';
            var brandRgb = styles.getPropertyValue('--brand-rgb').trim() || '57, 255, 20';

            var chartColors = {
                green: brandColor,
                greenBg: 'rgba(' + brandRgb + ', 0.15)',
                greenBorder: 'rgba(' + brandRgb + ', 0.6)',
                blue: '#60a5fa',
                orange: '#FFA400',
                red: '#f87171',
                purple: '#a78bfa',
                gray: 'rgba(255,255,255,0.1)',
                text: 'rgba(255,255,255,0.4)',
                grid: 'rgba(255,255,255,0.04)',
            };

            var defaultOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                },
                scales: {
                    x: { grid: { color: chartColors.grid }, ticks: { color: chartColors.text, font: { size: 10 } } },
                    y: { grid: { color: chartColors.grid }, ticks: { color: chartColors.text, font: { size: 10 } } },
                },
            };

            // Monthly Revenue
            var ctxRevenue = document.getElementById('chart-revenue');
            if (ctxRevenue) {
                new Chart(ctxRevenue, {
                    type: 'bar',
                    data: {
                        labels: data.monthly.map(function(m) { return m.label; }),
                        datasets: [{
                            label: 'Ingresos (€)',
                            data: data.monthly.map(function(m) { return m.revenue; }),
                            backgroundColor: chartColors.greenBg,
                            borderColor: chartColors.greenBorder,
                            borderWidth: 1,
                            borderRadius: 4,
                        }],
                    },
                    options: defaultOptions,
                });
            }

            // Status Doughnut
            var ctxStatus = document.getElementById('chart-status');
            if (ctxStatus) {
                var statusLabels = Object.keys(data.statusCounts);
                var statusMap = { pending: 'Pendiente', processing: 'Procesando', shipped: 'Enviado', delivered: 'Entregado', cancelled: 'Cancelado', refunded: 'Reembolso' };
                var statusColors = { pending: '#FFA400', processing: '#60a5fa', shipped: '#818cf8', delivered: brandColor, cancelled: '#f87171', refunded: '#a78bfa' };

                new Chart(ctxStatus, {
                    type: 'doughnut',
                    data: {
                        labels: statusLabels.map(function(s) { return statusMap[s] || s; }),
                        datasets: [{
                            data: statusLabels.map(function(s) { return data.statusCounts[s]; }),
                            backgroundColor: statusLabels.map(function(s) { return statusColors[s] || '#666'; }),
                            borderWidth: 0,
                        }],
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '65%',
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { color: chartColors.text, font: { size: 10 }, padding: 12, usePointStyle: true },
                            },
                        },
                    },
                });
            }

            // Top Products
            var ctxProducts = document.getElementById('chart-products');
            if (ctxProducts) {
                new Chart(ctxProducts, {
                    type: 'bar',
                    data: {
                        labels: data.topProducts.map(function(p) { return p.name.length > 20 ? p.name.substring(0, 20) + '...' : p.name; }),
                        datasets: [{
                            label: 'Unidades vendidas',
                            data: data.topProducts.map(function(p) { return p.qty; }),
                            backgroundColor: [chartColors.green, chartColors.blue, chartColors.orange, chartColors.purple, chartColors.red],
                            borderWidth: 0,
                            borderRadius: 4,
                        }],
                    },
                    options: Object.assign({}, defaultOptions, { indexAxis: 'y' }),
                });
            }

            // Daily Revenue Line
            var ctxDaily = document.getElementById('chart-daily');
            if (ctxDaily) {
                new Chart(ctxDaily, {
                    type: 'line',
                    data: {
                        labels: data.dailyRevenue.map(function(d) { return d.day; }),
                        datasets: [{
                            label: 'Ingresos (€)',
                            data: data.dailyRevenue.map(function(d) { return d.revenue; }),
                            borderColor: chartColors.green,
                            backgroundColor: chartColors.greenBg,
                            fill: true,
                            tension: 0.4,
                            pointRadius: 0,
                            pointHoverRadius: 4,
                            borderWidth: 2,
                        }],
                    },
                    options: Object.assign({}, defaultOptions, {
                        scales: {
                            x: { grid: { display: false }, ticks: { color: chartColors.text, font: { size: 9 }, maxRotation: 45 } },
                            y: { grid: { color: chartColors.grid }, ticks: { color: chartColors.text, font: { size: 10 } } },
                        },
                    }),
                });
            }
            }; // end s.onload
            document.head.appendChild(s);
        })();
    </script>

    <style>
        /* ── Dashboard charts: 1 columna en móvil ── */
        @media (max-width: 1024px) {
            div[style*="grid-template-columns: 2fr 1fr"],
            div[style*="grid-template-columns: 1fr 1fr"] {
                grid-template-columns: 1fr !important;
            }
            div[style*="height:220px"],
            div[style*="height:200px"] {
                height: 200px !important;
            }
        }
        @media (max-width: 400px) {
            div[style*="height:220px"],
            div[style*="height:200px"] {
                height: 170px !important;
            }
        }
    </style>
</AdminLayout>
