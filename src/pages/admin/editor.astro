                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            ><circle cx="12" cy="12" r="10"></circle><line
                                x1="22"
                                y1="12"
                                x2="18"
                                y2="12"></line><line
                                x1="6"
                                y1="12"
                                x2="2"
                                y2="12"></line><line
                                x1="12"
                                y1="6"
                                x2="12"
