    <style>
        /* ── Modern Premium Blocker ── */
        .vb-mobile-block {
            display: flex;
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: radial-gradient(circle at center, #111 0%, #000 100%);
            align-items: center;
            justify-content: center;
            padding: 2rem;
            overflow: hidden;
        }

        .vb-mobile-block-glass {
            position: absolute;
            inset: 0;
            background:
                radial-gradient(
                    circle at 20% 20%,
                    rgba(57, 255, 20, 0.03) 0%,
                    transparent 40%
                ),
                radial-gradient(
                    circle at 80% 80%,
                    rgba(57, 255, 20, 0.02) 0%,
                    transparent 40%
                );
            pointer-events: none;
        }

        .vb-mobile-block-content {
            position: relative;
            text-align: center;
            max-width: 440px;
            width: 100%;
            padding: 3rem 2rem;
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 24px;
            box-shadow:
                0 25px 50px -12px rgba(0, 0, 0, 0.5),
                0 0 40px rgba(57, 255, 20, 0.03);
            animation: vbAppear 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes vbAppear {
            from {
                opacity: 0;
                transform: translateY(20px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .vb-mobile-block-glow {
            position: absolute;
            top: -50px;
            left: 50%;
            transform: translateX(-50%);
            width: 200px;
            height: 100px;
            background: rgba(57, 255, 20, 0.1);
            filter: blur(60px);
            border-radius: 50%;
            pointer-events: none;
        }

        .vb-mobile-block-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(
                135deg,
                rgba(255, 255, 255, 0.05),
                rgba(255, 255, 255, 0.01)
            );
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            color: #39ff14;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            position: relative;
        }

        .vb-mobile-block-icon::after {
            content: "";
            position: absolute;
            inset: -1px;
            border-radius: 20px;
            padding: 1px;
            background: linear-gradient(
                135deg,
                rgba(57, 255, 20, 0.3),
                transparent
            );
            -webkit-mask:
                linear-gradient(#fff 0 0) content-box,
                linear-gradient(#fff 0 0);
            mask:
                linear-gradient(#fff 0 0) content-box,
                linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
        }

        .vb-mobile-block-title {
            font-family: "Oswald", system-ui, sans-serif;
            font-size: 1.75rem;
            font-weight: 700;
            color: #fff;
            margin: 0 0 1rem;
            letter-spacing: -0.02em;
            text-transform: uppercase;
        }

        .vb-mobile-block-divider {
            width: 40px;
            height: 2px;
            background: #39ff14;
            margin: 0 auto 1.5rem;
            border-radius: 1px;
            box-shadow: 0 0 10px rgba(57, 255, 20, 0.5);
        }

        .vb-mobile-block-msg {
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.8);
            line-height: 1.6;
            margin: 0 0 1rem;
        }

        .vb-mobile-block-hint {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.4);
            line-height: 1.5;
            margin: 0 0 2rem;
        }

        .vb-premium-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.85rem 1.75rem;
            background: #fff;
            color: #000;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.9rem;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }

        .vb-premium-btn:hover {
            transform: translateY(-3px);
            background: #39ff14;
            box-shadow: 0 15px 30px rgba(57, 255, 20, 0.2);
        }

        .vb-premium-btn i {
            width: 18px;
            height: 18px;
        }

        @media (min-width: 1024px) {
            .vb-mobile-block {
                display: none !important;
            }
        }

        /* Hide all editor content behind the blocker by default */
        .vb-toolbar,
        .vb-main,
        .vb-footer-bar,
        #vbAddBlockModal,
        #vbHistoryModal,
        #vbConfirmModal {
            display: none !important;
        }

        @media (min-width: 1024px) {
            .vb-toolbar,
            .vb-main {
                display: flex !important;
            }
        }

        /* ── Override admin-content for full-width editor ── */
        :global(.admin-content) {
            padding: 0 !important;
            display: flex;
            flex-direction: column;
            height: calc(100vh - 49px);
            overflow: hidden;
        }

        /* ── Toolbar ── */
        .vb-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.5rem 1rem;
            background: var(--ve2-bg-base, #0e0e0e);
            border-bottom: 1px solid
                var(--ve2-border-subtle, rgba(255, 255, 255, 0.04));
            gap: 0.5rem;
            flex-shrink: 0;
            z-index: 10;
        }
        .vb-toolbar-left,
        .vb-toolbar-center,
        .vb-toolbar-right {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Page tabs */
        .vb-page-tabs {
            display: flex;
            gap: 3px;
        }
        .vb-page-tab {
