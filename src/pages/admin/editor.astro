---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/admin";
import { supabaseAdmin } from "../../lib/supabase";
import SidebarSections from "../../components/editor/SidebarSections.astro";
import InspectorPanel from "../../components/editor/InspectorPanel.astro";
import "../../styles/editor-2026.css";

const admin = await requireAdmin(Astro);

const { data: allSections } = await supabaseAdmin
    .from("page_sections")
    .select("*")
    .order("page_name")
    .order("display_order", { ascending: true });

const sections = allSections || [];

let products: any[] = [];
{
    // Try with display_order first
    const { data: d1, error: e1 } = await supabaseAdmin
        .from("products")
        .select(
            "id, name, slug, image, price, compare_price, is_active, display_order, categories(name, slug)",
        )
        .eq("is_active", true)
        .order("display_order", { ascending: true })
        .order("created_at", { ascending: false });

    if (!e1 && d1) {
        products = d1;
    } else {
        // Fallback: display_order column might not exist yet
        const { data: d2 } = await supabaseAdmin
            .from("products")
            .select(
                "id, name, slug, image, price, compare_price, is_active, categories(name, slug)",
            )
            .eq("is_active", true)
            .order("created_at", { ascending: false });
        products = (d2 || []).map((p: any, i: number) => ({
            ...p,
            display_order: i,
        }));
    }
}
---

<AdminLayout title="Editor Visual" activeSection="editor" admin={admin}>
