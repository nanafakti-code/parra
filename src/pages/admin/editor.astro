                    + '<h2 data-sim-field="title_line1" style="font-family:\'Oswald\',sans-serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:700;text-transform:uppercase;letter-spacing:-0.02em;line-height:0.9;margin:0 0 0.15rem;color:' + esc(titleColor) + ';">' + esc(t1) + '</h2>'
                    + '<h2 data-sim-field="title_line2" style="font-family:\'Oswald\',sans-serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:700;text-transform:uppercase;letter-spacing:-0.02em;line-height:0.9;margin:0 0 2.5rem;color:' + esc(accentColor) + ';">' + esc(t2) + '</h2>'
                    + '<a data-sim-field="cta" class="sim-btn-primary">' + esc(ctaText) + '</a>'
                    + '</div></div>';
            }

            function renderNewsletter(c) {
                var btnText = c.button_text || 'Suscribirme';
                var titleColor = c.style_title_color || '#FFFFFF';
                var accentColor = c.style_btn_bg || '#39FF14';
                var subtitleColor = c.style_subtitle_color || 'rgba(255,255,255,0.5)';
                var inputBg = c.style_input_bg || '#111827';
                var inputBorder = c.style_input_border || '#1F2937';
                var inputText = c.style_input_text || '#FFFFFF';
                var btnBg = c.style_btn_bg || '#39FF14';
                var btnTextColor = c.style_btn_text || '#000';
                var sectionBg = c.style_section_bg || 'transparent';

                return '<div style="padding:5rem 2rem;background:' + esc(sectionBg) + ';">'
                    + '<div style="max-width:520px;margin:0 auto;text-align:center;">'
                    + '<div style="display:inline-block;padding:4px 16px;border:1px solid ' + esc(accentColor) + ';font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.3em;color:' + esc(accentColor) + ';opacity:0.8;margin-bottom:1.25rem;">Exclusivo</div>'
                    + '<h2 data-sim-field="title" style="font-family:\'Oswald\',sans-serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:700;text-transform:uppercase;letter-spacing:-0.02em;margin:0 0 1rem;color:' + esc(titleColor) + ';">Únete al <span style="color:' + esc(accentColor) + ';">Club</span></h2>'
                    + '<p data-sim-field="subtitle" style="font-size:0.88rem;color:' + esc(subtitleColor) + ';line-height:1.6;margin:0 0 2rem;max-width:380px;margin-left:auto;margin-right:auto;">Recibe ofertas exclusivas, novedades y un <strong style="color:' + esc(accentColor) + ';">10% de descuento</strong> en tu primera compra.</p>'
                    + '<div style="display:flex;gap:0.75rem;max-width:420px;margin:0 auto;">'
                    + '<input type="email" placeholder="Tu email..." style="flex:1;background:' + esc(inputBg) + ';border:1px solid ' + esc(inputBorder) + ';color:' + esc(inputText) + ';padding:0.85rem 1.1rem;font-size:0.85rem;outline:none;" disabled>'
                    + '<button data-sim-field="button" style="background:' + esc(btnBg) + ';color:' + esc(btnTextColor) + ';border:none;padding:0.85rem 1.6rem;font-family:\'Oswald\',sans-serif;font-weight:700;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.1em;cursor:pointer;white-space:nowrap;">' + esc(btnText) + '</button>'
                    + '</div>'
                    + '<p style="font-size:0.72rem;margin-top:1rem;color:rgba(255,255,255,0.3);letter-spacing:0.05em;">Sin spam. Cancela cuando quieras.</p>'
                    + '</div></div>';
            }

            function renderBanner(c) {
                var text = c.text || 'Banner de información';
                var bgColor = c.bg_color || '#39FF14';
                var textColor = c.text_color || '#000';
                return '<div data-sim-field="text" style="background:' + esc(bgColor) + ';color:' + esc(textColor) + ';text-align:center;padding:0.55rem 1rem;font-family:\'Inter\',sans-serif;font-size:0.75rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;">' 
                    + esc(text)
                    + '</div>';
            }

            function renderGeneric(key, c, sec) {
                return '<div style="padding:2rem;background:#111;border-top:1px solid #1F2937;display:flex;align-items:center;gap:1rem;opacity:0.7;">'
                    + '<div style="width:40px;height:40px;background:rgba(57,255,20,0.08);border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">'
                    + '<svg width="18" height="18" fill="none" stroke="#39FF14" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>'
                    + '</div>'
                    + '<div><p style="font-size:0.8rem;font-weight:600;color:#fff;margin:0;">' + esc(sec ? (sec.display_name || key) : key) + '</p>'
                    + '<p style="font-size:0.68rem;color:#555;margin:0;font-family:monospace;">' + esc(key) + '</p></div>'
                    + '</div>';
            }

            // ═══════ ADD BLOCK MODAL ═══════
            $("#vbAddBlock")?.addEventListener("click", function () {
                var modal = $("#vbAddBlockModal");
                if (modal) modal.style.display = "flex";
            });

            $("#vbAddBlockClose")?.addEventListener("click", function () {
                $("#vbAddBlockModal").style.display = "none";
            });

            $("#vbAddBlockModal")?.addEventListener("click", function (e) {
                if (e.target === this) this.style.display = "none";
            });

            // Handle block type selection
            function buildDefaultContent(schemaKey) {
                var schema = SCHEMAS[schemaKey];
                if (!schema) return {};
                var content = {};
                schema.forEach(function (field) {
                    if (field.type === "text") {
                        content[field.key] = "";
                    } else if (field.type === "textarea") {
                        content[field.key] = "";
                    } else if (field.type === "color") {
                        content[field.key] = "#000000";
                    } else if (field.type === "range") {
                        content[field.key] =
                            field.min !== undefined && field.max !== undefined
                                ? (field.min + field.max) / 2
                                : 0.5;
                    } else if (field.type === "image") {
                        content[field.key] = "";
                    } else if (field.type === "tags") {
                        content[field.key] = [];
                    } else if (field.type === "repeater" && field.fields) {
                        // Generate one empty item
                        var emptyItem = {};
                        field.fields.forEach(function (f) {
                            emptyItem[f.key] = "";
                        });
                        content[field.key] = [emptyItem];
                    } else {
                        content[field.key] = "";
                    }
                });
                return content;
            }

            document
                .querySelectorAll("#vbBlockGrid .vb-block-option")
                .forEach(function (btn) {
                    btn.addEventListener("click", async function () {
                        var key = this.dataset.blockKey;
                        var label = this.dataset.blockLabel;
                        if (!key || !label) return;

                        // Generate unique key if already exists
                        var existingKeys = allSections
                            .filter(function (s) {
                                return s.page_name === currentPage;
                            })
                            .map(function (s) {
                                return s.section_key;
                            });
                        var finalKey = key;
                        var counter = 2;
                        while (existingKeys.indexOf(finalKey) >= 0) {
                            finalKey = key + "_" + counter;
                            counter++;
                        }
                        var finalLabel = label;
                        if (finalKey !== key) {
                            finalLabel = label + " " + (counter - 1);
                        }

                        // Build default content from schema
                        var defaultContent = buildDefaultContent(key);

                        // Close modal immediately
                        $("#vbAddBlockModal").style.display = "none";

                        try {
                            var res = await fetch("/api/admin/sections", {
                                method: "POST",
                                headers: { "Content-Type": "application/json" },
                                body: JSON.stringify({
                                    action: "create",
                                    page_name: currentPage,
                                    section_key: finalKey,
                                    label: finalLabel,
                                    content: defaultContent,
                                }),
                            });
                            var data = await res.json();
                            if (res.ok && data.section) {
                                allSections.push(data.section);
                                render();
                                selectSection(data.section.id);
                                refreshPreview();
                                window.adminToast?.(
                                    'Bloque "' + finalLabel + '" creado',
                                    "success",
                                );
                            } else {
                                window.adminToast?.(
                                    data.error || "Error al crear bloque",
                                    "error",
                                );
                            }
                        } catch (e) {
                            window.adminToast?.("Error de conexión", "error");
                        }
                    });
                });

            // ═══════ INIT ═══════
            render();
            refreshPreview();

            // ═══════ PRODUCT ORDER SYSTEM ═══════
            function escHtml(str) {
                if (str == null) return "";
                return String(str)
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;");
            }

            function renderProductOrder() {
                var list = $("#vbProductList");
                var countEl = $("#vbProductCount");
                if (!list) return;
                if (countEl) countEl.textContent = allProducts.length;

                if (allProducts.length === 0) {
                    list.innerHTML =
                        '<div style="text-align:center;padding:2rem;color:rgba(255,255,255,0.2);font-size:0.75rem;">No hay productos activos</div>';
                    return;
                }

                var html = "";
                allProducts.forEach(function (p, i) {
                    var catName =
                        p.categories && p.categories.name
                            ? p.categories.name
                            : "";
                    var priceHtml = "€" + parseFloat(p.price).toFixed(2);
                    if (
                        p.compare_price &&
                        parseFloat(p.compare_price) > parseFloat(p.price)
                    ) {
                        priceHtml +=
                            ' <span class="old">€' +
                            parseFloat(p.compare_price).toFixed(2) +
                            "</span>";
                    }
                    html +=
                        '<div class="vb-po-item" data-product-id="' +
                        p.id +
                        '" draggable="true">' +
                        '<div class="vb-po-item-grip">' +
                        '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="5" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="19" r="1"/></svg>' +
                        "</div>" +
                        '<div class="vb-po-item-num">' +
                        (i + 1) +
                        "</div>" +
                        '<div class="vb-po-item-img">' +
                        '<img src="' +
                        escHtml(p.image) +
                        '" alt="' +
                        escHtml(p.name) +
                        '" onerror="this.style.display=\'none\'" />' +
                        "</div>" +
                        '<div class="vb-po-item-info">' +
                        '<div class="vb-po-item-name">' +
                        escHtml(p.name) +
                        "</div>" +
                        '<div class="vb-po-item-price">' +
                        priceHtml +
                        "</div>" +
                        (catName
                            ? '<div class="vb-po-item-cat">' +
                              escHtml(catName) +
                              "</div>"
                            : "") +
                        "</div>" +
                        "</div>";
                });
                list.innerHTML = html;
                bindProductDragDrop();
            }

            var _dragProductId = null;

            function bindProductDragDrop() {
                var list = $("#vbProductList");
                if (!list) return;
                list.querySelectorAll(".vb-po-item").forEach(function (el) {
                    el.addEventListener("dragstart", function (e) {
                        _dragProductId = this.dataset.productId;
                        this.classList.add("dragging");
                        e.dataTransfer.effectAllowed = "move";
                        e.dataTransfer.setData(
                            "text/plain",
                            this.dataset.productId,
                        );
                    });
                    el.addEventListener("dragend", function () {
                        this.classList.remove("dragging");
                        list.querySelectorAll(".vb-po-item").forEach(
                            function (b) {
                                b.classList.remove("drag-over");
                            },
                        );
                    });
                    el.addEventListener("dragover", function (e) {
                        e.preventDefault();
                        e.dataTransfer.dropEffect = "move";
                        list.querySelectorAll(".vb-po-item").forEach(
                            function (b) {
                                b.classList.remove("drag-over");
                            },
                        );
                        if (this.dataset.productId !== _dragProductId)
                            this.classList.add("drag-over");
                    });
                    el.addEventListener("dragleave", function () {
                        this.classList.remove("drag-over");
                    });
                    el.addEventListener("drop", function (e) {
                        e.preventDefault();
                        this.classList.remove("drag-over");
                        var dropId = this.dataset.productId;
                        if (_dragProductId && _dragProductId !== dropId) {
                            // Reorder in array
                            var fromIdx = allProducts.findIndex(function (p) {
                                return p.id === _dragProductId;
                            });
                            var toIdx = allProducts.findIndex(function (p) {
                                return p.id === dropId;
                            });
                            if (fromIdx >= 0 && toIdx >= 0) {
                                var moved = allProducts.splice(fromIdx, 1)[0];
                                allProducts.splice(toIdx, 0, moved);
                                productOrderChanged = true;
                                renderProductOrder();
                                // Update save button state
                                var saveBtn = $("#vbSaveProductOrder");
                                if (saveBtn)
                                    saveBtn.classList.add("has-changes");
                            }
                        }
                        _dragProductId = null;
                    });
                });
            }

            // Save product order
            $("#vbSaveProductOrder")?.addEventListener(
                "click",
                async function () {
                    if (!productOrderChanged) {
                        window.adminToast?.(
                            "No hay cambios en el orden",
                            "success",
                        );
                        return;
                    }
                    var btn = this;
                    btn.disabled = true;
                    btn.innerHTML =
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Guardando...';

                    var orders = allProducts.map(function (p, i) {
                        p.display_order = i;
                        return { id: p.id, display_order: i };
                    });

                    try {
                        var res = await fetch("/api/admin/products", {
                            method: "PUT",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ orders: orders }),
                        });
                        if (res.ok) {
                            productOrderChanged = false;
                            btn.classList.remove("has-changes");
                            window.adminToast?.(
                                "Orden de productos guardado",
                                "success",
                            );
                            refreshPreview();
                        } else {
                            var data = await res.json();
                            window.adminToast?.(
                                data.error || "Error al guardar orden",
                                "error",
                            );
                        }
                    } catch (e) {
                        window.adminToast?.("Error de conexión", "error");
                    } finally {
                        btn.disabled = false;
                        btn.innerHTML =
                            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Guardar orden';
                    }
                },
            );
        })();
    </script>
</AdminLayout>
