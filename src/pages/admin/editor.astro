                    <div class="vb-bo-icon">
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            ><path
                                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                            ></path><polyline points="22,6 12,13 2,6"
                            ></polyline></svg
                        >
                    </div>
                    <div class="vb-bo-info">
                        <span class="vb-bo-name">Newsletter</span><span
                            class="vb-bo-desc">Formulario de suscripción</span
                        >
                    </div>
                </button>
                <button
                    class="vb-block-option"
