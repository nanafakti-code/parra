                    + '<span style="display:inline-block;border:1px solid ' + esc(badgeText) + ';color:' + esc(badgeText) + ';background:' + esc(badgeBg) + ';font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;padding:5px 14px;border-radius:2px;margin-bottom:1.5rem;">' + esc(badge) + '</span>'
                    + '<h1 style="font-size:clamp(2.4rem,5vw,4rem);font-weight:900;line-height:1;margin:0 0 0.2rem;letter-spacing:-0.02em;text-transform:uppercase;color:' + esc(c1) + ';">' + esc(t1) + '</h1>'
                    + '<h1 style="font-size:clamp(2.4rem,5vw,4rem);font-weight:900;line-height:1;margin:0 0 1.2rem;letter-spacing:-0.02em;text-transform:uppercase;color:' + esc(c2) + ';">' + esc(t2) + '</h1>'
