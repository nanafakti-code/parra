                            class="vb-bo-desc"
                            >Texto con color de fondo personalizable</span
                        >
                    </div>
                </button>
            </div>
        </div>
    </div>

    <!-- ═══════ HISTORY MODAL ═══════ -->
    <div class="modal-overlay" id="vbHistoryModal" style="display:none;">
        <div class="modal" style="max-width:560px;">
            <div class="modal-header">
                <span class="modal-title">Historial de Cambios</span>
                <button class="modal-close" id="vbHistoryClose">
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><line x1="18" y1="6" x2="6" y2="18"></line><line
                            x1="6"
                            y1="6"
                            x2="18"
                            y2="18"></line></svg
                    >
                </button>
            </div>
            <div id="vbHistoryContent">
                <div class="empty-state">
                    <p>Selecciona una sección para ver su historial</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════ CONFIRM MODAL ═══════ -->
    <div class="modal-overlay" id="vbConfirmModal" style="display:none;">
        <div class="modal vb-confirm-modal" style="max-width:400px;">
            <div class="vb-confirm-icon">
                <svg
                    width="28"
                    height="28"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    ><circle cx="12" cy="12" r="10"></circle><line
                        x1="12"
                        y1="8"
                        x2="12"
                        y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"
                    ></line></svg
                >
            </div>
            <h3 class="vb-confirm-title" id="vbConfirmTitle">¿Estás seguro?</h3>
            <p class="vb-confirm-msg" id="vbConfirmMsg">
                Esta acción no se puede deshacer.
            </p>
            <div class="vb-confirm-actions">
                <button class="ve2-btn ve2-btn-ghost" id="vbConfirmCancel"
                    >Cancelar</button
                >
                <button class="ve2-btn vb-confirm-ok" id="vbConfirmOk"
                    >Confirmar</button
                >
            </div>
        </div>
