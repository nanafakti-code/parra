        }}
    >
        (function () {
            "use strict";

            // ═══════ STATE ═══════
            var allSections = [];
            try {
                allSections = JSON.parse(sectionsData);
            } catch (e) {
                console.error("Parse error:", e);
            }
            var allProducts = [];
            try {
                allProducts = JSON.parse(productsData);
            } catch (e) {
                console.error("Products parse error:", e);
            }
            var currentPage = "home";
            var selectedId = null;
            var unsavedIds = new Set();
