            // ═══════ CUSTOM CONFIRM ═══════
            function vbConfirm(title, msg, okText) {
                return new Promise(function (resolve) {
                    var modal = $("#vbConfirmModal");
                    var titleEl = $("#vbConfirmTitle");
                    var msgEl = $("#vbConfirmMsg");
                    var okBtn = $("#vbConfirmOk");
                    var cancelBtn = $("#vbConfirmCancel");
                    if (!modal) return resolve(false);

                    titleEl.textContent = title || "¿Estás seguro?";
                    msgEl.textContent =
                        msg || "Esta acción no se puede deshacer.";
                    okBtn.textContent = okText || "Confirmar";
                    modal.style.display = "flex";

                    function cleanup() {
                        modal.style.display = "none";
                        okBtn.removeEventListener("click", onOk);
                        cancelBtn.removeEventListener("click", onCancel);
                        modal.removeEventListener("click", onOverlay);
                    }
                    function onOk() {
                        cleanup();
                        resolve(true);
                    }
                    function onCancel() {
                        cleanup();
                        resolve(false);
                    }
                    function onOverlay(e) {
                        if (e.target === modal) {
                            cleanup();
                            resolve(false);
                        }
                    }

                    okBtn.addEventListener("click", onOk);
                    cancelBtn.addEventListener("click", onCancel);
                    modal.addEventListener("click", onOverlay);
                });
