            // ═══════ HELPERS ═══════
            function $(sel) {
                return document.querySelector(sel);
            }
            function pageSections() {
                return allSections
                    .filter(function (s) {
                        return s.page_name === currentPage;
                    })
                    .sort(function (a, b) {
                        return a.display_order - b.display_order;
                    });
            }
            function findSection(id) {
                return allSections.find(function (s) {
                    return s.id == id; // loose equality handles string/number mismatch
                });
            }
            function esc(str) {
                if (str == null) return "";
                return String(str)
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;");
            }

            // ═══════ RENDER ═══════
            function render() {
                if (window.VBSidebar) {
                    window.VBSidebar.render(
                        pageSections(),
                        selectedId,
                        unsavedIds,
                    );
                }
            }

            function selectSection(id) {
                selectedId = id;
                render();
                var section = findSection(id);
                if (section && window.VBInspector) {
                    // Resolve base schema key (hero_2 -> hero, cta_banner_3 -> cta_banner)
                    var schemaKey = section.section_key;
                    if (!SCHEMAS[schemaKey]) {
                        // Strip _N suffix to find base key
                        var baseKey = schemaKey.replace(/_\d+$/, "");
                        if (SCHEMAS[baseKey]) schemaKey = baseKey;
                    }
                    var schema = SCHEMAS[schemaKey] || [];
                    var styleSchema = STYLE_SCHEMAS[schemaKey] || [];
                    window.VBInspector.show(section, schema, styleSchema);
                }
                highlightSim(id);
            }

            function deselectSection() {
                selectedId = null;
                render();
                if (window.VBInspector) window.VBInspector.hide();
                highlightSim(null);
            }

            // Expose for onclick inline handlers inside innerHTML
            window._vbSelectSec = function(id) { selectSection(id); };
            window._vbSelectSecField = function(id, fieldName) {
                selectedId = id;
                render();
                var section = findSection(id);
                if (!section || !window.VBInspector) { highlightSim(id); return; }
                var schemaKey = section.section_key;
                if (!SCHEMAS[schemaKey]) {
                    var bk = schemaKey.replace(/_\d+$/, '');
                    if (SCHEMAS[bk]) schemaKey = bk;
                }
                var allC = SCHEMAS[schemaKey] || [];
                var allS = STYLE_SCHEMAS[schemaKey] || [];
                var fd = SIM_FIELD_MAP[schemaKey] && SIM_FIELD_MAP[schemaKey][fieldName];
                var fc = fd ? allC.filter(function(f){ return fd.c.indexOf(f.key) !== -1; }) : allC;
                var fs = fd ? allS.filter(function(f){ return fd.s.indexOf(f.key) !== -1; }) : allS;
                if (fc.length === 0 && fs.length === 0) { fc = allC; fs = allS; }
                window.VBInspector.show(section, fc, fs);
                highlightSim(id);
            };

            // ═══════ EVENTS FROM COMPONENTS ═══════
            document.addEventListener("vb:select", function (e) {
                selectSection(e.detail.id);
            });

            // Click on simulated preview to select section
            document.addEventListener("click", function(e) {
                var wrap = e.target.closest('#vbSimContent .sim-sec-wrap');
                if (wrap) {
                    var secId = wrap.getAttribute('data-sec-id');
                    if (!secId) return;
                    var fieldEl = e.target.closest('[data-sim-field]');
                    if (fieldEl && wrap.contains(fieldEl)) {
                        window._vbSelectSecField(secId, fieldEl.getAttribute('data-sim-field'));
                    } else {
                        window._vbSelectSec(secId);
                    }
                }
            });
            document.addEventListener("vb:toggle", function (e) {
                toggleSectionActive(e.detail.id);
            });
            document.addEventListener("vb:reorder", function (e) {
                reorderSections(e.detail.from, e.detail.to);
            });
            document.addEventListener("vb:unsaved", function (e) {
                unsavedIds.add(e.detail.id);
                render();
                updatePublishBtn();
            });

            // ═══════ PUBLISH BUTTON STATE ═══════
            function updatePublishBtn() {
                var btn = $("#vbBtnSaveAll");
                if (btn)
                    btn.classList.toggle("has-changes", unsavedIds.size > 0);
            }

            // ═══════ API CALLS ═══════
            async function fetchSections() {
                try {
                    var res = await fetch("/api/admin/sections");
                    var data = await res.json();
                    if (data.pages) {
                        allSections = [];
                        Object.values(data.pages).forEach(function (arr) {
                            allSections = allSections.concat(arr);
                        });
                    }
                } catch (e) {
                    console.error("Error loading sections", e);
                }
            }

            async function saveSection(id) {
                var content = window.VBInspector
                    ? window.VBInspector.collectData()
                    : null;
                if (!content) return;

                var btn = $("#vbBtnSave");
                if (btn) {
                    btn.disabled = true;
                    btn.innerHTML =
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Guardando...';
                }

                try {
                    var res = await fetch("/api/admin/sections", {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ id: id, content: content }),
                    });
                    var data = await res.json();
                    if (res.ok) {
                        var sec = findSection(id);
                        if (sec) sec.content = content;
                        unsavedIds.delete(id);
                        render();
                        updatePublishBtn();
                        window.adminToast?.(
                            "Sección guardada correctamente",
                            "success",
                        );
                        refreshPreview();
                    } else {
                        window.adminToast?.(
                            data.error || "Error al guardar",
                            "error",
                        );
                    }
                } catch (e) {
                    window.adminToast?.("Error de conexión", "error");
                } finally {
                    if (btn) {
                        btn.disabled = false;
                        btn.innerHTML =
                            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Publicar cambios';
                    }
                }
            }

            async function saveAllSections() {
                if (unsavedIds.size === 0) {
                    window.adminToast?.("No hay cambios pendientes", "success");
                    return;
                }
                if (selectedId && unsavedIds.has(selectedId)) {
                    await saveSection(selectedId);
                }
                window.adminToast?.("Todos los cambios guardados", "success");
            }

            async function toggleSectionActive(id) {
                var section = findSection(id);
                if (!section) return;
                var newState = !section.is_active;
                try {
                    var res = await fetch("/api/admin/sections", {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ id: id, is_active: newState }),
                    });
                    if (res.ok) {
                        section.is_active = newState;
                        render();
                        if (selectedId === id && window.VBInspector) {
                            var schemaKey2 = section.section_key;
                            if (!SCHEMAS[schemaKey2]) {
                                var baseKey2 = schemaKey2.replace(/_\d+$/, "");
                                if (SCHEMAS[baseKey2]) schemaKey2 = baseKey2;
                            }
                            var schema = SCHEMAS[schemaKey2] || [];
                            var styleSchema = STYLE_SCHEMAS[schemaKey2] || [];
                            window.VBInspector.show(
                                section,
                                schema,
                                styleSchema,
                            );
                        }
                        window.adminToast?.(
                            newState
                                ? "Sección activada"
                                : "Sección desactivada",
                            "success",
                        );
                        refreshPreview();
                    }
                } catch (e) {
                    window.adminToast?.("Error al cambiar estado", "error");
                }
            }

            async function duplicateSection(id) {
                try {
                    var res = await fetch("/api/admin/sections", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ action: "duplicate", id: id }),
                    });
                    var data = await res.json();
                    if (res.ok && data.section) {
                        allSections.push(data.section);
                        render();
                        window.adminToast?.("Sección duplicada", "success");
                    } else {
                        window.adminToast?.(
                            data.error || "Error al duplicar",
                            "error",
                        );
                    }
                } catch (e) {
                    window.adminToast?.("Error de conexión", "error");
                }
            }

            async function resetSection(id) {
                try {
                    var res = await fetch("/api/admin/sections", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ action: "reset", id: id }),
                    });
                    var data = await res.json();
                    if (res.ok) {
                        await fetchSections();
                        render();
                        if (selectedId === id) selectSection(id);
                        window.adminToast?.("Sección restaurada", "success");
                        refreshPreview();
                    } else {
                        window.adminToast?.(
                            data.error || "Sin historial disponible",
                            "error",
                        );
                    }
                } catch (e) {
                    window.adminToast?.("Error de conexión", "error");
                }
            }

            async function deleteSection(id) {
                try {
                    var res = await fetch("/api/admin/sections?id=" + id, {
                        method: "DELETE",
                    });
                    if (res.ok) {
                        allSections = allSections.filter(function (s) {
                            return s.id !== id;
                        });
                        unsavedIds.delete(id);
                        if (selectedId === id) deselectSection();
                        render();
                        updatePublishBtn();
                        window.adminToast?.("Sección eliminada", "success");
                        refreshPreview();
                    }
                } catch (e) {
                    window.adminToast?.("Error de conexión", "error");
                }
            }

            async function reorderSections(fromId, toId) {
                var items = pageSections();
                var fromIdx = items.findIndex(function (s) {
                    return s.id === fromId;
                });
                var toIdx = items.findIndex(function (s) {
                    return s.id === toId;
                });
                if (fromIdx < 0 || toIdx < 0) return;
                // El Hero siempre permanece en la primera posición
                if (items[fromIdx].section_key === 'hero') return;
                if (toIdx === 0 && items[0] && items[0].section_key === 'hero') return;
                var moved = items.splice(fromIdx, 1)[0];
                items.splice(toIdx, 0, moved);
                var orders = items.map(function (s, i) {
                    s.display_order = i;
                    return { id: s.id, display_order: i };
                });
                render();
                try {
                    await fetch("/api/admin/sections", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            action: "reorder",
                            orders: orders,
                        }),
                    });
                    window.adminToast?.("Orden actualizado", "success");
                    refreshPreview();
                } catch (e) {
                    window.adminToast?.("Error al reordenar", "error");
                }
            }

            // ═══════ INSPECTOR BUTTONS ═══════
            document.addEventListener("click", function (e) {
                if (e.target.closest("#vbBtnSave")) {
                    if (selectedId) saveSection(selectedId);
                }
                if (e.target.closest("#vbBtnDuplicate")) {
                    if (selectedId) duplicateSection(selectedId);
                }
                if (e.target.closest("#vbBtnReset")) {
                    if (selectedId) {
                        vbConfirm(
                            "¿Restaurar sección?",
                            "Se restaurará esta sección a su estado original. Los cambios actuales se perderán.",
                            "Restaurar",
                        ).then(function (ok) {
                            if (ok) resetSection(selectedId);
                        });
                    }
                }
                if (e.target.closest("#vbBtnDelete")) {
                    if (selectedId) {
                        var sec = findSection(selectedId);
                        var secLabel = sec ? sec.label : "esta sección";
                        vbConfirm(
                            "¿Eliminar bloque?",
                            'Se eliminará "' +
                                secLabel +
                                '" permanentemente. Esta acción no se puede deshacer.',
                            "Eliminar",
                        ).then(function (ok) {
                            if (ok) deleteSection(selectedId);
                        });
                    }
                }
            });

            // ═══════ VIEWPORT SWITCHER ═══════
            document
                .querySelectorAll("#vbViewport .vb-vp-btn")
                .forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        document
                            .querySelectorAll("#vbViewport .vb-vp-btn")
                            .forEach(function (b) {
                                b.classList.remove("active");
                            });
                        this.classList.add("active");
                        var wrapper = $("#vbPreviewWrapper");
                        wrapper.className = "vb-preview-wrapper";
                        if (this.dataset.vp === "tablet")
                            wrapper.classList.add("vp-tablet");
                        else if (this.dataset.vp === "mobile")
                            wrapper.classList.add("vp-mobile");
                    });
                });

            // ═══════ PAGE TABS ═══════
            document
                .querySelectorAll("#vbPageTabs .vb-page-tab")
                .forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        document
                            .querySelectorAll("#vbPageTabs .vb-page-tab")
                            .forEach(function (b) {
                                b.classList.remove("active");
                            });
                        this.classList.add("active");
                        currentPage = this.dataset.page;
                        deselectSection();
                        refreshPreview();
                        // Toggle product order panel
                        var poPanel = $("#vbProductOrder");
                        var sbPanel = $("#vbSidebar");
                        if (currentPage === "shop") {
                            if (poPanel) poPanel.style.display = "flex";
                            if (sbPanel) sbPanel.style.display = "none";
                            renderProductOrder();
                        } else {
                            if (poPanel) poPanel.style.display = "none";
                            if (sbPanel) sbPanel.style.display = "";
                        }
                    });
                });

            // ═══════ EDIT MODE TOGGLE ═══════
            document
                .querySelectorAll(".vb-edit-mode-btn")
                .forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        document
                            .querySelectorAll(".vb-edit-mode-btn")
                            .forEach(function (b) {
                                b.classList.remove("active");
                            });
                        this.classList.add("active");
                    });
                });

            // ═══════ HISTORY ═══════
            $("#vbBtnHistory")?.addEventListener("click", async function () {
                var modal = $("#vbHistoryModal");
                modal.style.display = "flex";
                var content = $("#vbHistoryContent");
                if (!selectedId) {
                    content.innerHTML =
                        '<div class="empty-state"><p>Selecciona una sección para ver su historial</p></div>';
                    return;
                }
                content.innerHTML =
                    '<div style="text-align:center;padding:2rem;color:rgba(255,255,255,0.3);">Cargando...</div>';
                try {
                    var res = await fetch("/api/admin/sections", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            action: "history",
                            id: selectedId,
                        }),
                    });
                    var data = await res.json();
                    var history = data.history || [];
                    if (history.length === 0) {
                        content.innerHTML =
                            '<div class="empty-state"><p>Sin historial para esta sección</p></div>';
                        return;
                    }
                    var html = '<div class="vb-history-list">';
                    history.forEach(function (entry) {
                        var date = new Date(entry.changed_at);
                        var dateStr =
                            date.toLocaleDateString("es-ES") +
                            " " +
                            date.toLocaleTimeString("es-ES", {
                                hour: "2-digit",
                                minute: "2-digit",
                            });
                        html +=
                            '<div class="vb-history-item"><div><div class="vb-history-date">' +
                            dateStr +
                            '</div><div class="vb-history-key">' +
                            esc(entry.section_key) +
                            "</div></div>";
                        html +=
                            '<button class="ve2-btn ve2-btn-ghost ve2-btn-sm" data-restore-history="' +
                            entry.id +
                            "\" data-content='" +
                            JSON.stringify(entry.content).replace(
                                /'/g,
                                "&#39;",
                            ) +
                            "'>Restaurar</button></div>";
                    });
                    html += "</div>";
                    content.innerHTML = html;
                    content
                        .querySelectorAll("[data-restore-history]")
                        .forEach(function (btn) {
                            btn.addEventListener("click", async function () {
                                var histContent = JSON.parse(
                                    this.dataset.content,
                                );
                                try {
                                    await fetch("/api/admin/sections", {
                                        method: "PATCH",
                                        headers: {
                                            "Content-Type": "application/json",
                                        },
                                        body: JSON.stringify({
                                            id: selectedId,
                                            content: histContent,
                                        }),
                                    });
                                    var sec = findSection(selectedId);
                                    if (sec) sec.content = histContent;
                                    selectSection(selectedId);
                                    unsavedIds.delete(selectedId);
                                    render();
                                    updatePublishBtn();
                                    modal.style.display = "none";
                                    window.adminToast?.(
                                        "Versión restaurada",
                                        "success",
                                    );
                                    refreshPreview();
                                } catch (e) {
                                    window.adminToast?.(
                                        "Error al restaurar",
                                        "error",
                                    );
                                }
                            });
                        });
                } catch (e) {
                    content.innerHTML =
                        '<div class="empty-state"><p>Error al cargar historial</p></div>';
                }
            });

            $("#vbHistoryClose")?.addEventListener("click", function () {
                $("#vbHistoryModal").style.display = "none";
            });
            $("#vbHistoryModal")?.addEventListener("click", function (e) {
                if (e.target === this) this.style.display = "none";
            });

            // ═══════ SAVE ALL ═══════
            $("#vbBtnSaveAll")?.addEventListener("click", function () {
                saveAllSections();
            });

            // ═══════ KEYBOARD SHORTCUTS ═══════
            document.addEventListener("keydown", function (e) {
                if ((e.ctrlKey || e.metaKey) && e.key === "s") {
                    e.preventDefault();
                    if (selectedId) saveSection(selectedId);
                }
            });

            // ═══════ SIMULATED PREVIEW ═══════
            function refreshPreview() {
                var container = $("#vbSimContent");
                if (!container) return;

                var sections = pageSections().filter(function(s){ return s.is_active; });
                var isShop = currentPage === 'shop';

                var html = getSimStyles();
                html += '<div class="sim-wrap">';



                // Simulated navbar
                html += renderNavbar(isShop);

                // Render page sections
                sections.forEach(function(sec) {
                    var c = sec.content || {};
                    var key = sec.section_key || '';
                    var baseKey = key.replace(/_\d+$/, '');
                    var label = sec.label || key;
                    html += '<div class="sim-sec-wrap" data-sec-id="' + sec.id + '" onclick="window._vbSelectSec(\'' + sec.id + '\')" title="Clic para editar: ' + label + '">'
                        + '<div class="sim-sec-label">&#9998; ' + label + '</div>'
                        + renderSection(baseKey, c, sec)
                        + '</div>';
                });

                // For shop page: always render the product grid simulation
                if (isShop) {
                    html += renderShopGrid();
                } else if (sections.length === 0) {
                    html += '<div style="display:flex;align-items:center;justify-content:center;height:300px;flex-direction:column;gap:1rem;color:rgba(255,255,255,0.3);">'
                        + '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>'
                        + '<p style="font-family:\'Inter\',sans-serif;font-size:0.85rem;margin:0;">No hay bloques activos</p>'
                        + '</div>';
                }

                html += '</div>';
                container.innerHTML = html;
                highlightSim(selectedId);
            }

            function highlightSim(id) {
                var wraps = document.querySelectorAll('#vbSimContent .sim-sec-wrap');
                wraps.forEach(function(el) { el.classList.remove('sim-sec-selected'); });
                if (id) {
                    var el = document.querySelector('#vbSimContent [data-sec-id="' + id + '"]');
                    if (el) el.classList.add('sim-sec-selected');
                }
            }

            function renderNavbar(isShop) {
                var links = ['Inicio','Tienda','Elite','Entrenamiento','Infantil'];
                var linksHtml = links.map(function(l) {
                    var active = (l === 'Tienda' && isShop) || (l === 'Inicio' && !isShop);
                    return '<a style="font-family:\'Inter\',sans-serif;font-size:0.78rem;font-weight:500;text-transform:uppercase;letter-spacing:0.12em;color:' + (active ? '#39FF14' : 'rgba(255,255,255,0.7)') + ';text-decoration:none;padding:4px 0;">' + l + '</a>';
                }).join('');
                return '<header style="position:sticky;top:27px;z-index:998;background:rgba(0,0,0,0.92);backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,0.05);">'
                    + '<div style="max-width:1200px;margin:0 auto;padding:0 2rem;height:60px;display:flex;align-items:center;justify-content:space-between;">'
                    + '<span style="font-family:\'Oswald\',sans-serif;font-size:1.5rem;font-weight:700;color:#39FF14;letter-spacing:0.05em;">PARRA</span>'
                    + '<nav style="display:flex;align-items:center;gap:1.5rem;">' + linksHtml + '</nav>'
                    + '<div style="display:flex;align-items:center;gap:1rem;">'
                    + '<svg width="18" height="18" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>'
                    + '<svg width="18" height="18" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>'
                    + '<svg width="18" height="18" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>'
                    + '</div></div></header>';
            }

            function renderShopGrid() {
                var prods = allProducts.slice(0, 12);
                var html = '<div style="padding:2.5rem 2rem;background:#0a0a0a;">';

                // Shop header
                html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;padding-bottom:1.25rem;border-bottom:1px solid #1F2937;">'
                    + '<div>'
                    + '<h1 style="font-family:\'Oswald\',sans-serif;font-size:1.8rem;font-weight:700;text-transform:uppercase;letter-spacing:-0.02em;color:#fff;margin:0 0 0.15rem;">Tienda</h1>'
                    + '<p style="font-size:0.72rem;color:rgba(255,255,255,0.3);margin:0;">' + prods.length + ' productos</p>'
                    + '</div>'
                    + '<div style="display:flex;gap:0.5rem;">'
                    + '<div style="background:#111827;border:1px solid #1F2937;padding:0.4rem 0.9rem;font-size:0.7rem;font-weight:600;color:rgba(255,255,255,0.5);letter-spacing:0.05em;cursor:pointer;">FILTROS</div>'
                    + '<div style="background:#111827;border:1px solid #1F2937;padding:0.4rem 0.9rem;font-size:0.7rem;font-weight:600;color:rgba(255,255,255,0.5);letter-spacing:0.05em;cursor:pointer;">ORDENAR</div>'
                    + '</div>'
                    + '</div>';

                html += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:1.25rem;">';
                if (prods.length === 0) {
                    for (var i = 0; i < 8; i++) {
                        html += '<article style="background:transparent;border:1px solid #1F2937;border-radius:8px;overflow:hidden;">'
                            + '<div style="aspect-ratio:3/4;background:rgba(255,255,255,0.02);"></div>'
                            + '<div style="padding:0.9rem 1rem;"><div style="height:8px;background:rgba(57,255,20,0.07);border-radius:2px;width:35%;margin-bottom:8px;"></div><div style="height:12px;background:rgba(255,255,255,0.04);border-radius:2px;margin-bottom:9px;"></div><div style="height:16px;background:rgba(57,255,20,0.08);border-radius:2px;width:45%;"></div></div>'
                            + '</article>';
                    }
                } else {
                    prods.forEach(function(p) {
                        var price = p.price ? ('€' + Number(p.price).toFixed(2)) : '';
                        var oldPrice = (p.compare_price && p.compare_price > p.price) ? ('€' + Number(p.compare_price).toFixed(2)) : '';
                        var pct = (p.compare_price && p.compare_price > p.price) ? Math.round((p.compare_price - p.price) / p.compare_price * 100) : 0;
                        var catName = (p.categories && p.categories.name) ? p.categories.name : 'Guantes';
                        html += '<article style="background:transparent;border:1px solid #1F2937;border-radius:8px;overflow:hidden;">'
                            + '<div style="position:relative;aspect-ratio:3/4;overflow:hidden;background:#0d1117;">'
                            + (p.image
                                ? '<img src="' + esc(p.image) + '" alt="' + esc(p.name) + '" loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform .7s ease;">'
                                : '<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3.5rem;">🧤</div>'
                              )
                            + (pct > 0 ? '<span style="position:absolute;top:8px;left:8px;background:#F59E0B;color:#000;font-size:9px;font-weight:900;padding:3px 8px;letter-spacing:0.04em;border-radius:2px;">-' + pct + '%</span>' : '')
                            + '</div>'
                            + '<div style="padding:0.85rem 1rem;">'
                            + '<span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:#39FF14;">' + esc(catName) + '</span>'
                            + '<h3 style="font-family:\'Oswald\',sans-serif;font-size:0.88rem;font-weight:600;text-transform:uppercase;letter-spacing:-0.01em;color:#fff;margin:4px 0 6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(p.name) + '</h3>'
                            + '<div style="display:flex;align-items:center;gap:8px;">'
                            + '<span style="font-size:0.95rem;font-weight:700;color:#39FF14;">' + esc(price) + '</span>'
                            + (oldPrice ? '<span style="font-size:0.72rem;color:rgba(255,255,255,0.2);text-decoration:line-through;">' + esc(oldPrice) + '</span>' : '')
                            + '</div>'
                            + '</div></article>';
                    });
                }
                html += '</div></div>';
                return html;
            }

            function esc(str) {
                return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }

            // Embed fonts + base CSS once per preview render
            function getSimStyles() {
                return '<style>'
                    + '@import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Oswald:wght@400;500;600;700&display=swap");'
                    + '.sim-wrap{font-family:"Inter",system-ui,sans-serif;background:#0a0a0a;color:#fff;-webkit-font-smoothing:antialiased;}'
                    + '.sim-wrap *{box-sizing:border-box;}'
                    + '.sim-h{font-family:"Oswald","Impact",sans-serif;}'
                    + '.sim-section{padding:5rem 0;}'
                    + '.sim-container{max-width:1200px;margin:0 auto;padding:0 2rem;}'
                    + '.sim-badge-sim{display:inline-block;padding:6px 20px;background:rgba(13,31,13,0.85);color:#39FF14;font-family:"Inter",sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.38em;border:none;}'
                    + '.sim-btn-primary{display:inline-flex;align-items:center;gap:8px;padding:14px 36px;background:linear-gradient(135deg,#39FF14 0%,#2DD60E 100%);color:#000;font-family:"Oswald",sans-serif;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;border:none;cursor:pointer;text-decoration:none;border-radius:4px;box-shadow:0 0 30px rgba(57,255,20,0.25);}'
                    + '.sim-btn-outline{display:inline-flex;align-items:center;padding:14px 32px;background:rgba(255,255,255,0.06);color:#fff;font-family:"Oswald",sans-serif;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;border:none;cursor:pointer;text-decoration:none;border-radius:4px;backdrop-filter:blur(8px);}'
                    + '.sim-card{background:#111827;border:1px solid #1F2937;transition:border-color .3s;}'
                    + '.sim-card:hover{border-color:rgba(57,255,20,0.3);}'
                    + '.sim-section-title{font-family:"Oswald",sans-serif;font-size:clamp(2rem,4vw,3.5rem);font-weight:700;text-transform:uppercase;letter-spacing:-0.02em;line-height:1;}'
                    + '.sim-section-sub{font-size:0.95rem;color:rgba(255,255,255,0.45);max-width:480px;margin:0.75rem auto 0;line-height:1.6;}'
                    + '.sim-sec-wrap{position:relative;cursor:pointer;outline:2px solid transparent;transition:outline 0.1s;}'
                    + '.sim-sec-wrap:hover{outline:2px solid rgba(57,255,20,0.4);}'
                    + '.sim-sec-wrap.sim-sec-selected{outline:2px solid #39FF14;}'
                    + '.sim-sec-label{position:absolute;top:0;right:0;z-index:200;background:#39FF14;color:#000;font-family:"Inter",sans-serif;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;padding:3px 10px;opacity:0;transition:opacity 0.15s;pointer-events:none;}'
                    + '.sim-sec-wrap:hover .sim-sec-label,.sim-sec-wrap.sim-sec-selected .sim-sec-label{opacity:1;}'
                    + '[data-sim-field]{cursor:pointer;}'
                    + '[data-sim-field]:hover{outline:1px dashed rgba(57,255,20,0.5);outline-offset:2px;border-radius:2px;}'
                    + '</style>';
            }

            function renderSection(key, c, sec) {
                switch(key) {
                    case 'hero': return renderHero(c);
                    case 'featured_products': return renderFeaturedProducts(c);
                    case 'benefits': return renderBenefits(c);
                    case 'glove_selector': return renderGloveSelector(c);
                    case 'testimonials': return renderTestimonials(c);
                    case 'cta_banner': return renderCtaBanner(c);
                    case 'newsletter': return renderNewsletter(c);
                    case 'banner': return renderBanner(c);
                    default: return renderGeneric(key, c, sec);
                }
            }

            function renderHero(c) {
                var bg = c.bg_image || 'https://res.cloudinary.com/djvj32zic/image/upload/f_webp,q_auto,w_1400/v1771850353/wmremove-transformed_qkiglz.png';
                var overlayColor = c.overlay_color || '#000000';
                var overlayOpacity = c.overlay_opacity != null ? c.overlay_opacity : 0.4;
                var t1 = c.title_line1 || 'DOMINA';
                var t2 = c.title_line2 || 'EL ÁREA';
                var sub = c.subtitle || 'Siente el agarre absoluto. Diseñados para porteros de elite que no aceptan menos que la perfección.';
                var badge = c.badge || 'Nueva Colección 2026';
                var ctaText = c.cta_text || 'Comprar Ahora';
                var secText = c.secondary_text || 'Serie Elite';
                var c1 = c.style_title_line1_color || '#FFFFFF';
                var c2 = c.style_title_line2_color || '#39FF14';
                var cs = c.style_subtitle_color || '#B0B0B0';
                var cbg = c.style_cta_bg || '#39FF14';
                var cct = c.style_cta_text || '#000000';
                var badgeText = c.style_badge_text || '#39FF14';
                return '<div style="position:relative;min-height:520px;display:flex;align-items:center;overflow:hidden;background:#000;">'
                    // bg image — positioned to the right like the real site
                    + '<div style="position:absolute;inset:0;background-image:url(\'' + esc(bg) + '\');background-size:cover;background-position:center right;"></div>'
                    // colour overlay
                    + '<div style="position:absolute;inset:0;background:' + esc(overlayColor) + ';opacity:' + overlayOpacity + ';"></div>'
                    // gradient-hero-side: left=black, fades right
