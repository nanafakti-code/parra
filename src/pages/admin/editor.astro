            // ═══════ HELPERS ═══════
            function $(sel) {
                return document.querySelector(sel);
            }
            function pageSections() {
                return allSections
                    .filter(function (s) {
                        return s.page_name === currentPage;
                    })
                    .sort(function (a, b) {
                        return a.display_order - b.display_order;
                    });
            }
            function findSection(id) {
                return allSections.find(function (s) {
                    return s.id === id;
                });
            }
            function esc(str) {
                if (str == null) return "";
                return String(str)
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;");
            }

            // ═══════ RENDER ═══════
            function render() {
                if (window.VBSidebar) {
                    window.VBSidebar.render(
                        pageSections(),
                        selectedId,
                        unsavedIds,
                    );
                }
            }

            function selectSection(id) {
                selectedId = id;
                render();
                var section = findSection(id);
                if (section && window.VBInspector) {
                    // Resolve base schema key (hero_2 -> hero, cta_banner_3 -> cta_banner)
                    var schemaKey = section.section_key;
                    if (!SCHEMAS[schemaKey]) {
                        // Strip _N suffix to find base key
                        var baseKey = schemaKey.replace(/_\d+$/, "");
                        if (SCHEMAS[baseKey]) schemaKey = baseKey;
                    }
                    var schema = SCHEMAS[schemaKey] || [];
                    var styleSchema = STYLE_SCHEMAS[schemaKey] || [];
                    window.VBInspector.show(section, schema, styleSchema);
                }
            }

            function deselectSection() {
                selectedId = null;
                render();
                if (window.VBInspector) window.VBInspector.hide();
            }

            // ═══════ EVENTS FROM COMPONENTS ═══════
            document.addEventListener("vb:select", function (e) {
                selectSection(e.detail.id);
            });
            document.addEventListener("vb:toggle", function (e) {
                toggleSectionActive(e.detail.id);
            });
            document.addEventListener("vb:reorder", function (e) {
                reorderSections(e.detail.from, e.detail.to);
            });
            document.addEventListener("vb:unsaved", function (e) {
                unsavedIds.add(e.detail.id);
                render();
                updatePublishBtn();
            });

            // ═══════ PUBLISH BUTTON STATE ═══════
            function updatePublishBtn() {
                var btn = $("#vbBtnSaveAll");
                if (btn)
                    btn.classList.toggle("has-changes", unsavedIds.size > 0);
            }

            // ═══════ API CALLS ═══════
            async function fetchSections() {
                try {
                    var res = await fetch("/api/admin/sections");
                    var data = await res.json();
                    if (data.pages) {
                        allSections = [];
                        Object.values(data.pages).forEach(function (arr) {
                            allSections = allSections.concat(arr);
                        });
                    }
                } catch (e) {
                    console.error("Error loading sections", e);
                }
            }

            async function saveSection(id) {
                var content = window.VBInspector
                    ? window.VBInspector.collectData()
                    : null;
                if (!content) return;

                var btn = $("#vbBtnSave");
                if (btn) {
                    btn.disabled = true;
                    btn.innerHTML =
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Guardando...';
                }

                try {
                    var res = await fetch("/api/admin/sections", {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ id: id, content: content }),
                    });
                    var data = await res.json();
                    if (res.ok) {
                        var sec = findSection(id);
                        if (sec) sec.content = content;
                        unsavedIds.delete(id);
                        render();
                        updatePublishBtn();
                        window.adminToast?.(
                            "Sección guardada correctamente",
                            "success",
                        );
                        refreshPreview();
                    } else {
                        window.adminToast?.(
                            data.error || "Error al guardar",
                            "error",
                        );
                    }
                } catch (e) {
                    window.adminToast?.("Error de conexión", "error");
                } finally {
                    if (btn) {
                        btn.disabled = false;
                        btn.innerHTML =
                            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Publicar cambios';
                    }
                }
            }

            async function saveAllSections() {
                if (unsavedIds.size === 0) {
                    window.adminToast?.("No hay cambios pendientes", "success");
                    return;
                }
                if (selectedId && unsavedIds.has(selectedId)) {
                    await saveSection(selectedId);
                }
                window.adminToast?.("Todos los cambios guardados", "success");
            }

            async function toggleSectionActive(id) {
                var section = findSection(id);
                if (!section) return;
                var newState = !section.is_active;
                try {
                    var res = await fetch("/api/admin/sections", {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ id: id, is_active: newState }),
                    });
                    if (res.ok) {
                        section.is_active = newState;
                        render();
                        if (selectedId === id && window.VBInspector) {
                            var schemaKey2 = section.section_key;
                            if (!SCHEMAS[schemaKey2]) {
                                var baseKey2 = schemaKey2.replace(/_\d+$/, "");
                                if (SCHEMAS[baseKey2]) schemaKey2 = baseKey2;
                            }
                            var schema = SCHEMAS[schemaKey2] || [];
                            var styleSchema = STYLE_SCHEMAS[schemaKey2] || [];
                            window.VBInspector.show(
                                section,
                                schema,
                                styleSchema,
                            );
                        }
                        window.adminToast?.(
                            newState
                                ? "Sección activada"
                                : "Sección desactivada",
                            "success",
                        );
                        refreshPreview();
                    }
                } catch (e) {
                    window.adminToast?.("Error al cambiar estado", "error");
                }
            }

            async function duplicateSection(id) {
                try {
                    var res = await fetch("/api/admin/sections", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ action: "duplicate", id: id }),
                    });
                    var data = await res.json();
                    if (res.ok && data.section) {
                        allSections.push(data.section);
                        render();
                        window.adminToast?.("Sección duplicada", "success");
                    } else {
                        window.adminToast?.(
                            data.error || "Error al duplicar",
                            "error",
                        );
                    }
                } catch (e) {
                    window.adminToast?.("Error de conexión", "error");
                }
            }

            async function resetSection(id) {
                try {
                    var res = await fetch("/api/admin/sections", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ action: "reset", id: id }),
                    });
                    var data = await res.json();
                    if (res.ok) {
                        await fetchSections();
                        render();
                        if (selectedId === id) selectSection(id);
                        window.adminToast?.("Sección restaurada", "success");
                        refreshPreview();
                    } else {
                        window.adminToast?.(
                            data.error || "Sin historial disponible",
                            "error",
                        );
                    }
                } catch (e) {
                    window.adminToast?.("Error de conexión", "error");
                }
            }

            async function deleteSection(id) {
                try {
                    var res = await fetch("/api/admin/sections?id=" + id, {
                        method: "DELETE",
                    });
                    if (res.ok) {
                        allSections = allSections.filter(function (s) {
                            return s.id !== id;
                        });
                        unsavedIds.delete(id);
                        if (selectedId === id) deselectSection();
                        render();
                        updatePublishBtn();
                        window.adminToast?.("Sección eliminada", "success");
                        refreshPreview();
                    }
                } catch (e) {
                    window.adminToast?.("Error de conexión", "error");
                }
            }

            async function reorderSections(fromId, toId) {
                var items = pageSections();
                var fromIdx = items.findIndex(function (s) {
                    return s.id === fromId;
                });
                var toIdx = items.findIndex(function (s) {
                    return s.id === toId;
                });
                if (fromIdx < 0 || toIdx < 0) return;
                var moved = items.splice(fromIdx, 1)[0];
                items.splice(toIdx, 0, moved);
                var orders = items.map(function (s, i) {
                    s.display_order = i;
                    return { id: s.id, display_order: i };
                });
                render();
                try {
                    await fetch("/api/admin/sections", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            action: "reorder",
                            orders: orders,
                        }),
                    });
                    window.adminToast?.("Orden actualizado", "success");
                    refreshPreview();
                } catch (e) {
                    window.adminToast?.("Error al reordenar", "error");
                }
            }

            // ═══════ INSPECTOR BUTTONS ═══════
            document.addEventListener("click", function (e) {
                if (e.target.closest("#vbBtnSave")) {
                    if (selectedId) saveSection(selectedId);
                }
                if (e.target.closest("#vbBtnDuplicate")) {
                    if (selectedId) duplicateSection(selectedId);
                }
                if (e.target.closest("#vbBtnReset")) {
                    if (selectedId) {
                        vbConfirm(
                            "¿Restaurar sección?",
                            "Se restaurará esta sección a su estado original. Los cambios actuales se perderán.",
                            "Restaurar",
                        ).then(function (ok) {
                            if (ok) resetSection(selectedId);
                        });
                    }
                }
                if (e.target.closest("#vbBtnDelete")) {
                    if (selectedId) {
                        var sec = findSection(selectedId);
                        var secLabel = sec ? sec.label : "esta sección";
                        vbConfirm(
                            "¿Eliminar bloque?",
                            'Se eliminará "' +
                                secLabel +
                                '" permanentemente. Esta acción no se puede deshacer.',
                            "Eliminar",
                        ).then(function (ok) {
                            if (ok) deleteSection(selectedId);
                        });
                    }
                }
            });

            // ═══════ VIEWPORT SWITCHER ═══════
            document
                .querySelectorAll("#vbViewport .vb-vp-btn")
                .forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        document
                            .querySelectorAll("#vbViewport .vb-vp-btn")
                            .forEach(function (b) {
                                b.classList.remove("active");
                            });
                        this.classList.add("active");
                        var wrapper = $("#vbPreviewWrapper");
                        wrapper.className = "vb-preview-wrapper";
                        if (this.dataset.vp === "tablet")
                            wrapper.classList.add("vp-tablet");
                        else if (this.dataset.vp === "mobile")
                            wrapper.classList.add("vp-mobile");
                    });
                });

            // ═══════ PAGE TABS ═══════
            document
                .querySelectorAll("#vbPageTabs .vb-page-tab")
                .forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        document
                            .querySelectorAll("#vbPageTabs .vb-page-tab")
                            .forEach(function (b) {
                                b.classList.remove("active");
                            });
                        this.classList.add("active");
                        currentPage = this.dataset.page;
                        deselectSection();
                        refreshPreview();
                        // Toggle product order panel
                        var poPanel = $("#vbProductOrder");
                        var sbPanel = $("#vbSidebar");
                        if (currentPage === "shop") {
                            if (poPanel) poPanel.style.display = "flex";
                            renderProductOrder();
                        } else {
                            if (poPanel) poPanel.style.display = "none";
                        }
                    });
                });

            // ═══════ EDIT MODE TOGGLE ═══════
            document
                .querySelectorAll(".vb-edit-mode-btn")
                .forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        document
                            .querySelectorAll(".vb-edit-mode-btn")
                            .forEach(function (b) {
                                b.classList.remove("active");
                            });
                        this.classList.add("active");
                    });
                });

            // ═══════ HISTORY ═══════
            $("#vbBtnHistory")?.addEventListener("click", async function () {
                var modal = $("#vbHistoryModal");
                modal.style.display = "flex";
                var content = $("#vbHistoryContent");
                if (!selectedId) {
                    content.innerHTML =
                        '<div class="empty-state"><p>Selecciona una sección para ver su historial</p></div>';
                    return;
                }
                content.innerHTML =
                    '<div style="text-align:center;padding:2rem;color:rgba(255,255,255,0.3);">Cargando...</div>';
                try {
                    var res = await fetch("/api/admin/sections", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            action: "history",
                            id: selectedId,
                        }),
                    });
                    var data = await res.json();
                    var history = data.history || [];
                    if (history.length === 0) {
                        content.innerHTML =
                            '<div class="empty-state"><p>Sin historial para esta sección</p></div>';
                        return;
                    }
                    var html = '<div class="vb-history-list">';
                    history.forEach(function (entry) {
                        var date = new Date(entry.changed_at);
                        var dateStr =
                            date.toLocaleDateString("es-ES") +
                            " " +
                            date.toLocaleTimeString("es-ES", {
                                hour: "2-digit",
                                minute: "2-digit",
                            });
                        html +=
                            '<div class="vb-history-item"><div><div class="vb-history-date">' +
                            dateStr +
                            '</div><div class="vb-history-key">' +
                            esc(entry.section_key) +
                            "</div></div>";
                        html +=
                            '<button class="ve2-btn ve2-btn-ghost ve2-btn-sm" data-restore-history="' +
                            entry.id +
                            "\" data-content='" +
                            JSON.stringify(entry.content).replace(
                                /'/g,
                                "&#39;",
                            ) +
                            "'>Restaurar</button></div>";
                    });
                    html += "</div>";
                    content.innerHTML = html;
                    content
                        .querySelectorAll("[data-restore-history]")
                        .forEach(function (btn) {
                            btn.addEventListener("click", async function () {
                                var histContent = JSON.parse(
                                    this.dataset.content,
                                );
                                try {
                                    await fetch("/api/admin/sections", {
                                        method: "PATCH",
                                        headers: {
                                            "Content-Type": "application/json",
                                        },
                                        body: JSON.stringify({
                                            id: selectedId,
                                            content: histContent,
                                        }),
                                    });
                                    var sec = findSection(selectedId);
                                    if (sec) sec.content = histContent;
                                    selectSection(selectedId);
                                    unsavedIds.delete(selectedId);
                                    render();
                                    updatePublishBtn();
                                    modal.style.display = "none";
                                    window.adminToast?.(
                                        "Versión restaurada",
                                        "success",
                                    );
                                    refreshPreview();
                                } catch (e) {
                                    window.adminToast?.(
                                        "Error al restaurar",
                                        "error",
                                    );
                                }
                            });
                        });
                } catch (e) {
                    content.innerHTML =
                        '<div class="empty-state"><p>Error al cargar historial</p></div>';
                }
            });

            $("#vbHistoryClose")?.addEventListener("click", function () {
                $("#vbHistoryModal").style.display = "none";
            });
            $("#vbHistoryModal")?.addEventListener("click", function (e) {
                if (e.target === this) this.style.display = "none";
            });

            // ═══════ SAVE ALL ═══════
            $("#vbBtnSaveAll")?.addEventListener("click", function () {
                saveAllSections();
            });

            // ═══════ KEYBOARD SHORTCUTS ═══════
            document.addEventListener("keydown", function (e) {
                if ((e.ctrlKey || e.metaKey) && e.key === "s") {
                    e.preventDefault();
                    if (selectedId) saveSection(selectedId);
                }
            });

            // ═══════ SIMULATED PREVIEW ═══════
            function refreshPreview() {
                var container = $("#vbSimContent");
                if (!container) return;

                var sections = pageSections().filter(function(s){ return s.is_active; });

                if (sections.length === 0) {
                    container.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:300px;flex-direction:column;gap:1rem;color:rgba(255,255,255,0.3);">'
                        + '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>'
                        + '<p style="font-size:0.85rem;margin:0;">No hay bloques activos</p>'
                        + '</div>';
                    return;
                }

                var html = '<div style="background:#0a0a0a;">';

                // Sim badge
                html += '<div style="position:sticky;top:0;z-index:999;background:rgba(57,255,20,0.08);border-bottom:1px solid rgba(57,255,20,0.2);padding:6px 16px;display:flex;align-items:center;gap:8px;">'
                    + '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#39FF14" stroke-width="2.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>'
                    + '<span style="font-size:0.65rem;font-weight:700;letter-spacing:0.15em;color:#39FF14;text-transform:uppercase;">Vista previa simulada</span>'
                    + '</div>';

                sections.forEach(function(sec) {
                    var c = sec.content || {};
                    var key = sec.section_key || '';
                    var baseKey = key.replace(/_\d+$/, '');
                    html += renderSection(baseKey, c, sec);
                });

                html += '</div>';
                container.innerHTML = html;
            }

            function esc(str) {
                return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }

            function renderSection(key, c, sec) {
                switch(key) {
                    case 'hero': return renderHero(c);
                    case 'featured_products': return renderFeaturedProducts(c);
                    case 'benefits': return renderBenefits(c);
                    case 'glove_selector': return renderGloveSelector(c);
                    case 'testimonials': return renderTestimonials(c);
                    case 'cta_banner': return renderCtaBanner(c);
                    case 'newsletter': return renderNewsletter(c);
                    case 'banner': return renderBanner(c);
                    default: return renderGeneric(key, c, sec);
                }
            }

            function renderHero(c) {
                var bg = c.bg_image || 'https://res.cloudinary.com/djvj32zic/image/upload/f_webp,q_auto,w_1400/v1771850353/wmremove-transformed_qkiglz.png';
