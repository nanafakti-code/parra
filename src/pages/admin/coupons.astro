---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/admin";
import { supabaseAdmin } from "../../lib/supabase";

const adminResult = await requireAdmin(Astro);
if (adminResult instanceof Response) return adminResult;
const admin = adminResult;

const { data: coupons } = await supabaseAdmin
    .from("coupons")
    .select("*")
    .order("created_at", { ascending: false });

// Usage counts
const { data: usage } = await supabaseAdmin
    .from("coupon_usage")
    .select("coupon_id");
const usageMap: Record<string, number> = {};
(usage || []).forEach((u: any) => {
    usageMap[u.coupon_id] = (usageMap[u.coupon_id] || 0) + 1;
});
---

<AdminLayout title="Cupones" activeSection="coupons" admin={admin}>
    <div
        style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;"
    >
        <div style="font-size:0.8rem;color:rgba(255,255,255,0.4);">
            {coupons?.length || 0} cupones
        </div>
        <button class="btn btn-primary" id="btn-new-coupon">
            + Nuevo Cupón
        </button>
    </div>

    <!-- Search Bar -->
    <div style="margin-bottom: 1rem; max-width: 400px; position: relative;">
        <svg
            style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4);"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
            type="text"
            id="page-search"
            class="form-input"
            placeholder="Buscar por código..."
            style="padding-left: 2.5rem;"
        />
    </div>

    <div class="card">
        {
            !coupons || coupons.length === 0 ? (
                <div class="empty-state">
                    <h3>Sin cupones</h3>
                    <p>Crea tu primer cupón de descuento.</p>
                </div>
            ) : (
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Tipo</th>
                            <th>Valor</th>
                            <th>Compra Mín.</th>
                            <th>Usos</th>
                            <th>Expira</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {coupons.map((c: any) => {
                            const used = usageMap[c.id] || 0;
                            const expired =
                                c.expires_at &&
                                new Date(c.expires_at) < new Date();
                            const maxReached = c.max_uses && used >= c.max_uses;
                            return (
                                <tr data-search={c.code}>
                                    <td data-label="Código">
                                        <code style="background:rgba(var(--brand-rgb),0.06);color:var(--brand);padding:0.15rem 0.4rem;border-radius:3px;font-size:0.75rem;font-weight:700;">
                                            {c.code}
                                        </code>
                                    </td>
                                    <td
                                        data-label="Tipo"
                                        style="font-size:0.75rem;"
                                    >
                                        {c.type === "percentage"
                                            ? "Porcentaje"
                                            : "Fijo"}
                                    </td>
                                    <td
                                        data-label="Valor"
                                        style="font-weight:600;"
                                    >
                                        {c.type === "percentage"
                                            ? `${c.value}%`
                                            : `€${parseFloat(c.value).toFixed(2)}`}
                                    </td>
                                    <td
                                        data-label="Mín."
                                        style="font-size:0.75rem;"
                                    >
                                        {c.min_purchase
                                            ? `€${parseFloat(c.min_purchase).toFixed(2)}`
                                            : "—"}
                                    </td>
                                    <td
                                        data-label="Usos"
                                        style="font-size:0.75rem;"
                                    >
                                        {used}
                                        {c.max_uses ? `/${c.max_uses}` : ""}
                                    </td>
                                    <td
                                        data-label="Expira"
                                        style="font-size:0.7rem;color:rgba(255,255,255,0.4);"
                                    >
                                        {c.expires_at
                                            ? new Date(
                                                  c.expires_at,
                                              ).toLocaleDateString("es-ES")
                                            : "Nunca"}
                                    </td>
                                    <td data-label="Estado">
                                        {expired || maxReached ? (
                                            <span class="badge badge-danger">
                                                Expirado
                                            </span>
                                        ) : c.is_active ? (
                                            <span class="badge badge-success">
                                                Activo
                                            </span>
                                        ) : (
                                            <span class="badge badge-neutral">
                                                Inactivo
                                            </span>
                                        )}
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:0.3rem;flex-wrap:wrap;">
                                            <button
                                                class="btn btn-secondary btn-sm btn-edit-coupon"
                                                data-coupon={JSON.stringify(c)}
                                            >
                                                Editar
                                            </button>
                                            <button
                                                class="btn btn-danger btn-sm btn-delete-coupon"
                                                data-id={c.id}
                                                data-code={c.code}
                                            >
                                                Eliminar
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            );
                        })}
                    </tbody>
                </table>
            )
        }
    </div>

    <!-- Coupon Modal -->
    <div id="coupon-modal" class="modal-overlay" style="display:none;">
        <div class="modal" style="max-width:440px;">
            <div class="modal-header">
                <div class="modal-title" id="coupon-modal-title">
                    Nuevo Cupón
                </div>
                <button
                    class="modal-close"
                    onclick="document.getElementById('coupon-modal').style.display='none'"
                >
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="18" y1="6" x2="6" y2="18"></line><line
                            x1="6"
                            y1="6"
                            x2="18"
                            y2="18"></line></svg
                    >
                </button>
            </div>
            <form id="coupon-form">
                <input type="hidden" id="coupon-id" />
                <div class="form-group">
                    <label class="form-label">Código</label>
                    <input
                        type="text"
                        class="form-input"
                        id="coupon-code"
                        placeholder="DESCUENTO20"
                        required
                        style="text-transform:uppercase;"
                    />
                </div>
                <div
                    style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;"
                >
                    <div class="form-group">
                        <label class="form-label">Tipo</label>
                        <select class="form-select" id="coupon-type">
                            <option value="percentage">Porcentaje (%)</option>
                            <option value="fixed">Fijo (€)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Valor</label>
                        <input
                            type="number"
                            step="0.01"
                            class="form-input"
                            id="coupon-value"
                            placeholder="20"
                            required
                        />
                    </div>
                </div>
                <div
                    style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;"
                >
                    <div class="form-group">
                        <label class="form-label">Compra Mínima (€)</label>
                        <input
                            type="number"
                            step="0.01"
                            class="form-input"
                            id="coupon-min"
                            placeholder="Opcional"
                        />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Usos Máximos</label>
                        <input
                            type="number"
                            class="form-input"
                            id="coupon-max-uses"
                            placeholder="Ilimitado"
                        />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha Expiración</label>
                    <input type="date" class="form-input" id="coupon-expires" />
                </div>
                <div
                    class="form-group"
                    style="display:flex;align-items:center;gap:0.5rem;"
                >
                    <input
                        type="checkbox"
                        id="coupon-active"
                        checked
                        style="accent-color: var(--brand);"
                    />
                    <label
                        for="coupon-active"
                        style="font-size:0.8rem;color:rgba(255,255,255,0.6);cursor:pointer;"
                        >Cupón activo</label
                    >
                </div>
                <div class="modal-actions">
                    <button
                        type="button"
                        class="btn btn-secondary"
                        onclick="document.getElementById('coupon-modal').style.display='none'"
                        >Cancelar</button
                    >
                    <button
                        type="submit"
                        class="btn btn-primary"
                        id="coupon-submit-btn">Crear</button
                    >
                </div>
            </form>
        </div>
    </div>

    <script is:inline>
        (function () {
            var isEditing = false;

            // New coupon
            document
                .getElementById("btn-new-coupon")
                .addEventListener("click", function () {
                    isEditing = false;
                    document.getElementById("coupon-modal-title").textContent =
                        "Nuevo Cupón";
                    document.getElementById("coupon-submit-btn").textContent =
                        "Crear";
                    document.getElementById("coupon-id").value = "";
                    document.getElementById("coupon-code").value = "";
                    document.getElementById("coupon-type").value = "percentage";
                    document.getElementById("coupon-value").value = "";
                    document.getElementById("coupon-min").value = "";
                    document.getElementById("coupon-max-uses").value = "";
                    document.getElementById("coupon-expires").value = "";
                    document.getElementById("coupon-active").checked = true;
                    document.getElementById("coupon-modal").style.display =
                        "flex";
                });

            // Edit coupon
            document
                .querySelectorAll(".btn-edit-coupon")
                .forEach(function (btn) {
                    btn.addEventListener("click", function () {
                        isEditing = true;
                        var c = JSON.parse(this.getAttribute("data-coupon"));
                        document.getElementById(
                            "coupon-modal-title",
                        ).textContent = "Editar Cupón";
                        document.getElementById(
                            "coupon-submit-btn",
                        ).textContent = "Guardar";
                        document.getElementById("coupon-id").value = c.id;
                        document.getElementById("coupon-code").value = c.code;
                        document.getElementById("coupon-type").value = c.type;
                        document.getElementById("coupon-value").value = c.value;
                        document.getElementById("coupon-min").value =
                            c.min_purchase || "";
                        document.getElementById("coupon-max-uses").value =
                            c.max_uses || "";
                        document.getElementById("coupon-expires").value =
                            c.expires_at ? c.expires_at.slice(0, 10) : "";
                        document.getElementById("coupon-active").checked =
                            c.is_active;
                        document.getElementById("coupon-modal").style.display =
                            "flex";
                    });
                });

            // Delete coupon
            document
                .querySelectorAll(".btn-delete-coupon")
                .forEach(function (btn) {
                    btn.addEventListener("click", async function () {
                        var id = this.getAttribute("data-id");
                        var code = this.getAttribute("data-code");
                        if (
                            !(await window.adminConfirm(
                                "¿Eliminar el cupón " +
                                    code +
                                    "? Esta acción no se puede deshacer.",
                            ))
                        )
                            return;

                        try {
                            var res = await fetch(
                                "/api/admin/coupons?id=" + id,
                                { method: "DELETE" },
                            );
                            if (res.ok) {
                                window.adminToast("Cupón eliminado", "success");
                                setTimeout(function () {
                                    window.location.reload();
                                }, 600);
                            } else {
                                window.adminToast("Error al eliminar", "error");
                            }
                        } catch (err) {
                            window.adminToast("Error de conexión", "error");
                        }
                    });
                });

            // Submit form
            document
                .getElementById("coupon-form")
                .addEventListener("submit", async function (e) {
                    e.preventDefault();
                    var couponId = document.getElementById("coupon-id").value;
                    var payload = {
                        code: document.getElementById("coupon-code").value,
                        type: document.getElementById("coupon-type").value,
                        value: document.getElementById("coupon-value").value,
                        minPurchase:
                            document.getElementById("coupon-min").value || null,
                        maxUses:
                            document.getElementById("coupon-max-uses").value ||
                            null,
                        expiresAt:
                            document.getElementById("coupon-expires").value ||
                            null,
                        isActive:
                            document.getElementById("coupon-active").checked,
                    };

                    if (isEditing) payload.couponId = couponId;

                    try {
                        var res = await fetch("/api/admin/coupons", {
                            method: isEditing ? "PATCH" : "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify(payload),
                        });
                        var data = await res.json();
                        if (res.ok) {
                            window.adminToast(
                                isEditing
                                    ? "Cupón actualizado"
                                    : "Cupón creado",
                                "success",
                            );
                            document.getElementById(
                                "coupon-modal",
                            ).style.display = "none";
                            setTimeout(function () {
                                window.location.reload();
                            }, 600);
                        } else {
                            window.adminToast(data.error || "Error", "error");
                        }
                    } catch (err) {
                        window.adminToast("Error de conexión", "error");
                    }
                });
        })();
    </script>
</AdminLayout>
