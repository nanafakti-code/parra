---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/admin";
import { supabaseAdmin } from "../../lib/supabase";

const adminResult = await requireAdmin(Astro);
if (adminResult instanceof Response) return adminResult;
const admin = adminResult;

const { data: coupons } = await supabaseAdmin
    .from("coupons")
    .select("*")
    .order("created_at", { ascending: false });

// Usage counts
const { data: usage } = await supabaseAdmin
    .from("coupon_usage")
    .select("coupon_id");
const usageMap: Record<string, number> = {};
(usage || []).forEach((u: any) => {
    usageMap[u.coupon_id] = (usageMap[u.coupon_id] || 0) + 1;
});

// Allowed users for exclusive coupons
const { data: allowlist } = await supabaseAdmin
    .from("coupon_user_allowlist")
    .select("coupon_id, user_id, users!inner(id, name, email)");

const allowlistMap: Record<string, { id: string; name: string; email: string }[]> = {};
(allowlist || []).forEach((entry: any) => {
    if (!allowlistMap[entry.coupon_id]) allowlistMap[entry.coupon_id] = [];
    allowlistMap[entry.coupon_id].push({
        id: entry.users.id,
        name: entry.users.name,
        email: entry.users.email,
    });
});

const couponsWithMeta = (coupons || []).map((c: any) => ({
    ...c,
    timesUsed: usageMap[c.id] || 0,
    allowedUsers: allowlistMap[c.id] || [],
}));
---

<AdminLayout title="Cupones" activeSection="coupons" admin={admin}>
    <div
        style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;"
    >
        <div style="font-size:0.8rem;color:rgba(255,255,255,0.4);">
            {couponsWithMeta.length} cupones
        </div>
        <button class="btn btn-primary" id="btn-new-coupon">
            + Nuevo Cupón
        </button>
    </div>

    <!-- Search Bar -->
    <div style="margin-bottom: 1rem; max-width: 400px; position: relative;">
        <svg
            style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4);"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
            type="text"
            id="page-search"
            class="form-input"
            placeholder="Buscar por código..."
            style="padding-left: 2.5rem;"
        />
    </div>

    <div class="card">
        {
            couponsWithMeta.length === 0 ? (
                <div class="empty-state">
                    <h3>Sin cupones</h3>
                    <p>Crea tu primer cupón de descuento.</p>
                </div>
            ) : (
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Alcance</th>
                            <th>Tipo</th>
                            <th>Valor</th>
                            <th>Compra Mín.</th>
                            <th>Usos</th>
                            <th>Expira</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {couponsWithMeta.map((c: any) => {
                            const used = c.timesUsed;
                            const expired =
                                c.expires_at &&
                                new Date(c.expires_at) < new Date();
                            const maxReached = c.max_uses && used >= c.max_uses;
                            return (
                                <tr data-search={c.code}>
                                    <td data-label="Código">
                                        <code style="background:rgba(var(--brand-rgb),0.06);color:var(--brand);padding:0.15rem 0.4rem;border-radius:3px;font-size:0.75rem;font-weight:700;">
                                            {c.code}
                                        </code>
                                    </td>
                                    <td data-label="Alcance">
                                        {c.is_exclusive ? (
                                            <span
                                                class="badge"
                                                style="background:rgba(168,85,247,0.15);color:#c084fc;border:1px solid rgba(168,85,247,0.3);font-size:0.65rem;"
                                                title={`Solo para: ${c.allowedUsers.map((u: any) => u.name || u.email).join(', ') || 'ningún usuario asignado'}`}
                                            >
                                                Exclusivo ({c.allowedUsers.length})
                                            </span>
                                        ) : (
                                            <span
                                                class="badge"
                                                style="background:rgba(59,130,246,0.12);color:#60a5fa;border:1px solid rgba(59,130,246,0.2);font-size:0.65rem;"
                                            >
                                                General
                                            </span>
                                        )}
                                    </td>
                                    <td
                                        data-label="Tipo"
                                        style="font-size:0.75rem;"
                                    >
                                        {c.type === "percentage"
                                            ? "Porcentaje"
                                            : "Fijo"}
                                    </td>
                                    <td
                                        data-label="Valor"
                                        style="font-weight:600;"
                                    >
                                        {c.type === "percentage"
                                            ? `${c.value}%`
                                            : `€${parseFloat(c.value).toFixed(2)}`}
                                    </td>
                                    <td
                                        data-label="Mín."
                                        style="font-size:0.75rem;"
                                    >
                                        {c.min_purchase
                                            ? `€${parseFloat(c.min_purchase).toFixed(2)}`
                                            : "—"}
                                    </td>
                                    <td
                                        data-label="Usos"
                                        style="font-size:0.75rem;"
                                    >
                                        {used}
                                        {c.max_uses ? `/${c.max_uses}` : ""}
                                    </td>
                                    <td
                                        data-label="Expira"
                                        style="font-size:0.7rem;color:rgba(255,255,255,0.4);"
                                    >
                                        {c.expires_at
                                            ? new Date(
                                                  c.expires_at,
                                              ).toLocaleDateString("es-ES")
                                            : "Nunca"}
                                    </td>
                                    <td data-label="Estado">
                                        {expired || maxReached ? (
                                            <span class="badge badge-danger">
                                                Expirado
                                            </span>
                                        ) : c.is_active ? (
                                            <span class="badge badge-success">
                                                Activo
                                            </span>
                                        ) : (
                                            <span class="badge badge-neutral">
                                                Inactivo
                                            </span>
                                        )}
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:0.3rem;flex-wrap:wrap;">
                                            <button
                                                class="btn btn-secondary btn-sm btn-edit-coupon"
                                                data-coupon={JSON.stringify(c)}
                                            >
                                                Editar
                                            </button>
                                            <button
                                                class="btn btn-danger btn-sm btn-delete-coupon"
                                                data-id={c.id}
                                                data-code={c.code}
                                            >
                                                Eliminar
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            );
                        })}
                    </tbody>
                </table>
            )
        }
    </div>

    <!-- Coupon Modal -->
    <div id="coupon-modal" class="modal-overlay" style="display:none;">
        <div class="modal" style="max-width:480px;">
            <div class="modal-header">
                <div class="modal-title" id="coupon-modal-title">
                    Nuevo Cupón
                </div>
                <button
                    class="modal-close"
                    onclick="document.getElementById('coupon-modal').style.display='none'"
                >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <form id="coupon-form">
                <input type="hidden" id="coupon-id" />
                <div class="form-group">
                    <label class="form-label">Código</label>
                    <input
                        type="text"
                        class="form-input"
                        id="coupon-code"
                        placeholder="DESCUENTO20"
                        required
                        style="text-transform:uppercase;"
                    />
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                    <div class="form-group">
                        <label class="form-label">Tipo</label>
                        <select class="form-select" id="coupon-type">
                            <option value="percentage">Porcentaje (%)</option>
                            <option value="fixed">Fijo (€)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Valor</label>
                        <input
                            type="number"
                            step="0.01"
                            class="form-input"
                            id="coupon-value"
                            placeholder="20"
                            required
                        />
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                    <div class="form-group">
                        <label class="form-label">Compra Mínima (€)</label>
                        <input
                            type="number"
                            step="0.01"
                            class="form-input"
                            id="coupon-min"
                            placeholder="Opcional"
                        />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Usos Máximos</label>
                        <input
                            type="number"
                            class="form-input"
                            id="coupon-max-uses"
                            placeholder="Ilimitado"
                        />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha Expiración</label>
                    <input type="date" class="form-input" id="coupon-expires" />
                </div>

                <!-- Toggles row -->
                <div style="display:flex;gap:1.5rem;margin-bottom:0.75rem;">
                    <div style="display:flex;align-items:center;gap:0.5rem;">
                        <input
                            type="checkbox"
                            id="coupon-active"
                            checked
                            style="accent-color: var(--brand);"
                        />
                        <label for="coupon-active" style="font-size:0.8rem;color:rgba(255,255,255,0.6);cursor:pointer;">Activo</label>
                    </div>
                    <div style="display:flex;align-items:center;gap:0.5rem;">
                        <input
                            type="checkbox"
                            id="coupon-exclusive"
                            style="accent-color:#c084fc;"
                        />
                        <label for="coupon-exclusive" style="font-size:0.8rem;color:rgba(255,255,255,0.6);cursor:pointer;">
                            Exclusivo (usuarios específicos)
                        </label>
                    </div>
                </div>

                <!-- Exclusive users section (hidden unless exclusive is checked) -->
                <div id="exclusive-section" style="display:none;border:1px solid rgba(168,85,247,0.25);border-radius:6px;padding:0.75rem;margin-bottom:0.75rem;background:rgba(168,85,247,0.04);">
                    <div style="font-size:0.75rem;color:#c084fc;font-weight:600;margin-bottom:0.5rem;">
                        Usuarios con acceso
                    </div>

                    <!-- User search -->
                    <div style="position:relative;margin-bottom:0.5rem;">
                        <input
                            type="text"
                            id="user-search-input"
                            class="form-input"
                            placeholder="Buscar usuario por nombre o email..."
                            autocomplete="off"
                            style="font-size:0.8rem;"
                        />
                        <div
                            id="user-search-results"
                            style="display:none;position:absolute;top:100%;left:0;right:0;z-index:100;background:#1a1a2e;border:1px solid rgba(255,255,255,0.1);border-radius:0 0 6px 6px;max-height:180px;overflow-y:auto;"
                        ></div>
                    </div>

                    <!-- Selected users list -->
                    <div id="allowed-users-list" style="display:flex;flex-direction:column;gap:0.3rem;"></div>
                    <div
                        id="allowed-users-empty"
                        style="font-size:0.75rem;color:rgba(255,255,255,0.3);font-style:italic;"
                    >
                        Ningún usuario asignado — el cupón no podrá usarse.
                    </div>
                </div>

                <div class="modal-actions">
                    <button
                        type="button"
                        class="btn btn-secondary"
                        onclick="document.getElementById('coupon-modal').style.display='none'"
                    >Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="coupon-submit-btn">Crear</button>
                </div>
            </form>
        </div>
    </div>

    <script is:inline>
        (function () {
            var isEditing = false;
            // Block past dates in the expiry picker
            document.getElementById('coupon-expires').min = new Date().toISOString().slice(0, 10);
            // allowedUsers: array of { id, name, email }
            var allowedUsers = [];

            // ── Helpers ───────────────────────────────────────────────────────
            function renderAllowedUsers() {
                var list = document.getElementById('allowed-users-list');
                var empty = document.getElementById('allowed-users-empty');
                list.innerHTML = '';
                if (allowedUsers.length === 0) {
                    empty.style.display = '';
                    return;
                }
                empty.style.display = 'none';
                allowedUsers.forEach(function (u) {
                    var row = document.createElement('div');
                    row.style.cssText = 'display:flex;align-items:center;justify-content:space-between;background:rgba(168,85,247,0.08);border:1px solid rgba(168,85,247,0.2);border-radius:4px;padding:0.3rem 0.5rem;font-size:0.75rem;';
                    row.innerHTML =
                        '<span style="color:rgba(255,255,255,0.85);">' +
                        escHtml(u.name || u.email) +
                        ' <span style="color:rgba(255,255,255,0.4);">' + escHtml(u.email) + '</span></span>' +
                        '<button type="button" data-uid="' + escHtml(u.id) + '" style="background:none;border:none;color:rgba(255,100,100,0.7);cursor:pointer;font-size:0.8rem;padding:0 0.2rem;line-height:1;" title="Quitar">✕</button>';
                    row.querySelector('button').addEventListener('click', function () {
                        var uid = this.getAttribute('data-uid');
                        allowedUsers = allowedUsers.filter(function (x) { return x.id !== uid; });
                        renderAllowedUsers();
                    });
                    list.appendChild(row);
                });
            }

            function escHtml(str) {
                return String(str || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;');
            }

            // ── Exclusive toggle ──────────────────────────────────────────────
            document.getElementById('coupon-exclusive').addEventListener('change', function () {
                document.getElementById('exclusive-section').style.display =
                    this.checked ? '' : 'none';
            });

            // ── User search ───────────────────────────────────────────────────
            var searchTimeout = null;
            var searchInput = document.getElementById('user-search-input');
            var searchResults = document.getElementById('user-search-results');

            searchInput.addEventListener('input', function () {
                clearTimeout(searchTimeout);
                var q = this.value.trim();
                if (q.length < 2) { searchResults.style.display = 'none'; return; }
                searchTimeout = setTimeout(function () {
                    fetch('/api/admin/users?q=' + encodeURIComponent(q))
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            var users = (data.users || []).filter(function (u) {
                                return !allowedUsers.find(function (a) { return a.id === u.id; });
                            });
                            if (users.length === 0) {
                                searchResults.innerHTML = '<div style="padding:0.5rem 0.75rem;font-size:0.75rem;color:rgba(255,255,255,0.4);">Sin resultados</div>';
                            } else {
                                searchResults.innerHTML = users.map(function (u) {
                                    return '<div class="user-result" data-user=\'' + JSON.stringify(u).replace(/'/g, '&#39;') + '\' style="padding:0.4rem 0.75rem;cursor:pointer;font-size:0.8rem;border-bottom:1px solid rgba(255,255,255,0.05);">' +
                                        '<span style="color:rgba(255,255,255,0.85);">' + escHtml(u.name) + '</span>' +
                                        ' <span style="color:rgba(255,255,255,0.4);font-size:0.72rem;">' + escHtml(u.email) + '</span>' +
                                        '</div>';
                                }).join('');
                                searchResults.querySelectorAll('.user-result').forEach(function (el) {
                                    el.addEventListener('mouseenter', function () { this.style.background = 'rgba(168,85,247,0.15)'; });
                                    el.addEventListener('mouseleave', function () { this.style.background = ''; });
                                    el.addEventListener('click', function () {
                                        var u = JSON.parse(this.getAttribute('data-user'));
                                        if (!allowedUsers.find(function (a) { return a.id === u.id; })) {
                                            allowedUsers.push(u);
                                            renderAllowedUsers();
                                        }
                                        searchInput.value = '';
                                        searchResults.style.display = 'none';
                                    });
                                });
                            }
                            searchResults.style.display = '';
                        })
                        .catch(function () { searchResults.style.display = 'none'; });
                }, 280);
            });

            document.addEventListener('click', function (e) {
                if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                    searchResults.style.display = 'none';
                }
            });

            // ── Reset modal ───────────────────────────────────────────────────
            function resetModal() {
                document.getElementById('coupon-id').value = '';
                document.getElementById('coupon-code').value = '';
                document.getElementById('coupon-type').value = 'percentage';
                document.getElementById('coupon-value').value = '';
                document.getElementById('coupon-min').value = '';
                document.getElementById('coupon-max-uses').value = '';
                document.getElementById('coupon-expires').value = '';
                document.getElementById('coupon-active').checked = true;
                document.getElementById('coupon-exclusive').checked = false;
                document.getElementById('exclusive-section').style.display = 'none';
                allowedUsers = [];
                renderAllowedUsers();
                searchInput.value = '';
                searchResults.style.display = 'none';
            }

            // ── New coupon ────────────────────────────────────────────────────
            document.getElementById('btn-new-coupon').addEventListener('click', function () {
                isEditing = false;
                document.getElementById('coupon-modal-title').textContent = 'Nuevo Cupón';
                document.getElementById('coupon-submit-btn').textContent = 'Crear';
                resetModal();
                document.getElementById('coupon-modal').style.display = 'flex';
            });

            // ── Edit coupon ───────────────────────────────────────────────────
            document.querySelectorAll('.btn-edit-coupon').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    isEditing = true;
                    var c = JSON.parse(this.getAttribute('data-coupon'));
                    document.getElementById('coupon-modal-title').textContent = 'Editar Cupón';
                    document.getElementById('coupon-submit-btn').textContent = 'Guardar';
                    document.getElementById('coupon-id').value = c.id;
                    document.getElementById('coupon-code').value = c.code;
                    document.getElementById('coupon-type').value = c.type;
                    document.getElementById('coupon-value').value = c.value;
                    document.getElementById('coupon-min').value = c.min_purchase || '';
                    document.getElementById('coupon-max-uses').value = c.max_uses || '';
                    document.getElementById('coupon-expires').value = c.expires_at ? c.expires_at.slice(0, 10) : '';
                    document.getElementById('coupon-active').checked = c.is_active;
                    document.getElementById('coupon-exclusive').checked = !!c.is_exclusive;
                    document.getElementById('exclusive-section').style.display = c.is_exclusive ? '' : 'none';
                    allowedUsers = Array.isArray(c.allowedUsers) ? c.allowedUsers.slice() : [];
                    renderAllowedUsers();
                    searchInput.value = '';
                    searchResults.style.display = 'none';
                    document.getElementById('coupon-modal').style.display = 'flex';
                });
            });

            // ── Delete coupon ─────────────────────────────────────────────────
            document.querySelectorAll('.btn-delete-coupon').forEach(function (btn) {
                btn.addEventListener('click', async function () {
                    var id = this.getAttribute('data-id');
                    var code = this.getAttribute('data-code');
                    if (!(await window.adminConfirm('¿Eliminar el cupón ' + code + '? Esta acción no se puede deshacer.'))) return;
                    try {
                        var res = await fetch('/api/admin/coupons?id=' + id, { method: 'DELETE' });
                        if (res.ok) {
                            window.adminToast('Cupón eliminado', 'success');
                            setTimeout(function () { window.location.reload(); }, 600);
                        } else {
                            window.adminToast('Error al eliminar', 'error');
                        }
                    } catch (err) {
                        window.adminToast('Error de conexión', 'error');
                    }
                });
            });

            // ── Submit form ───────────────────────────────────────────────────
            document.getElementById('coupon-form').addEventListener('submit', async function (e) {
                e.preventDefault();
                var couponId = document.getElementById('coupon-id').value;
                var isExclusive = document.getElementById('coupon-exclusive').checked;
                var payload = {
                    code:        document.getElementById('coupon-code').value,
                    type:        document.getElementById('coupon-type').value,
                    value:       document.getElementById('coupon-value').value,
                    minPurchase: document.getElementById('coupon-min').value || null,
                    maxUses:     document.getElementById('coupon-max-uses').value || null,
                    expiresAt:   document.getElementById('coupon-expires').value || null,
                    isActive:    document.getElementById('coupon-active').checked,
                    isExclusive: isExclusive,
                    allowedUsers: isExclusive ? allowedUsers.map(function (u) { return u.id; }) : [],
                };
                if (isEditing) payload.couponId = couponId;

                try {
                    var res = await fetch('/api/admin/coupons', {
                        method: isEditing ? 'PATCH' : 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    });
                    var data = await res.json();
                    if (res.ok) {
                        window.adminToast(isEditing ? 'Cupón actualizado' : 'Cupón creado', 'success');
                        document.getElementById('coupon-modal').style.display = 'none';
                        setTimeout(function () { window.location.reload(); }, 600);
                    } else {
                        window.adminToast(data.error || 'Error', 'error');
                    }
                } catch (err) {
                    window.adminToast('Error de conexión', 'error');
                }
            });
        })();
    </script>
</AdminLayout>
