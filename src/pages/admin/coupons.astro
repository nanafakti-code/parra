---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/admin";
import { supabaseAdmin } from "../../lib/supabase";

const adminResult = await requireAdmin(Astro);
if (adminResult instanceof Response) return adminResult;
const admin = adminResult;

const { data: coupons } = await supabaseAdmin
    .from("coupons")
    .select("*")
    .order("created_at", { ascending: false });

// Usage counts
const { data: usage } = await supabaseAdmin
    .from("coupon_usage")
    .select("coupon_id");
const usageMap: Record<string, number> = {};
(usage || []).forEach((u: any) => {
    usageMap[u.coupon_id] = (usageMap[u.coupon_id] || 0) + 1;
});

// Allowed users for exclusive coupons
const { data: allowlist } = await supabaseAdmin
    .from("coupon_user_allowlist")
    .select("coupon_id, user_id, users!inner(id, name, email)");

const allowlistMap: Record<string, { id: string; name: string; email: string }[]> = {};
(allowlist || []).forEach((entry: any) => {
    if (!allowlistMap[entry.coupon_id]) allowlistMap[entry.coupon_id] = [];
    allowlistMap[entry.coupon_id].push({
        id: entry.users.id,
        name: entry.users.name,
        email: entry.users.email,
    });
});

const couponsWithMeta = (coupons || []).map((c: any) => ({
    ...c,
    timesUsed: usageMap[c.id] || 0,
    allowedUsers: allowlistMap[c.id] || [],
}));

// Stats
const now = new Date();
const activeCoupons = couponsWithMeta.filter((c: any) => {
    const expired = c.expires_at && new Date(c.expires_at) < now;
    const maxReached = c.max_uses && c.timesUsed >= c.max_uses;
    return c.is_active && !expired && !maxReached;
}).length;
const exclusiveCoupons = couponsWithMeta.filter((c: any) => c.is_exclusive).length;
const totalRedemptions = couponsWithMeta.reduce((sum: number, c: any) => sum + c.timesUsed, 0);
---

<style>
    /* Toggle switch */
    .toggle-wrap { display: flex; align-items: center; gap: 0.6rem; }
    .toggle-wrap input[type="checkbox"] { display: none; }
    .toggle-track {
        position: relative; width: 36px; height: 20px;
        background: rgba(255,255,255,0.1); border-radius: 10px;
        cursor: pointer; transition: background 0.2s;
        border: 1px solid rgba(255,255,255,0.12);
        flex-shrink: 0;
    }
    .toggle-track::after {
        content: ''; position: absolute; top: 2px; left: 2px;
        width: 14px; height: 14px; border-radius: 50%;
        background: rgba(255,255,255,0.5); transition: all 0.2s;
    }
    .toggle-active .toggle-track { background: rgba(var(--brand-rgb), 0.35); border-color: rgba(var(--brand-rgb), 0.5); }
    .toggle-active .toggle-track::after { left: 18px; background: var(--brand); }
    .toggle-exclusive .toggle-track { background: rgba(168,85,247,0.3); border-color: rgba(168,85,247,0.5); }
    .toggle-exclusive .toggle-track::after { left: 18px; background: #c084fc; }
    .toggle-label { font-size: 0.8rem; color: rgba(255,255,255,0.6); cursor: pointer; user-select: none; }

    /* Stat cards */
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
    @media (max-width: 640px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-card {
        background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
        border-radius: 8px; padding: 0.875rem 1rem;
        display: flex; flex-direction: column; gap: 0.25rem;
    }
    .stat-card-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.35); }
    .stat-card-value { font-size: 1.6rem; font-weight: 700; line-height: 1; }
    .stat-card-sub { font-size: 0.68rem; color: rgba(255,255,255,0.3); }

    /* Action icon buttons */
    .btn-icon {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px; border-radius: 6px; border: 1px solid transparent;
        cursor: pointer; transition: all 0.15s; padding: 0;
        background: transparent;
    }
    .btn-icon-edit {
        border-color: rgba(255,255,255,0.1); color: rgba(255,255,255,0.5);
    }
    .btn-icon-edit:hover { border-color: var(--brand); color: var(--brand); background: rgba(var(--brand-rgb),0.08); }
    .btn-icon-delete {
        border-color: rgba(239,68,68,0.2); color: rgba(239,68,68,0.5);
    }
    .btn-icon-delete:hover { border-color: rgba(239,68,68,0.6); color: #f87171; background: rgba(239,68,68,0.08); }

    /* Coupon code pill */
    .coupon-code-pill {
        display: inline-block;
        font-family: 'Courier New', monospace;
        font-size: 0.7rem; font-weight: 800;
        letter-spacing: 0.08em; text-transform: uppercase;
        color: var(--brand);
        background: rgba(var(--brand-rgb), 0.07);
        border: 1px solid rgba(var(--brand-rgb), 0.2);
        border-radius: 4px; padding: 0.2rem 0.55rem;
        transition: all 0.15s;
    }
    tr:hover .coupon-code-pill {
        background: rgba(var(--brand-rgb), 0.12);
        border-color: rgba(var(--brand-rgb), 0.35);
        box-shadow: 0 0 8px rgba(var(--brand-rgb), 0.15);
    }

    /* Value display */
    .coupon-value-display { font-size: 0.95rem; font-weight: 700; }

    /* Table row hover */
    .data-table tbody tr { transition: background 0.12s; }
    .data-table tbody tr:hover { background: rgba(255,255,255,0.025); }

    /* Section divider in modal */
    .modal-section {
        border-top: 1px solid rgba(255,255,255,0.07);
        padding-top: 0.875rem; margin-top: 0.125rem;
    }
    .modal-section-title {
        font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em;
        color: rgba(255,255,255,0.3); margin-bottom: 0.75rem;
    }
</style>

<AdminLayout title="Cupones" activeSection="coupons" admin={admin}>

    <!-- Stats -->
    <div class="stat-grid">
        <div class="stat-card">
            <span class="stat-card-label">Total</span>
            <span class="stat-card-value" style="color: rgba(255,255,255,0.9);">{couponsWithMeta.length}</span>
            <span class="stat-card-sub">cupones creados</span>
        </div>
        <div class="stat-card">
            <span class="stat-card-label">Activos</span>
            <span class="stat-card-value" style="color: #4ade80;">{activeCoupons}</span>
            <span class="stat-card-sub">disponibles ahora</span>
        </div>
        <div class="stat-card">
            <span class="stat-card-label">Exclusivos</span>
            <span class="stat-card-value" style="color: #c084fc;">{exclusiveCoupons}</span>
            <span class="stat-card-sub">de usuario específico</span>
        </div>
        <div class="stat-card">
            <span class="stat-card-label">Canjes</span>
            <span class="stat-card-value" style="color: var(--brand);">{totalRedemptions}</span>
            <span class="stat-card-sub">usos totales</span>
        </div>
    </div>

    <!-- Toolbar -->
    <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;margin-bottom:1rem;flex-wrap:wrap;">
        <div style="position:relative;flex:1;max-width:360px;">
            <svg style="position:absolute;left:0.875rem;top:50%;transform:translateY(-50%);color:rgba(255,255,255,0.3);pointer-events:none;" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" id="page-search" class="form-input" placeholder="Buscar por código..." style="padding-left:2.4rem;height:36px;font-size:0.8rem;" />
        </div>
        <button class="btn btn-primary" id="btn-new-coupon" style="display:inline-flex;align-items:center;gap:0.4rem;height:36px;padding:0 1rem;font-size:0.82rem;white-space:nowrap;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nuevo Cupón
        </button>
    </div>

    <!-- Table -->
    <div class="card" style="overflow:hidden;padding:0;">
        {
            couponsWithMeta.length === 0 ? (
                <div class="empty-state" style="padding:3rem;">
                    <div style="font-size:2rem;margin-bottom:0.75rem;opacity:0.3;">🎟</div>
                    <h3>Sin cupones</h3>
                    <p>Crea tu primer cupón de descuento.</p>
                </div>
            ) : (
                <table class="data-table" style="margin:0;">
                    <thead>
                        <tr>
                            <th style="padding-left:1.25rem;">Código</th>
                            <th>Alcance</th>
                            <th>Descuento</th>
                            <th>Compra Mín.</th>
                            <th>Usos</th>
                            <th>Expira</th>
                            <th>Estado</th>
                            <th style="text-align:right;padding-right:1.25rem;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {couponsWithMeta.map((c: any) => {
                            const used = c.timesUsed;
                            const expired = c.expires_at && new Date(c.expires_at) < new Date();
                            const maxReached = c.max_uses && used >= c.max_uses;
                            const isInactive = expired || maxReached || !c.is_active;
                            return (
                                <tr data-search={c.code} style={isInactive ? 'opacity:0.6;' : ''}>
                                    <td style="padding-left:1.25rem;" data-label="Código">
                                        <span class="coupon-code-pill">{c.code}</span>
                                    </td>
                                    <td data-label="Alcance">
                                        {c.is_exclusive ? (
                                            <span
                                                class="badge"
                                                style="background:rgba(168,85,247,0.12);color:#c084fc;border:1px solid rgba(168,85,247,0.25);font-size:0.63rem;letter-spacing:0.03em;"
                                                title={`Solo para: ${c.allowedUsers.map((u: any) => u.name || u.email).join(', ') || 'ningún usuario asignado'}`}
                                            >
                                                ◈ Exclusivo ({c.allowedUsers.length})
                                            </span>
                                        ) : (
                                            <span
                                                class="badge"
                                                style="background:rgba(59,130,246,0.1);color:#60a5fa;border:1px solid rgba(59,130,246,0.18);font-size:0.63rem;letter-spacing:0.03em;"
                                            >
                                                ● General
                                            </span>
                                        )}
                                    </td>
                                    <td data-label="Descuento">
                                        <span class="coupon-value-display" style={`color:${c.type === 'percentage' ? '#4ade80' : 'var(--brand)'};`}>
                                            {c.type === "percentage" ? `${c.value}%` : `€${parseFloat(c.value).toFixed(2)}`}
                                        </span>
                                        <span style="font-size:0.65rem;color:rgba(255,255,255,0.3);margin-left:0.3rem;">
                                            {c.type === "percentage" ? "dto." : "fijo"}
                                        </span>
                                    </td>
                                    <td data-label="Mín." style="font-size:0.78rem;color:rgba(255,255,255,0.55);">
                                        {c.min_purchase ? `€${parseFloat(c.min_purchase).toFixed(2)}` : <span style="color:rgba(255,255,255,0.2);">—</span>}
                                    </td>
                                    <td data-label="Usos" style="font-size:0.78rem;">
                                        <span style="color:rgba(255,255,255,0.8);">{used}</span>
                                        {c.max_uses ? (
                                            <span style="color:rgba(255,255,255,0.3);">/{c.max_uses}</span>
                                        ) : (
                                            <span style="color:rgba(255,255,255,0.2);"> ∞</span>
                                        )}
                                    </td>
                                    <td data-label="Expira" style="font-size:0.72rem;color:rgba(255,255,255,0.4);">
                                        {c.expires_at
                                            ? new Date(c.expires_at).toLocaleDateString("es-ES", { day:"2-digit", month:"short", year:"2-digit" })
                                            : <span style="color:rgba(255,255,255,0.2);">Sin límite</span>}
                                    </td>
                                    <td data-label="Estado">
                                        {expired || maxReached ? (
                                            <span class="badge badge-danger" style="font-size:0.63rem;">Expirado</span>
                                        ) : c.is_active ? (
                                            <span class="badge badge-success" style="font-size:0.63rem;">Activo</span>
                                        ) : (
                                            <span class="badge badge-neutral" style="font-size:0.63rem;">Inactivo</span>
                                        )}
                                    </td>
                                    <td style="text-align:right;padding-right:1.25rem;">
                                        <div style="display:inline-flex;gap:0.3rem;align-items:center;">
                                            <button
                                                class="btn-icon btn-icon-edit btn-edit-coupon"
                                                data-coupon={JSON.stringify(c)}
                                                title="Editar"
                                            >
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                            <button
                                                class="btn-icon btn-icon-delete btn-delete-coupon"
                                                data-id={c.id}
                                                data-code={c.code}
                                                title="Eliminar"
                                            >
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            );
                        })}
                    </tbody>
                </table>
            )
        }
    </div>

    <!-- Coupon Modal -->
    <div id="coupon-modal" class="modal-overlay" style="display:none;">
        <div class="modal" style="max-width:500px;gap:0;">

            <div class="modal-header" style="padding-bottom:1rem;border-bottom:1px solid rgba(255,255,255,0.07);">
                <div style="display:flex;align-items:center;gap:0.6rem;">
                    <div style="width:28px;height:28px;background:rgba(var(--brand-rgb),0.1);border:1px solid rgba(var(--brand-rgb),0.2);border-radius:6px;display:flex;align-items:center;justify-content:center;">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                    </div>
                    <div class="modal-title" id="coupon-modal-title" style="font-size:0.9rem;">Nuevo Cupón</div>
                </div>
                <button class="modal-close" onclick="document.getElementById('coupon-modal').style.display='none'">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>

            <form id="coupon-form" style="padding-top:1rem;">
                <input type="hidden" id="coupon-id" />

                <!-- Code -->
                <div class="form-group" style="margin-bottom:0.875rem;">
                    <label class="form-label" style="font-size:0.72rem;">Código del cupón</label>
                    <input
                        type="text" class="form-input" id="coupon-code"
                        placeholder="DESCUENTO20" required
                        style="text-transform:uppercase;font-family:'Courier New',monospace;font-weight:700;font-size:0.9rem;letter-spacing:0.06em;"
                    />
                </div>

                <!-- Type + Value -->
                <div class="modal-section">
                    <div class="modal-section-title">Descuento</div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:0.75rem;">
                        <div class="form-group" style="margin:0;">
                            <label class="form-label" style="font-size:0.72rem;">Tipo</label>
                            <select class="form-select" id="coupon-type" style="font-size:0.82rem;">
                                <option value="percentage">Porcentaje (%)</option>
                                <option value="fixed">Importe fijo (€)</option>
                            </select>
                        </div>
                        <div class="form-group" style="margin:0;">
                            <label class="form-label" style="font-size:0.72rem;">Valor</label>
                            <input type="number" step="0.01" class="form-input" id="coupon-value" placeholder="20" required style="font-size:0.82rem;" />
                        </div>
                    </div>
                    <div class="form-group" style="margin:0;">
                        <label class="form-label" style="font-size:0.72rem;">Compra mínima (€) — opcional</label>
                        <input type="number" step="0.01" class="form-input" id="coupon-min" placeholder="Sin mínimo" style="font-size:0.82rem;" />
                    </div>
                </div>

                <!-- Limits -->
                <div class="modal-section">
                    <div class="modal-section-title">Límites</div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                        <div class="form-group" style="margin:0;">
                            <label class="form-label" style="font-size:0.72rem;">Usos máximos</label>
                            <input type="number" class="form-input" id="coupon-max-uses" placeholder="Ilimitado" style="font-size:0.82rem;" />
                        </div>
                        <div class="form-group" style="margin:0;">
                            <label class="form-label" style="font-size:0.72rem;">Fecha de expiración</label>
                            <input type="date" class="form-input" id="coupon-expires" style="font-size:0.82rem;" />
                        </div>
                    </div>
                </div>

                <!-- Toggles -->
                <div class="modal-section">
                    <div class="modal-section-title">Configuración</div>
                    <div style="display:flex;flex-direction:column;gap:0.6rem;">
                        <!-- Active toggle -->
                        <label class="toggle-wrap" id="toggle-active-wrap">
                            <input type="checkbox" id="coupon-active" checked />
                            <span class="toggle-track"></span>
                            <span class="toggle-label">Cupón activo</span>
                        </label>
                        <!-- Exclusive toggle -->
                        <label class="toggle-wrap" id="toggle-exclusive-wrap">
                            <input type="checkbox" id="coupon-exclusive" />
                            <span class="toggle-track"></span>
                            <span class="toggle-label">Exclusivo — restringir a usuarios específicos</span>
                        </label>
                    </div>
                </div>

                <!-- Exclusive users section -->
                <div id="exclusive-section" style="display:none;margin-top:0.75rem;border:1px solid rgba(168,85,247,0.22);border-radius:8px;padding:0.875rem;background:rgba(168,85,247,0.04);">
                    <div style="display:flex;align-items:center;gap:0.4rem;margin-bottom:0.6rem;">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#c084fc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                        <span style="font-size:0.72rem;color:#c084fc;font-weight:600;letter-spacing:0.04em;">USUARIOS CON ACCESO</span>
                    </div>
                    <div style="position:relative;margin-bottom:0.5rem;">
                        <input
                            type="text" id="user-search-input" class="form-input"
                            placeholder="Buscar por nombre o email…"
                            autocomplete="off"
                            style="font-size:0.8rem;padding-right:2rem;"
                        />
                        <div id="user-search-results" style="display:none;position:absolute;top:100%;left:0;right:0;z-index:100;background:#1a1a2e;border:1px solid rgba(255,255,255,0.1);border-radius:0 0 6px 6px;max-height:160px;overflow-y:auto;"></div>
                    </div>
                    <div id="allowed-users-list" style="display:flex;flex-direction:column;gap:0.3rem;"></div>
                    <div id="allowed-users-empty" style="font-size:0.75rem;color:rgba(255,255,255,0.28);font-style:italic;">
                        Ningún usuario asignado — el cupón no podrá usarse.
                    </div>
                </div>

                <div class="modal-actions" style="margin-top:1.25rem;padding-top:0.875rem;border-top:1px solid rgba(255,255,255,0.07);">
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('coupon-modal').style.display='none'" style="font-size:0.82rem;">Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="coupon-submit-btn" style="font-size:0.82rem;">Crear</button>
                </div>
            </form>
        </div>
    </div>

    <script is:inline>
        (function () {
            var isEditing = false;
            // Block past dates in the expiry picker
            document.getElementById('coupon-expires').min = new Date().toISOString().slice(0, 10);
            // allowedUsers: array of { id, name, email }
            var allowedUsers = [];

            // ── Toggle switch visual sync ─────────────────────────────────────
            function syncToggle(checkboxId, wrapId, activeClass) {
                var cb = document.getElementById(checkboxId);
                var wrap = document.getElementById(wrapId);
                function update() {
                    if (cb.checked) wrap.classList.add(activeClass);
                    else wrap.classList.remove(activeClass);
                }
                cb.addEventListener('change', update);
                update();
            }
            syncToggle('coupon-active', 'toggle-active-wrap', 'toggle-active');
            syncToggle('coupon-exclusive', 'toggle-exclusive-wrap', 'toggle-exclusive');

            // ── Helpers ───────────────────────────────────────────────────────
            function renderAllowedUsers() {
                var list = document.getElementById('allowed-users-list');
                var empty = document.getElementById('allowed-users-empty');
                list.innerHTML = '';
                if (allowedUsers.length === 0) {
                    empty.style.display = '';
                    return;
                }
                empty.style.display = 'none';
                allowedUsers.forEach(function (u) {
                    var row = document.createElement('div');
                    row.style.cssText = 'display:flex;align-items:center;justify-content:space-between;background:rgba(168,85,247,0.08);border:1px solid rgba(168,85,247,0.2);border-radius:4px;padding:0.3rem 0.5rem;font-size:0.75rem;';
                    row.innerHTML =
                        '<span style="color:rgba(255,255,255,0.85);">' +
                        escHtml(u.name || u.email) +
                        ' <span style="color:rgba(255,255,255,0.4);">' + escHtml(u.email) + '</span></span>' +
                        '<button type="button" data-uid="' + escHtml(u.id) + '" style="background:none;border:none;color:rgba(255,100,100,0.7);cursor:pointer;font-size:0.8rem;padding:0 0.2rem;line-height:1;" title="Quitar">✕</button>';
                    row.querySelector('button').addEventListener('click', function () {
                        var uid = this.getAttribute('data-uid');
                        allowedUsers = allowedUsers.filter(function (x) { return x.id !== uid; });
                        renderAllowedUsers();
                    });
                    list.appendChild(row);
                });
            }

            function escHtml(str) {
                return String(str || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;');
            }

            // ── Exclusive toggle ──────────────────────────────────────────────
            document.getElementById('coupon-exclusive').addEventListener('change', function () {
                document.getElementById('exclusive-section').style.display =
                    this.checked ? '' : 'none';
            });

            // ── User search ───────────────────────────────────────────────────
            var searchTimeout = null;
            var searchInput = document.getElementById('user-search-input');
            var searchResults = document.getElementById('user-search-results');

            searchInput.addEventListener('input', function () {
                clearTimeout(searchTimeout);
                var q = this.value.trim();
                if (q.length < 2) { searchResults.style.display = 'none'; return; }
                searchTimeout = setTimeout(function () {
                    fetch('/api/admin/users?q=' + encodeURIComponent(q))
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            var users = (data.users || []).filter(function (u) {
                                return !allowedUsers.find(function (a) { return a.id === u.id; });
                            });
                            if (users.length === 0) {
                                searchResults.innerHTML = '<div style="padding:0.5rem 0.75rem;font-size:0.75rem;color:rgba(255,255,255,0.4);">Sin resultados</div>';
                            } else {
                                searchResults.innerHTML = users.map(function (u) {
                                    return '<div class="user-result" data-user=\'' + JSON.stringify(u).replace(/'/g, '&#39;') + '\' style="padding:0.4rem 0.75rem;cursor:pointer;font-size:0.8rem;border-bottom:1px solid rgba(255,255,255,0.05);">' +
                                        '<span style="color:rgba(255,255,255,0.85);">' + escHtml(u.name) + '</span>' +
                                        ' <span style="color:rgba(255,255,255,0.4);font-size:0.72rem;">' + escHtml(u.email) + '</span>' +
                                        '</div>';
                                }).join('');
                                searchResults.querySelectorAll('.user-result').forEach(function (el) {
                                    el.addEventListener('mouseenter', function () { this.style.background = 'rgba(168,85,247,0.15)'; });
                                    el.addEventListener('mouseleave', function () { this.style.background = ''; });
                                    el.addEventListener('click', function () {
                                        var u = JSON.parse(this.getAttribute('data-user'));
                                        if (!allowedUsers.find(function (a) { return a.id === u.id; })) {
                                            allowedUsers.push(u);
                                            renderAllowedUsers();
                                        }
                                        searchInput.value = '';
                                        searchResults.style.display = 'none';
                                    });
                                });
                            }
                            searchResults.style.display = '';
                        })
                        .catch(function () { searchResults.style.display = 'none'; });
                }, 280);
            });

            document.addEventListener('click', function (e) {
                if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                    searchResults.style.display = 'none';
                }
            });

            // ── Reset modal ───────────────────────────────────────────────────
            function resetModal() {
                document.getElementById('coupon-id').value = '';
                document.getElementById('coupon-code').value = '';
                document.getElementById('coupon-type').value = 'percentage';
                document.getElementById('coupon-value').value = '';
                document.getElementById('coupon-min').value = '';
                document.getElementById('coupon-max-uses').value = '';
                document.getElementById('coupon-expires').value = '';
                document.getElementById('coupon-active').checked = true;
                document.getElementById('coupon-exclusive').checked = false;
                document.getElementById('exclusive-section').style.display = 'none';
                // sync toggle visuals
                document.getElementById('toggle-active-wrap').classList.add('toggle-active');
                document.getElementById('toggle-exclusive-wrap').classList.remove('toggle-exclusive');
                allowedUsers = [];
                renderAllowedUsers();
                searchInput.value = '';
                searchResults.style.display = 'none';
            }

            // ── New coupon ────────────────────────────────────────────────────
            document.getElementById('btn-new-coupon').addEventListener('click', function () {
                isEditing = false;
                document.getElementById('coupon-modal-title').textContent = 'Nuevo Cupón';
                document.getElementById('coupon-submit-btn').textContent = 'Crear';
                resetModal();
                document.getElementById('coupon-modal').style.display = 'flex';
            });

            // ── Edit coupon ───────────────────────────────────────────────────
            document.querySelectorAll('.btn-edit-coupon').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    isEditing = true;
                    var c = JSON.parse(this.getAttribute('data-coupon'));
                    document.getElementById('coupon-modal-title').textContent = 'Editar Cupón';
                    document.getElementById('coupon-submit-btn').textContent = 'Guardar';
                    document.getElementById('coupon-id').value = c.id;
                    document.getElementById('coupon-code').value = c.code;
                    document.getElementById('coupon-type').value = c.type;
                    document.getElementById('coupon-value').value = c.value;
                    document.getElementById('coupon-min').value = c.min_purchase || '';
                    document.getElementById('coupon-max-uses').value = c.max_uses || '';
                    document.getElementById('coupon-expires').value = c.expires_at ? c.expires_at.slice(0, 10) : '';
                    document.getElementById('coupon-active').checked = c.is_active;
                    document.getElementById('coupon-exclusive').checked = !!c.is_exclusive;
                    document.getElementById('exclusive-section').style.display = c.is_exclusive ? '' : 'none';
                    // sync toggle visuals
                    if (c.is_active) document.getElementById('toggle-active-wrap').classList.add('toggle-active');
                    else document.getElementById('toggle-active-wrap').classList.remove('toggle-active');
                    if (c.is_exclusive) document.getElementById('toggle-exclusive-wrap').classList.add('toggle-exclusive');
                    else document.getElementById('toggle-exclusive-wrap').classList.remove('toggle-exclusive');
                    allowedUsers = Array.isArray(c.allowedUsers) ? c.allowedUsers.slice() : [];
                    renderAllowedUsers();
                    searchInput.value = '';
                    searchResults.style.display = 'none';
                    document.getElementById('coupon-modal').style.display = 'flex';
                });
            });

            // ── Delete coupon ─────────────────────────────────────────────────
            document.querySelectorAll('.btn-delete-coupon').forEach(function (btn) {
                btn.addEventListener('click', async function () {
                    var id = this.getAttribute('data-id');
                    var code = this.getAttribute('data-code');
                    if (!(await window.adminConfirm('¿Eliminar el cupón ' + code + '? Esta acción no se puede deshacer.'))) return;
                    try {
                        var res = await fetch('/api/admin/coupons?id=' + id, { method: 'DELETE' });
                        if (res.ok) {
                            window.adminToast('Cupón eliminado', 'success');
                            setTimeout(function () { window.location.reload(); }, 600);
                        } else {
                            window.adminToast('Error al eliminar', 'error');
                        }
                    } catch (err) {
                        window.adminToast('Error de conexión', 'error');
                    }
                });
            });

            // ── Submit form ───────────────────────────────────────────────────
            document.getElementById('coupon-form').addEventListener('submit', async function (e) {
                e.preventDefault();
                var couponId = document.getElementById('coupon-id').value;
                var isExclusive = document.getElementById('coupon-exclusive').checked;
                var payload = {
                    code:        document.getElementById('coupon-code').value,
                    type:        document.getElementById('coupon-type').value,
                    value:       document.getElementById('coupon-value').value,
                    minPurchase: document.getElementById('coupon-min').value || null,
                    maxUses:     document.getElementById('coupon-max-uses').value || null,
                    expiresAt:   document.getElementById('coupon-expires').value || null,
                    isActive:    document.getElementById('coupon-active').checked,
                    isExclusive: isExclusive,
                    allowedUsers: isExclusive ? allowedUsers.map(function (u) { return u.id; }) : [],
                };
                if (isEditing) payload.couponId = couponId;

                try {
                    var res = await fetch('/api/admin/coupons', {
                        method: isEditing ? 'PATCH' : 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    });
                    var data = await res.json();
                    if (res.ok) {
                        window.adminToast(isEditing ? 'Cupón actualizado' : 'Cupón creado', 'success');
                        document.getElementById('coupon-modal').style.display = 'none';
                        setTimeout(function () { window.location.reload(); }, 600);
                    } else {
                        window.adminToast(data.error || 'Error', 'error');
                    }
                } catch (err) {
                    window.adminToast('Error de conexión', 'error');
                }
            });
        })();
    </script>
</AdminLayout>
