---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="¡Gracias por tu compra!" robots="noindex, nofollow">
    <Header />
    <main
        class="min-h-screen py-24 flex items-center justify-center"
        style="background-color: var(--bg-primary);"
    >
        <div class="container max-w-2xl text-center">
            <div
                class="w-24 h-24 bg-brand text-black flex items-center justify-center mx-auto mb-10 rounded-full animate-bounce"
            >
                <svg
                    class="w-12 h-12"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"></path>
                </svg>
            </div>

            <h1
                class="font-display text-5xl md:text-6xl font-black uppercase tracking-tighter mb-6"
            >
                ¡PEDIDO <span class="text-brand">CONFIRMADO</span>!
            </h1>

            <p
                class="text-lg mb-8 text-[var(--text-secondary)] leading-relaxed"
            >
                Gracias por confiar en PARRA. Hemos recibido tu pago
                correctamente. Tu pedido está siendo procesado por nuestros
                expertos.
            </p>

            <!-- Order summary (populated from sessionStorage) -->
            <div id="order-summary-container" style="display:none;" class="mb-10"></div>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/shop" class="btn-glow inline-flex h-14 items-center">
                    Seguir Comprando
                </a>
                <a
                    href="/profile"
                    class="btn-glow inline-flex h-14 items-center"
                    style="background: transparent; color: var(--brand); border: 2px solid var(--brand); box-shadow: none;"
                    onmouseover="this.style.background='rgba(var(--brand-rgb),0.1)'"
                    onmouseout="this.style.background='transparent'"
                >
                    Ver mis pedidos
                </a>
            </div>
        </div>
    </main>
    <Footer />
</Layout>

<script>
    import { clearCart } from "../lib/cart";

    document.addEventListener("astro:page-load", async () => {
        if (window.location.pathname !== "/success") return;

        // Limpiar carrito local
        clearCart();

        // Show order summary from sessionStorage (saved by checkout before redirect)
        try {
            const raw = sessionStorage.getItem("lastOrderSummary");
            if (raw) {
                const summary = JSON.parse(raw);
                sessionStorage.removeItem("lastOrderSummary");
                const fmt = (n: number) =>
                    n.toLocaleString("es-ES", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " €";
                const container = document.getElementById("order-summary-container");
                if (container && summary) {
                    const itemsHtml = (summary.items || []).map((item: any) => `
                        <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border-color,#1e2433);">
                            ${item.image
                                ? `<img src="${item.image}" alt="${item.name}" style="width:52px;height:52px;object-fit:cover;border-radius:6px;flex-shrink:0;">`
                                : `<div style="width:52px;height:52px;background:#1a1a1a;border-radius:6px;flex-shrink:0;"></div>`
                            }
                            <div style="flex:1;min-width:0;text-align:left;">
                                <p style="margin:0 0 2px;font-size:14px;font-weight:700;color:var(--text-primary,#fff);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${item.name}</p>
                                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                                    ${item.size ? `<span style="font-size:11px;color:var(--brand);background:rgba(57,255,20,0.08);border:1px solid var(--brand);border-radius:4px;padding:1px 6px;">Talla ${item.size}</span>` : ""}
                                    <span style="font-size:11px;color:var(--text-muted,#6b7280);">× ${item.quantity}</span>
                                </div>
                            </div>
                            <span style="font-size:14px;font-weight:700;color:var(--text-primary,#fff);white-space:nowrap;">${fmt(item.price * item.quantity)}</span>
                        </div>`).join("");

                    container.innerHTML = `
                        <div style="background:var(--card-bg,#111);border:1px solid var(--brand);border-radius:10px;padding:20px 24px;max-width:420px;margin:0 auto;text-align:left;">
                            <p style="font-size:10px;font-weight:700;letter-spacing:0.2em;color:var(--text-muted);text-transform:uppercase;margin:0 0 12px;">Resumen del pedido</p>
                            ${itemsHtml}
                            <div style="padding-top:12px;margin-top:4px;">
                                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:5px;">
                                    <span style="color:var(--text-muted);">Productos</span>
                                    <span>${fmt(summary.subtotal)}</span>
                                </div>
                                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:12px;">
                                    <span style="color:var(--text-muted);">Envío</span>
                                    <span style="color:var(--brand);">${summary.shipping === 0 ? "Gratis" : fmt(summary.shipping)}</span>
                                </div>
                                <div style="height:1px;background:var(--border-color,#1e2433);margin-bottom:12px;"></div>
                                <div style="display:flex;justify-content:space-between;font-size:16px;font-weight:700;">
                                    <span>Total</span>
                                    <span style="color:var(--brand);">${fmt(summary.total)}</span>
                                </div>
                            </div>
                        </div>`;
                    container.style.display = "";
                }
            }
        } catch { /* non-critical */ }

        // Llamar al endpoint de respaldo para garantizar que el email se envíe
        // aunque el webhook de Stripe no haya llegado (localhost, webhook tardío, etc.)
        const params = new URLSearchParams(window.location.search);
        const sessionId = params.get("session_id");

        if (sessionId) {
            // Esperamos 3 segundos para dar tiempo al webhook de llegar primero
            await new Promise((resolve) => setTimeout(resolve, 3000));

            try {
                const res = await fetch("/api/stripe/confirm-order", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ session_id: sessionId }),
                });
                const data = await res.json();
                if (data.already_sent) {
                    console.log("[success] Email ya fue enviado por el webhook.");
                } else if (data.ok) {
                    console.log("[success] Orden confirmada y email enviado por endpoint de respaldo.");
                } else {
                    console.warn("[success] confirm-order respondió:", data);
                }
            } catch (err) {
                console.warn("[success] Error al llamar confirm-order:", err);
            }
        }
    });
</script>
