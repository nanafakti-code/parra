---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import ProductCard from "../../components/ProductCard.astro";
import Footer from "../../components/Footer.astro";
import { supabase } from "../../lib/supabase";

const { slug } = Astro.params;

// Fetch main product
let product: any = null;
try {
    const { data } = await supabase
        .from("products")
        .select("*, categories(name, slug)")
        .eq("slug", slug)
        .eq("is_active", true)
        .single();
    product = data;
} catch (e) {
    console.error("Supabase product detail error:", e);
}

if (!product) {
    return Astro.redirect("/shop");
}

// Cache pública del producto (10 min CDN, stale-while-revalidate 30 min)
Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=600, stale-while-revalidate=1800",
);

// Fetch images + variants + related en paralelo
const [{ data: images }, { data: variants }, { data: relatedRaw }] =
    await Promise.all([
        supabase
            .from("product_images")
            .select("*")
            .eq("product_id", product.id)
            .order("display_order"),
        supabase
            .from("product_variants")
            .select("*")
            .eq("product_id", product.id)
            .eq("is_active", true)
            .order("size"),
        supabase
            .from("products")
            .select("*, categories(name, slug)")
            .eq("is_active", true)
            .eq("category_id", product.category_id)
            .neq("id", product.id)
            .limit(4),
    ]);

const relatedProducts: any[] = relatedRaw || [];

// Extra gallery images for specific products (fallback when DB images missing)
const extraGalleries: Record<
    string,
    Array<{ url: string; alt_text?: string }>
> = {
    "parra-kids": [
        {
            url: "https://res.cloudinary.com/djvj32zic/image/upload/v1772482267/SaveClip.App_640870346_18028056920616241_3257153926183807774_n_tktfgq.jpg",
            alt_text: "Parra Kids 1",
        },
        {
            url: "https://res.cloudinary.com/djvj32zic/image/upload/v1772482267/SaveClip.App_641732915_18028056917616241_450452175200423146_n_b9fyjr.jpg",
            alt_text: "Parra Kids 2",
        },
        {
            url: "https://res.cloudinary.com/djvj32zic/image/upload/v1772482267/SaveClip.App_642485756_18028056929616241_8015745512839676158_n_tu1y0o.jpg",
            alt_text: "Parra Kids 3",
        },
        {
            url: "https://res.cloudinary.com/djvj32zic/image/upload/v1772482267/SaveClip.App_641755575_18028056884616241_5518621849251149366_n_d3gfr5.jpg",
            alt_text: "Parra Kids 4",
        },
        {
            url: "https://res.cloudinary.com/djvj32zic/image/upload/v1772482267/SaveClip.App_642491909_18028056896616241_4204515129068799710_n_fpem6v.jpg",
            alt_text: "Parra Kids 5",
        },
    ],
};

// Normalize images fetched from DB: ensure they have `url` and `alt_text`
const dbImages = (images || [])
    .map((img: any) => {
        if (!img) return null;
        const url =
            img.url ||
            img.image ||
            img.product_image ||
            img.productImage ||
            null;
        return url
            ? {
                  url: url as string,
                  alt_text: (img.alt_text || img.alt || product.name) as string,
              }
            : null;
    })
    .filter((x): x is { url: string; alt_text: string } => x !== null);

// Helper to deduplicate by URL while preserving order
function uniqueByUrl(arr: Array<{ url: string; alt_text?: string }>) {
    const seen = new Set<string>();
    const out: Array<{ url: string; alt_text?: string }> = [];
    for (const it of arr) {
        if (!it || !it.url) continue;
        if (seen.has(it.url)) continue;
        seen.add(it.url);
        out.push(it);
    }
    return out;
}

let merged: Array<{ url: string; alt_text?: string }> = [];
// Prefer DB images if present (they are the source of truth). Otherwise use the code fallback gallery.
if (dbImages.length > 0) {
    merged = [{ url: product.image, alt_text: product.name }, ...dbImages];
} else if (extraGalleries[product.slug]) {
    merged = [
        ...extraGalleries[product.slug],
        { url: product.image, alt_text: product.name },
    ];
} else {
    merged = [{ url: product.image, alt_text: product.name }];
}

const allImages = uniqueByUrl(merged).filter((img) => img && img.url);

const hasDiscount =
    product.compare_price && product.compare_price > product.price;
const discountPercent = hasDiscount
    ? Math.round(
          ((product.compare_price - product.price) / product.compare_price) *
              100,
      )
    : 0;

const specs = [
    { title: "Descripción", content: product.description },
    {
        title: "Materiales",
        content:
            "Látex de contacto alemán premium. Dorso de malla transpirable con protección EVA. Cierre de muñeca ajustable con banda elástica reforzada.",
    },
    {
        title: "Cuidado",
        content:
            "Lavar a mano con agua tibia y jabón neutro. Secar a la sombra. No usar secadora. Usar limpiador específico para guantes de portero para mantener la adherencia del látex.",
    },
    {
        title: "Envío",
        content:
            "Envío gratuito en pedidos superiores a 60€. Entrega en 24-48h en Península. Devoluciones gratuitas en 30 días.",
    },
];

// ── JSON-LD: Product schema ─────────────────────────────────────────────
const SITE = "https://parragkgloves.es";
const productUrl = `${SITE}/product/${product.slug}`;

const productSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: `${product.name} – Guantes de Portero Parra GK Gloves`,
    description:
        product.short_description ||
        product.description ||
        "Guantes de portero profesionales con látex alemán de alta adherencia.",
    brand: { "@type": "Brand", name: "Parra GK Gloves" },
    url: productUrl,
    image: allImages.map((img) => img.url),
    sku: product.id,
    category: product.categories?.name || "Guantes de Portero",
    offers: {
        "@type": "Offer",
        url: productUrl,
        priceCurrency: "EUR",
        price: product.price.toFixed(2),
        priceValidUntil: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000)
            .toISOString()
            .split("T")[0],
        availability:
            variants && variants.some((v: any) => v.stock > 0)
                ? "https://schema.org/InStock"
                : "https://schema.org/OutOfStock",
        seller: { "@type": "Organization", name: "Parra GK Gloves" },
        shippingDetails: {
            "@type": "OfferShippingDetails",
            shippingRate: {
                "@type": "MonetaryAmount",
                value: "0",
                currency: "EUR",
            },
            shippingDestination: {
                "@type": "DefinedRegion",
                addressCountry: "ES",
            },
        },
        hasMerchantReturnPolicy: {
            "@type": "MerchantReturnPolicy",
            returnPolicyCategory:
                "https://schema.org/MerchantReturnFiniteReturnWindow",
            merchantReturnDays: 30,
        },
    },
});

// ── JSON-LD: BreadcrumbList ─────────────────────────────────────────────
const productBreadcrumb = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "Inicio", item: `${SITE}/` },
        {
            "@type": "ListItem",
            position: 2,
            name: "Tienda",
            item: `${SITE}/shop`,
        },
        ...(product.categories
            ? [
                  {
                      "@type": "ListItem",
                      position: 3,
                      name: product.categories.name,
                      item: `${SITE}/shop?category=${product.categories.slug}`,
                  },
              ]
            : []),
        {
            "@type": "ListItem",
            position: product.categories ? 4 : 3,
            name: product.name,
            item: productUrl,
        },
    ],
});

const productSchemaJson = `[${productSchema},${productBreadcrumb}]`;

// ── SEO Strings ────────────────────────────────────────────────────────
const seoTitle = `${product.name} – Guantes de Portero | Parra GK Gloves`;
const seoDescription = product.short_description
    ? `${product.short_description.slice(0, 130)} · Envío gratis en España · Parra GK Gloves`
    : `Compra ${product.name}, guantes de portero profesionales de Parra GK Gloves. Látex alemán, grip élite. Envío gratis y devolución 30 días.`;
---

<Layout
    title={seoTitle}
    description={seoDescription}
    image={allImages[0]?.url || "https://parragkgloves.es/og-image.jpg"}
    schemaJson={productSchemaJson}
>
    <Header />
    <main class="min-h-screen" style="background-color: var(--bg-primary);">
        <!-- Breadcrumb -->
        <div class="container pt-8">
            <div
                class="flex items-center gap-2 text-xs uppercase tracking-[0.2em] mb-8"
                style="color: var(--text-muted);"
            >
                <a href="/" class="hover:text-brand transition-colors">Inicio</a
                >
                <span>/</span>
                <a href="/shop" class="hover:text-brand transition-colors"
                    >Tienda</a
                >
                <span>/</span>
                {
                    product.categories && (
                        <>
                            <a
                                href={`/shop?category=${product.categories.slug}`}
                                class="hover:text-brand transition-colors"
                            >
                                {product.categories.name}
                            </a>
                            <span>/</span>
                        </>
                    )
                }
                <span style="color: var(--text-secondary);">{product.name}</span
                >
            </div>
        </div>

        <!-- Product Detail -->
        <section class="pb-20">
            <div class="container">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
                    <!-- Image Gallery -->
                    <div class="space-y-4">
                        <!-- Main Image -->
                        <div
                            class="aspect-square overflow-hidden relative group"
                            style="background-color: var(--bg-secondary); border: 1px solid var(--border-color);"
                        >
                            <img
                                id="main-image"
                                src={allImages[0]?.url}
                                alt={product.name}
                                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                            />
                            <!-- PRO badge removed -->
                            {
                                hasDiscount && (
                                    <span class="badge-sale absolute top-4 right-4">
                                        -{discountPercent}%
                                    </span>
                                )
                            }
                        </div>

                        <!-- Thumbnails -->
                        {
                            allImages.length > 1 && (
                                <div class="flex gap-3 overflow-x-auto pb-2">
                                    {allImages.map((img, i) => (
                                        <button
                                            class:list={[
                                                "thumb-btn w-20 h-20 flex-shrink-0 border overflow-hidden transition-all duration-200",
                                                i === 0
                                                    ? "border-brand"
                                                    : "border-[var(--border-color)] hover:border-[var(--text-muted)]",
                                            ]}
                                            data-src={img.url}
                                        >
                                            <img
                                                src={img.url}
                                                alt={
                                                    img.alt_text || product.name
                                                }
                                                class="w-full h-full object-cover"
                                            />
                                        </button>
                                    ))}
                                </div>
                            )
                        }
                    </div>

                    <!-- Product Info -->
                    <div class="lg:py-4">
                        {/* Category */}
                        {
                            product.categories && (
                                <span class="text-brand text-xs font-bold uppercase tracking-[0.2em] mb-3 block">
                                    {product.categories.name}
                                </span>
                            )
                        }

                        <h1
                            class="font-display text-4xl md:text-5xl font-bold uppercase tracking-tight mb-6"
                        >
                            {product.name}
                        </h1>

                        {/* Price */}
                        <div class="flex items-center gap-4 mb-6">
                            <span class="text-3xl font-bold"
                                >€{product.price.toFixed(2)}</span
                            >
                            {
                                hasDiscount && (
                                    <>
                                        <span
                                            class="text-lg line-through"
                                            style="color: var(--text-muted);"
                                        >
                                            €{product.compare_price.toFixed(2)}
                                        </span>
                                        <span class="badge-sale">
                                            -{discountPercent}%
                                        </span>
                                    </>
                                )
                            }
                        </div>

                        {/* Short Description */}
                        {
                            product.short_description && (
                                <p
                                    class="leading-relaxed mb-8"
                                    style="color: var(--text-secondary);"
                                >
                                    {product.short_description}
                                </p>
                            )
                        }

                        {/* Size Selector */}
                        {
                            variants && variants.length > 0 && (
                                <div class="mb-8">
                                    <div class="flex justify-between items-center mb-3">
                                        <span
                                            class="text-xs font-bold uppercase tracking-[0.2em]"
                                            style="color: var(--text-secondary);"
                                        >
                                            Talla
                                        </span>
                                        <a
                                            href="#"
                                            class="text-xs text-brand hover:underline"
                                        >
                                            Guía de tallas
                                        </a>
                                    </div>
                                    <div
                                        class="flex flex-wrap gap-2"
                                        id="size-selector"
                                    >
                                        {variants.map((v: any, i: number) => (
                                            <button
                                                class:list={[
                                                    "size-btn w-14 h-14 border flex items-center justify-center text-sm font-bold uppercase transition-all duration-200",
                                                    i === 0
                                                        ? "border-brand bg-brand/10 text-brand"
                                                        : "border-[var(--border-color)] text-[var(--text-muted)] hover:border-brand/50 hover:text-brand",
                                                    v.stock <= 0 &&
                                                        "opacity-30 pointer-events-none line-through",
                                                ]}
                                                data-size={v.size}
                                                data-stock={v.stock}
                                                data-variant-id={v.id}
                                                disabled={v.stock <= 0}
                                            >
                                                {v.size}
                                            </button>
                                        ))}
                                    </div>
                                    <p
                                        id="stock-info"
                                        class="text-xs mt-2"
                                        style="color: var(--text-muted);"
                                    >
                                        {variants[0]?.stock > 0
                                            ? `${variants[0].stock} disponibles`
                                            : "Agotado"}
                                    </p>
                                </div>
                            )
                        }

                        {/* Add to Cart */}
                        <div class="flex gap-3 mb-8">
                            <button
                                id="add-to-cart-btn"
                                class="btn-glow flex-1 flex items-center justify-center gap-3 h-14"
                                data-product-id={product.id}
                                data-price={product.price}
                                data-name={product.name}
                                data-image={product.image ||
                                    (product.variants &&
                                        product.variants[0]?.image) ||
                                    ""}
                            >
                                <svg
                                    class="w-5 h-5"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"
                                    ></path>
                                </svg>
                                Añadir al Carrito
                            </button>
                        </div>

                        {/* Benefits Row */}
                        <div
                            class="grid grid-cols-3 gap-4 mb-10 py-6"
                            style="border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);"
                        >
                            <div class="text-center">
                                <svg
                                    class="w-5 h-5 text-brand mx-auto mb-2"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="1.5"
                                        d="M5 13l4 4L19 7"></path>
                                </svg>
                                <span
                                    class="text-[10px] uppercase tracking-wider"
                                    style="color: var(--text-muted);"
                                    >Envío Gratis +60€</span
                                >
                            </div>
                            <div class="text-center">
                                <svg
                                    class="w-5 h-5 text-brand mx-auto mb-2"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="1.5"
                                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                                    ></path>
                                </svg>
                                <span
                                    class="text-[10px] uppercase tracking-wider"
                                    style="color: var(--text-muted);"
                                    >Devolución 30 días</span
                                >
                            </div>
                            <div class="text-center">
                                <svg
                                    class="w-5 h-5 text-brand mx-auto mb-2"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="1.5"
                                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                    ></path>
                                </svg>
                                <span
                                    class="text-[10px] uppercase tracking-wider"
                                    style="color: var(--text-muted);"
                                    >Garantía incluida</span
                                >
                            </div>
                        </div>

                        {/* Specs Accordion */}
                        <div class="space-y-0" id="specs-accordion">
                            {
                                specs.map((spec, i) => (
                                    <div style="border-bottom: 1px solid var(--border-color);">
                                        <button
                                            class="accordion-trigger w-full flex justify-between items-center py-4 text-left"
                                            data-index={i}
                                        >
                                            <span class="text-sm font-semibold uppercase tracking-wider">
                                                {spec.title}
                                            </span>
                                            <svg
                                                class="accordion-icon w-4 h-4 transition-transform duration-300"
                                                style="color: var(--text-muted);"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M19 9l-7 7-7-7"
                                                />
                                            </svg>
                                        </button>
                                        <div
                                            class:list={[
                                                "accordion-content overflow-hidden transition-all duration-300",
                                                i === 0
                                                    ? "max-h-96"
                                                    : "max-h-0",
                                            ]}
                                            data-index={i}
                                        >
                                            <p
                                                class="text-sm leading-relaxed pb-4"
                                                style="color: var(--text-muted);"
                                            >
                                                {spec.content}
                                            </p>
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Related Products -->
        {
            relatedProducts && relatedProducts.length > 0 && (
                <section
                    class="section"
                    style="border-top: 1px solid var(--border-color);"
                >
                    <div class="container">
                        <h2 class="section-title mb-12">
                            También Te Puede{" "}
                            <span class="text-brand">Gustar</span>
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
                            {relatedProducts.map((p: any, i: number) => (
                                <ProductCard product={p} index={i} />
                            ))}
                        </div>
                    </div>
                </section>
            )
        }
    </main>
    <Footer />
</Layout>

<script>
    import { addItem } from "../../lib/cart";

    function initProductPage() {
        // Thumbnail gallery
        const thumbButtons = Array.from(
            document.querySelectorAll(".thumb-btn"),
        ) as HTMLButtonElement[];

        thumbButtons.forEach(function (btn) {
            const img = btn.querySelector("img") as HTMLImageElement | null;
            const src = btn.dataset.src || (img && img.src) || null;

            // If no src, remove the thumbnail
            if (!src) {
                btn.remove();
                return;
            }

            // If image fails to load, remove the thumbnail
            if (img) {
                img.addEventListener("error", function () {
                    btn.remove();
                });
                img.addEventListener("load", function () {
                    if (img.naturalWidth === 0) btn.remove();
                });
            }

            btn.addEventListener("click", function () {
                var mainImg = document.getElementById(
                    "main-image",
                ) as HTMLImageElement;
                if (mainImg && src) {
                    mainImg.src = src;
                }
                // Update active classes
                document.querySelectorAll(".thumb-btn").forEach(function (b) {
                    b.classList.remove("border-brand");
                    b.classList.add("border-[var(--border-color)]");
                });
                btn.classList.add("border-brand");
                btn.classList.remove("border-[var(--border-color)]");
            });
        });

        // After bindings, remove any thumbnails that became empty and set initial main image
        (function finalizeGallery() {
            const remaining = Array.from(
                document.querySelectorAll(".thumb-btn"),
            ) as HTMLButtonElement[];
            const mainImg = document.getElementById(
                "main-image",
            ) as HTMLImageElement | null;

            if (remaining.length === 0) {
                // no thumbs, ensure main image exists
                if (mainImg && (!mainImg.src || mainImg.src.trim() === "")) {
                    mainImg.src = "/images/placeholder-product.svg";
                }
                return;
            }

            // If main image is missing or failed, pick the first valid thumb
            if (mainImg && (!mainImg.src || mainImg.src.trim() === "")) {
                const first = remaining[0];
                const src =
                    first.dataset.src ||
                    (first.querySelector("img") as HTMLImageElement).src;
                if (src) mainImg.src = src;
            }

            // Mark first visible thumb as active if none active
            const hasActive = remaining.some((b) =>
                b.classList.contains("border-brand"),
            );
            if (!hasActive) {
                remaining[0].classList.add("border-brand");
            }
        })();

        // Size selector
        document.querySelectorAll(".size-btn").forEach(function (btnEl) {
            const btn = btnEl as HTMLButtonElement;
            btn.addEventListener("click", function () {
                document.querySelectorAll(".size-btn").forEach(function (b) {
                    b.classList.remove(
                        "border-brand",
                        "bg-brand/10",
                        "text-brand",
                    );
                    b.classList.add(
                        "border-[var(--border-color)]",
                        "text-[var(--text-muted)]",
                    );
                });
                btn.classList.add("border-brand", "bg-brand/10", "text-brand");
                btn.classList.remove(
                    "border-[var(--border-color)]",
                    "text-[var(--text-muted)]",
                );

                var stock = parseInt(btn.dataset.stock || "0");
                var stockInfo = document.getElementById("stock-info");
                if (stockInfo) {
                    stockInfo.textContent =
                        stock > 0 ? stock + " disponibles" : "Agotado";
                }
            });
        });

        // Accordion
        document
            .querySelectorAll(".accordion-trigger")
            .forEach(function (triggerEl) {
                const trigger = triggerEl as HTMLButtonElement;
                trigger.addEventListener("click", function () {
                    var index = trigger.dataset.index;
                    var content = document.querySelector(
                        '.accordion-content[data-index="' + index + '"]',
                    );
                    var icon = trigger.querySelector(".accordion-icon");

                    if (content) {
                        if (content.classList.contains("max-h-0")) {
                            content.classList.remove("max-h-0");
                            content.classList.add("max-h-96");
                            if (icon) icon.classList.add("rotate-180");
                        } else {
                            content.classList.add("max-h-0");
                            content.classList.remove("max-h-96");
                            if (icon) icon.classList.remove("rotate-180");
                        }
                    }
                });
            });

        // Add to cart
        var addToCartBtn = document.getElementById(
            "add-to-cart-btn",
        ) as HTMLButtonElement;
        if (addToCartBtn) {
            addToCartBtn.addEventListener("click", async function () {
                var productId = addToCartBtn.dataset.productId!;
                var selectedSizeBtn = document.querySelector(
                    ".size-btn.border-brand",
                ) as HTMLButtonElement;

                if (
                    !selectedSizeBtn &&
                    document.getElementById("size-selector")
                ) {
                    alert("Por favor, selecciona una talla");
                    return;
                }

                const variantId = selectedSizeBtn?.dataset.variantId;
                const size = selectedSizeBtn?.dataset.size;
                const stock = parseInt(
                    selectedSizeBtn?.dataset.stock ||
                        addToCartBtn.dataset.stock ||
                        "0",
                );

                const productName = addToCartBtn?.dataset.name || "Producto";
                const productPrice = parseFloat(
                    addToCartBtn?.dataset.price || "0",
                );
                const productImage = addToCartBtn?.dataset.image || "";
                const productSlug =
                    window.location.pathname.split("/").pop() || "";

                await addItem({
                    id: productId,
                    variantId,
                    name: productName,
                    price: productPrice,
                    image: productImage,
                    size,
                    stock,
                    slug: productSlug,
                    quantity: 1,
                });

                addToCartBtn.innerHTML =
                    '<span class="flex items-center gap-2"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> ¡Añadido!</span>';

                setTimeout(function () {
                    addToCartBtn.innerHTML =
                        '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg> Añadir al Carrito';
                }, 2000);
            });
        }
    }

    // Run on every page load (including View Transitions)
    document.addEventListener("astro:page-load", initProductPage);
</script>
