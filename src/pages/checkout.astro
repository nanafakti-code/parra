---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { supabaseAdmin } from "../lib/supabase";

// Pre-fill email if logged in
const { user } = Astro.locals;

// Cargar direcciones + configuración de envío en paralelo
let savedAddresses: any[] = [];
let shippingConfig = { free_threshold: 50, standard_cost: 4.99, express_cost: 9.99, express_cost_over_threshold: 5.00 };

const [addressesResult, shippingResult] = await Promise.all([
    user
        ? supabaseAdmin
              .from("addresses")
              .select("*")
              .eq("user_id", user.id)
              .order("is_default", { ascending: false })
        : Promise.resolve({ data: [] as any[], error: null }),
    supabaseAdmin.from("site_settings").select("value").eq("key", "shipping").maybeSingle(),
]);

savedAddresses = addressesResult.data ?? [];
if (shippingResult.data?.value) {
    shippingConfig = { ...shippingConfig, ...(shippingResult.data.value as any) };
}

const stripePubKey =
    import.meta.env.STRIPE_PUBLIC_KEY ||
    process.env.STRIPE_PUBLIC_KEY ||
    ""; // Sin fallback inválido — si falta la variable, Stripe fallará de forma explícita
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
---

<Layout title="Pago Seguro" robots="noindex, nofollow">
    <Header />
    <main
        class="min-h-screen py-24"
        style="background-color: var(--bg-primary);"
    >
        <div class="container max-w-4xl">
            <!-- Breadcrumb -->
            <div
                class="flex items-center gap-2 text-xs uppercase tracking-[0.2em] mb-8"
                style="color: var(--text-muted);"
            >
                <a href="/" class="hover:text-brand transition-colors">Inicio</a
                >
                <span>/</span>
                <a href="/cart" class="hover:text-brand transition-colors"
                    >Carrito</a
                >
                <span>/</span>
                <span style="color: var(--text-secondary);">Checkout</span>
            </div>

            <h1 class="section-title mb-12">
                Finalizar <span class="text-brand">Compra</span>
            </h1>

            <div
                id="checkout-form-container"
                class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16"
            >
                <!-- Shipping Info -->
                <section class="space-y-6">
                    <div class="flex items-center gap-3 text-brand mb-2">
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
                            ></path>
                        </svg>
                        <h2
                            class="font-display text-lg font-semibold uppercase tracking-tight"
                        >
                            Datos de Envío
                        </h2>
                    </div>

                    {/* ── Selector de direcciones guardadas ── */}
                    {
                        savedAddresses.length > 0 && (
                            <div class="card p-4 space-y-3">
                                <p
                                    class="text-[10px] font-bold uppercase tracking-[0.2em]"
                                    style="color: var(--text-muted);"
                                >
                                    Mis direcciones guardadas
                                </p>
                                <div
                                    id="saved-addresses-list"
                                    class="grid gap-2"
                                >
                                    {savedAddresses.map((addr: any) => (
                                        <button
                                            type="button"
                                            class:list={[
                                                "saved-addr-card text-left w-full p-3 border transition-colors hover:border-brand/50",
                                                addr.is_default
                                                    ? "border-brand/40 bg-brand/5"
                                                    : "",
                                            ]}
                                            style={
                                                addr.is_default
                                                    ? ""
                                                    : "border-color: var(--border-color);"
                                            }
                                            data-addr={JSON.stringify({
                                                full_name: addr.full_name,
                                                street: addr.street,
                                                city: addr.city,
                                                postal_code: addr.postal_code,
                                                phone: addr.phone ?? "",
                                            })}
                                        >
                                            <span class="flex items-center justify-between gap-2 flex-wrap">
                                                <span class="font-semibold text-xs">
                                                    {addr.full_name} —{" "}
                                                    {addr.label || "Dirección"}
                                                </span>
                                                {addr.is_default && (
                                                    <span class="text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 bg-brand/10 text-brand">
                                                        Predeterminada
                                                    </span>
                                                )}
                                            </span>
                                            <span
                                                class="block text-[11px] mt-0.5"
                                                style="color: var(--text-muted);"
                                            >
                                                {addr.street},{" "}
                                                {addr.postal_code} {addr.city}
                                            </span>
                                        </button>
                                    ))}
                                </div>
                                <button
                                    type="button"
                                    id="addr-manual-btn"
                                    class="text-[10px] uppercase tracking-widest py-1 hover:text-brand transition-colors"
                                    style="color: var(--text-muted);"
                                >
                                    + Introducir dirección manualmente
                                </button>
                            </div>
                        )
                    }

                    <form id="checkout-form" class="space-y-4">
                        <input
                            type="email"
                            id="input-email"
                            placeholder="Email para seguimiento"
                            required
                            class="input"
                            value={user?.email || ""}
                        />
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <input
                                id="input-nombre"
                                placeholder="Nombre"
                                required
                                class="input"
                            />
                            <input
                                id="input-apellidos"
                                placeholder="Apellidos"
                                required
                                class="input"
                            />
                        </div>
                        <input
                            id="input-direccion"
                            placeholder="Dirección"
                            required
                            class="input"
                        />
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <input
                                id="input-ciudad"
                                placeholder="Ciudad"
                                required
                                class="input"
                            />
                            <input
                                id="input-cp"
                                placeholder="Código Postal"
                                required
                                class="input"
                            />
                        </div>
                        <input
                            id="input-telefono"
                            placeholder="Teléfono"
                            type="tel"
                            class="input"
                        />
                    </form>

                    <!-- Método de Envío -->
                    <div class="space-y-3">
                        <p
                            class="text-[10px] font-bold uppercase tracking-[0.2em]"
                            style="color: var(--text-muted);"
                        >
                            Método de Envío
                        </p>
                        <div class="space-y-2" id="shipping-options">
                            <button
                                type="button"
                                id="option-standard"
                                class="shipping-opt w-full flex items-center justify-between p-4 border transition-all text-left border-brand/40 bg-brand/5"
                                data-method="standard"
                            >
                                <div>
                                    <span class="font-semibold text-sm block"
                                        >Envío Estándar</span
                                    >
                                    <span
                                        class="text-[11px]"
                                        style="color: var(--text-muted);"
                                        >3-5 días hábiles</span
                                    >
                                </div>
                                <span
                                    id="cost-standard"
                                    class="text-sm font-bold text-brand"
                                >{shippingConfig.standard_cost.toFixed(2)} €</span>
                            </button>
                            <button
                                type="button"
                                id="option-express"
                                class="shipping-opt w-full flex items-center justify-between p-4 border transition-all text-left"
                                style="border-color: var(--border-color);"
                                data-method="express"
                            >
                                <div>
                                    <span class="font-semibold text-sm block"
                                        >Envío Express</span
                                    >
                                    <span
                                        class="text-[11px]"
                                        style="color: var(--text-muted);"
                                        >24-48 h</span
                                    >
                                </div>
                                <span
                                    id="cost-express"
                                    class="text-sm font-bold text-brand"
                                >{shippingConfig.express_cost.toFixed(2)} €</span>
                            </button>
                        </div>
                    </div>
                </section>

                <!-- Payment -->
                <section class="space-y-6">
                    <div class="flex items-center gap-3 text-brand mb-2">
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                            ></path>
                        </svg>
                        <h2
                            class="font-display text-lg font-semibold uppercase tracking-tight"
                        >
                            Método de Pago
                        </h2>
                    </div>

                    <!-- Resumen del pedido -->
                    <div class="card p-4 space-y-2" id="order-summary">
                        <p
                            class="text-[10px] font-bold uppercase tracking-[0.2em] pb-1"
                            style="color: var(--text-muted);"
                        >
                            Resumen del pedido
                        </p>
                        <div class="flex justify-between text-sm">
                            <span style="color: var(--text-muted);">Productos</span>
                            <span id="summary-products" class="font-semibold">—</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span style="color: var(--text-muted);">Envío</span>
                            <span id="summary-shipping" class="font-semibold text-brand">—</span>
                        </div>
                        <div id="summary-discount-row" class="flex justify-between text-sm" style="display:none;">
                            <span style="color: var(--text-muted);">
                                Descuento <span id="summary-discount-code" class="font-mono" style="color:var(--brand);font-size:0.65rem;"></span>
                            </span>
                            <span id="summary-discount-amount" class="font-semibold" style="color:#4ade80;"></span>
                        </div>
                        <div
                            class="h-px mt-1"
                            style="background: var(--border-color);"
                        ></div>
                        <div class="flex justify-between text-sm font-bold pt-1">
                            <span>Total</span>
                            <span id="summary-total" class="text-brand text-base">—</span>
                        </div>
                    </div>

                    <div class="card p-6 space-y-4">
                        <div
                            id="payment-element"
                            class="min-h-[150px] p-2 bg-brand/5 border border-brand/20 rounded flex items-center justify-center"
                        >
                            <span
                                id="payment-element-placeholder"
                                style="color: var(--text-muted);"
                                class="text-sm text-center"
                                >Completa la verificación de seguridad para cargar el pago</span
                            >
                        </div>
                        <div
                            id="payment-message"
                            class="hidden text-red-500 text-sm mt-2 font-semibold"
                        >
                        </div>
                        <p
                            class="text-[10px] uppercase tracking-[0.2em] text-center"
                            style="color: var(--text-muted);"
                        >
                            Transacción segura y encriptada
                        </p>
                    </div>

                    <!-- Cloudflare Turnstile — verificación anti-bot -->
                    <div
                        class="cf-turnstile"
                        data-sitekey={turnstileSiteKey}
                        data-callback="onTurnstileVerified"
                    ></div>

                    <button
                        id="place-order-btn"
                        class="btn-glow w-full h-14 flex items-center justify-center gap-3 text-base opacity-40 cursor-not-allowed"
                        disabled
                    >
                        Pagar y Finalizar
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path>
                        </svg>
                    </button>
                </section>
            </div>

            <!-- Success State -->
            <div id="success-message" class="hidden py-24 text-center">
                <div
                    class="w-20 h-20 bg-brand text-black flex items-center justify-center mx-auto mb-8"
                >
                    <svg
                        class="w-10 h-10"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>
                <h2 class="section-title mb-4">
                    ¡Pedido <span class="text-brand">Confirmado</span>!
                </h2>
                <p
                    class="mb-8 max-w-md mx-auto"
                    style="color: var(--text-muted);"
                >
                    Gracias por confiar en PARRA. Recibirás un email con los
                    detalles de tu pedido.
                </p>
                <a href="/profile" class="btn-outline inline-flex"
                    >Ver mis pedidos</a
                >
            </div>
        </div>
    </main>
    <Footer />
</Layout>

<style>
    @media (max-width: 767px) {
        .container {
            padding-left: 12px;
            padding-right: 12px;
        }
        #checkout-form-container {
            gap: 18px !important;
        }
        .card.p-6,
        .card.p-4 {
            padding: 12px !important;
        }
        .btn-glow {
            height: 48px;
            font-size: 15px;
        }
        .saved-addr-card {
            padding: 10px;
            font-size: 14px;
        }
        .input {
            padding: 10px 12px;
        }
    }
</style>

<script is:inline src="https://js.stripe.com/v3/"></script>
<script is:inline define:vars={{ stripePubKey }}>
    window.STRIPE_PUBLIC_KEY = stripePubKey;
</script>
<script is:inline define:vars={{ shippingConfig }}>
    window.SHIPPING_CONFIG = {
        freeThreshold:       shippingConfig.free_threshold,
        standardCost:        shippingConfig.standard_cost,
        expressCost:         shippingConfig.express_cost,
        expressOverThreshold: shippingConfig.express_cost_over_threshold ?? 5.00,
    };
</script>
<!-- Buffer inline: captura el token de Turnstile aunque dispare antes de que el módulo JS esté listo -->
<script is:inline>
    // Si Turnstile completa ANTES de que el módulo principal cargue,
    // guardamos el token y lo consumimos cuando el módulo se inicialice.
    window.__cfTokenBuffer = null;
    window.onTurnstileVerified = function (token) {
        window.__cfTokenBuffer = token;
        // Si el módulo ya está listo, invocarlo directamente
        if (typeof window.__stripeInit === 'function') {
            window.__stripeInit(token);
            window.__cfTokenBuffer = null;
        }
    };
</script>
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
    import { getCart, getSessionId, clearCart, removeItem } from "../lib/cart";

    let stripe: any = null;
    let elements: any = null;
    let clientSecret: string | null = null;
    let piId: string | null = null;
    let selectedShippingMethod = "standard";

    // ── Shipping UI helpers ─────────────────────────────────────────────────
    function updateShippingUI() {
        const cfg = (window as any).SHIPPING_CONFIG || { freeThreshold: 50, standardCost: 4.99, expressCost: 9.99, expressOverThreshold: 5.00 };
        const cart = getCart();
        const subtotal = cart.reduce((s: number, i: any) => s + (Number(i.price) * Number(i.quantity)), 0);
        const isFree = subtotal >= cfg.freeThreshold;
        const stdEl = document.getElementById("cost-standard");
        const expEl = document.getElementById("cost-express");
        if (stdEl) stdEl.textContent = isFree ? "Gratis" : `${cfg.standardCost.toFixed(2)} €`;
        if (expEl) expEl.textContent = isFree ? `${cfg.expressOverThreshold.toFixed(2)} €` : `${cfg.expressCost.toFixed(2)} €`;
        updateOrderSummary();
    }

    function updateOrderSummary() {
        const cfg = (window as any).SHIPPING_CONFIG || { freeThreshold: 50, standardCost: 4.99, expressCost: 9.99, expressOverThreshold: 5.00 };
        const cart = getCart();
        const subtotal = cart.reduce((s: number, i: any) => s + (Number(i.price) * Number(i.quantity)), 0);
        const isFree = subtotal >= cfg.freeThreshold;
        let shippingCost: number;
        if (isFree) {
            shippingCost = selectedShippingMethod === "express" ? cfg.expressOverThreshold : 0;
        } else {
            shippingCost = selectedShippingMethod === "express" ? cfg.expressCost : cfg.standardCost;
        }
        const total = subtotal + shippingCost;
        const fmt = (n: number) => `${n.toLocaleString("es-ES", { minimumFractionDigits: 2, maximumFractionDigits: 2 })} €`;
        const productsEl  = document.getElementById("summary-products");
        const shippingEl  = document.getElementById("summary-shipping");
        const totalEl     = document.getElementById("summary-total");
        const discRow     = document.getElementById("summary-discount-row");
        const discCodeEl  = document.getElementById("summary-discount-code");
        const discAmtEl   = document.getElementById("summary-discount-amount");

        if (productsEl) productsEl.textContent = fmt(subtotal);
        if (shippingEl) shippingEl.textContent = shippingCost === 0 ? "Gratis" : fmt(shippingCost);

        // Apply coupon discount from sessionStorage
        const savedCoupon = sessionStorage.getItem('applied_coupon');
        const coupon = savedCoupon ? JSON.parse(savedCoupon) : null;
        if (coupon?.discountAmount && discRow) {
            discRow.style.display = '';
            if (discCodeEl) discCodeEl.textContent = coupon.code;
            if (discAmtEl)  discAmtEl.textContent  = `-${fmt(coupon.discountAmount)}`;
            if (totalEl)    totalEl.textContent    = fmt(Math.max(0, total - coupon.discountAmount));
        } else {
            if (discRow) discRow.style.display = 'none';
            if (totalEl) totalEl.textContent   = fmt(total);
        }
    }

    function setActiveShippingOption(method: string) {
        document.querySelectorAll<HTMLButtonElement>(".shipping-opt").forEach((btn) => {
            const isSelected = btn.dataset.method === method;
            btn.classList.toggle("border-brand/40", isSelected);
            btn.classList.toggle("bg-brand/5", isSelected);
            if (!isSelected) btn.style.borderColor = "var(--border-color)";
            else btn.style.borderColor = "";
        });
    }

    // ── initStripeElements ─────────────────────────────────────────────────
    // Called automatically by the Cloudflare Turnstile widget once bot-
    // verification completes (data-callback="onTurnstileVerified").
    // Receives the one-time token and exchanges it with create-payment-intent.
    async function initStripeElements(token: string) {
        const _items = getCart();
        const pubKey = (window as any).STRIPE_PUBLIC_KEY;

        if (!_items.length || !pubKey) return;

        const _msgDiv = document.getElementById(
            "payment-message",
        ) as HTMLDivElement;
        function _showMsg(msg: string) {
            if (!_msgDiv) return;
            _msgDiv.classList.remove("hidden");
            _msgDiv.textContent = msg;
            _msgDiv.classList.add("text-red-500");
            _msgDiv.classList.remove("text-green-500");
        }

        if (pubKey.includes("...")) {
            _showMsg(
                "STRIPE_PUBLIC_KEY está incompleta en el archivo .env o faltan credenciales en Configuraciones.",
            );
            return;
        }

        try {
            const res = await fetch("/api/stripe/create-payment-intent", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    items: _items,
                    shippingInfo: {},
                    email: "guest@example.com",
                    turnstileToken: token,
                    shippingMethod: selectedShippingMethod,
                    couponCode: (() => {
                        try { return JSON.parse(sessionStorage.getItem('applied_coupon') || '{}')?.code ?? null; }
                        catch { return null; }
                    })(),
                }),
            });
            const data = await res.json();

            if (data.clientSecret) {
                clientSecret = data.clientSecret;
                piId = data.paymentIntentId ?? null;
                stripe = (window as any).Stripe(pubKey);
                const appearance = {
                    theme: "night",
                    variables: {
                        colorPrimary: "#39FF14",
                        colorBackground: "#111827",
                        colorText: "#ffffff",
                        colorDanger: "#ef4444",
                    },
                };

                elements = stripe.elements({ appearance, clientSecret });
                const paymentElement = elements.create("payment");

                // Guardar referencia para validación posterior si es necesario
                (window as any).stripePaymentElement = paymentElement;

                const container = document.getElementById("payment-element");
                if (container) {
                    container.innerHTML = "";
                    paymentElement.mount("#payment-element");

                    paymentElement.on("ready", () => {
                        console.log(
                            "[stripe] Payment Element mounted and ready.",
                        );
                    });

                    paymentElement.on("change", (event: any) => {
                        const btn = document.getElementById("place-order-btn") as HTMLButtonElement;
                        if (event.complete) {
                            btn?.removeAttribute("disabled");
                            btn?.classList.remove("opacity-40", "cursor-not-allowed");
                        } else {
                            btn?.setAttribute("disabled", "true");
                            btn?.classList.add("opacity-40", "cursor-not-allowed");
                        }
                        if (event.error) {
                            _showMsg(event.error.message);
                        } else {
                            _msgDiv?.classList.add("hidden");
                        }
                    });
                }
            } else if (data.error) {
                _showMsg(data.error);
            }
        } catch (err: any) {
            console.warn("[stripe] Error al inicializar pagos:", err);
            _showMsg(
                "Error al conectar con el sistema de pago. Por favor, recarga la página e inténtalo de nuevo.",
            );
            // Resetear Turnstile para que el usuario pueda reintentar sin recargar
            if ((window as any).turnstile) {
                (window as any).turnstile.reset();
            }
        }
    }

    // ── Registrar el init para que el buffer inline y Turnstile puedan invocarlo ──
    // Esto resuelve la race condition: si Turnstile disparó antes de que este
    // módulo cargara, el token está en __cfTokenBuffer y lo consumimos aquí.
    (window as any).__stripeInit = initStripeElements;
    // Sobrescribir la callback con la referencia real del módulo
    (window as any).onTurnstileVerified = function (token: string) {
        (window as any).__cfTokenBuffer = null;
        initStripeElements(token);
    };
    // Consumir token bufferizado si Turnstile ya disparó antes de este módulo
    const _buffered = (window as any).__cfTokenBuffer;
    if (_buffered) {
        (window as any).__cfTokenBuffer = null;
        initStripeElements(_buffered);
    }

    async function initCheckoutPage() {
        // Reset variables in case of View Transitions
        stripe = null;
        elements = null;
        clientSecret = null;
        piId = null;
        selectedShippingMethod = "standard";

        // ── Shipping selector ───────────────────────────────────────────────────
        updateShippingUI();
        setActiveShippingOption("standard");

        document.querySelectorAll<HTMLButtonElement>(".shipping-opt").forEach((btn) => {
            btn.addEventListener("click", async () => {
                const method = btn.dataset.method ?? "standard";
                selectedShippingMethod = method;
                setActiveShippingOption(method);
                updateOrderSummary();

                // If PI already created, update its amount
                if (piId && elements) {
                    try {
                        await fetch("/api/stripe/update-shipping", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ paymentIntentId: piId, shippingMethod: method }),
                        });
                        await elements.fetchUpdates();
                    } catch (e) {
                        console.warn("[shipping] Error updating PI amount:", e);
                    }
                }
            });
        });

        // Re-registrar callbacks tras cada navegación por View Transitions
        (window as any).__stripeInit = initStripeElements;
        (window as any).onTurnstileVerified = function (token: string) {
            (window as any).__cfTokenBuffer = null;
            initStripeElements(token);
        };
        // Si Turnstile ya tiene token (widget no se reseteó), consumirlo
        const buffered = (window as any).__cfTokenBuffer;
        if (buffered) {
            (window as any).__cfTokenBuffer = null;
            initStripeElements(buffered);
        }

        // ── Auto-relleno desde dirección guardada ──────────────────────────────
        const addrCards =
            document.querySelectorAll<HTMLButtonElement>(".saved-addr-card");
        const manualBtn = document.getElementById("addr-manual-btn");

        function selectAddrCard(card: HTMLButtonElement) {
            // Quitar selección previa
            addrCards.forEach((c) => {
                c.classList.remove(
                    "border-brand/40",
                    "bg-brand/5",
                    "ring-1",
                    "ring-brand/30",
                );
                c.style.borderColor = "var(--border-color)";
            });
            // Marcar seleccionada
            card.classList.add(
                "border-brand/40",
                "bg-brand/5",
                "ring-1",
                "ring-brand/30",
            );
            card.style.borderColor = "";

            // Rellenar el formulario
            try {
                const data = JSON.parse(card.dataset.addr ?? "{}");
                const [firstName, ...lastParts] = (data.full_name ?? "").split(
                    " ",
                );
                const lastName = lastParts.join(" ");
                (
                    document.getElementById("input-nombre") as HTMLInputElement
                ).value = firstName ?? "";
                (
                    document.getElementById(
                        "input-apellidos",
                    ) as HTMLInputElement
                ).value = lastName ?? "";
                (
                    document.getElementById(
                        "input-direccion",
                    ) as HTMLInputElement
                ).value = data.street ?? "";
                (
                    document.getElementById("input-ciudad") as HTMLInputElement
                ).value = data.city ?? "";
                (
                    document.getElementById("input-cp") as HTMLInputElement
                ).value = data.postal_code ?? "";
                (
                    document.getElementById(
                        "input-telefono",
                    ) as HTMLInputElement
                ).value = data.phone ?? "";
            } catch {}
        }

        addrCards.forEach((card) => {
            card.addEventListener("click", () => selectAddrCard(card));
        });

        // Seleccionar automáticamente la predeterminada (primera de la lista porque se ordena is_default DESC)
        if (addrCards.length > 0) {
            selectAddrCard(addrCards[0]);
        }

        // Botón "introducir manualmente" limpia la selección y vacía los campos
        manualBtn?.addEventListener("click", () => {
            addrCards.forEach((c) => {
                c.classList.remove(
                    "border-brand/40",
                    "bg-brand/5",
                    "ring-1",
                    "ring-brand/30",
                );
                c.style.borderColor = "var(--border-color)";
            });
            [
                "input-nombre",
                "input-apellidos",
                "input-direccion",
                "input-ciudad",
                "input-cp",
                "input-telefono",
            ].forEach((id) => {
                (document.getElementById(id) as HTMLInputElement).value = "";
            });
            document.getElementById("input-nombre")?.focus();
        });

        // ── Envío al checkout ──────────────────────────────────────────────────
        var orderBtn = document.getElementById(
            "place-order-btn",
        ) as HTMLButtonElement;
        var checkoutForm = document.getElementById(
            "checkout-form",
        ) as HTMLFormElement;
        var msgDiv = document.getElementById(
            "payment-message",
        ) as HTMLDivElement;

        function showMessage(msgText: string, isError = true) {
            msgDiv.classList.remove("hidden");
            msgDiv.textContent = msgText;
            if (isError) {
                msgDiv.classList.add("text-red-500");
                msgDiv.classList.remove("text-green-500");
            } else {
                msgDiv.classList.remove("text-red-500");
                msgDiv.classList.add("text-green-500");
            }
        }

        // Stripe Elements se inicializa en onTurnstileVerified una vez que
        // el widget de Cloudflare Turnstile completa la verificación anti-bot.

        if (orderBtn && checkoutForm) {
            orderBtn.addEventListener("click", async function (e) {
                e.preventDefault();

                // STEP 5 — Safety: bloquear si el widget de Turnstile no ha verificado
                const turnstileToken = document.querySelector<HTMLInputElement>(
                    '[name="cf-turnstile-response"]',
                )?.value;
                if (!turnstileToken) {
                    showMessage(
                        "Por favor, completa la verificación de seguridad antes de continuar.",
                    );
                    return;
                }

                // Validate form
                if (!checkoutForm.checkValidity()) {
                    checkoutForm.reportValidity();
                    return;
                }

                if (!stripe || !elements || !clientSecret) {
                    console.error(
                        "[stripe] Click handled but stripe/elements/secret missing:",
                        {
                            stripe: !!stripe,
                            elements: !!elements,
                            secret: !!clientSecret,
                        },
                    );
                    showMessage(
                        "El sistema de pago no se ha cargado correctamente. Por favor, refresca la página.",
                    );
                    return;
                }

                const items = getCart();
                if (items.length === 0) {
                    const { toast } = await import("../lib/toast");
                    toast.warning("Tu carrito está vacío.");
                    return;
                }

                const shippingInfo = {
                    firstName: (
                        document.getElementById(
                            "input-nombre",
                        ) as HTMLInputElement
                    )?.value,
                    lastName: (
                        document.getElementById(
                            "input-apellidos",
                        ) as HTMLInputElement
                    )?.value,
                    address: (
                        document.getElementById(
                            "input-direccion",
                        ) as HTMLInputElement
                    )?.value,
                    city: (
                        document.getElementById(
                            "input-ciudad",
                        ) as HTMLInputElement
                    )?.value,
                    zip: (
                        document.getElementById("input-cp") as HTMLInputElement
                    )?.value,
                    phone: (
                        document.getElementById(
                            "input-telefono",
                        ) as HTMLInputElement
                    )?.value,
                };

                const email =
                    (document.getElementById("input-email") as HTMLInputElement)
                        ?.value || "guest@example.com";

                orderBtn.innerHTML =
                    '<span class="flex items-center gap-2"><svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Procesando pago...</span>';
                orderBtn.setAttribute("disabled", "true");
                msgDiv.classList.add("hidden");

                try {
                    // Confirm Stripe Payment First
                    const { error: stripeError, paymentIntent } =
                        await stripe.confirmPayment({
                            elements,
                            confirmParams: {
                                receipt_email: email,
                                payment_method_data: {
                                    billing_details: {
                                        name: `${shippingInfo.firstName} ${shippingInfo.lastName}`,
                                        email: email,
                                        phone: shippingInfo.phone,
                                        address: {
                                            line1: shippingInfo.address,
                                            city: shippingInfo.city,
                                            postal_code: shippingInfo.zip,
                                        },
                                    },
                                },
                            },
                            redirect: "if_required",
                        });

                    if (stripeError) {
                        throw new Error(
                            stripeError.message ||
                                "Pago fallido en la tarjeta.",
                        );
                    }

                    if (
                        paymentIntent &&
                        paymentIntent.status === "requires_capture"
                    ) {
                        // Card Authorized! Call our backend to perform Stock check + Order Creation + Capture
                        const response = await fetch(
                            "/api/stripe/confirm-payment-intent",
                            {
                                method: "POST",
                                headers: { "Content-Type": "application/json" },
                                body: JSON.stringify({
                                    paymentIntentId: paymentIntent.id,
                                    items,
                                    shippingInfo,
                                    email,
                                }),
                            },
                        );

                        const data = await response.json();

                        if (data.ok) {
                            // Save order summary so the success page can show the breakdown
                            try {
                                const cfg = (window as any).SHIPPING_CONFIG || { freeThreshold: 50, standardCost: 4.99, expressCost: 9.99, expressOverThreshold: 5.00 };
                                const sub = items.reduce((s: number, i: any) => s + (Number(i.price) * Number(i.quantity)), 0);
                                const isFree = sub >= cfg.freeThreshold;
                                const ship = isFree
                                    ? (selectedShippingMethod === "express" ? cfg.expressOverThreshold : 0)
                                    : (selectedShippingMethod === "express" ? cfg.expressCost : cfg.standardCost);
                                let discountAmount = 0, couponCode: string | null = null;
                                try {
                                    const cpn = JSON.parse(sessionStorage.getItem('applied_coupon') || '{}');
                                    if (cpn.discountAmount) { discountAmount = Number(cpn.discountAmount); couponCode = cpn.code || null; }
                                } catch {}
                                sessionStorage.setItem("lastOrderSummary", JSON.stringify({
                                    subtotal: sub,
                                    shipping: ship,
                                    discount: discountAmount,
                                    couponCode: couponCode,
                                    total: sub - discountAmount + ship,
                                    items: items.map((i: any) => ({ name: i.name, image: i.image, size: i.size, quantity: i.quantity, price: i.price })),
                                }));
                                sessionStorage.removeItem('applied_coupon');
                            } catch { /* non-critical */ }
                            clearCart();
                            window.location.href = `/success`;
                        } else {
                            // Transaction rolled back due to stock issue, PaymentIntent Cancelled!
                            if (data.failed_product_id) {
                                const failedItem = items.find(
                                    (i: any) => i.id === data.failed_product_id,
                                );
                                if (failedItem) {
                                    removeItem(
                                        failedItem.id,
                                        failedItem.variantId,
                                    );
                                }
                            }
                            throw new Error(
                                data.error ||
                                    "El producto acaba de agotarse y el pago ha sido cancelado automáticamente.",
                            );
                        }
                    } else if (
                        paymentIntent &&
                        paymentIntent.status === "succeeded"
                    ) {
                        // Already succeeded? (Maybe not manual capture incorrectly configured)
                        clearCart();
                        window.location.href = `/success`;
                    } else {
                        throw new Error(
                            "Estado de pago inesperado. Recarga y prueba de nuevo.",
                        );
                    }
                } catch (err: any) {
                    const msg =
                        err instanceof Error
                            ? err.message
                            : "Error al procesar el pago.";
                    showMessage(msg);
                    orderBtn.textContent = "Pagar y Finalizar";
                    orderBtn.removeAttribute("disabled");
                }
            });
        }
    }

    document.addEventListener("astro:page-load", initCheckoutPage);
</script>
