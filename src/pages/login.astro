---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { user } = Astro.locals;
if (user) return Astro.redirect("/");
---

<Layout title="Iniciar Sesión | PARRA" robots="noindex, nofollow">
    <Header />
    <main class="login-main">
        <!-- Columna izquierda: branding -->
        <div class="brand-col">
            <div class="brand-inner">
                <p class="brand-eyebrow">Bienvenido de nuevo</p>
                <div class="brand-title-wrap">
                    <img
                        src="/images/brand-mark.svg"
                        alt="Parra"
                        class="brand-logo"
                        loading="eager"
                        decoding="async"
                    />
                    <h1 class="brand-title">PARRA</h1>
                </div>
                <p class="brand-sub">GOALKEEPER GLOVES</p>
                <div class="brand-divider"></div>
                <p class="brand-desc">
                    Accede a tu cuenta para gestionar tus pedidos, descargar
                    facturas y mucho más.
                </p>
                <div class="brand-stats">
                    <div class="stat">
                        <span class="stat-val">+500</span>
                        <span class="stat-lbl">Clientes</span>
                    </div>
                    <div class="stat-sep"></div>
                    <div class="stat">
                        <span class="stat-val">Elite</span>
                        <span class="stat-lbl">Calidad</span>
                    </div>
                    <div class="stat-sep"></div>
                    <div class="stat">
                        <span class="stat-val">Pro</span>
                        <span class="stat-lbl">Rendimiento</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna derecha: formulario -->
        <div class="form-col">
            <div class="form-inner">
                <!-- Cabecera -->
                <div class="form-header">
                    <h2 class="form-title">Iniciar Sesión</h2>
                    <p class="form-subtitle">
                        Introduce tus credenciales para acceder
                    </p>
                </div>

                <form id="login-form" class="lform" novalidate>
                    <!-- Email -->
                    <div class="lfield">
                        <label class="llabel" for="l-email">Email</label>
                        <div class="linput-wrap">
                            <svg
                                class="linput-icon"
                                width="15"
                                height="15"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                ></path>
                            </svg>
                            <input
                                type="email"
                                id="l-email"
                                name="email"
                                class="input linput"
                                placeholder="tu@email.com"
                                required
                                autocomplete="email"
                            />
                        </div>
                    </div>

                    <!-- Contraseña -->
                    <div class="lfield">
                        <label class="llabel" for="l-pass">Contraseña</label>
                        <div class="linput-wrap">
                            <svg
                                class="linput-icon"
                                width="15"
                                height="15"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                                ></path>
                            </svg>
                            <input
                                type="password"
                                id="l-pass"
                                name="password"
                                class="input linput"
                                placeholder="••••••••"
                                required
                                autocomplete="current-password"
                            />
                            <button
                                type="button"
                                id="toggle-pw"
                                class="lpw-toggle"
                                tabindex="0"
                                aria-label="Ver contraseña"
                            >
                                <svg
                                    id="eye-icon"
                                    width="15"
                                    height="15"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                    ></path>
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                    ></path>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Error -->
                    <div id="login-error" class="lerror hidden">
                        <svg
                            width="13"
                            height="13"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                            style="flex-shrink:0"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                        <span id="login-error-text"></span>
                    </div>

                    <!-- Submit -->
                    <button
                        type="submit"
                        id="submit-btn"
                        class="btn-glow w-full h-13 lsubmit"
                    >
                        <span id="btn-text">Iniciar Sesión</span>
                        <span id="btn-loader" class="hidden lloader">
                            <svg
                                class="lspin"
                                width="16"
                                height="16"
                                fill="none"
                                viewBox="0 0 24 24"
                            >
                                <circle
                                    cx="12"
                                    cy="12"
                                    r="10"
                                    stroke="currentColor"
                                    stroke-width="3"
                                    stroke-dasharray="31.4"
                                    stroke-dashoffset="10"
                                    stroke-linecap="round"
                                    opacity=".4"></circle>
                                <path
                                    d="M12 2a10 10 0 0110 10"
                                    stroke="currentColor"
                                    stroke-width="3"
                                    stroke-linecap="round"></path>
                            </svg>
                            Accediendo...
                        </span>
                    </button>
                </form>

                <!-- Footer del form -->
                <div class="lform-footer">
                    <span>¿No tienes cuenta?</span>
                    <a href="/register" class="lform-link">Regístrate</a>
                </div>

                <!-- Separador -->
                <div class="lsep">
                    <span class="lsep-line"></span>
                    <span class="lsep-text">PARRA SPORT S.L.</span>
                    <span class="lsep-line"></span>
                </div>
            </div>
        </div>
    </main>
    <Footer />
</Layout>

<style>
    /* ── Layout principal ─────────────────────────────────────── */
    .login-main {
        min-height: calc(100vh - 140px);
        display: grid;
        grid-template-columns: 1fr 1fr;
        background-color: #0a0a0a;
        position: relative;
    }
    .login-main::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 600px;
        height: 600px;
        background: radial-gradient(
            circle,
            rgba(var(--brand-rgb),0.05) 0%,
            transparent 70%
        );
        pointer-events: none;
        z-index: 0;
    }
    @media (max-width: 768px) {
        .login-main {
            grid-template-columns: 1fr;
        }
        .brand-col {
            display: none;
        }
    }

    /* ── Columna branding ─────────────────────────────────────── */
    .brand-col {
        background-color: #0a0a0a;
        border-right: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 48px;
        position: relative;
        overflow: hidden;
        z-index: 1;
    }
    /* Acento verde vertical izquierdo */
    .brand-col::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 3px;
        height: 100%;
        background: var(--brand);
    }
    /* Glow de fondo sutil */
    .brand-col::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 380px;
        height: 380px;
        background: radial-gradient(
            circle,
            rgba(var(--brand-rgb),0.07) 0%,
            transparent 70%
        );
        pointer-events: none;
    }

    .brand-inner {
        position: relative;
        z-index: 1;
        animation: fadeInLeft 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes fadeInLeft {
        from {
            opacity: 0;
            transform: translateX(-24px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .brand-eyebrow {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--brand);
        margin: 0 0 16px;
    }

    .brand-title {
        font-family: "Oswald", system-ui, sans-serif;
        font-size: clamp(64px, 8vw, 88px);
        font-weight: 700;
        letter-spacing: 0.06em;
        color: var(--text-primary);
        margin: 0;
        line-height: 1;
    }

    .brand-title-wrap {
        display: inline-flex;
        align-items: center;
        gap: 14px;
    }

    .brand-logo {
        width: clamp(52px, 6vw, 74px);
        height: auto;
        filter: drop-shadow(0 0 10px rgba(var(--brand-rgb), 0.25));
    }

    .brand-sub {
        font-size: 10px;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin: 10px 0 0;
    }

    .brand-divider {
        width: 48px;
        height: 2px;
        background: var(--brand);
        margin: 28px 0;
    }

    .brand-desc {
        font-size: 14px;
        line-height: 1.7;
        color: var(--text-secondary);
        max-width: 320px;
        margin: 0 0 36px;
    }

    .brand-stats {
        display: flex;
        align-items: center;
        gap: 20px;
    }
    .stat {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }
    .stat-val {
        font-family: "Oswald", system-ui, sans-serif;
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
    }
    .stat-lbl {
        font-size: 9px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-muted);
    }
    .stat-sep {
        width: 1px;
        height: 32px;
        background: var(--border-color);
    }

    /* ── Columna formulario ───────────────────────────────────── */
    .form-col {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 48px;
        background-color: #0a0a0a;
        z-index: 1;
    }

    .form-inner {
        width: 100%;
        max-width: 400px;
        animation: fadeInRight 0.6s 0.1s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes fadeInRight {
        from {
            opacity: 0;
            transform: translateX(24px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* ── Form header ──────────────────────────────────────────── */
    .form-header {
        margin-bottom: 36px;
    }
    .form-title {
        font-family: "Oswald", system-ui, sans-serif;
        font-size: 32px;
        font-weight: 700;
        letter-spacing: 0.04em;
        color: var(--text-primary);
        margin: 0 0 8px;
        text-transform: uppercase;
    }
    .form-subtitle {
        font-size: 13px;
        color: var(--text-muted);
        margin: 0;
    }

    /* ── Campos ───────────────────────────────────────────────── */
    .lform {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .lfield {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .llabel {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-secondary);
    }

    .linput-wrap {
        position: relative;
    }
    .linput-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        pointer-events: none;
        transition: color 0.2s;
    }
    .linput-wrap:focus-within .linput-icon {
        color: var(--brand);
    }

    .linput {
        padding-left: 40px !important;
        padding-right: 40px !important;
        font-size: 14px !important;
        height: 48px;
        transition:
            border-color 0.2s,
            box-shadow 0.2s !important;
    }

    .lpw-toggle {
        position: absolute;
        right: 13px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: var(--text-muted);
        padding: 0;
        display: flex;
        transition: color 0.2s;
    }
    /* Ensure the toggle is above the input */
    .lpw-toggle {
        z-index: 5;
    }
    .lpw-toggle:hover {
        color: var(--brand);
    }

    /* ── Error ────────────────────────────────────────────────── */
    .lerror {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: #f87171;
        background: rgba(248, 113, 113, 0.07);
        border: 1px solid rgba(248, 113, 113, 0.18);
        padding: 10px 14px;
    }
    .lerror.hidden {
        display: none;
    }

    /* ── Submit ───────────────────────────────────────────────── */
    .lsubmit {
        height: 50px !important;
        font-size: 12px !important;
        margin-top: 4px;
        transition:
            box-shadow 0.3s,
            transform 0.2s !important;
    }
    .lsubmit:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .lloader {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .lloader.hidden {
        display: none;
    }
    .lspin {
        animation: lspin 0.75s linear infinite;
    }
    @keyframes lspin {
        to {
            transform: rotate(360deg);
        }
    }

    /* ── Footer ───────────────────────────────────────────────── */
    .lform-footer {
        margin-top: 24px;
        font-size: 13px;
        color: var(--text-muted);
        text-align: center;
    }
    .lform-link {
        color: var(--brand);
        font-weight: 700;
        margin-left: 5px;
        text-decoration: none;
        transition: opacity 0.2s;
    }
    .lform-link:hover {
        opacity: 0.8;
        text-decoration: underline;
    }

    /* ── Separador ────────────────────────────────────────────── */
    .lsep {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 28px;
    }
    .lsep-line {
        flex: 1;
        height: 1px;
        background: var(--border-color);
    }
    .lsep-text {
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-muted);
        white-space: nowrap;
    }

    /* Mobile tweaks to ensure forms adapt well */
    @media (max-width: 768px) {
        .login-main {
            min-height: calc(100vh - 120px);
        }

        .brand-col {
            display: none;
        }

        .form-col {
            padding: 32px 20px !important;
            align-items: flex-start;
            justify-content: flex-start;
        }

        .form-inner {
            max-width: 100%;
            width: 100%;
            padding-top: 18px;
        }

        .form-title {
            font-size: 28px;
        }

        .linput {
            height: 48px;
            font-size: 15px !important;
            padding-left: 44px !important;
            padding-right: 44px !important;
        }

        .linput-icon {
            left: 12px;
        }
        .lpw-toggle {
            right: 12px;
        }

        /* Make submit button pleasant and not oversized */
        .lsubmit {
            width: 100%;
            min-width: 0;
            height: 48px !important;
            font-size: 13px !important;
            border-radius: 8px;
            box-shadow:
                0 6px 18px rgba(0, 0, 0, 0.5),
                0 0 12px rgba(var(--brand-rgb),0.06);
        }

        /* Reduce hero/branding pseudo-size to avoid overflow */
        .login-main::before {
            width: 360px;
            height: 360px;
            opacity: 0.7;
        }
    }
</style>

<script is:inline>
    function initLoginPage() {
        var main = document.querySelector(".login-main");
        if (!main || main.dataset.initialized) return;
        main.dataset.initialized = "true";

        var form = document.getElementById("login-form");
        var errorEl = document.getElementById("login-error");
        var errTxt = document.getElementById("login-error-text");
        var btnText = document.getElementById("btn-text");
        var btnLoad = document.getElementById("btn-loader");
        var submitBtn = document.getElementById("submit-btn");
        var togglePw = document.getElementById("toggle-pw");
        var pwInput = document.getElementById("l-pass");
        var eyeIcon = document.getElementById("eye-icon");

        if (togglePw && pwInput) {
            togglePw.addEventListener("click", function (e) {
                e.preventDefault();
                e.stopPropagation();
                var isText = pwInput.type === "text";
                pwInput.type = isText ? "password" : "text";
                eyeIcon.innerHTML = isText
                    ? '<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>' +
                      '<path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>'
                    : '<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>';
            });
        }

        if (!form) return;

        form.addEventListener("submit", async function (e) {
            e.preventDefault();
            if (errorEl) errorEl.classList.add("hidden");

            var fd = new FormData(form);
            var email = fd.get("email");
            var pass = fd.get("password");

            if (btnText) btnText.classList.add("hidden");
            if (btnLoad) btnLoad.classList.remove("hidden");
            if (submitBtn) submitBtn.disabled = true;

            try {
                var res = await fetch("/api/auth/login", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ email: email, password: pass }),
                });
                var data = await res.json();

                if (res.ok) {
                    // Activar el carrito específico de este usuario
                    if (data.user && data.user.id) {
                        localStorage.setItem(
                            "parra_cart_user_id",
                            data.user.id,
                        );
                    }
                    window.location.href = "/";
                } else {
                    if (errTxt)
                        errTxt.textContent =
                            data.message ||
                            data.error ||
                            "Credenciales incorrectas";
                    if (errorEl) errorEl.classList.remove("hidden");
                }
            } catch (err) {
                if (errTxt)
                    errTxt.textContent =
                        "Error de conexión. Inténtalo de nuevo.";
                if (errorEl) errorEl.classList.remove("hidden");
            } finally {
                if (btnText) btnText.classList.remove("hidden");
                if (btnLoad) btnLoad.classList.add("hidden");
                if (submitBtn) submitBtn.disabled = false;
            }
        });
    }

    document.addEventListener("astro:page-load", initLoginPage);
    if (document.readyState !== "loading") initLoginPage();
    else document.addEventListener("DOMContentLoaded", initLoginPage);
</script>
