                                                    <div class="flex items-center justify-between gap-2 mb-1 flex-wrap">
                                                        <p class="text-sm font-bold uppercase">
                                                            {r.products?.name ||
                                                                "Producto"}
                                                        </p>
                                                        <div class="flex gap-0.5">
