                                                                1, 2, 3, 4, 5,
                                                            ].map((s) => (
                                                                <svg
                                                                    class:list={[
                                                                        "w-4 h-4",
                                                                        s <=
                                                                        r.rating
                                                                            ? "text-brand"
                                                                            : "text-white/20",
                                                                    ]}
                                                                    fill="currentColor"
                                                                    viewBox="0 0 20 20"
                                                                >
                                                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                                                </svg>
                                                            ))}
                                                        </div>
                                                    </div>
                                                    {r.title && (
                                                        <p class="text-sm font-semibold mb-1">
                                                            {r.title}
                                                        </p>
                                                    )}
                                                    {r.comment && (
                                                        <p
                                                            class="text-sm"
                                                            style="color: var(--text-muted);"
                                                        >
                                                            {r.comment}
                                                        </p>
                                                    )}
                                                    <div class="flex items-center gap-3 mt-2">
                                                        <p
                                                            class="text-[10px] uppercase tracking-wider"
                                                            style="color: var(--text-muted);"
                                                        >
                                                            {new Date(
                                                                r.created_at,
                                                            ).toLocaleDateString(
                                                                "es-ES",
                                                            )}
                                                        </p>
                                                        {!r.is_approved && (
                                                            <span class="text-[10px] uppercase tracking-wider px-2 py-0.5 bg-amber-500/10 text-amber-500">
                                                                Pendiente
                                                                aprobación
                                                            </span>
                                                        )}
                                                        {r.is_approved && (
                                                            <span class="text-[10px] uppercase tracking-wider px-2 py-0.5 bg-brand/10 text-brand">
                                                                Publicada
                                                            </span>
                                                        )}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            ) : (
                                <div class="py-24 text-center card">
                                    <svg
                                        class="w-12 h-12 mx-auto mb-6"
                                        style="color: var(--text-muted); opacity:.4;"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="1.5"
                                            d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                                        />
                                    </svg>
                                    <p
                                        class="uppercase tracking-[0.2em] text-sm mb-6"
                                        style="color: var(--text-muted);"
                                    >
                                        Todavía no has escrito ninguna reseña.
                                    </p>
                                    <a
                                        href="/shop"
                                        class="btn-primary inline-flex"
                                    >
                                        Explorar productos
                                    </a>
                                </div>
                            )
                        }
                    </div>

                    {/* ════ MIS DIRECCIONES ════ */}
                    <div
                        data-tab-panel="direcciones"
                        hidden={tab !== "direcciones"}
                    >
                        <div
                            class="flex items-center justify-between mb-8 flex-wrap gap-4"
                        >
                            <h2 class="section-title">
                                Mis <span class="text-brand">Direcciones</span>
                            </h2>
                            <button
                                id="new-address-btn"
                                class="btn-outline text-sm"
                                >+ Nueva dirección</button
                            >
                        </div>

                        <!-- Form nueva dirección (oculto por defecto) -->
                        <div
                            id="address-form-wrap"
