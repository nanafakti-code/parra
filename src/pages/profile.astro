                            <form
                                id="address-form"
                                class="grid grid-cols-1 sm:grid-cols-2 gap-4"
                            >
                                <div class="sm:col-span-2">
                                    <label
                                        class="block text-[10px] font-bold uppercase tracking-[0.2em] mb-1.5"
                                        style="color: var(--text-muted);"
