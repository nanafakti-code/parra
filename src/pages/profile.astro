    function initProfilePage() {
        // ── Tab switching client-side (sin recarga) ──────────────────────────
        const ACTIVE = ["bg-brand", "text-black"];
        const INACTIVE = ["card", "hover:text-brand"];
        const MUTED_STYLE = "color: var(--text-muted);";

        function activateTab(id: string, pushUrl = true) {
            document
                .querySelectorAll<HTMLElement>("[data-tab-panel]")
                .forEach((panel) => {
                    panel.hidden = panel.dataset.tabPanel !== id;
                });
            document
                .querySelectorAll<HTMLElement>("[data-tab-link]")
                .forEach((link) => {
                    const isActive = link.dataset.tabLink === id;
                    ACTIVE.forEach((c) => link.classList.toggle(c, isActive));
                    INACTIVE.forEach((c) =>
                        link.classList.toggle(c, !isActive),
                    );
                    if (isActive) {
                        link.removeAttribute("style");
                    } else {
                        link.setAttribute("style", MUTED_STYLE);
                    }
                });
            if (pushUrl) {
                const url = new URL(window.location.href);
                url.searchParams.set("tab", id);
                history.replaceState(null, "", url.toString());
            }
        }

        document
            .getElementById("profile-nav")
            ?.addEventListener("click", (e) => {
                const link = (e.target as HTMLElement).closest<HTMLElement>(
                    "[data-tab-link]",
                );
                if (!link) return;
                e.preventDefault();
                activateTab(link.dataset.tabLink!);
            });

        // ── Formulario perfil ─────────────────────────────────────────────────
        const profileForm = document.getElementById(
            "profile-form",
        ) as HTMLFormElement | null;
        const profileMsg = document.getElementById("profile-msg");
        const saveBtn = document.getElementById(
            "save-profile-btn",
        ) as HTMLButtonElement | null;
        if (profileForm && saveBtn) {
            const nameInput =
                profileForm.querySelector<HTMLInputElement>('[name="name"]')!;
            const phoneInput =
                profileForm.querySelector<HTMLInputElement>('[name="phone"]')!;
            // Valores iniciales al cargar la página
            let origName = nameInput.value;
            let origPhone = phoneInput.value;

            function checkDirty() {
                const dirty =
                    nameInput.value.trim() !== origName.trim() ||
                    phoneInput.value.trim() !== origPhone.trim();
                if (!saveBtn) return;
                saveBtn.disabled = !dirty;
                saveBtn.classList.toggle("opacity-40", !dirty);
                saveBtn.classList.toggle("cursor-not-allowed", !dirty);
            }

            nameInput.addEventListener("input", checkDirty);
            phoneInput.addEventListener("input", checkDirty);

            profileForm.addEventListener("submit", async (e) => {
                e.preventDefault();
                const fd = new FormData(profileForm);
                const name = fd.get("name") as string;
                const phone = fd.get("phone") as string;
                const res = await fetch("/api/auth/update-profile", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ name, phone }),
                });
                if (profileMsg) {
                    profileMsg.classList.remove("hidden");
                    if (res.ok) {
                        profileMsg.textContent =
                            "✓ Datos guardados correctamente.";
                        profileMsg.style.color = "#22c55e";
                        // Actualizar valores de referencia → botón vuelve a deshabilitarse
                        origName = name;
                        origPhone = phone;
                        checkDirty();
                        // ── Actualizar sidebar sin recargar ──
                        const sidebarName =
                            document.getElementById("sidebar-name");
                        const sidebarAvatar =
                            document.getElementById("sidebar-avatar");
                        if (sidebarName) sidebarName.textContent = name;
                        if (sidebarAvatar)
                            sidebarAvatar.textContent = name
                                .charAt(0)
                                .toUpperCase();
                        setTimeout(
                            () => profileMsg.classList.add("hidden"),
                            3000,
                        );
                    } else {
                        profileMsg.textContent =
                            "Error al guardar. Inténtalo de nuevo.";
                        profileMsg.style.color = "#ef4444";
                        setTimeout(
                            () => profileMsg.classList.add("hidden"),
                            4000,
                        );
                    }
                }
            });
        }

        // ── Eye toggle (mostrar/ocultar contraseña) ───────────────────────────
        document
            .querySelectorAll<HTMLButtonElement>("[data-eye]")
            .forEach((btn) => {
                btn.addEventListener("click", () => {
                    const input = document.getElementById(
                        btn.dataset.eye!,
                    ) as HTMLInputElement | null;
                    if (!input) return;
                    const show = input.type === "password";
                    input.type = show ? "text" : "password";
                    btn.querySelector(".eye-off")!.classList.toggle(
                        "hidden",
                        show,
                    );
                    btn.querySelector(".eye-on")!.classList.toggle(
                        "hidden",
                        !show,
                    );
                });
            });

        // ── Barra de seguridad ────────────────────────────────────────────────
        const pwdNewInput = document.getElementById(
            "pwd-new",
        ) as HTMLInputElement | null;
        const bars = [1, 2, 3, 4].map((n) =>
            document.getElementById(`str-${n}`),
        );
        const strLabel = document.getElementById("str-label");
        const COLORS = ["#ef4444", "#f97316", "#eab308", "#22c55e"];
        const LABELS = ["Muy débil", "Débil", "Aceptable", "Fuerte"];
        function getStrength(pw: string): number {
            let score = 0;
            if (pw.length >= 8) score++;
            if (pw.length >= 12) score++;
            if (/[A-Z]/.test(pw) && /[a-z]/.test(pw)) score++;
            if (/[0-9]/.test(pw) && /[^A-Za-z0-9]/.test(pw)) score++;
            return score; // 0-4
        }
        pwdNewInput?.addEventListener("input", () => {
            const pw = pwdNewInput.value;
            const s = pw.length === 0 ? 0 : Math.max(1, getStrength(pw));
            bars.forEach((bar, i) => {
                if (!bar) return;
                bar.style.backgroundColor =
                    i < s ? COLORS[s - 1] : "var(--border-color)";
            });
            if (strLabel) {
                strLabel.textContent = pw.length === 0 ? "" : LABELS[s - 1];
                strLabel.style.color =
                    pw.length === 0 ? "var(--text-muted)" : COLORS[s - 1];
            }
        });

        // ── Formulario contraseña ─────────────────────────────────────────────
        const pwdForm = document.getElementById(
            "pwd-form",
        ) as HTMLFormElement | null;
        const pwdMsg = document.getElementById("pwd-msg");
        if (pwdForm) {
            pwdForm.addEventListener("submit", async (e) => {
                e.preventDefault();
                const fd = new FormData(pwdForm);
                const currentPw = fd.get("current_password") as string;
                const pw = fd.get("password") as string;
                const pwRepeat = fd.get("password_repeat") as string;

                const showMsg = (text: string, color = "var(--text-muted)") => {
                    if (pwdMsg) {
                        pwdMsg.classList.remove("hidden");
                        pwdMsg.textContent = text;
                        pwdMsg.style.color = color;
                    }
                };

                if (!currentPw) {
                    showMsg("Introduce tu contraseña actual.");
                    return;
                }
                if (pw.length < 8) {
                    showMsg(
                        "La nueva contraseña debe tener al menos 8 caracteres.",
                    );
                    return;
                }
                if (pw !== pwRepeat) {
                    showMsg("Las contraseñas no coinciden.", "#ef4444");
                    return;
                }

                const res = await fetch("/api/auth/update-password", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        current_password: currentPw,
                        password: pw,
                    }),
                });
                const data = await res.json().catch(() => ({}));
                if (res.ok) {
                    showMsg("✓ Contraseña actualizada.", "#22c55e");
                    pwdForm.reset();
                    bars.forEach((b) => {
                        if (b) b.style.backgroundColor = "var(--border-color)";
                    });
                    if (strLabel) strLabel.textContent = "";
                    setTimeout(() => pwdMsg?.classList.add("hidden"), 3000);
                } else {
                    showMsg(
                        data.error ||
                            "Error al actualizar. Inténtalo de nuevo.",
                        "#ef4444",
                    );
                    setTimeout(() => pwdMsg?.classList.add("hidden"), 4000);
                }
            });
        }

        // ── Establecer predeterminada / eliminar (delegación en el panel) ─────
        // Anclar al panel (no a document) para evitar duplicados en navegación
        const addrPanel = document.querySelector<HTMLElement>(
            '[data-tab-panel="direcciones"]',
        );
        addrPanel?.addEventListener("click", async (e) => {
            const target = e.target as HTMLElement;
            const btn = target.closest<HTMLButtonElement>(
                "[data-set-default], [data-delete-addr]",
            );
            if (!btn) return;

            if (btn.dataset.setDefault) {
                btn.textContent = "…";
                btn.disabled = true;
                const res = await fetch("/api/auth/set-default-address", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        address_id: btn.dataset.setDefault,
                    }),
                });
                if (res.ok) {
                    window.location.reload();
                } else {
                    btn.textContent = "★ Predeterminada";
                    btn.disabled = false;
                    const { toast } = await import("../lib/toast");
                    toast.error("Error al actualizar la dirección.");
                }
            } else if (btn.dataset.deleteAddr) {
                const ok = await customConfirm(
                    "¿Eliminar dirección?",
                    "Esta acción no se puede deshacer.",
                );
                if (!ok) return;
                btn.textContent = "…";
                btn.disabled = true;
                const res = await fetch("/api/auth/delete-address", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        address_id: btn.dataset.deleteAddr,
                    }),
                });
                if (res.ok) {
                    window.location.reload();
                } else {
                    btn.textContent = "Eliminar";
                    btn.disabled = false;
                    const { toast } = await import("../lib/toast");
                    toast.error("Error al eliminar la dirección.");
                }
            }
        });

        // ── Formulario nueva dirección ────────────────────────────────────────
        const newAddrBtn = document.getElementById("new-address-btn");
        const cancelAddrBtn = document.getElementById("cancel-address-btn");
        const addrFormWrap = document.getElementById("address-form-wrap");
        const addrForm = document.getElementById(
            "address-form",
        ) as HTMLFormElement | null;
        const addrMsg = document.getElementById("address-msg");

        newAddrBtn?.addEventListener("click", () =>
            addrFormWrap?.classList.remove("hidden"),
        );
        cancelAddrBtn?.addEventListener("click", () =>
            addrFormWrap?.classList.add("hidden"),
        );

        if (addrForm) {
            addrForm.addEventListener("submit", async (e) => {
                e.preventDefault();
                const fd = new FormData(addrForm);
                const body = {
                    label: fd.get("label") || "Casa",
                    full_name: fd.get("full_name"),
                    street: fd.get("street"),
                    city: fd.get("city"),
                    postal_code: fd.get("postal_code"),
                    state: fd.get("state"),
                    phone: fd.get("phone"),
                    is_default: fd.get("is_default") === "on",
                };
                const res = await fetch("/api/auth/save-address", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(body),
                });
                if (addrMsg) {
                    addrMsg.classList.remove("hidden");
                    if (res.ok) {
                        addrMsg.textContent =
                            "✓ Dirección guardada. Recargando…";
                        setTimeout(() => window.location.reload(), 800);
                    } else {
                        addrMsg.textContent = "Error al guardar la dirección.";
                    }
                }
            });
        }

        // ── Invoice download via fetch (sends cookies reliably) ──────────────
        document
            .querySelectorAll<HTMLButtonElement>(".invoice-dl-btn")
            .forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const url = btn.dataset.invoiceUrl;
                    const name = btn.dataset.invoiceName || "factura.pdf";
                    if (!url) return;

                    const originalText = btn.innerHTML;
                    btn.innerHTML =
                        '<svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Generando...';
                    btn.disabled = true;

                    try {
                        const res = await fetch(url, {
                            credentials: "include",
                        });
                        if (!res.ok) {
                            const text = await res.text();
                            throw new Error(text || `Error ${res.status}`);
                        }
                        const blob = await res.blob();
                        const a = document.createElement("a");
                        a.href = URL.createObjectURL(blob);
                        a.download = name;
                        document.body.appendChild(a);
                        a.click();
                        URL.revokeObjectURL(a.href);
                        a.remove();
                    } catch (err: any) {
                        alert(
                            "Error al descargar la factura: " +
                                (err?.message || "desconocido"),
                        );
                    } finally {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    }
                });
            });

        // ── Return invoice (nota de abono) download ──────────────────────────────
        document
            .querySelectorAll<HTMLButtonElement>(".return-invoice-dl-btn")
            .forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const url = btn.dataset.returnInvoiceUrl;
                    const name = btn.dataset.returnInvoiceName || "nota-abono.pdf";
                    if (!url) return;

                    const originalHTML = btn.innerHTML;
                    btn.innerHTML =
                        '<svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Generando...';
                    btn.disabled = true;

                    try {
                        const res = await fetch(url, { credentials: "include" });
                        if (!res.ok) {
                            const text = await res.text();
                            throw new Error(text || `Error ${res.status}`);
                        }
                        const blob = await res.blob();
                        const a = document.createElement("a");
                        a.href = URL.createObjectURL(blob);
                        a.download = name;
                        document.body.appendChild(a);
                        a.click();
                        URL.revokeObjectURL(a.href);
                        a.remove();
                    } catch (err: any) {
                        alert("Error al descargar la nota de abono: " + (err?.message || "desconocido"));
                    } finally {
                        btn.innerHTML = originalHTML;
                        btn.disabled = false;
                    }
                });
            });

        // ── Cancelar pedido ─────────────────────────────────────────────────────
        document
            .querySelectorAll<HTMLButtonElement>(".cancel-order-btn")
            .forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const orderId = btn.dataset.orderId;
                    if (!orderId) return;

                    const confirmed = await showCancelOrderModal();
                    if (!confirmed) return;

                    btn.disabled = true;
                    const originalText = btn.innerHTML;
                    btn.innerHTML = '<svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>';

                    try {
                        const res = await fetch(`/api/orders/${orderId}/cancel`, {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            credentials: "include",
                        });
                        const data = await res.json();

                        if (res.ok) {
                            const { toast } = await import("../lib/toast");
                            toast.success("✓ Pedido cancelado. Tu reembolso se procesará en 3-5 días.");
                            setTimeout(() => window.location.reload(), 1500);
                        } else {
                            const { toast } = await import("../lib/toast");
                            toast.error(data.message || "Error al cancelar el pedido");
                        }
                    } catch (err: any) {
                        const { toast } = await import("../lib/toast");
                        toast.error("Error de conexión al cancelar el pedido");
                    } finally {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    }
                });
            });

        // ── Solicitar devolución ────────────────────────────────────────────────────
        document
            .querySelectorAll<HTMLButtonElement>(".request-return-btn")
            .forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const orderId = btn.dataset.orderId;
                    const updatedAt = btn.dataset.orderUpdated;
                    if (!orderId || !updatedAt) return;

                    // Calcular días desde entrega
                    const deliveryDate = new Date(updatedAt);
                    const now = new Date();
                    const daysSinceDelivery = Math.floor(
                        (now.getTime() - deliveryDate.getTime()) / (1000 * 60 * 60 * 24),
                    );

                    const result = await showReturnReasonModal();
                    if (!result?.reason?.trim()) return;

                    btn.disabled = true;
                    const originalText = btn.innerHTML;
                    btn.innerHTML = '<svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>';

                    try {
                        const res = await fetch(
                            `/api/orders/${orderId}/request-return`,
                            {
                                method: "POST",
                                headers: { "Content-Type": "application/json" },
                                credentials: "include",
                                body: JSON.stringify({
                                    reason: result.reason.trim(),
                                    images: result.images,
                                    notes: `Días desde entrega: ${daysSinceDelivery}`,
                                }),
                            },
                        );
                        const data = await res.json();

                        if (res.ok) {
                            const { toast } = await import("../lib/toast");
                            toast.success(
                                "✓ Solicitud de devolución enviada. Nuestro equipo la revisará pronto.",
                            );
                            setTimeout(() => window.location.reload(), 1500);
                        } else {
                            const { toast } = await import("../lib/toast");
                            toast.error(data.message || "Error al solicitar la devolución");
                        }
                    } catch (err: any) {
                        const { toast } = await import("../lib/toast");
                        toast.error("Error de conexión al solicitar la devolución");
                    } finally {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    }
                });
            });

        // ── Escribir reseña ─────────────────────────────────────────────────────
        function openReviewModal(productId: string, productName: string, productImage: string): Promise<{ rating: number; title: string; comment: string } | null> {
            return new Promise((resolve) => {
                const modal = document.getElementById("review-modal")!;
                const okBtn = document.getElementById("review-modal-ok")!;
                const cancelBtn = document.getElementById("review-modal-cancel")!;
                const productNameEl = document.getElementById("review-modal-product-name")!;
                const imgWrap = document.getElementById("review-modal-img-wrap")!;
                const imgEl = document.getElementById("review-modal-img") as HTMLImageElement;
                const ratingInput = document.getElementById("review-rating-value") as HTMLInputElement;
                const titleInput = document.getElementById("review-title-input") as HTMLInputElement;
                const commentInput = document.getElementById("review-comment-input") as HTMLTextAreaElement;
                const ratingHint = document.getElementById("review-rating-hint")!;
                const starBtns = modal.querySelectorAll<HTMLButtonElement>(".review-star-btn");

                // Reset state
                ratingInput.value = "0";
                titleInput.value = "";
                commentInput.value = "";
                ratingHint.classList.add("hidden");
                productNameEl.textContent = productName;

                if (productImage) {
                    imgEl.src = productImage;
                    imgEl.alt = productName;
                    imgWrap.classList.remove("hidden");
                } else {
                    imgWrap.classList.add("hidden");
                }

                // Reset stars
                starBtns.forEach((btn) => {
                    const svg = btn.querySelector("svg")!;
                    svg.style.color = "var(--border-color)";
                });

                function updateStars(value: number) {
                    starBtns.forEach((btn) => {
                        const s = parseInt(btn.dataset.star || "0");
                        const svg = btn.querySelector("svg")!;
                        svg.style.color = s <= value ? "var(--brand, #d4a843)" : "var(--border-color)";
                    });
                    ratingInput.value = String(value);
                }

                starBtns.forEach((btn) => {
                    btn.onclick = () => {
                        const s = parseInt(btn.dataset.star || "0");
                        updateStars(s);
                        ratingHint.classList.add("hidden");
                    };
                    btn.onmouseenter = () => {
                        const s = parseInt(btn.dataset.star || "0");
                        starBtns.forEach((b) => {
                            const bs = parseInt(b.dataset.star || "0");
                            const svg = b.querySelector("svg")!;
                            svg.style.color = bs <= s ? "var(--brand, #d4a843)" : "var(--border-color)";
                        });
                    };
                    btn.onmouseleave = () => {
                        updateStars(parseInt(ratingInput.value) || 0);
                    };
                });

                modal.classList.remove("hidden");
                modal.classList.add("flex");
                document.body.style.overflow = "hidden";

                function cleanup() {
                    modal.classList.add("hidden");
                    modal.classList.remove("flex");
                    document.body.style.overflow = "";
                    okBtn.onclick = null;
                    cancelBtn.onclick = null;
                }

                okBtn.onclick = () => {
                    const rating = parseInt(ratingInput.value) || 0;
                    if (rating < 1) {
                        ratingHint.classList.remove("hidden");
                        return;
                    }
                    cleanup();
                    resolve({
                        rating,
                        title: titleInput.value.trim(),
                        comment: commentInput.value.trim(),
                    });
                };

                cancelBtn.onclick = () => {
                    cleanup();
                    resolve(null);
                };
            });
        }

        document
            .querySelectorAll<HTMLButtonElement>(".write-review-btn")
            .forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const productId = btn.dataset.productId || "";
                    const productName = btn.dataset.productName || "Producto";
                    const productImage = btn.dataset.productImage || "";

                    const result = await openReviewModal(productId, productName, productImage);
                    if (!result || result.rating < 1) return;

                    btn.disabled = true;
                    const originalHtml = btn.innerHTML;
                    btn.innerHTML = '<svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>';

                    try {
                        const res = await fetch("/api/reviews", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            credentials: "include",
                            body: JSON.stringify({
                                productId,
                                rating: result.rating,
                                title: result.title || undefined,
                                comment: result.comment || undefined,
                            }),
                        });
                        const data = await res.json();

                        if (res.ok) {
                            const { toast } = await import("../lib/toast");
                            toast.success("✓ Reseña enviada. Estará visible tras su aprobación.");
                            setTimeout(() => window.location.reload(), 1500);
                        } else {
                            const { toast } = await import("../lib/toast");
                            toast.error(data.error || "Error al enviar la reseña");
                            btn.innerHTML = originalHtml;
                            btn.disabled = false;
                        }
                    } catch {
                        const { toast } = await import("../lib/toast");
                        toast.error("Error de conexión al enviar la reseña");
                        btn.innerHTML = originalHtml;
                        btn.disabled = false;
                    }
                });
            });
    }

    // Se ejecuta en cada navegación de Astro (y en la carga inicial)
    document.addEventListener("astro:page-load", initProfilePage);
</script>
