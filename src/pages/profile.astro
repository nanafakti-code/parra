                                </div>
                                <div
                                    class="sm:col-span-2 flex items-center gap-2"
                                >
                                    <input
                                        type="checkbox"
                                        name="is_default"
                                        id="is_default"
                                        class="w-4 h-4 accent-brand"
                                    />
                                    <label
                                        for="is_default"
                                        class="text-xs uppercase tracking-wider"
                                        style="color: var(--text-muted);"
                                        >Establecer como dirección
                                        predeterminada</label
