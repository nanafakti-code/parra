                                                    <div
                                                        class="w-14 h-14 overflow-hidden flex-shrink-0"
                                                        style="background-color: var(--bg-secondary);"
                                                    >
                                                        <img
                                                            src={
                                                                r.products.image
                                                            }
                                                            alt={
                                                                r.products.name
                                                            }
