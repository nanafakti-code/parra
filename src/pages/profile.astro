                                    <button
                                        type="button"
                                        id="cancel-address-btn"
                                        class="btn-outline flex-1"
                                        >Cancelar</button
                                    >
                                </div>
                                <p
                                    id="address-msg"
                                    class="sm:col-span-2 text-xs text-center hidden"
                                    style="color: var(--text-muted);"
                                >
                                </p>
                            </form>
                        </div>

                        {
                            (addresses || []).length > 0 ? (
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    {(addresses || []).map((addr: any) => (
                                        <div
                                            class:list={[
                                                "card p-5 relative",
                                                addr.is_default &&
                                                    "border-brand/30",
                                            ]}
                                        >
                                            {addr.is_default && (
                                                <span class="absolute top-3 right-3 text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 bg-brand/10 text-brand">
                                                    Predeterminada
                                                </span>
                                            )}
                                            <p
                                                class="text-xs font-bold uppercase tracking-widest mb-2"
                                                style="color: var(--text-muted);"
                                            >
                                                {addr.label || "Dirección"}
                                            </p>
                                            <p class="font-semibold text-sm mb-0.5">
                                                {addr.full_name}
                                            </p>
                                            <p
                                                class="text-sm"
                                                style="color: var(--text-secondary);"
                                            >
                                                {addr.street}
                                            </p>
                                            <p
                                                class="text-sm"
                                                style="color: var(--text-secondary);"
                                            >
                                                {addr.postal_code} {addr.city}
                                                {addr.state
                                                    ? `, ${addr.state}`
                                                    : ""}
                                            </p>
                                            {addr.phone && (
                                                <p
                                                    class="text-sm mt-1"
                                                    style="color: var(--text-muted);"
                                                >
                                                    {addr.phone}
                                                </p>
                                            )}
                                            <div
                                                class="flex gap-2 mt-4 pt-3"
                                                style="border-top: 1px solid var(--border-color);"
                                            >
                                                {!addr.is_default && (
                                                    <button
                                                        data-set-default={
                                                            addr.id
                                                        }
                                                        class="text-[10px] font-bold uppercase tracking-widest btn-outline py-1.5 px-3 flex-1 hover:border-brand hover:text-brand transition-colors"
                                                    >
                                                        ★ Predeterminada
                                                    </button>
                                                )}
                                                <button
                                                    data-delete-addr={addr.id}
                                                    class="text-[10px] font-bold uppercase tracking-widest py-1.5 px-3 border transition-colors hover:border-red-400/50 hover:text-red-400"
                                                    style="border-color: var(--border-color); color: var(--text-muted);"
                                                >
                                                    Eliminar
                                                </button>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            ) : (
                                <div class="py-24 text-center card">
                                    <svg
                                        class="w-12 h-12 mx-auto mb-6"
                                        style="color: var(--text-muted); opacity:.4;"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="1.5"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                        />
                                    </svg>
                                    <p
                                        class="uppercase tracking-[0.2em] text-sm"
                                        style="color: var(--text-muted);"
                                    >
                                        No tienes direcciones guardadas.
                                    </p>
                                </div>
                            )
                        }
                    </div>

                    {/* ════ MIS CUPONES ════ */}
                    <div data-tab-panel="cupones" hidden={tab !== "cupones"}>
                        <h2 class="section-title mb-8">
                            Mis <span class="text-brand">Cupones</span>
                        </h2>
                        {
                            (couponUsages || []).length > 0 ? (
                                <div class="space-y-4">
                                    {(couponUsages || []).map((cu: any) => (
                                        <div class="card p-5 flex items-center justify-between gap-4 flex-wrap">
                                            <div>
                                                <p class="font-mono font-bold text-brand tracking-widest text-base">
                                                    {cu.coupons?.code}
                                                </p>
                                                {cu.coupons?.description && (
                                                    <p
                                                        class="text-xs mt-0.5"
                                                        style="color: var(--text-muted);"
                                                    >
                                                        {cu.coupons.description}
                                                    </p>
                                                )}
                                                <p
                                                    class="text-[10px] uppercase tracking-wider mt-1"
                                                    style="color: var(--text-muted);"
                                                >
                                                    Usado el{" "}
                                                    {new Date(
                                                        cu.used_at,
                                                    ).toLocaleDateString(
                                                        "es-ES",
                                                    )}
                                                </p>
                                            </div>
                                            <div class="text-right">
                                                <p class="text-lg font-bold text-brand">
                                                    {cu.coupons
                                                        ?.discount_type ===
                                                    "percentage"
                                                        ? `-${cu.coupons.discount_value}%`
                                                        : `-€${parseFloat(cu.coupons?.discount_value || 0).toFixed(2)}`}
                                                </p>
                                                <p
                                                    class="text-[10px] uppercase tracking-wider"
                                                    style="color: var(--text-muted);"
                                                >
                                                    descuento aplicado
                                                </p>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            ) : (
                                <div class="py-24 text-center card">
                                    <svg
                                        class="w-12 h-12 mx-auto mb-6"
                                        style="color: var(--text-muted); opacity:.4;"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="1.5"
                                            d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
                                        />
                                    </svg>
                                    <p
                                        class="uppercase tracking-[0.2em] text-sm"
                                        style="color: var(--text-muted);"
                                    >
                                        No has usado ningún cupón todavía.
                                    </p>
                                </div>
                            )
                        }
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- ── Modal de confirmación personalizado ── -->
    <div
        id="confirm-modal"
        class="fixed inset-0 z-50 hidden items-center justify-center p-4"
        style="background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);"
    >
        <div
            class="card max-w-sm w-full p-8 space-y-6 text-center"
            style="border-color: var(--border-color);"
        >
            <div
                class="w-12 h-12 mx-auto flex items-center justify-center"
                style="background: rgba(255,59,59,0.1); border: 1px solid rgba(255,59,59,0.2);"
            >
                <svg
                    class="w-6 h-6"
                    style="color: #ff3b3b;"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                    ></path>
                </svg>
            </div>
            <div>
                <p
                    id="confirm-modal-title"
                    class="font-display font-bold uppercase tracking-tight text-base mb-1"
                >
                    ¿Eliminar dirección?
                </p>
                <p
                    id="confirm-modal-body"
                    class="text-xs"
                    style="color: var(--text-muted);"
                >
                    Esta acción no se puede deshacer.
                </p>
            </div>
            <div class="flex gap-3">
                <button
                    id="confirm-modal-cancel"
                    class="btn-outline flex-1 h-10 text-xs uppercase tracking-widest"
                    >Cancelar</button
                >
                <button
                    id="confirm-modal-ok"
                    class="flex-1 h-10 text-xs font-bold uppercase tracking-widest transition-colors"
                    style="background: rgba(255,59,59,0.15); border: 1px solid rgba(255,59,59,0.3); color: #ff3b3b;"
                    >Eliminar</button
                >
            </div>
        </div>
    </div>

    <!-- ── Modal para solicitar devolución ── -->
    <div
        id="return-modal"
        class="fixed inset-0 z-50 hidden items-center justify-center p-4"
        style="background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);"
    >
        <div
            class="card w-full p-8 space-y-5 overflow-y-auto"
            style="border-color: var(--border-color); max-width: 420px; max-height: 90vh;"
        >
            <div>
                <p
                    class="font-display font-bold uppercase tracking-tight text-base mb-1"
                >
                    Motivo de la Devolución
                </p>
                <p
                    class="text-xs"
                    style="color: var(--text-muted);"
                >
                    Selecciona el motivo de tu devolución
                </p>
            </div>
            <div class="space-y-2">
                <label class="flex items-center gap-3 p-3 rounded cursor-pointer transition-colors" style="background: rgba(59,130,246,0.05); border: 1px solid rgba(59,130,246,0.2);">
                    <input type="radio" name="return-reason" value="Talla incorrecta" class="cursor-pointer" />
                    <span class="text-xs">Talla incorrecta</span>
                </label>
                <label class="flex items-center gap-3 p-3 rounded cursor-pointer transition-colors" style="background: rgba(59,130,246,0.05); border: 1px solid rgba(59,130,246,0.2);">
                    <input type="radio" name="return-reason" value="No me gustó" class="cursor-pointer" />
                    <span class="text-xs">No me gustó</span>
                </label>
                <label class="flex items-center gap-3 p-3 rounded cursor-pointer transition-colors" style="background: rgba(59,130,246,0.05); border: 1px solid rgba(59,130,246,0.2);">
                    <input type="radio" name="return-reason" value="Defecto de fabricación" class="cursor-pointer" />
                    <span class="text-xs">Defecto de fabricación</span>
                </label>
                <label class="flex items-center gap-3 p-3 rounded cursor-pointer transition-colors" style="background: rgba(59,130,246,0.05); border: 1px solid rgba(59,130,246,0.2);">
                    <input type="radio" name="return-reason" value="Color diferente" class="cursor-pointer" />
                    <span class="text-xs">Color diferente al esperado</span>
                </label>
                <label class="flex items-center gap-3 p-3 rounded cursor-pointer transition-colors" style="background: rgba(59,130,246,0.05); border: 1px solid rgba(59,130,246,0.2);">
                    <input type="radio" name="return-reason" value="Otro" class="cursor-pointer" />
                    <span class="text-xs">Otro motivo</span>
                </label>
            </div>
            <div id="return-other-reason-wrap" style="display:none;">
                <textarea
                    id="return-other-reason"
                    class="w-full text-xs rounded p-3 resize-none"
                    rows="3"
                    maxlength="300"
                    placeholder="Describe el motivo de tu devolución..."
                    style="background:rgba(59,130,246,0.05);border:1px solid rgba(59,130,246,0.2);color:inherit;outline:none;"
                ></textarea>
            </div>
            <!-- ── Fotos del producto ── -->
