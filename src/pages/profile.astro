---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { supabaseAdmin } from "../lib/supabase";

const authUser = Astro.locals.user;
if (!authUser) return Astro.redirect("/login");

const { data: userProfile, error: profileError } = await supabaseAdmin
    .from("users")
    .select("*")
    .eq("id", authUser.id)
    .single();
if (profileError || !userProfile) {
    // Si el usuario existe en Auth pero no en la tabla "users" (o hay un error de DB),
    // borramos las cookies para no crear un bucle de redirecciones infinito con /login.
    Astro.cookies.delete("sb-access-token", { path: "/" });
    Astro.cookies.delete("sb-refresh-token", { path: "/" });
    return Astro.redirect("/login?error=profile_missing");
}

// Cache 30s en el navegador (private = solo browser, no CDN)
// Permite que back/forward y revisitas recientes sean instantáneas
Astro.response.headers.set(
    "Cache-Control",
    "no-store, no-cache, must-revalidate, max-age=0",
);

const tab = Astro.url.searchParams.get("tab") || "perfil";

// ── Todas las queries en paralelo (1 sola vuelta al servidor) ─────────────────
const [
    { data: rawOrders },
    { data: reviews },
    { data: addresses },
    { data: couponUsages },
    { data: rawReturns },
] = await Promise.all([
    // Pedidos + items + producto en una sola query anidada (sin N+1)
    supabaseAdmin
        .from("orders")
        .select("*, order_items(*, products(name, image))")
        .or(userProfile.email
            ? `user_id.eq.${authUser.id},email.eq.${userProfile.email}`
            : `user_id.eq.${authUser.id}`)
        .order("created_at", { ascending: false })
        .limit(50),
    supabaseAdmin
        .from("reviews")
        .select("*, products(name, slug, image)")
        .eq("user_id", authUser.id)
        .order("created_at", { ascending: false }),
    supabaseAdmin
        .from("addresses")
        .select("*")
        .eq("user_id", authUser.id)
        .order("is_default", { ascending: false }),
    supabaseAdmin
        .from("coupon_usage")
        .select("*, coupons(*)")
        .eq("user_id", authUser.id)
        .order("used_at", { ascending: false }),
    supabaseAdmin
        .from("returns")
        .select("*, orders(order_number, total, created_at, order_items(*, products(name, image)))")
        .eq("user_id", authUser.id)
        .order("created_at", { ascending: false }),
]);

// Normalizar items para que el template funcione igual
const ordersWithItems: any[] = (rawOrders || []).map((o: any) => ({
    ...o,
    items: (o.order_items || []).map((i: any) => ({
        ...i,
        product: i.products,
    })),
}));

// Solicitudes de devolución reales desde la tabla returns
const returnRequests: any[] = (rawReturns || []).map((r: any) => ({
    ...r,
    order: r.orders ? {
        ...r.orders,
        items: (r.orders.order_items || []).map((i: any) => ({
            ...i,
            product: i.products,
        })),
    } : null,
}));

const returnStatusMap: Record<string, string> = {
    pending: "Pendiente revisión",
    approved: "Aprobada",
    rejected: "Rechazada",
    refunded: "Reembolsada",
};

// IDs de pedidos que ya tienen una solicitud de devolución activa
const ordersWithReturn = new Set(returnRequests.map((r: any) => r.order_id));

// Pedidos que se muestran en el tab "pedidos" (excluye los que tienen devolución)
const pedidosOrders = ordersWithItems.filter((o: any) => !ordersWithReturn.has(o.id));

const statusMap: Record<string, string> = {
    pending: "Pendiente",
    confirmed: "Confirmado",
    processing: "Procesando",
    shipped: "Enviado",
    delivered: "Entregado",
    cancelled: "Cancelado",
    refunded: "Reembolsado",
};

// ── Producto IDs ya reseñados por el usuario ─────────────────────────────────
const reviewedProductIds = new Set<string>(
    (reviews || []).map((r: any) => r.product_id).filter(Boolean),
);

const tabs = [
    {
        id: "perfil",
        label: "Mi Perfil",
        icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
    },
    {
        id: "pedidos",
        label: "Mis Pedidos",
        icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
    },
    {
        id: "devoluciones",
        label: "Mis Devoluciones",
        icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15",
    },
    {
        id: "reseñas",
        label: "Mis Reseñas",
        icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
    },
    {
        id: "direcciones",
        label: "Mis Direcciones",
        icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z",
    },
    {
        id: "cupones",
        label: "Mis Cupones",
        icon: "M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z",
    },
];
---

<Layout title="Mi Perfil | PARRA" robots="noindex, nofollow">
    <Header />
    <main
        class="min-h-screen py-24"
        style="background-color: var(--bg-primary);"
    >
        <div class="container">
            <div class="flex flex-col lg:flex-row gap-10 lg:gap-14">
                <!-- ── Sidebar ───────────────────────────────────────────── -->
                <aside class="w-full lg:w-72 shrink-0 space-y-4">
                    <!-- Avatar card -->
                    <div class="card p-6 text-center">
                        <div
                            id="sidebar-avatar"
                            class="w-16 h-16 bg-brand/10 border border-brand/20 flex items-center justify-center mx-auto mb-3 text-brand font-display text-2xl font-bold"
                        >
                            {(userProfile.name || userProfile.email || '?').charAt(0).toUpperCase()}
                        </div>
                        <h2
                            id="sidebar-name"
                            class="font-display text-base font-bold uppercase tracking-tight mb-0.5"
                        >
                            {userProfile.name || userProfile.email}
                        </h2>
                        <p
                            class="text-xs mb-2"
                            style="color: var(--text-muted);"
                        >
                            {userProfile.email}
                        </p>
                        <p
                            class="text-[10px] uppercase tracking-widest"
                            style="color: var(--text-muted); opacity:.5;"
                        >
                            Miembro desde {
                                new Date(
                                    userProfile.created_at,
                                ).toLocaleDateString("es-ES")
                            }
                        </p>
                    </div>

                    <!-- Nav tabs -->
                    <nav class="space-y-1" id="profile-nav">
                        {
                            tabs.map((t) => (
                                <a
                                    href={`/profile?tab=${t.id}`}
                                    data-tab-link={t.id}
                                    class:list={[
                                        "flex items-center gap-3 px-4 py-3 text-xs font-bold uppercase tracking-wider transition-all duration-200",
                                        tab === t.id
                                            ? "bg-brand text-black"
                                            : "card hover:text-brand",
                                    ]}
                                    style={
                                        tab !== t.id
                                            ? "color: var(--text-muted);"
                                            : ""
                                    }
                                >
                                    <svg
                                        class="w-4 h-4 shrink-0"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="1.5"
                                            d={t.icon}
                                        />
                                    </svg>
                                    {t.label}
                                </a>
                            ))
                        }
                        {
                            userProfile.role === "admin" && (
                                <a
                                    href="/admin"
                                    class="flex items-center gap-3 px-4 py-3 text-xs font-bold uppercase tracking-wider card hover:text-brand transition-colors"
                                    style="color: var(--text-muted);"
                                >
                                    <svg
                                        class="w-4 h-4 shrink-0"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <>
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="1.5"
                                                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                                            />
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="1.5"
                                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                            />
                                        </>
                                    </svg>
                                    Panel Admin
                                </a>
                            )
                        }
                    </nav>
                </aside>

                <!-- ── Contenido principal ─────────────────────────────── -->
                <div class="flex-1 min-w-0">
                    {/* ════ MIS PEDIDOS ════ */}
                    <div data-tab-panel="pedidos" hidden={tab !== "pedidos"}>
                        <h2 class="section-title mb-8">
                            Mis <span class="text-brand">Pedidos</span>
                        </h2>
                        {
                            pedidosOrders.length > 0 ? (
                                <div class="space-y-5">
                                    {pedidosOrders.map((order: any) => (
                                        <div class="card p-6">
                                            <div class="flex flex-col md:flex-row md:gap-6">
                                            <div class="flex-1 min-w-0">
                                            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-5">
                                                <div>
                                                    <p
                                                        class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-1"
                                                        style="color: var(--text-muted);"
                                                    >
                                                        Pedido
                                                    </p>
                                                    <p class="text-sm font-mono text-brand">
                                                        {order.order_number ||
                                                            `#${order.id.slice(-8).toUpperCase()}`}
                                                    </p>
                                                </div>
                                                <div>
                                                    <p
                                                        class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-1"
                                                        style="color: var(--text-muted);"
                                                    >
                                                        Fecha
                                                    </p>
                                                    <p
                                                        class="text-sm"
                                                        style="color: var(--text-secondary);"
                                                    >
                                                        {new Date(
                                                            order.created_at,
                                                        ).toLocaleDateString(
                                                            "es-ES",
                                                        )}
                                                    </p>
                                                </div>
                                                <div>
                                                    <p
                                                        class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-1"
                                                        style="color: var(--text-muted);"
                                                    >
                                                        Estado
                                                    </p>
                                                    <span
                                                        class:list={[
                                                            "inline-block px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider",
                                                            order.status ===
                                                            "delivered"
                                                                ? "bg-brand/10 text-brand"
                                                                : order.status ===
                                                                    "cancelled"
                                                                  ? "bg-red-500/10 text-red-500"
                                                                  : order.status ===
                                                                      "pending"
                                                                    ? "bg-amber-500/10 text-amber-500"
                                                                    : "bg-blue-500/10 text-blue-500",
                                                        ]}
                                                    >
                                                        {statusMap[
                                                            order.status
                                                        ] || order.status}
                                                    </span>
                                                </div>
                                                <div>
                                                    <p
                                                        class="text-[10px] font-semibold uppercase tracking-[0.2em] mb-1"
                                                        style="color: var(--text-muted);"
                                                    >
                                                        Total
                                                    </p>
                                                    <p class="text-lg font-bold">
                                                        €
                                                        {parseFloat(
                                                            order.total,
                                                        ).toFixed(2)}
                                                    </p>
                                                </div>
                                            </div>

                                            {/* Tracking / Notas internas — solo cuando estado = enviado */}
                                            {order.status === 'shipped' && (order.tracking_number || order.notes) && (
                                                <div class="mt-4 mb-1 rounded-lg px-4 py-3 flex flex-col gap-2" style="background:rgba(59,130,246,0.06);border:1px solid rgba(59,130,246,0.18);">
                                                    {order.tracking_number && (
                                                        <div class="flex items-center gap-2">
                                                            <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#3b82f6;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/>
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2 1h8zM13 8h4l3 5v3h-7V8z"/>
                                                            </svg>
                                                            <span class="text-[10px] font-bold uppercase tracking-widest" style="color:#3b82f6;">Nº Seguimiento:</span>
                                                            <span class="text-[11px] font-mono font-semibold" style="color:var(--text-primary);">{order.tracking_number}</span>
                                                        </div>
                                                    )}
                                                    {order.notes && (
                                                        <div class="flex items-start gap-2">
                                                            <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color:#3b82f6;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z"/>
                                                            </svg>
                                                            <span class="text-[11px]" style="color:var(--text-secondary);">{order.notes}</span>
                                                        </div>
                                                    )}
                                                </div>
                                            )}

                                            <div
                                                class="space-y-3 pt-4"
                                                style="border-top: 1px solid var(--border-color);"
                                            >
                                                {order.items.map(
                                                    (item: any) => (
                                                        <div class="flex items-center gap-4">
                                                            <div
                                                                class="w-12 h-12 overflow-hidden flex-shrink-0"
                                                                style="background-color: var(--bg-secondary);"
                                                            >
                                                                <img
                                                                    src={
                                                                        item
                                                                            .product
                                                                            ?.image ||
                                                                        item.product_image
                                                                    }
                                                                    alt={
                                                                        item
                                                                            .product
                                                                            ?.name ||
                                                                        item.product_name
                                                                    }
                                                                    class="w-full h-full object-cover"
                                                                />
                                                            </div>
                                                            <div class="flex-1 min-w-0">
                                                                <p class="text-sm font-semibold uppercase truncate">
                                                                    {item
                                                                        .product
                                                                        ?.name ||
                                                                        item.product_name}
                                                                </p>
                                                                <p
                                                                    class="text-xs uppercase tracking-wider"
                                                                    style="color: var(--text-muted);"
                                                                >
                                                                    {
                                                                        item.quantity
                                                                    }{" "}
                                                                    x €
                                                                    {parseFloat(
                                                                        item.unit_price,
                                                                    ).toFixed(
                                                                        2,
                                                                    )}
                                                                    {item.size &&
                                                                        ` · Talla ${item.size}`}
                                                                </p>
                                                            </div>
                                                            {/* Botón reseñar por producto (solo pedidos entregados) */}
                                                            {order.status === "delivered" && item.product_id && (
                                                                reviewedProductIds.has(item.product_id) ? (
                                                                    <span class="flex-shrink-0 inline-flex items-center gap-1 px-2.5 py-1.5 text-[10px] font-bold uppercase tracking-widest" style="color:var(--brand,#d4a843);opacity:0.7;">
                                                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                                                        Reseñado
                                                                    </span>
                                                                ) : (
                                                                    <button
                                                                        type="button"
                                                                        class="write-review-btn flex-shrink-0 inline-flex items-center gap-1.5 px-2.5 py-1.5 text-[10px] font-bold uppercase tracking-widest transition-all duration-200 cursor-pointer"
                                                                        style="background:rgba(212,168,67,0.10);color:var(--brand,#d4a843);border:1px solid rgba(212,168,67,0.35);border-radius:6px;"
                                                                        data-product-id={item.product_id}
                                                                        data-product-name={item.product?.name || item.product_name}
                                                                        data-product-image={item.product?.image || item.product_image || ""}
                                                                        onmouseover="this.style.background='var(--brand,#d4a843)';this.style.color='#0a0a0a';"
                                                                        onmouseout="this.style.background='rgba(212,168,67,0.10)';this.style.color='var(--brand,#d4a843)';"
                                                                    >
                                                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                                                        Reseñar
                                                                    </button>
                                                                )
                                                            )}
                                                        </div>
                                                    ),
                                                )}
                                            </div>{/* end items */}
                                            </div>{/* end left col */}
                                            {/* ── Acciones del pedido ── */}
                                            <div class="flex flex-col gap-2 pt-4 mt-4 md:pt-0 md:mt-0 items-stretch md:justify-start md:min-w-[160px] border-t md:border-t-0 md:border-l md:pl-6" style="border-color: var(--border-color);">
                                                {/* Botón Descargar Factura */}
                                                <button
                                                    type="button"
                                                    data-invoice-url={`/api/orders/invoice/${order.id}`}
                                                    data-invoice-name={`factura-${order.order_number || order.id.slice(-8).toUpperCase()}.pdf`}
                                                    class="invoice-dl-btn inline-flex items-center gap-2 px-4 py-2.5 text-[10px] font-bold uppercase tracking-widest transition-all duration-200 cursor-pointer"
                                                    style="background:rgba(34,197,94,0.08);color:#22c55e;border:1px solid rgba(34,197,94,0.30);border-radius:6px;"
                                                    onmouseover="this.style.background='#22c55e';this.style.color='#0a0a0a';"
                                                    onmouseout="this.style.background='rgba(34,197,94,0.08)';this.style.color='#22c55e';"
                                                >
                                                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
                                                    </svg>
                                                    Descargar Factura
                                                </button>

                                                {/* Botón Cancelar (pending/processing) */}
                                                {['pending', 'processing'].includes(order.status) && (
                                                    <button
                                                        type="button"
                                                        data-order-id={order.id}
                                                        class="cancel-order-btn inline-flex items-center gap-2 px-4 py-2.5 text-[10px] font-bold uppercase tracking-widest transition-all duration-200 cursor-pointer"
                                                        style="background:rgba(239,68,68,0.08);color:#ef4444;border:1px solid rgba(239,68,68,0.30);border-radius:6px;"
                                                        onmouseover="this.style.background='#ef4444';this.style.color='#fff';"
                                                        onmouseout="this.style.background='rgba(239,68,68,0.08)';this.style.color='#ef4444';"
                                                    >
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                                        </svg>
                                                        Cancelar Pedido
                                                    </button>
                                                )}

                                                {/* Botón Solicitar Devolución (delivered, dentro del plazo, sin devolución previa) */}
                                                {order.status === 'delivered' && !ordersWithReturn.has(order.id) && (
                                                    <button
                                                        type="button"
                                                        data-order-id={order.id}
                                                        data-order-updated={order.updated_at}
                                                        class="request-return-btn inline-flex items-center gap-2 px-4 py-2.5 text-[10px] font-bold uppercase tracking-widest transition-all duration-200 cursor-pointer"
                                                        style="background:rgba(59,130,246,0.08);color:#3b82f6;border:1px solid rgba(59,130,246,0.30);border-radius:6px;"
                                                        onmouseover="this.style.background='#3b82f6';this.style.color='#fff';"
                                                        onmouseout="this.style.background='rgba(59,130,246,0.08)';this.style.color='#3b82f6';"
                                                    >
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
