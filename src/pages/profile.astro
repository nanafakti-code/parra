                                    >
                                    <input
                                        type="text"
                                        name="city"
                                        required
                                        class="w-full px-4 py-3 text-sm bg-transparent border focus:outline-none focus:border-brand transition-colors"
                                        style="border-color: var(--border-color); color: var(--text-primary);"
                                    />
                                </div>
                                <div>
                                    <label
                                        class="block text-[10px] font-bold uppercase tracking-[0.2em] mb-1.5"
                                        style="color: var(--text-muted);"
                                        >Código postal</label
