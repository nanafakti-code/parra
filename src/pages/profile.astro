<script>
    // ── Modal de confirmación (Promise-based) ─────────────────────────────────
    function customConfirm(title: string, body: string): Promise<boolean> {
        return new Promise((resolve) => {
            const modal = document.getElementById("confirm-modal")!;
            const titleEl = document.getElementById("confirm-modal-title")!;
            const bodyEl = document.getElementById("confirm-modal-body")!;
            const okBtn = document.getElementById("confirm-modal-ok")!;
            const cancelBtn = document.getElementById("confirm-modal-cancel")!;

            titleEl.textContent = title;
            bodyEl.textContent = body;
            modal.classList.remove("hidden");
            modal.classList.add("flex");
            document.body.style.overflow = "hidden";

            function close(result: boolean) {
                modal.classList.add("hidden");
                modal.classList.remove("flex");
                document.body.style.overflow = "";
                okBtn.removeEventListener("click", onOk);
                cancelBtn.removeEventListener("click", onCancel);
                modal.removeEventListener("click", onBackdrop);
                resolve(result);
            }
            const onOk = () => close(true);
            const onCancel = () => close(false);
            const onBackdrop = (e: Event) => {
                if (e.target === modal) close(false);
            };

            okBtn.addEventListener("click", onOk);
            cancelBtn.addEventListener("click", onCancel);
            modal.addEventListener("click", onBackdrop);
        });
    }

    // ── Modal para solicitar devolución (retorna motivo + imágenes o null) ─
    function showReturnReasonModal(): Promise<{ reason: string; images: string[] } | null> {
        return new Promise((resolve) => {
            const modal = document.getElementById("return-modal")!;
            const okBtn = document.getElementById("return-modal-ok")!;
            const cancelBtn = document.getElementById("return-modal-cancel")!;
            const otherWrap = document.getElementById("return-other-reason-wrap")!;
            const otherText = document.getElementById("return-other-reason") as HTMLTextAreaElement;
            const uploadBtn = document.getElementById("return-upload-btn")!;
            const previewContainer = document.getElementById("return-images-preview")!;

            let returnImages: string[] = [];
            let clWidget: any = null;

            modal.classList.remove("hidden");
            modal.classList.add("flex");
            document.body.style.overflow = "hidden";

            function getWidget() {
                if (clWidget) return clWidget;
                const cl = (window as any).cloudinary;
                if (!cl) return null;
                clWidget = cl.createUploadWidget(
                    {
                        cloudName: "djvj32zic",
                        uploadPreset: "parragk",
                        multiple: true,
                        maxFiles: 5,
                        sources: ["local", "camera"],
                        folder: "parra/returns",
                        resourceType: "image",
                        clientAllowedFormats: ["jpg", "jpeg", "png", "webp"],
                        maxImageFileSize: 5000000,
                        cropping: false,
                        styles: { palette: { window: "#0d0f14", windowBorder: "#1e2433", tabIcon: "#3b82f6", menuIcons: "#9ca3af", textDark: "#f0f4f8", textLight: "#0d0f14", link: "#3b82f6", action: "#3b82f6", inactiveTabIcon: "#6b7280", error: "#ef4444", inProgress: "#3b82f6", complete: "#22c55e", sourceBg: "#111520" } },
                    },
                    (error: any, result: any) => {
                        if (error) { console.error("[cloudinary]", error); return; }
                        if (result?.event === "success" && returnImages.length < 5) {
                            const url = result.info.secure_url;
                            returnImages.push(url);
                            addThumbnail(url);
                        }
                    }
                );
                return clWidget;
            }

            function addThumbnail(url: string) {
                const wrap = document.createElement("div");
                wrap.style.cssText = "position:relative;width:56px;height:56px;flex-shrink:0;";
                const img = document.createElement("img");
                img.src = url;
                img.style.cssText = "width:56px;height:56px;object-fit:cover;border-radius:4px;border:1px solid rgba(59,130,246,0.25);";
                const del = document.createElement("button");
                del.type = "button";
                del.innerHTML = "&times;";
                del.style.cssText = "position:absolute;top:-5px;right:-5px;width:18px;height:18px;border-radius:50%;background:#ef4444;color:#fff;font-size:13px;line-height:18px;text-align:center;border:none;cursor:pointer;padding:0;";
                del.addEventListener("click", () => {
                    returnImages = returnImages.filter(u => u !== url);
                    wrap.remove();
                });
                wrap.appendChild(img);
                wrap.appendChild(del);
                previewContainer.appendChild(wrap);
            }

            const onUpload = () => {
                if (returnImages.length >= 5) return;
                const openWidget = () => {
                    const w = getWidget();
                    if (w) w.open();
                };
                if ((window as any).cloudinary) {
                    openWidget();
                } else {
                    const s = document.createElement('script');
                    s.src = 'https://upload-widget.cloudinary.com/global/all.js';
                    s.onload = openWidget;
                    document.head.appendChild(s);
                }
            };
            uploadBtn.addEventListener("click", onUpload);

            // Mostrar/ocultar textarea según selección
            const radios = modal.querySelectorAll<HTMLInputElement>('input[name="return-reason"]');
            function onRadioChange() {
                const selected = Array.from(radios).find(r => r.checked);
                otherWrap.style.display = selected?.value === "Otro" ? "block" : "none";
                if (selected?.value !== "Otro") otherText.value = "";
            }
            radios.forEach(r => r.addEventListener("change", onRadioChange));

            function close(result: { reason: string; images: string[] } | null) {
                modal.classList.add("hidden");
                modal.classList.remove("flex");
                document.body.style.overflow = "";
                okBtn.removeEventListener("click", onOk);
                cancelBtn.removeEventListener("click", onCancel);
                modal.removeEventListener("click", onBackdrop);
                uploadBtn.removeEventListener("click", onUpload);
                radios.forEach(r => {
                    r.checked = false;
                    r.removeEventListener("change", onRadioChange);
                });
                otherWrap.style.display = "none";
                otherText.value = "";
                returnImages = [];
                previewContainer.innerHTML = "";
                if (clWidget) { try { clWidget.destroy(); } catch {} clWidget = null; }
                resolve(result);
            }

            const onOk = () => {
                const selected = Array.from(radios).find(r => r.checked);
                if (!selected) return;
                if (selected.value === "Otro") {
                    const custom = otherText.value.trim();
                    if (!custom) {
                        otherText.style.borderColor = "rgba(239,68,68,0.5)";
                        otherText.focus();
                        return;
                    }
                    close({ reason: custom, images: [...returnImages] });
                } else {
                    close({ reason: selected.value, images: [...returnImages] });
                }
            };
            const onCancel = () => close(null);
            const onBackdrop = (e: Event) => {
                if (e.target === modal) close(null);
            };

            okBtn.addEventListener("click", onOk);
            cancelBtn.addEventListener("click", onCancel);
            modal.addEventListener("click", onBackdrop);
        });
    }

    // ── Modal para cancelar pedido (Promise-based) ───────────────────────────────
    function showCancelOrderModal(): Promise<boolean> {
        return new Promise((resolve) => {
            const modal = document.getElementById("cancel-order-modal")!;
            const okBtn = document.getElementById("cancel-modal-ok")!;
